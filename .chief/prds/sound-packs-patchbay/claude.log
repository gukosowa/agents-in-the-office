{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Bzp1vchGxmTde98XoPmER1","type":"tool_result","content":"     1→import { defineStore } from 'pinia';\n     2→import { ref } from 'vue';\n     3→import { homeDir } from '@tauri-apps/api/path';\n     4→import {\n     5→  readTextFile,\n     6→  writeTextFile,\n     7→  mkdir,\n     8→  exists,\n     9→  readDir,\n    10→  readFile,\n    11→} from '@tauri-apps/plugin-fs';\n    12→import type { AgentEvent, AgentEventType } from '../drivers/types';\n    13→\n    14→export const AGENT_EVENT_TYPES: AgentEventType[] = [\n    15→  'session_start',\n    16→  'session_end',\n    17→  'prompt_submit',\n    18→  'tool_start',\n    19→  'tool_end',\n    20→  'turn_end',\n    21→  'permission_wait',\n    22→  'subagent_start',\n    23→  'subagent_end',\n    24→  'idle_notification',\n    25→  'elicitation_wait',\n    26→  'auth_success',\n    27→  'worktree_create',\n    28→  'worktree_remove',\n    29→  'teammate_idle',\n    30→  'task_completed',\n    31→];\n    32→\n    33→export interface TrackConfig {\n    34→  enabled: boolean;\n    35→  volume: number;\n    36→}\n    37→\n    38→export interface SoundConfig {\n    39→  enabled: boolean;\n    40→  globalVolume: number;\n    41→  cooldownSeconds: number;\n    42→  activePacks: string[];\n    43→  tracks: Record<string, Record<string, TrackConfig>>;\n    44→}\n    45→\n    46→export interface PackManifestSound {\n    47→  file: string;\n    48→  volume: number;\n    49→  enabled: boolean;\n    50→}\n    51→\n    52→export interface PackManifestAssignment {\n    53→  file: string;\n    54→  event: AgentEventType;\n    55→}\n    56→\n    57→export interface PackManifest {\n    58→  sounds: PackManifestSound[];\n    59→  assignments: PackManifestAssignment[];\n    60→}\n    61→\n    62→export interface PackInfo {\n    63→  name: string;\n    64→  categories: Record<string, string[]>;\n    65→  manifest: PackManifest;\n    66→  hasManifest: boolean;\n    67→}\n    68→\n    69→\n    70→const DEFAULT_CONFIG: SoundConfig = {\n    71→  enabled: true,\n    72→  globalVolume: 0.8,\n    73→  cooldownSeconds: 2,\n    74→  activePacks: [],\n    75→  tracks: {},\n    76→};\n    77→\n    78→const AUDIO_EXTENSIONS = new Set(['.mp3', '.ogg', '.wav', '.flac', '.m4a', '.webm']);\n    79→\n    80→function hasAudioExtension(filename: string): boolean {\n    81→  const dot = filename.lastIndexOf('.');\n    82→  if (dot < 0) return false;\n    83→  return AUDIO_EXTENSIONS.has(filename.slice(dot).toLowerCase());\n    84→}\n    85→\n    86→export const useSoundStore = defineStore('sound', () => {\n    87→  const config = ref<SoundConfig>({ ...DEFAULT_CONFIG, tracks: {} });\n    88→  const packs = ref<PackInfo[]>([]);\n    89→\n    90→  // Reactive state for sound indicator (US-009)\n    91→  const lastPlayedSessionId = ref<string | null>(null);\n    92→\n    93→  let soundPacksDir = '';\n    94→  let configPath = '';\n    95→\n    96→  // AudioContext — lazy init on first playback\n    97→  let audioCtx: AudioContext | null = null;\n    98→\n    99→  // Buffer cache: absolute file path → AudioBuffer\n   100→  const bufferCache = new Map<string, AudioBuffer>();\n   101→\n   102→  // Per-category cooldown timestamps (category → last played ms)\n   103→  const cooldownMap = new Map<string, number>();\n   104→\n   105→  // Whether any sound is currently playing\n   106→  let playing = false;\n   107→\n   108→  // Per-session pack assignment\n   109→  const sessionPacks = new Map<string, string>();\n   110→\n   111→  // -------------------------------------------------------------------------\n   112→  // Init / persistence\n   113→  // -------------------------------------------------------------------------\n   114→\n   115→  async function init(): Promise<void> {\n   116→    const home = await homeDir();\n   117→    soundPacksDir = `${home}/.agents-in-the-office/sound-packs`;\n   118→    configPath = `${soundPacksDir}/config.json`;\n   119→\n   120→    const dirExists = await exists(soundPacksDir);\n   121→    if (!dirExists) {\n   122→      await mkdir(soundPacksDir, { recursive: true });\n   123→    }\n   124→\n   125→    const cfgExists = await exists(configPath);\n   126→    if (cfgExists) {\n   127→      try {\n   128→        const raw = await readTextFile(configPath);\n   129→        config.value = { ...DEFAULT_CONFIG, ...JSON.parse(raw) as Partial<SoundConfig> };\n   130→      } catch {\n   131→        config.value = { ...DEFAULT_CONFIG, tracks: {} };\n   132→      }\n   133→    } else {\n   134→      config.value = { ...DEFAULT_CONFIG, tracks: {} };\n   135→      await saveConfig();\n   136→    }\n   137→  }\n   138→\n   139→  async function saveConfig(): Promise<void> {\n   140→    await writeTextFile(configPath, JSON.stringify(config.value, null, 2));\n   141→  }\n   142→\n   143→  // -------------------------------------------------------------------------\n   144→  // Pack manifest read/write\n   145→  // -------------------------------------------------------------------------\n   146→\n   147→  async function loadPackManifest(packName: string): Promise<PackManifest> {\n   148→    const manifestPath = `${soundPacksDir}/${packName}/manifest.json`;\n   149→    const manifestExists = await exists(manifestPath);\n   150→    if (!manifestExists) return { sounds: [], assignments: [] };\n   151→    try {\n   152→      const raw = await readTextFile(manifestPath);\n   153→      const parsed = JSON.parse(raw) as Partial<PackManifest>;\n   154→      return {\n   155→        sounds: Array.isArray(parsed.sounds) ? parsed.sounds : [],\n   156→        assignments: Array.isArray(parsed.assignments) ? parsed.assignments : [],\n   157→      };\n   158→    } catch {\n   159→      return { sounds: [], assignments: [] };\n   160→    }\n   161→  }\n   162→\n   163→  async function savePackManifest(packName: string, manifest: PackManifest): Promise<void> {\n   164→    const manifestPath = `${soundPacksDir}/${packName}/manifest.json`;\n   165→    await writeTextFile(manifestPath, JSON.stringify(manifest, null, 2));\n   166→  }\n   167→\n   168→  // -------------------------------------------------------------------------\n   169→  // Pack scanning\n   170→  // -------------------------------------------------------------------------\n   171→\n   172→  async function scanPacks(): Promise<PackInfo[]> {\n   173→    const discovered: PackInfo[] = [];\n   174→\n   175→    const dirExists = await exists(soundPacksDir);\n   176→    if (!dirExists) return discovered;\n   177→\n   178→    const entries = await readDir(soundPacksDir);\n   179→    for (const entry of entries) {\n   180→      if (!entry.isDirectory) continue;\n   181→      if (entry.name === undefined || entry.name.startsWith('.')) continue;\n   182→      const packName = entry.name;\n   183→      const packPath = `${soundPacksDir}/${packName}`;\n   184→      const categories: Record<string, string[]> = {};\n   185→\n   186→      const manifest = await loadPackManifest(packName);\n   187→      const hasManifest = await exists(`${packPath}/manifest.json`);\n   188→\n   189→      const catEntries = await readDir(packPath);\n   190→      for (const cat of catEntries) {\n   191→        if (!cat.isDirectory) continue;\n   192→        if (cat.name === undefined || cat.name.startsWith('.')) continue;\n   193→        const catName = cat.name;\n   194→        const catPath = `${packPath}/${catName}`;\n   195→        const fileEntries = await readDir(catPath);\n   196→        const audioFiles = fileEntries\n   197→          .filter((f) => !f.isDirectory && f.name !== undefined && hasAudioExtension(f.name))\n   198→          .map((f) => f.name as string);\n   199→        if (audioFiles.length > 0 || AGENT_EVENT_TYPES.includes(catName as AgentEventType)) {\n   200→          categories[catName] = audioFiles.sort();\n   201→        }\n   202→      }\n   203→\n   204→      for (const eventType of AGENT_EVENT_TYPES) {\n   205→        if (!(eventType in categories)) {\n   206→          categories[eventType] = [];\n   207→        }\n   208→      }\n   209→\n   210→      discovered.push({ name: packName, categories, manifest, hasManifest });\n   211→    }\n   212→\n   213→    packs.value = discovered;\n   214→    return discovered;\n   215→  }\n   216→\n   217→  // -------------------------------------------------------------------------\n   218→  // Track config helpers\n   219→  // -------------------------------------------------------------------------\n   220→\n   221→  function getTrackConfig(packName: string, categoryAndFile: string): TrackConfig {\n   222→    const packTracks = config.value.tracks[packName];\n   223→    if (packTracks) {\n   224→      const existing = packTracks[categoryAndFile];\n   225→      if (existing !== undefined) return existing;\n   226→    }\n   227→    const defaultTrack: TrackConfig = { enabled: true, volume: 1.0 };\n   228→    if (!config.value.tracks[packName]) {\n   229→      config.value.tracks[packName] = {};\n   230→    }\n   231→    config.value.tracks[packName][categoryAndFile] = defaultTrack;\n   232→    return defaultTrack;\n   233→  }\n   234→\n   235→  function setTrackConfig(packName: string, categoryAndFile: string, track: TrackConfig): void {\n   236→    if (!config.value.tracks[packName]) {\n   237→      config.value.tracks[packName] = {};\n   238→    }\n   239→    config.value.tracks[packName][categoryAndFile] = track;\n   240→  }\n   241→\n   242→  function getSoundPacksDir(): string {\n   243→    return soundPacksDir;\n   244→  }\n   245→\n   246→  function getSessionPack(sessionId: string): string | undefined {\n   247→    return sessionPacks.get(sessionId);\n   248→  }\n   249→\n   250→  function assignSessionPack(sessionId: string, preferredPacks: string[]): void {\n   251→    const pool = preferredPacks.length > 0 ? preferredPacks : config.value.activePacks;\n   252→    if (pool.length === 0) return;\n   253→    const chosen = pool[Math.floor(Math.random() * pool.length)];\n   254→    if (chosen !== undefined) {\n   255→      sessionPacks.set(sessionId, chosen);\n   256→    }\n   257→  }\n   258→\n   259→  // -------------------------------------------------------------------------\n   260→  // AudioContext helpers\n   261→  // -------------------------------------------------------------------------\n   262→\n   263→  function getAudioContext(): AudioContext {\n   264→    if (!audioCtx) {\n   265→      audioCtx = new AudioContext();\n   266→    }\n   267→    return audioCtx;\n   268→  }\n   269→\n   270→  async function loadBuffer(filePath: string): Promise<AudioBuffer | null> {\n   271→    const cached = bufferCache.get(filePath);\n   272→    if (cached !== undefined) return cached;\n   273→\n   274→    try {\n   275→      const bytes = await readFile(filePath);\n   276→      const ctx = getAudioContext();\n   277→      const buffer = await ctx.decodeAudioData(bytes.buffer as ArrayBuffer);\n   278→      bufferCache.set(filePath, buffer);\n   279→      return buffer;\n   280→    } catch (err) {\n   281→      console.warn(`[soundStore] Failed to decode audio: ${filePath}`, err);\n   282→      return null;\n   283→    }\n   284→  }\n   285→\n   286→  // -------------------------------------------------------------------------\n   287→  // Playback engine\n   288→  // -------------------------------------------------------------------------\n   289→\n   290→  async function playForEvent(event: AgentEvent): Promise<void> {\n   291→    if (!config.value.enabled) return;\n   292→\n   293→    // Session pack assignment on session_start\n   294→    if (event.type === 'session_start') {\n   295→      const { activePacks } = config.value;\n   296→      if (activePacks.length > 0) {\n   297→        const randomIdx = Math.floor(Math.random() * activePacks.length);\n   298→        const chosen = activePacks[randomIdx];\n   299→        if (chosen !== undefined) {\n   300→          sessionPacks.set(event.sessionId, chosen);\n   301→        }\n   302→      }\n   303→    }\n   304→\n   305→    const packName = sessionPacks.get(event.sessionId);\n   306→    if (!packName) return;\n   307→\n   308→    const category = event.type;\n   309→    const now = Date.now();\n   310→    const cooldownMs = config.value.cooldownSeconds * 1000;\n   311→    const lastPlayed = cooldownMap.get(category) ?? 0;\n   312→    if (now - lastPlayed < cooldownMs) return;\n   313→\n   314→    if (playing) return;\n   315→\n   316→    // Find the pack info\n   317→    const packInfo = packs.value.find((p) => p.name === packName);\n   318→    const files = packInfo?.categories[category] ?? [];\n   319→\n   320→    // Filter to enabled tracks\n   321→    const enabledFiles = files.filter((filename) => {\n   322→      const key = `${category}/${filename}`;\n   323→      return getTrackConfig(packName, key).enabled;\n   324→    });\n   325→\n   326→    if (enabledFiles.length === 0) return;\n   327→\n   328→    const randomFileIdx = Math.floor(Math.random() * enabledFiles.length);\n   329→    const chosenFile = enabledFiles[randomFileIdx];\n   330→    if (chosenFile === undefined) return;\n   331→\n   332→    const filePath = `${soundPacksDir}/${packName}/${category}/${chosenFile}`;\n   333→    const buffer = await loadBuffer(filePath);\n   334→    if (!buffer) return;\n   335→\n   336→    const trackKey = `${category}/${chosenFile}`;\n   337→    const trackCfg = getTrackConfig(packName, trackKey);\n   338→    const ctx = getAudioContext();\n   339→\n   340→    const gainNode = ctx.createGain();\n   341→    gainNode.gain.value = config.value.globalVolume * trackCfg.volume;\n   342→    gainNode.connect(ctx.destination);\n   343→\n   344→    const source = ctx.createBufferSource();\n   345→    source.buffer = buffer;\n   346→    source.connect(gainNode);\n   347→\n   348→    playing = true;\n   349→    cooldownMap.set(category, now);\n   350→    lastPlayedSessionId.value = event.sessionId;\n   351→\n   352→    source.onended = () => {\n   353→      playing = false;\n   354→    };\n   355→\n   356→    source.start();\n   357→  }\n   358→\n   359→  // -------------------------------------------------------------------------\n   360→  // Public AudioContext access (for AudioPlayer.vue)\n   361→  // -------------------------------------------------------------------------\n   362→\n   363→  function getOrCreateAudioContext(): AudioContext {\n   364→    return getAudioContext();\n   365→  }\n   366→\n   367→  function getBufferCache(): Map<string, AudioBuffer> {\n   368→    return bufferCache;\n   369→  }\n   370→\n   371→  return {\n   372→    config,\n   373→    packs,\n   374→    lastPlayedSessionId,\n   375→    init,\n   376→    saveConfig,\n   377→    scanPacks,\n   378→    loadPackManifest,\n   379→    savePackManifest,\n   380→    getTrackConfig,\n   381→    setTrackConfig,\n   382→    getSoundPacksDir,\n   383→    playForEvent,\n   384→    getOrCreateAudioContext,\n   385→    getBufferCache,\n   386→    loadBuffer,\n   387→    getSessionPack,\n   388→    assignSessionPack,\n   389→  };\n   390→});\n   391→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"b273f168-5152-4d5e-b9e2-1d2ad43401b5","uuid":"a60a45b6-da30-40e0-9b9a-e068bc6093f1","tool_use_result":{"type":"text","file":{"filePath":"/Users/markus/baustelle/projects/agents-in-the-office/agents-in-the-office/.chief/worktrees/sound-packs-patchbay/src/stores/soundStore.ts","content":"import { defineStore } from 'pinia';\nimport { ref } from 'vue';\nimport { homeDir } from '@tauri-apps/api/path';\nimport {\n  readTextFile,\n  writeTextFile,\n  mkdir,\n  exists,\n  readDir,\n  readFile,\n} from '@tauri-apps/plugin-fs';\nimport type { AgentEvent, AgentEventType } from '../drivers/types';\n\nexport const AGENT_EVENT_TYPES: AgentEventType[] = [\n  'session_start',\n  'session_end',\n  'prompt_submit',\n  'tool_start',\n  'tool_end',\n  'turn_end',\n  'permission_wait',\n  'subagent_start',\n  'subagent_end',\n  'idle_notification',\n  'elicitation_wait',\n  'auth_success',\n  'worktree_create',\n  'worktree_remove',\n  'teammate_idle',\n  'task_completed',\n];\n\nexport interface TrackConfig {\n  enabled: boolean;\n  volume: number;\n}\n\nexport interface SoundConfig {\n  enabled: boolean;\n  globalVolume: number;\n  cooldownSeconds: number;\n  activePacks: string[];\n  tracks: Record<string, Record<string, TrackConfig>>;\n}\n\nexport interface PackManifestSound {\n  file: string;\n  volume: number;\n  enabled: boolean;\n}\n\nexport interface PackManifestAssignment {\n  file: string;\n  event: AgentEventType;\n}\n\nexport interface PackManifest {\n  sounds: PackManifestSound[];\n  assignments: PackManifestAssignment[];\n}\n\nexport interface PackInfo {\n  name: string;\n  categories: Record<string, string[]>;\n  manifest: PackManifest;\n  hasManifest: boolean;\n}\n\n\nconst DEFAULT_CONFIG: SoundConfig = {\n  enabled: true,\n  globalVolume: 0.8,\n  cooldownSeconds: 2,\n  activePacks: [],\n  tracks: {},\n};\n\nconst AUDIO_EXTENSIONS = new Set(['.mp3', '.ogg', '.wav', '.flac', '.m4a', '.webm']);\n\nfunction hasAudioExtension(filename: string): boolean {\n  const dot = filename.lastIndexOf('.');\n  if (dot < 0) return false;\n  return AUDIO_EXTENSIONS.has(filename.slice(dot).toLowerCase());\n}\n\nexport const useSoundStore = defineStore('sound', () => {\n  const config = ref<SoundConfig>({ ...DEFAULT_CONFIG, tracks: {} });\n  const packs = ref<PackInfo[]>([]);\n\n  // Reactive state for sound indicator (US-009)\n  const lastPlayedSessionId = ref<string | null>(null);\n\n  let soundPacksDir = '';\n  let configPath = '';\n\n  // AudioContext — lazy init on first playback\n  let audioCtx: AudioContext | null = null;\n\n  // Buffer cache: absolute file path → AudioBuffer\n  const bufferCache = new Map<string, AudioBuffer>();\n\n  // Per-category cooldown timestamps (category → last played ms)\n  const cooldownMap = new Map<string, number>();\n\n  // Whether any sound is currently playing\n  let playing = false;\n\n  // Per-session pack assignment\n  const sessionPacks = new Map<string, string>();\n\n  // -------------------------------------------------------------------------\n  // Init / persistence\n  // -------------------------------------------------------------------------\n\n  async function init(): Promise<void> {\n    const home = await homeDir();\n    soundPacksDir = `${home}/.agents-in-the-office/sound-packs`;\n    configPath = `${soundPacksDir}/config.json`;\n\n    const dirExists = await exists(soundPacksDir);\n    if (!dirExists) {\n      await mkdir(soundPacksDir, { recursive: true });\n    }\n\n    const cfgExists = await exists(configPath);\n    if (cfgExists) {\n      try {\n        const raw = await readTextFile(configPath);\n        config.value = { ...DEFAULT_CONFIG, ...JSON.parse(raw) as Partial<SoundConfig> };\n      } catch {\n        config.value = { ...DEFAULT_CONFIG, tracks: {} };\n      }\n    } else {\n      config.value = { ...DEFAULT_CONFIG, tracks: {} };\n      await saveConfig();\n    }\n  }\n\n  async function saveConfig(): Promise<void> {\n    await writeTextFile(configPath, JSON.stringify(config.value, null, 2));\n  }\n\n  // -------------------------------------------------------------------------\n  // Pack manifest read/write\n  // -------------------------------------------------------------------------\n\n  async function loadPackManifest(packName: string): Promise<PackManifest> {\n    const manifestPath = `${soundPacksDir}/${packName}/manifest.json`;\n    const manifestExists = await exists(manifestPath);\n    if (!manifestExists) return { sounds: [], assignments: [] };\n    try {\n      const raw = await readTextFile(manifestPath);\n      const parsed = JSON.parse(raw) as Partial<PackManifest>;\n      return {\n        sounds: Array.isArray(parsed.sounds) ? parsed.sounds : [],\n        assignments: Array.isArray(parsed.assignments) ? parsed.assignments : [],\n      };\n    } catch {\n      return { sounds: [], assignments: [] };\n    }\n  }\n\n  async function savePackManifest(packName: string, manifest: PackManifest): Promise<void> {\n    const manifestPath = `${soundPacksDir}/${packName}/manifest.json`;\n    await writeTextFile(manifestPath, JSON.stringify(manifest, null, 2));\n  }\n\n  // -------------------------------------------------------------------------\n  // Pack scanning\n  // -------------------------------------------------------------------------\n\n  async function scanPacks(): Promise<PackInfo[]> {\n    const discovered: PackInfo[] = [];\n\n    const dirExists = await exists(soundPacksDir);\n    if (!dirExists) return discovered;\n\n    const entries = await readDir(soundPacksDir);\n    for (const entry of entries) {\n      if (!entry.isDirectory) continue;\n      if (entry.name === undefined || entry.name.startsWith('.')) continue;\n      const packName = entry.name;\n      const packPath = `${soundPacksDir}/${packName}`;\n      const categories: Record<string, string[]> = {};\n\n      const manifest = await loadPackManifest(packName);\n      const hasManifest = await exists(`${packPath}/manifest.json`);\n\n      const catEntries = await readDir(packPath);\n      for (const cat of catEntries) {\n        if (!cat.isDirectory) continue;\n        if (cat.name === undefined || cat.name.startsWith('.')) continue;\n        const catName = cat.name;\n        const catPath = `${packPath}/${catName}`;\n        const fileEntries = await readDir(catPath);\n        const audioFiles = fileEntries\n          .filter((f) => !f.isDirectory && f.name !== undefined && hasAudioExtension(f.name))\n          .map((f) => f.name as string);\n        if (audioFiles.length > 0 || AGENT_EVENT_TYPES.includes(catName as AgentEventType)) {\n          categories[catName] = audioFiles.sort();\n        }\n      }\n\n      for (const eventType of AGENT_EVENT_TYPES) {\n        if (!(eventType in categories)) {\n          categories[eventType] = [];\n        }\n      }\n\n      discovered.push({ name: packName, categories, manifest, hasManifest });\n    }\n\n    packs.value = discovered;\n    return discovered;\n  }\n\n  // -------------------------------------------------------------------------\n  // Track config helpers\n  // -------------------------------------------------------------------------\n\n  function getTrackConfig(packName: string, categoryAndFile: string): TrackConfig {\n    const packTracks = config.value.tracks[packName];\n    if (packTracks) {\n      const existing = packTracks[categoryAndFile];\n      if (existing !== undefined) return existing;\n    }\n    const defaultTrack: TrackConfig = { enabled: true, volume: 1.0 };\n    if (!config.value.tracks[packName]) {\n      config.value.tracks[packName] = {};\n    }\n    config.value.tracks[packName][categoryAndFile] = defaultTrack;\n    return defaultTrack;\n  }\n\n  function setTrackConfig(packName: string, categoryAndFile: string, track: TrackConfig): void {\n    if (!config.value.tracks[packName]) {\n      config.value.tracks[packName] = {};\n    }\n    config.value.tracks[packName][categoryAndFile] = track;\n  }\n\n  function getSoundPacksDir(): string {\n    return soundPacksDir;\n  }\n\n  function getSessionPack(sessionId: string): string | undefined {\n    return sessionPacks.get(sessionId);\n  }\n\n  function assignSessionPack(sessionId: string, preferredPacks: string[]): void {\n    const pool = preferredPacks.length > 0 ? preferredPacks : config.value.activePacks;\n    if (pool.length === 0) return;\n    const chosen = pool[Math.floor(Math.random() * pool.length)];\n    if (chosen !== undefined) {\n      sessionPacks.set(sessionId, chosen);\n    }\n  }\n\n  // -------------------------------------------------------------------------\n  // AudioContext helpers\n  // -------------------------------------------------------------------------\n\n  function getAudioContext(): AudioContext {\n    if (!audioCtx) {\n      audioCtx = new AudioContext();\n    }\n    return audioCtx;\n  }\n\n  async function loadBuffer(filePath: string): Promise<AudioBuffer | null> {\n    const cached = bufferCache.get(filePath);\n    if (cached !== undefined) return cached;\n\n    try {\n      const bytes = await readFile(filePath);\n      const ctx = getAudioContext();\n      const buffer = await ctx.decodeAudioData(bytes.buffer as ArrayBuffer);\n      bufferCache.set(filePath, buffer);\n      return buffer;\n    } catch (err) {\n      console.warn(`[soundStore] Failed to decode audio: ${filePath}`, err);\n      return null;\n    }\n  }\n\n  // -------------------------------------------------------------------------\n  // Playback engine\n  // -------------------------------------------------------------------------\n\n  async function playForEvent(event: AgentEvent): Promise<void> {\n    if (!config.value.enabled) return;\n\n    // Session pack assignment on session_start\n    if (event.type === 'session_start') {\n      const { activePacks } = config.value;\n      if (activePacks.length > 0) {\n        const randomIdx = Math.floor(Math.random() * activePacks.length);\n        const chosen = activePacks[randomIdx];\n        if (chosen !== undefined) {\n          sessionPacks.set(event.sessionId, chosen);\n        }\n      }\n    }\n\n    const packName = sessionPacks.get(event.sessionId);\n    if (!packName) return;\n\n    const category = event.type;\n    const now = Date.now();\n    const cooldownMs = config.value.cooldownSeconds * 1000;\n    const lastPlayed = cooldownMap.get(category) ?? 0;\n    if (now - lastPlayed < cooldownMs) return;\n\n    if (playing) return;\n\n    // Find the pack info\n    const packInfo = packs.value.find((p) => p.name === packName);\n    const files = packInfo?.categories[category] ?? [];\n\n    // Filter to enabled tracks\n    const enabledFiles = files.filter((filename) => {\n      const key = `${category}/${filename}`;\n      return getTrackConfig(packName, key).enabled;\n    });\n\n    if (enabledFiles.length === 0) return;\n\n    const randomFileIdx = Math.floor(Math.random() * enabledFiles.length);\n    const chosenFile = enabledFiles[randomFileIdx];\n    if (chosenFile === undefined) return;\n\n    const filePath = `${soundPacksDir}/${packName}/${category}/${chosenFile}`;\n    const buffer = await loadBuffer(filePath);\n    if (!buffer) return;\n\n    const trackKey = `${category}/${chosenFile}`;\n    const trackCfg = getTrackConfig(packName, trackKey);\n    const ctx = getAudioContext();\n\n    const gainNode = ctx.createGain();\n    gainNode.gain.value = config.value.globalVolume * trackCfg.volume;\n    gainNode.connect(ctx.destination);\n\n    const source = ctx.createBufferSource();\n    source.buffer = buffer;\n    source.connect(gainNode);\n\n    playing = true;\n    cooldownMap.set(category, now);\n    lastPlayedSessionId.value = event.sessionId;\n\n    source.onended = () => {\n      playing = false;\n    };\n\n    source.start();\n  }\n\n  // -------------------------------------------------------------------------\n  // Public AudioContext access (for AudioPlayer.vue)\n  // -------------------------------------------------------------------------\n\n  function getOrCreateAudioContext(): AudioContext {\n    return getAudioContext();\n  }\n\n  function getBufferCache(): Map<string, AudioBuffer> {\n    return bufferCache;\n  }\n\n  return {\n    config,\n    packs,\n    lastPlayedSessionId,\n    init,\n    saveConfig,\n    scanPacks,\n    loadPackManifest,\n    savePackManifest,\n    getTrackConfig,\n    setTrackConfig,\n    getSoundPacksDir,\n    playForEvent,\n    getOrCreateAudioContext,\n    getBufferCache,\n    loadBuffer,\n    getSessionPack,\n    assignSessionPack,\n  };\n});\n","numLines":391,"startLine":1,"totalLines":391}}}
