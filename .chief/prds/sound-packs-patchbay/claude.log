{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0175zGbCeCBC6SDnmZDuoUVp","type":"tool_result","content":"     1→<script setup lang=\"ts\">\n     2→import {\n     3→  ref,\n     4→  computed,\n     5→  watch,\n     6→  nextTick,\n     7→  onMounted,\n     8→  onUnmounted,\n     9→} from 'vue';\n    10→import { listen } from '@tauri-apps/api/event';\n    11→import type { UnlistenFn } from '@tauri-apps/api/event';\n    12→import { open } from '@tauri-apps/plugin-dialog';\n    13→import {\n    14→  mkdir,\n    15→  readFile,\n    16→  writeFile,\n    17→  exists,\n    18→  rename,\n    19→  remove,\n    20→} from '@tauri-apps/plugin-fs';\n    21→import JSZip from 'jszip';\n    22→import { useSoundStore, AGENT_EVENT_TYPES } from '../stores/soundStore';\n    23→import type { PackManifestSound } from '../stores/soundStore';\n    24→import type { AgentEvent, AgentEventType } from '../drivers/types';\n    25→import PackContextMenu from './PackContextMenu.vue';\n    26→\n    27→const emit = defineEmits<{ close: [] }>();\n    28→\n    29→const soundStore = useSoundStore();\n    30→\n    31→// ---- Global settings ----\n    32→const globalEnabled = computed({\n    33→  get: () => soundStore.config.enabled,\n    34→  set: (v: boolean) => { soundStore.config.enabled = v; void soundStore.saveConfig(); },\n    35→});\n    36→const globalVolume = computed({\n    37→  get: () => Math.round(soundStore.config.globalVolume * 100),\n    38→  set: (v: number) => { soundStore.config.globalVolume = v / 100; void soundStore.saveConfig(); },\n    39→});\n    40→const cooldown = computed({\n    41→  get: () => soundStore.config.cooldownSeconds,\n    42→  set: (v: number) => { soundStore.config.cooldownSeconds = v; void soundStore.saveConfig(); },\n    43→});\n    44→\n    45→// ---- Pack list ----\n    46→const selectedPack = ref<string | null>(null);\n    47→const rightPanel = ref<HTMLElement | null>(null);\n    48→\n    49→onMounted(async () => {\n    50→  await soundStore.init();\n    51→  await soundStore.scanPacks();\n    52→  if (soundStore.packs.length > 0 && soundStore.packs[0]) {\n    53→    selectedPack.value = soundStore.packs[0].name;\n    54→  }\n    55→  agentEventUnlisten = await listen<string>(\n    56→    'agent-event',\n    57→    (e) => {\n    58→      try {\n    59→        const parsed = JSON.parse(e.payload) as AgentEvent;\n    60→        flashEventRow(parsed.type);\n    61→      } catch { /* ignore parse errors */ }\n    62→    },\n    63→  );\n    64→});\n    65→\n    66→onUnmounted(() => {\n    67→  if (agentEventUnlisten) agentEventUnlisten();\n    68→  if (flashTimeout) clearTimeout(flashTimeout);\n    69→  if (importErrorTimeout) clearTimeout(importErrorTimeout);\n    70→});\n    71→\n    72→function isPackActive(packName: string): boolean {\n    73→  return soundStore.config.activePacks.includes(packName);\n    74→}\n    75→\n    76→function togglePackActive(packName: string, active: boolean) {\n    77→  if (active) {\n    78→    if (!soundStore.config.activePacks.includes(packName)) {\n    79→      soundStore.config.activePacks.push(packName);\n    80→    }\n    81→  } else {\n    82→    soundStore.config.activePacks = soundStore.config.activePacks.filter(\n    83→      (p) => p !== packName,\n    84→    );\n    85→  }\n    86→  void soundStore.saveConfig();\n    87→}\n    88→\n    89→function selectPack(name: string) {\n    90→  selectedPack.value = name;\n    91→  void nextTick(() => {\n    92→    if (rightPanel.value) rightPanel.value.scrollTop = 0;\n    93→  });\n    94→}\n    95→\n    96→// ---- Context menu ----\n    97→const ctxMenu = ref<{ packName: string; x: number; y: number } | null>(null);\n    98→\n    99→function onPackRightClick(e: MouseEvent, packName: string) {\n   100→  e.preventDefault();\n   101→  ctxMenu.value = { packName, x: e.clientX, y: e.clientY };\n   102→}\n   103→\n   104→function closeCtxMenu() {\n   105→  ctxMenu.value = null;\n   106→}\n   107→\n   108→async function onPackRenamed(oldName: string, newName: string) {\n   109→  await soundStore.scanPacks();\n   110→  if (selectedPack.value === oldName) selectedPack.value = newName;\n   111→  closeCtxMenu();\n   112→}\n   113→\n   114→async function onPackDuplicated() {\n   115→  await soundStore.scanPacks();\n   116→  closeCtxMenu();\n   117→}\n   118→\n   119→async function onPackDeleted(name: string) {\n   120→  await soundStore.scanPacks();\n   121→  if (selectedPack.value === name) {\n   122→    selectedPack.value = soundStore.packs[0]?.name ?? null;\n   123→  }\n   124→  closeCtxMenu();\n   125→}\n   126→\n   127→// ---- New pack / inline rename ----\n   128→const editingPackName = ref<string | null>(null);\n   129→const editPackNameValue = ref('');\n   130→const editPackInput = ref<HTMLInputElement | null>(null);\n   131→const isNewPack = ref(false);\n   132→\n   133→function generatePackName(): string {\n   134→  const existingNames = new Set(soundStore.packs.map((p) => p.name));\n   135→  const base = 'New Pack';\n   136→  if (!existingNames.has(base)) return base;\n   137→  for (let i = 2; i < 100; i++) {\n   138→    const candidate = `${base} ${i}`;\n   139→    if (!existingNames.has(candidate)) return candidate;\n   140→  }\n   141→  return `${base} ${Date.now()}`;\n   142→}\n   143→\n   144→async function startCreatePack(): Promise<void> {\n   145→  const packName = generatePackName();\n   146→  const baseDir = soundStore.getSoundPacksDir();\n   147→  const packPath = `${baseDir}/${packName}`;\n   148→  try {\n   149→    await mkdir(packPath, { recursive: true });\n   150→    await soundStore.savePackManifest(packName, { sounds: [], assignments: [] });\n   151→    await soundStore.scanPacks();\n   152→    selectedPack.value = packName;\n   153→    isNewPack.value = true;\n   154→    editingPackName.value = packName;\n   155→    editPackNameValue.value = packName;\n   156→    void nextTick(() => editPackInput.value?.select());\n   157→  } catch (err) {\n   158→    console.error('[SoundsDialog] createNewPack failed', err);\n   159→  }\n   160→}\n   161→\n   162→async function confirmEditPackName(): Promise<void> {\n   163→  const oldName = editingPackName.value;\n   164→  if (!oldName) return;\n   165→  const newName = editPackNameValue.value.trim();\n   166→  editingPackName.value = null;\n   167→  isNewPack.value = false;\n   168→\n   169→  if (!newName || newName === oldName) return;\n   170→\n   171→  const baseDir = soundStore.getSoundPacksDir();\n   172→  try {\n   173→    await rename(`${baseDir}/${oldName}`, `${baseDir}/${newName}`);\n   174→    // Update activePacks\n   175→    const idx = soundStore.config.activePacks.indexOf(oldName);\n   176→    if (idx >= 0) soundStore.config.activePacks[idx] = newName;\n   177→    // Move soundOverrides entries\n   178→    const oldPrefix = `${oldName}/`;\n   179→    const newPrefix = `${newName}/`;\n   180→    for (const key of Object.keys(soundStore.config.soundOverrides)) {\n   181→      if (key.startsWith(oldPrefix)) {\n   182→        const filename = key.slice(oldPrefix.length);\n   183→        soundStore.config.soundOverrides[`${newPrefix}${filename}`] =\n   184→          soundStore.config.soundOverrides[key]!;\n   185→        delete soundStore.config.soundOverrides[key];\n   186→      }\n   187→    }\n   188→    await soundStore.saveConfig();\n   189→    await soundStore.scanPacks();\n   190→    if (selectedPack.value === oldName) selectedPack.value = newName;\n   191→  } catch (err) {\n   192→    console.error('[SoundsDialog] rename pack failed', err);\n   193→  }\n   194→}\n   195→\n   196→async function cancelEditPackName(): Promise<void> {\n   197→  const oldName = editingPackName.value;\n   198→  const wasNew = isNewPack.value;\n   199→  editingPackName.value = null;\n   200→  isNewPack.value = false;\n   201→\n   202→  if (wasNew && oldName) {\n   203→    const baseDir = soundStore.getSoundPacksDir();\n   204→    try {\n   205→      await remove(`${baseDir}/${oldName}`, { recursive: true });\n   206→      await soundStore.scanPacks();\n   207→      if (selectedPack.value === oldName) {\n   208→        selectedPack.value = soundStore.packs[0]?.name ?? null;\n   209→      }\n   210→    } catch (err) {\n   211→      console.error('[SoundsDialog] cancel new pack failed', err);\n   212→    }\n   213→  }\n   214→}\n   215→\n   216→// ---- Import zip ----\n   217→const dragOver = ref(false);\n   218→const importError = ref<string | null>(null);\n   219→let importErrorTimeout: ReturnType<typeof setTimeout> | null = null;\n   220→\n   221→function showImportError(message: string): void {\n   222→  importError.value = message;\n   223→  if (importErrorTimeout) clearTimeout(importErrorTimeout);\n   224→  importErrorTimeout = setTimeout(() => {\n   225→    importError.value = null;\n   226→    importErrorTimeout = null;\n   227→  }, 5000);\n   228→}\n   229→\n   230→async function importZipBytes(filename: string, bytes: Uint8Array): Promise<void> {\n   231→  const dotIdx = filename.lastIndexOf('.');\n   232→  const packName = dotIdx > 0 ? filename.slice(0, dotIdx) : filename;\n   233→\n   234→  const zip = await JSZip.loadAsync(bytes);\n   235→\n   236→  // Find manifest.json — could be at root or inside a single top-level folder\n   237→  let manifestFile = zip.file('manifest.json');\n   238→  let stripPrefix = '';\n   239→  if (!manifestFile) {\n   240→    const topDirs = Object.keys(zip.files).filter(\n   241→      (p) => p.endsWith('/') && !p.slice(0, -1).includes('/'),\n   242→    );\n   243→    if (topDirs.length === 1 && topDirs[0]) {\n   244→      stripPrefix = topDirs[0];\n   245→      manifestFile = zip.file(`${stripPrefix}manifest.json`);\n   246→    }\n   247→  }\n   248→\n   249→  if (!manifestFile) {\n   250→    showImportError(\n   251→      'This ZIP does not contain a manifest.json. Please use the new pack format.',\n   252→    );\n   253→    return;\n   254→  }\n   255→\n   256→  const baseDir = soundStore.getSoundPacksDir();\n   257→  const packPath = `${baseDir}/${packName}`;\n   258→  await mkdir(packPath, { recursive: true });\n   259→\n   260→  // Write manifest.json\n   261→  const manifestData = await manifestFile.async('uint8array');\n   262→  await writeFile(`${packPath}/manifest.json`, manifestData);\n   263→\n   264→  // Extract audio files to pack root (flat — no subdirectories)\n   265→  for (const [relativePath, file] of Object.entries(zip.files)) {\n   266→    if (file.dir) continue;\n   267→    let effectivePath = relativePath;\n   268→    if (stripPrefix && effectivePath.startsWith(stripPrefix)) {\n   269→      effectivePath = effectivePath.slice(stripPrefix.length);\n   270→    }\n   271→    if (effectivePath === 'manifest.json') continue;\n   272→    // Only extract files at the root level (no subdirectories)\n   273→    if (effectivePath.includes('/')) continue;\n   274→    const data = await file.async('uint8array');\n   275→    await writeFile(`${packPath}/${effectivePath}`, data);\n   276→  }\n   277→\n   278→  await soundStore.scanPacks();\n   279→  selectedPack.value = packName;\n   280→}\n   281→\n   282→async function openImportPicker() {\n   283→  const result = await open({\n   284→    filters: [{ name: 'ZIP', extensions: ['zip'] }],\n   285→    multiple: false,\n   286→  });\n   287→  if (!result) return;\n   288→  const filePath = typeof result === 'string' ? result : result;\n   289→  if (!filePath) return;\n   290→  try {\n   291→    const bytes = await readFile(filePath);\n   292→    const filename = (filePath as string).split('/').pop() ?? 'pack.zip';\n   293→    await importZipBytes(filename, bytes);\n   294→  } catch (err) {\n   295→    console.error('[SoundsDialog] import failed', err);\n   296→  }\n   297→}\n   298→\n   299→function onDragOver(e: DragEvent) {\n   300→  e.preventDefault();\n   301→  dragOver.value = true;\n   302→}\n   303→\n   304→function onDragLeave() {\n   305→  dragOver.value = false;\n   306→}\n   307→\n   308→async function onDrop(e: DragEvent) {\n   309→  e.preventDefault();\n   310→  dragOver.value = false;\n   311→  const file = e.dataTransfer?.files[0];\n   312→  if (!file) return;\n   313→  try {\n   314→    const arrayBuffer = await file.arrayBuffer();\n   315→    await importZipBytes(file.name, new Uint8Array(arrayBuffer));\n   316→  } catch (err) {\n   317→    console.error('[SoundsDialog] drop import failed', err);\n   318→  }\n   319→}\n   320→\n   321→// ---- Event descriptions ----\n   322→const EVENT_DESCRIPTIONS: Record<string, string> = {\n   323→  session_start: 'Agent session begins.',\n   324→  session_end: 'Agent session ends or is interrupted.',\n   325→  prompt_submit: 'User submits a prompt to the agent.',\n   326→  tool_start: 'Agent begins executing a tool (e.g. Bash, Read, Edit).',\n   327→  tool_end: 'Agent finishes executing a tool.',\n   328→  turn_end: 'Agent completes a full response turn.',\n   329→  permission_wait: 'Agent pauses waiting for the user to approve a tool call.',\n   330→  subagent_start: 'A subagent is spawned by the parent agent.',\n   331→  subagent_end: 'A subagent finishes its work.',\n   332→  idle_notification: 'Agent has been idle and sends a nudge notification.',\n   333→  elicitation_wait: 'Agent pauses waiting for user input.',\n   334→  auth_success: 'Authentication to an external service succeeds.',\n   335→  worktree_create: 'A new git worktree is created.',\n   336→  worktree_remove: 'A git worktree is removed.',\n   337→  teammate_idle: \"A teammate's agent session goes idle.\",\n   338→  task_completed: 'Agent marks a task as completed.',\n   339→};\n   340→\n   341→const activeInfoPopover = ref<string | null>(null);\n   342→\n   343→function toggleInfoPopover(eventType: string) {\n   344→  activeInfoPopover.value = activeInfoPopover.value === eventType ? null : eventType;\n   345→}\n   346→\n   347→// ---- Patchbay data ----\n   348→const selectedPackInfo = computed(() =>\n   349→  soundStore.packs.find((p) => p.name === selectedPack.value) ?? null,\n   350→);\n   351→\n   352→function hasAssignments(eventType: AgentEventType): boolean {\n   353→  if (!selectedPackInfo.value) return false;\n   354→  return selectedPackInfo.value.manifest.assignments.some((a) => a.event === eventType);\n   355→}\n   356→\n   357→// ---- Sound preview (left column) ----\n   358→let previewSource: AudioBufferSourceNode | null = null;\n   359→const previewFile = ref<string | null>(null);\n   360→const soundFileExists = ref<Map<string, boolean>>(new Map());\n   361→const hoveredSoundFile = ref<string | null>(null);\n   362→\n   363→async function checkSoundFileExistence(packName: string): Promise<void> {\n   364→  const sounds = selectedPackInfo.value?.manifest.sounds ?? [];\n   365→  const baseDir = soundStore.getSoundPacksDir();\n   366→  const newMap = new Map<string, boolean>();\n   367→  await Promise.all(\n   368→    sounds.map(async (sound) => {\n   369→      const filePath = `${baseDir}/${packName}/${sound.file}`;\n   370→      const fileExists = await exists(filePath);\n   371→      newMap.set(sound.file, fileExists);\n   372→    }),\n   373→  );\n   374→  soundFileExists.value = newMap;\n   375→}\n   376→\n   377→function stopPreview(): void {\n   378→  if (previewSource) {\n   379→    try { previewSource.stop(); } catch { /* already stopped */ }\n   380→    previewSource = null;\n   381→  }\n   382→  previewFile.value = null;\n   383→}\n   384→\n   385→async function playPreview(filename: string): Promise<void> {\n   386→  if (!selectedPack.value) return;\n   387→  stopPreview();\n   388→  const baseDir = soundStore.getSoundPacksDir();\n   389→  const filePath = `${baseDir}/${selectedPack.value}/${filename}`;\n   390→  const buffer = await soundStore.loadBuffer(filePath);\n   391→  if (!buffer) return;\n   392→  const ctx = soundStore.getOrCreateAudioContext();\n   393→  const sound = selectedPackInfo.value?.manifest.sounds.find((s) => s.file === filename);\n   394→  const gainNode = ctx.createGain();\n   395→  gainNode.gain.value =\n   396→    soundStore.config.globalVolume * soundStore.effectiveVolume(selectedPack.value, filename, sound);\n   397→  gainNode.connect(ctx.destination);\n   398→  const source = ctx.createBufferSource();\n   399→  source.buffer = buffer;\n   400→  source.connect(gainNode);\n   401→  previewFile.value = filename;\n   402→  previewSource = source;\n   403→  source.onended = () => {\n   404→    if (previewFile.value === filename) {\n   405→      previewFile.value = null;\n   406→      previewSource = null;\n   407→    }\n   408→  };\n   409→  source.start();\n   410→}\n   411→\n   412→async function updateSoundVolume(sound: PackManifestSound, volume: number): Promise<void> {\n   413→  if (!selectedPack.value || !selectedPackInfo.value) return;\n   414→  sound.volume = volume;\n   415→  await soundStore.savePackManifest(selectedPack.value, selectedPackInfo.value.manifest);\n   416→}\n   417→\n   418→async function updateSoundEnabled(sound: PackManifestSound, enabled: boolean): Promise<void> {\n   419→  if (!selectedPack.value || !selectedPackInfo.value) return;\n   420→  sound.enabled = enabled;\n   421→  await soundStore.savePackManifest(selectedPack.value, selectedPackInfo.value.manifest);\n   422→}\n   423→\n   424→// ---- Assignment chips (right column) ----\n   425→function assignmentsForEvent(eventType: AgentEventType): string[] {\n   426→  if (!selectedPackInfo.value) return [];\n   427→  return selectedPackInfo.value.manifest.assignments\n   428→    .filter((a) => a.event === eventType)\n   429→    .map((a) => a.file);\n   430→}\n   431→\n   432→function truncateFilename(name: string, max = 20): string {\n   433→  if (name.length <= max) return name;\n   434→  return name.slice(0, max - 1) + '\\u2026';\n   435→}\n   436→\n   437→async function removeAssignment(\n   438→  file: string,\n   439→  eventType: AgentEventType,\n   440→): Promise<void> {\n   441→  if (!selectedPack.value || !selectedPackInfo.value) return;\n   442→  const manifest = selectedPackInfo.value.manifest;\n   443→  manifest.assignments = manifest.assignments.filter(\n   444→    (a) => !(a.file === file && a.event === eventType),\n   445→  );\n   446→  await soundStore.savePackManifest(selectedPack.value, manifest);\n   447→}\n   448→\n   449→// ---- Drag-and-drop: sound → event row ----\n   450→const draggingSoundFile = ref<string | null>(null);\n   451→const dragOverEventType = ref<AgentEventType | null>(null);\n   452→\n   453→// ---- Drag-and-drop: chip → sound row (re-assign) ----\n   454→const draggingChip = ref<{ file: string; event: AgentEventType } | null>(null);\n   455→const dragOverSoundFile = ref<string | null>(null);\n   456→\n   457→function onSoundDragStart(e: DragEvent, filename: string): void {\n   458→  draggingSoundFile.value = filename;\n   459→  if (e.dataTransfer) {\n   460→    e.dataTransfer.effectAllowed = 'copy';\n   461→    e.dataTransfer.setData('text/plain', filename);\n   462→  }\n   463→}\n   464→\n   465→function onSoundDragEnd(): void {\n   466→  draggingSoundFile.value = null;\n   467→  dragOverEventType.value = null;\n   468→}\n   469→\n   470→function onEventDragOver(e: DragEvent, eventType: AgentEventType): void {\n   471→  if (!draggingSoundFile.value) return;\n   472→  e.preventDefault();\n   473→  if (e.dataTransfer) e.dataTransfer.dropEffect = 'copy';\n   474→  dragOverEventType.value = eventType;\n   475→}\n   476→\n   477→function onEventDragLeaveRow(): void {\n   478→  dragOverEventType.value = null;\n   479→}\n   480→\n   481→async function onEventDrop(\n   482→  e: DragEvent,\n   483→  eventType: AgentEventType,\n   484→): Promise<void> {\n   485→  e.preventDefault();\n   486→  dragOverEventType.value = null;\n   487→  const file = draggingSoundFile.value;\n   488→  draggingSoundFile.value = null;\n   489→  if (!file) return;\n   490→  await addAssignment(file, eventType);\n   491→}\n   492→\n   493→async function addAssignment(\n   494→  file: string,\n   495→  eventType: AgentEventType,\n   496→): Promise<void> {\n   497→  if (!selectedPack.value || !selectedPackInfo.value) return;\n   498→  const manifest = selectedPackInfo.value.manifest;\n   499→  const alreadyExists = manifest.assignments.some(\n   500→    (a) => a.file === file && a.event === eventType,\n   501→  );\n   502→  if (alreadyExists) return;\n   503→  manifest.assignments.push({ file, event: eventType });\n   504→  await soundStore.savePackManifest(selectedPack.value, manifest);\n   505→}\n   506→\n   507→// ---- Chip drag handlers (re-assign chip to different sound) ----\n   508→function onChipDragStart(\n   509→  e: DragEvent,\n   510→  file: string,\n   511→  eventType: AgentEventType,\n   512→): void {\n   513→  draggingChip.value = { file, event: eventType };\n   514→  if (e.dataTransfer) {\n   515→    e.dataTransfer.effectAllowed = 'move';\n   516→    e.dataTransfer.setData('text/plain', file);\n   517→  }\n   518→}\n   519→\n   520→function onChipDragEnd(): void {\n   521→  draggingChip.value = null;\n   522→  dragOverSoundFile.value = null;\n   523→}\n   524→\n   525→function onSoundRowDragOver(e: DragEvent, filename: string): void {\n   526→  if (!draggingChip.value) return;\n   527→  e.preventDefault();\n   528→  if (e.dataTransfer) e.dataTransfer.dropEffect = 'move';\n   529→  dragOverSoundFile.value = filename;\n   530→}\n   531→\n   532→function onSoundRowDragLeave(): void {\n   533→  dragOverSoundFile.value = null;\n   534→}\n   535→\n   536→async function onSoundRowDrop(\n   537→  e: DragEvent,\n   538→  newFile: string,\n   539→): Promise<void> {\n   540→  e.preventDefault();\n   541→  dragOverSoundFile.value = null;\n   542→  const chip = draggingChip.value;\n   543→  draggingChip.value = null;\n   544→  if (!chip || !selectedPack.value || !selectedPackInfo.value) return;\n   545→  if (chip.file === newFile) return;\n   546→  const manifest = selectedPackInfo.value.manifest;\n   547→  manifest.assignments = manifest.assignments.filter(\n   548→    (a) => !(a.file === chip.file && a.event === chip.event),\n   549→  );\n   550→  const alreadyExists = manifest.assignments.some(\n   551→    (a) => a.file === newFile && a.event === chip.event,\n   552→  );\n   553→  if (!alreadyExists) {\n   554→    manifest.assignments.push({ file: newFile, event: chip.event });\n   555→  }\n   556→  await soundStore.savePackManifest(selectedPack.value, manifest);\n   557→}\n   558→\n   559→// ---- Live highlight on incoming agent events ----\n   560→const flashingEvent = ref<AgentEventType | null>(null);\n   561→let flashTimeout: ReturnType<typeof setTimeout> | null = null;\n   562→let agentEventUnlisten: UnlistenFn | null = null;\n   563→\n   564→function flashEventRow(eventType: AgentEventType): void {\n   565→  flashingEvent.value = eventType;\n   566→  if (flashTimeout) clearTimeout(flashTimeout);\n   567→  flashTimeout = setTimeout(() => {\n   568→    flashingEvent.value = null;\n   569→    flashTimeout = null;\n   570→  }, 200);\n   571→}\n   572→\n   573→// ---- Add audio files to pack (OS drag + file picker) ----\n   574→const AUDIO_EXTENSIONS = new Set(['.wav', '.mp3', '.ogg', '.flac', '.m4a', '.webm']);\n   575→const audioDragOver = ref(false);\n   576→\n   577→function isAudioFile(filename: string): boolean {\n   578→  const dot = filename.lastIndexOf('.');\n   579→  if (dot < 0) return false;\n   580→  return AUDIO_EXTENSIONS.has(filename.slice(dot).toLowerCase());\n   581→}\n   582→\n   583→async function addAudioFilesFromBlobs(\n   584→  files: { name: string; bytes: Uint8Array }[],\n   585→): Promise<void> {\n   586→  if (!selectedPack.value || !selectedPackInfo.value) return;\n   587→  const baseDir = soundStore.getSoundPacksDir();\n   588→  const packPath = `${baseDir}/${selectedPack.value}`;\n   589→  const manifest = selectedPackInfo.value.manifest;\n   590→  let changed = false;\n   591→\n   592→  for (const file of files) {\n   593→    if (!isAudioFile(file.name)) continue;\n   594→    await writeFile(`${packPath}/${file.name}`, file.bytes);\n   595→    const alreadyInManifest = manifest.sounds.some(\n   596→      (s) => s.file === file.name,\n   597→    );\n   598→    if (!alreadyInManifest) {\n   599→      manifest.sounds.push({\n   600→        file: file.name,\n   601→        volume: 1.0,\n   602→        enabled: true,\n   603→      });\n   604→      changed = true;\n   605→    }\n   606→  }\n   607→\n   608→  if (changed) {\n   609→    await soundStore.savePackManifest(selectedPack.value, manifest);\n   610→  }\n   611→  if (selectedPack.value) {\n   612→    void checkSoundFileExistence(selectedPack.value);\n   613→  }\n   614→}\n   615→\n   616→function onAudioDragOver(e: DragEvent): void {\n   617→  if (!selectedPack.value) return;\n   618→  e.preventDefault();\n   619→  e.stopPropagation();\n   620→  audioDragOver.value = true;\n   621→}\n   622→\n   623→function onAudioDragLeave(): void {\n   624→  audioDragOver.value = false;\n   625→}\n   626→\n   627→async function onAudioDrop(e: DragEvent): Promise<void> {\n   628→  e.preventDefault();\n   629→  e.stopPropagation();\n   630→  audioDragOver.value = false;\n   631→  if (!selectedPack.value) return;\n   632→  const dataFiles = e.dataTransfer?.files;\n   633→  if (!dataFiles || dataFiles.length === 0) return;\n   634→\n   635→  const blobs: { name: string; bytes: Uint8Array }[] = [];\n   636→  for (let i = 0; i < dataFiles.length; i++) {\n   637→    const f = dataFiles[i];\n   638→    if (!f || !isAudioFile(f.name)) continue;\n   639→    const buf = await f.arrayBuffer();\n   640→    blobs.push({ name: f.name, bytes: new Uint8Array(buf) });\n   641→  }\n   642→  if (blobs.length > 0) {\n   643→    await addAudioFilesFromBlobs(blobs);\n   644→  }\n   645→}\n   646→\n   647→async function openAddFilePicker(): Promise<void> {\n   648→  if (!selectedPack.value) return;\n   649→  const result = await open({\n   650→    filters: [{\n   651→      name: 'Audio',\n   652→      extensions: ['wav', 'mp3', 'ogg', 'flac', 'm4a', 'webm'],\n   653→    }],\n   654→    multiple: true,\n   655→  });\n   656→  if (!result) return;\n   657→  const paths = Array.isArray(result) ? result : [result];\n   658→  const blobs: { name: string; bytes: Uint8Array }[] = [];\n   659→  for (const filePath of paths) {\n   660→    if (!filePath) continue;\n   661→    const filename = filePath.split('/').pop() ?? '';\n   662→    if (!isAudioFile(filename)) continue;\n   663→    const bytes = await readFile(filePath);\n   664→    blobs.push({ name: filename, bytes });\n   665→  }\n   666→  if (blobs.length > 0) {\n   667→    await addAudioFilesFromBlobs(blobs);\n   668→  }\n   669→}\n   670→\n   671→// Reset scroll + stop preview + check file existence on pack change\n   672→watch(selectedPack, async (packName) => {\n   673→  stopPreview();\n   674→  soundFileExists.value = new Map();\n   675→  if (packName) void checkSoundFileExistence(packName);\n   676→  await nextTick(() => {\n   677→    if (rightPanel.value) rightPanel.value.scrollTop = 0;\n   678→  });\n   679→});\n   680→\n   681→</script>\n   682→\n   683→<template>\n   684→  <Teleport to=\"body\">\n   685→    <!-- Backdrop -->\n   686→    <div class=\"fixed inset-0 z-[100] flex items-center justify-center bg-black/50\">\n   687→      <!-- Drop zone wrapper -->\n   688→      <div\n   689→        class=\"relative w-[960px] max-w-[90vw] h-[700px] max-h-[90vh] flex flex-col bg-gray-900 border border-gray-700 rounded-lg shadow-2xl overflow-hidden\"\n   690→        @dragover=\"onDragOver\"\n   691→        @dragleave=\"onDragLeave\"\n   692→        @drop=\"onDrop\"\n   693→      >\n   694→        <!-- Drag overlay -->\n   695→        <div\n   696→          v-if=\"dragOver\"\n   697→          class=\"absolute inset-0 z-[150] flex items-center justify-center bg-indigo-900/80 border-2 border-dashed border-indigo-400 rounded-lg pointer-events-none\"\n   698→        >\n   699→          <span class=\"text-indigo-200 text-lg font-semibold\">Drop sound pack here</span>\n   700→        </div>\n   701→\n   702→        <!-- Import error toast -->\n   703→        <div\n   704→          v-if=\"importError\"\n   705→          class=\"absolute top-3 left-1/2 -translate-x-1/2 z-[160] px-4 py-2 bg-red-900/90 border border-red-500 rounded-lg text-red-200 text-sm max-w-md text-center shadow-lg\"\n   706→        >\n   707→          {{ importError }}\n   708→        </div>\n   709→\n   710→        <!-- Header -->\n   711→        <div class=\"flex items-center gap-4 px-4 py-3 border-b border-gray-700 shrink-0\">\n   712→          <span class=\"text-gray-200 font-semibold text-sm\">Sounds</span>\n   713→\n   714→          <!-- Master enable -->\n   715→          <label class=\"flex items-center gap-1.5 text-xs text-gray-300 cursor-pointer\">\n   716→            <input\n   717→              type=\"checkbox\"\n   718→              :checked=\"globalEnabled\"\n   719→              class=\"w-4 h-4 accent-indigo-400\"\n   720→              @change=\"globalEnabled = ($event.target as HTMLInputElement).checked\"\n   721→            />\n   722→            Enable\n   723→          </label>\n   724→\n   725→          <!-- Global volume -->\n   726→          <label class=\"flex items-center gap-1.5 text-xs text-gray-300\">\n   727→            Vol\n   728→            <input\n   729→              type=\"range\"\n   730→              min=\"0\"\n   731→              max=\"100\"\n   732→              :value=\"globalVolume\"\n   733→              class=\"w-24 accent-indigo-400\"\n   734→              @input=\"globalVolume = parseInt(($event.target as HTMLInputElement).value)\"\n   735→            />\n   736→            <span class=\"w-7 tabular-nums\">{{ globalVolume }}%</span>\n   737→          </label>\n   738→\n   739→          <!-- Cooldown -->\n   740→          <label class=\"flex items-center gap-1.5 text-xs text-gray-300\">\n   741→            Cooldown\n   742→            <input\n   743→              type=\"range\"\n   744→              min=\"0\"\n   745→              max=\"10\"\n   746→              step=\"0.5\"\n   747→              :value=\"cooldown\"\n   748→              class=\"w-20 accent-indigo-400\"\n   749→              @input=\"cooldown = parseFloat(($event.target as HTMLInputElement).value)\"\n   750→            />\n   751→            <span class=\"w-8 tabular-nums\">{{ cooldown }}s</span>\n   752→          </label>\n   753→        </div>\n   754→\n   755→        <!-- Body -->\n   756→        <div class=\"flex flex-1 min-h-0\">\n   757→          <!-- Left panel: pack list -->\n   758→          <div class=\"w-60 shrink-0 border-r border-gray-700 flex flex-col\">\n   759→            <div class=\"px-3 pt-2 pb-1 text-xs font-semibold text-gray-400 uppercase tracking-wide\">\n   760→              Packs\n   761→            </div>\n   762→            <div class=\"flex-1 overflow-y-auto\">\n   763→              <div\n   764→                v-for=\"pack in soundStore.packs\"\n   765→                :key=\"pack.name\"\n   766→                class=\"flex items-center gap-2 px-2 py-1.5 cursor-pointer rounded mx-1\"\n   767→                :class=\"selectedPack === pack.name ? 'bg-gray-700' : 'hover:bg-gray-800'\"\n   768→                @click=\"selectPack(pack.name)\"\n   769→                @contextmenu=\"onPackRightClick($event, pack.name)\"\n   770→              >\n   771→                <input\n   772→                  type=\"checkbox\"\n   773→                  :checked=\"isPackActive(pack.name)\"\n   774→                  class=\"w-4 h-4 accent-indigo-400 cursor-pointer\"\n   775→                  @click.stop\n   776→                  @change=\"togglePackActive(pack.name, ($event.target as HTMLInputElement).checked)\"\n   777→                />\n   778→                <input\n   779→                  v-if=\"editingPackName === pack.name\"\n   780→                  ref=\"editPackInput\"\n   781→                  v-model=\"editPackNameValue\"\n   782→                  class=\"flex-1 min-w-0 px-1 py-0.5 bg-gray-800 border border-indigo-400 rounded text-xs text-gray-200 outline-none\"\n   783→                  @click.stop\n   784→                  @keydown.enter.prevent=\"confirmEditPackName\"\n   785→                  @keydown.escape.prevent=\"cancelEditPackName\"\n   786→                  @blur=\"confirmEditPackName\"\n   787→                />\n   788→                <span v-else class=\"text-sm text-gray-200 truncate flex-1\">{{ pack.name }}</span>\n   789→              </div>\n   790→            </div>\n   791→            <!-- Buttons -->\n   792→            <div class=\"flex gap-1 p-2 border-t border-gray-700\">\n   793→              <button\n   794→                class=\"flex-1 px-2 py-1 bg-gray-700/60 rounded hover:bg-gray-600/70 text-xs text-gray-200\"\n   795→                @click=\"startCreatePack\"\n   796→              >\n   797→                New Pack\n   798→              </button>\n   799→              <button\n   800→                class=\"flex-1 px-2 py-1 bg-gray-700/60 rounded hover:bg-gray-600/70 text-xs text-gray-200\"\n   801→                @click=\"openImportPicker\"\n   802→              >\n   803→                Import\n   804→              </button>\n   805→            </div>\n   806→          </div>\n   807→\n   808→          <!-- Patchbay: Sounds + Events columns -->\n   809→          <div ref=\"rightPanel\" class=\"flex flex-1 min-h-0 overflow-hidden\">\n   810→            <!-- Sounds column -->\n   811→            <div\n   812→              class=\"flex-1 border-r border-gray-700 flex flex-col min-w-0\"\n   813→              @dragover=\"onAudioDragOver\"\n   814→              @dragleave=\"onAudioDragLeave\"\n   815→              @drop=\"onAudioDrop\"\n   816→            >\n   817→              <div class=\"flex items-center gap-2 px-3 py-2 border-b border-gray-700 shrink-0\">\n   818→                <span class=\"text-xs font-semibold text-gray-400 uppercase tracking-wide flex-1\">Sounds</span>\n   819→                <button\n   820→                  v-if=\"selectedPack\"\n   821→                  class=\"px-2 py-0.5 bg-gray-700/60 rounded hover:bg-gray-600/70 text-xs text-gray-300\"\n   822→                  @click=\"openAddFilePicker\"\n   823→                >Add file</button>\n   824→              </div>\n   825→              <div class=\"flex-1 overflow-y-auto relative\">\n   826→                <!-- Audio file drop overlay -->\n   827→                <div\n   828→                  v-if=\"audioDragOver && selectedPack\"\n   829→                  class=\"absolute inset-0 z-10 flex items-center justify-center bg-indigo-900/60 border-2 border-dashed border-indigo-400 rounded pointer-events-none\"\n   830→                >\n   831→                  <span class=\"text-indigo-200 text-sm font-semibold\">Drop audio files here</span>\n   832→                </div>\n   833→                <div\n   834→                  v-if=\"!selectedPackInfo\"\n   835→                  class=\"flex items-center justify-center h-full text-gray-600 text-sm\"\n   836→                >\n   837→                  Select a pack\n   838→                </div>\n   839→                <div\n   840→                  v-else-if=\"selectedPackInfo.manifest.sounds.length === 0\"\n   841→                  class=\"flex items-center justify-center h-full text-gray-600 text-sm\"\n   842→                >\n   843→                  No sounds in this pack\n   844→                </div>\n   845→                <div\n   846→                  v-for=\"sound in selectedPackInfo.manifest.sounds\"\n   847→                  v-else\n   848→                  :key=\"sound.file\"\n   849→                  draggable=\"true\"\n   850→                  class=\"flex items-center gap-2 px-3 py-1.5 border-b border-gray-800 hover:bg-gray-800/40 cursor-grab transition-colors duration-150\"\n   851→                  :class=\"[\n   852→                    draggingSoundFile === sound.file ? 'opacity-50' : '',\n   853→                    dragOverSoundFile === sound.file ? 'bg-indigo-500/20' : '',\n   854→                    draggingChip ? 'opacity-100' : '',\n   855→                  ]\"\n   856→                  @mouseenter=\"hoveredSoundFile = sound.file\"\n   857→                  @mouseleave=\"hoveredSoundFile = null\"\n   858→                  @dragstart=\"onSoundDragStart($event, sound.file)\"\n   859→                  @dragend=\"onSoundDragEnd\"\n   860→                  @dragover=\"onSoundRowDragOver($event, sound.file)\"\n   861→                  @dragleave=\"onSoundRowDragLeave\"\n   862→                  @drop=\"onSoundRowDrop($event, sound.file)\"\n   863→                >\n   864→                  <!-- Play button -->\n   865→                  <button\n   866→                    class=\"shrink-0 w-6 h-6 flex items-center justify-center rounded text-gray-400 hover:text-white hover:bg-gray-700 text-xs\"\n   867→                    title=\"Play preview\"\n   868→                    @click=\"playPreview(sound.file)\"\n   869→                  >▶</button>\n   870→\n   871→                  <!-- Filename -->\n   872→                  <span class=\"flex-1 text-xs font-mono text-gray-200 truncate min-w-0\">{{ sound.file }}</span>\n   873→\n   874→                  <!-- Broken link indicator -->\n   875→                  <span\n   876→                    v-if=\"soundFileExists.get(sound.file) === false\"\n   877→                    class=\"shrink-0 text-red-400 text-xs\"\n   878→                    title=\"File not found on disk\"\n   879→                  >⚠</span>\n   880→\n   881→                  <!-- Volume slider (visible on hover) -->\n   882→                  <input\n   883→                    v-show=\"hoveredSoundFile === sound.file\"\n   884→                    type=\"range\"\n   885→                    min=\"0\"\n   886→                    max=\"1\"\n   887→                    step=\"0.01\"\n   888→                    :value=\"sound.volume\"\n   889→                    class=\"shrink-0 w-16 accent-indigo-400\"\n   890→                    title=\"Volume\"\n   891→                    @input=\"updateSoundVolume(sound, parseFloat(($event.target as HTMLInputElement).value))\"\n   892→                  />\n   893→\n   894→                  <!-- Enabled toggle -->\n   895→                  <input\n   896→                    type=\"checkbox\"\n   897→                    :checked=\"sound.enabled\"\n   898→                    class=\"shrink-0 w-4 h-4 accent-indigo-400 cursor-pointer\"\n   899→                    title=\"Enable/disable this sound\"\n   900→                    @change=\"updateSoundEnabled(sound, ($event.target as HTMLInputElement).checked)\"\n   901→                  />\n   902→\n   903→                  <!-- Stop button -->\n   904→                  <button\n   905→                    class=\"shrink-0 w-6 h-6 flex items-center justify-center rounded text-xs\"\n   906→                    :class=\"previewFile === sound.file\n   907→                      ? 'text-red-400 hover:text-red-300 hover:bg-gray-700'\n   908→                      : 'text-gray-600 cursor-default'\"\n   909→                    title=\"Stop preview\"\n   910→                    @click=\"previewFile === sound.file ? stopPreview() : undefined\"\n   911→                  >■</button>\n   912→                </div>\n   913→              </div>\n   914→            </div>\n   915→\n   916→            <!-- Events column -->\n   917→            <div class=\"flex-1 flex flex-col min-w-0\">\n   918→              <div class=\"px-3 py-2 border-b border-gray-700 shrink-0\">\n   919→                <span class=\"text-xs font-semibold text-gray-400 uppercase tracking-wide\">Events</span>\n   920→              </div>\n   921→              <div class=\"flex-1 overflow-y-auto\">\n   922→                <div\n   923→                  v-for=\"eventType in AGENT_EVENT_TYPES\"\n   924→                  :key=\"eventType\"\n   925→                  class=\"px-3 py-2 border-b border-gray-800 transition-all duration-200\"\n   926→                  :class=\"[\n   927→                    hasAssignments(eventType) ? 'opacity-100' : 'opacity-40',\n   928→                    flashingEvent === eventType ? 'bg-indigo-600/30' : '',\n   929→                    dragOverEventType === eventType ? 'bg-indigo-500/20 opacity-100' : '',\n   930→                    draggingSoundFile ? 'opacity-100' : '',\n   931→                  ]\"\n   932→                  @dragover=\"onEventDragOver($event, eventType)\"\n   933→                  @dragleave=\"onEventDragLeaveRow\"\n   934→                  @drop=\"onEventDrop($event, eventType)\"\n   935→                >\n   936→                  <div class=\"flex items-center gap-2\">\n   937→                    <span class=\"text-sm font-mono text-gray-300 flex-1\">{{ eventType }}</span>\n   938→                    <!-- Info icon + popover -->\n   939→                    <span\n   940→                      v-if=\"EVENT_DESCRIPTIONS[eventType]\"\n   941→                      class=\"relative shrink-0\"\n   942→                      @click.stop\n   943→                    >\n   944→                      <span\n   945→                        class=\"w-4 h-4 flex items-center justify-center rounded-full border text-[10px] leading-none cursor-pointer select-none\"\n   946→                        :class=\"activeInfoPopover === eventType\n   947→                          ? 'border-indigo-400 text-indigo-300 bg-indigo-900/40'\n   948→                          : 'border-gray-500 text-gray-400 hover:border-gray-300 hover:text-gray-200'\"\n   949→                        @click=\"toggleInfoPopover(eventType)\"\n   950→                      >i</span>\n   951→                      <div\n   952→                        v-if=\"activeInfoPopover === eventType\"\n   953→                        class=\"absolute right-0 top-6 z-50 w-56 bg-gray-800 border border-gray-600 rounded shadow-lg px-3 py-2 text-xs text-gray-200 leading-relaxed\"\n   954→                      >\n   955→                        {{ EVENT_DESCRIPTIONS[eventType] }}\n   956→                      </div>\n   957→                    </span>\n   958→                  </div>\n   959→                  <!-- Assignment chips -->\n   960→                  <div\n   961→                    v-if=\"assignmentsForEvent(eventType).length > 0\"\n   962→                    class=\"flex flex-wrap gap-1 mt-1\"\n   963→                  >\n   964→                    <span\n   965→                      v-for=\"file in assignmentsForEvent(eventType)\"\n   966→                      :key=\"file\"\n   967→                      draggable=\"true\"\n   968→                      class=\"inline-flex items-center gap-1 px-2 py-0.5 bg-gray-700/80 rounded text-xs text-gray-200 cursor-grab hover:bg-gray-600/80\"\n   969→                      :class=\"draggingChip?.file === file && draggingChip?.event === eventType ? 'opacity-50' : ''\"\n   970→                      :title=\"file\"\n   971→                      @click=\"playPreview(file)\"\n   972→                      @dragstart.stop=\"onChipDragStart($event, file, eventType)\"\n   973→                      @dragend=\"onChipDragEnd\"\n   974→                    >\n   975→                      {{ truncateFilename(file) }}\n   976→                      <button\n   977→                        class=\"ml-0.5 text-gray-400 hover:text-red-400 leading-none\"\n   978→                        title=\"Remove assignment\"\n   979→                        @click.stop=\"removeAssignment(file, eventType)\"\n   980→                      >&times;</button>\n   981→                    </span>\n   982→                  </div>\n   983→                </div>\n   984→              </div>\n   985→            </div>\n   986→          </div>\n   987→        </div>\n   988→\n   989→        <!-- Footer -->\n   990→        <div class=\"flex justify-end px-4 py-3 border-t border-gray-700 shrink-0\">\n   991→          <button\n   992→            class=\"px-4 py-1.5 bg-gray-700/60 rounded hover:bg-gray-600/70 text-sm text-gray-200\"\n   993→            @click=\"emit('close')\"\n   994→          >\n   995→            Close\n   996→          </button>\n   997→        </div>\n   998→      </div>\n   999→    </div>\n  1000→\n  1001→    <!-- Context menu -->\n  1002→    <PackContextMenu\n  1003→      v-if=\"ctxMenu\"\n  1004→      :pack-name=\"ctxMenu.packName\"\n  1005→      :x=\"ctxMenu.x\"\n  1006→      :y=\"ctxMenu.y\"\n  1007→      @close=\"closeCtxMenu\"\n  1008→      @renamed=\"onPackRenamed\"\n  1009→      @duplicated=\"onPackDuplicated\"\n  1010→      @deleted=\"onPackDeleted\"\n  1011→    />\n  1012→  </Teleport>\n  1013→</template>\n  1014→"}]},"parent_tool_use_id":null,"session_id":"3f33bfd1-2c4e-4a38-8c03-42ac89bc40cd","uuid":"cc00e4a8-1943-416e-bf1d-7fbde6abc3d1","tool_use_result":{"type":"text","file":{"filePath":"/Users/markus/baustelle/projects/agents-in-the-office/agents-in-the-office/.chief/worktrees/sound-packs-patchbay/src/components/SoundsDialog.vue","content":"<script setup lang=\"ts\">\nimport {\n  ref,\n  computed,\n  watch,\n  nextTick,\n  onMounted,\n  onUnmounted,\n} from 'vue';\nimport { listen } from '@tauri-apps/api/event';\nimport type { UnlistenFn } from '@tauri-apps/api/event';\nimport { open } from '@tauri-apps/plugin-dialog';\nimport {\n  mkdir,\n  readFile,\n  writeFile,\n  exists,\n  rename,\n  remove,\n} from '@tauri-apps/plugin-fs';\nimport JSZip from 'jszip';\nimport { useSoundStore, AGENT_EVENT_TYPES } from '../stores/soundStore';\nimport type { PackManifestSound } from '../stores/soundStore';\nimport type { AgentEvent, AgentEventType } from '../drivers/types';\nimport PackContextMenu from './PackContextMenu.vue';\n\nconst emit = defineEmits<{ close: [] }>();\n\nconst soundStore = useSoundStore();\n\n// ---- Global settings ----\nconst globalEnabled = computed({\n  get: () => soundStore.config.enabled,\n  set: (v: boolean) => { soundStore.config.enabled = v; void soundStore.saveConfig(); },\n});\nconst globalVolume = computed({\n  get: () => Math.round(soundStore.config.globalVolume * 100),\n  set: (v: number) => { soundStore.config.globalVolume = v / 100; void soundStore.saveConfig(); },\n});\nconst cooldown = computed({\n  get: () => soundStore.config.cooldownSeconds,\n  set: (v: number) => { soundStore.config.cooldownSeconds = v; void soundStore.saveConfig(); },\n});\n\n// ---- Pack list ----\nconst selectedPack = ref<string | null>(null);\nconst rightPanel = ref<HTMLElement | null>(null);\n\nonMounted(async () => {\n  await soundStore.init();\n  await soundStore.scanPacks();\n  if (soundStore.packs.length > 0 && soundStore.packs[0]) {\n    selectedPack.value = soundStore.packs[0].name;\n  }\n  agentEventUnlisten = await listen<string>(\n    'agent-event',\n    (e) => {\n      try {\n        const parsed = JSON.parse(e.payload) as AgentEvent;\n        flashEventRow(parsed.type);\n      } catch { /* ignore parse errors */ }\n    },\n  );\n});\n\nonUnmounted(() => {\n  if (agentEventUnlisten) agentEventUnlisten();\n  if (flashTimeout) clearTimeout(flashTimeout);\n  if (importErrorTimeout) clearTimeout(importErrorTimeout);\n});\n\nfunction isPackActive(packName: string): boolean {\n  return soundStore.config.activePacks.includes(packName);\n}\n\nfunction togglePackActive(packName: string, active: boolean) {\n  if (active) {\n    if (!soundStore.config.activePacks.includes(packName)) {\n      soundStore.config.activePacks.push(packName);\n    }\n  } else {\n    soundStore.config.activePacks = soundStore.config.activePacks.filter(\n      (p) => p !== packName,\n    );\n  }\n  void soundStore.saveConfig();\n}\n\nfunction selectPack(name: string) {\n  selectedPack.value = name;\n  void nextTick(() => {\n    if (rightPanel.value) rightPanel.value.scrollTop = 0;\n  });\n}\n\n// ---- Context menu ----\nconst ctxMenu = ref<{ packName: string; x: number; y: number } | null>(null);\n\nfunction onPackRightClick(e: MouseEvent, packName: string) {\n  e.preventDefault();\n  ctxMenu.value = { packName, x: e.clientX, y: e.clientY };\n}\n\nfunction closeCtxMenu() {\n  ctxMenu.value = null;\n}\n\nasync function onPackRenamed(oldName: string, newName: string) {\n  await soundStore.scanPacks();\n  if (selectedPack.value === oldName) selectedPack.value = newName;\n  closeCtxMenu();\n}\n\nasync function onPackDuplicated() {\n  await soundStore.scanPacks();\n  closeCtxMenu();\n}\n\nasync function onPackDeleted(name: string) {\n  await soundStore.scanPacks();\n  if (selectedPack.value === name) {\n    selectedPack.value = soundStore.packs[0]?.name ?? null;\n  }\n  closeCtxMenu();\n}\n\n// ---- New pack / inline rename ----\nconst editingPackName = ref<string | null>(null);\nconst editPackNameValue = ref('');\nconst editPackInput = ref<HTMLInputElement | null>(null);\nconst isNewPack = ref(false);\n\nfunction generatePackName(): string {\n  const existingNames = new Set(soundStore.packs.map((p) => p.name));\n  const base = 'New Pack';\n  if (!existingNames.has(base)) return base;\n  for (let i = 2; i < 100; i++) {\n    const candidate = `${base} ${i}`;\n    if (!existingNames.has(candidate)) return candidate;\n  }\n  return `${base} ${Date.now()}`;\n}\n\nasync function startCreatePack(): Promise<void> {\n  const packName = generatePackName();\n  const baseDir = soundStore.getSoundPacksDir();\n  const packPath = `${baseDir}/${packName}`;\n  try {\n    await mkdir(packPath, { recursive: true });\n    await soundStore.savePackManifest(packName, { sounds: [], assignments: [] });\n    await soundStore.scanPacks();\n    selectedPack.value = packName;\n    isNewPack.value = true;\n    editingPackName.value = packName;\n    editPackNameValue.value = packName;\n    void nextTick(() => editPackInput.value?.select());\n  } catch (err) {\n    console.error('[SoundsDialog] createNewPack failed', err);\n  }\n}\n\nasync function confirmEditPackName(): Promise<void> {\n  const oldName = editingPackName.value;\n  if (!oldName) return;\n  const newName = editPackNameValue.value.trim();\n  editingPackName.value = null;\n  isNewPack.value = false;\n\n  if (!newName || newName === oldName) return;\n\n  const baseDir = soundStore.getSoundPacksDir();\n  try {\n    await rename(`${baseDir}/${oldName}`, `${baseDir}/${newName}`);\n    // Update activePacks\n    const idx = soundStore.config.activePacks.indexOf(oldName);\n    if (idx >= 0) soundStore.config.activePacks[idx] = newName;\n    // Move soundOverrides entries\n    const oldPrefix = `${oldName}/`;\n    const newPrefix = `${newName}/`;\n    for (const key of Object.keys(soundStore.config.soundOverrides)) {\n      if (key.startsWith(oldPrefix)) {\n        const filename = key.slice(oldPrefix.length);\n        soundStore.config.soundOverrides[`${newPrefix}${filename}`] =\n          soundStore.config.soundOverrides[key]!;\n        delete soundStore.config.soundOverrides[key];\n      }\n    }\n    await soundStore.saveConfig();\n    await soundStore.scanPacks();\n    if (selectedPack.value === oldName) selectedPack.value = newName;\n  } catch (err) {\n    console.error('[SoundsDialog] rename pack failed', err);\n  }\n}\n\nasync function cancelEditPackName(): Promise<void> {\n  const oldName = editingPackName.value;\n  const wasNew = isNewPack.value;\n  editingPackName.value = null;\n  isNewPack.value = false;\n\n  if (wasNew && oldName) {\n    const baseDir = soundStore.getSoundPacksDir();\n    try {\n      await remove(`${baseDir}/${oldName}`, { recursive: true });\n      await soundStore.scanPacks();\n      if (selectedPack.value === oldName) {\n        selectedPack.value = soundStore.packs[0]?.name ?? null;\n      }\n    } catch (err) {\n      console.error('[SoundsDialog] cancel new pack failed', err);\n    }\n  }\n}\n\n// ---- Import zip ----\nconst dragOver = ref(false);\nconst importError = ref<string | null>(null);\nlet importErrorTimeout: ReturnType<typeof setTimeout> | null = null;\n\nfunction showImportError(message: string): void {\n  importError.value = message;\n  if (importErrorTimeout) clearTimeout(importErrorTimeout);\n  importErrorTimeout = setTimeout(() => {\n    importError.value = null;\n    importErrorTimeout = null;\n  }, 5000);\n}\n\nasync function importZipBytes(filename: string, bytes: Uint8Array): Promise<void> {\n  const dotIdx = filename.lastIndexOf('.');\n  const packName = dotIdx > 0 ? filename.slice(0, dotIdx) : filename;\n\n  const zip = await JSZip.loadAsync(bytes);\n\n  // Find manifest.json — could be at root or inside a single top-level folder\n  let manifestFile = zip.file('manifest.json');\n  let stripPrefix = '';\n  if (!manifestFile) {\n    const topDirs = Object.keys(zip.files).filter(\n      (p) => p.endsWith('/') && !p.slice(0, -1).includes('/'),\n    );\n    if (topDirs.length === 1 && topDirs[0]) {\n      stripPrefix = topDirs[0];\n      manifestFile = zip.file(`${stripPrefix}manifest.json`);\n    }\n  }\n\n  if (!manifestFile) {\n    showImportError(\n      'This ZIP does not contain a manifest.json. Please use the new pack format.',\n    );\n    return;\n  }\n\n  const baseDir = soundStore.getSoundPacksDir();\n  const packPath = `${baseDir}/${packName}`;\n  await mkdir(packPath, { recursive: true });\n\n  // Write manifest.json\n  const manifestData = await manifestFile.async('uint8array');\n  await writeFile(`${packPath}/manifest.json`, manifestData);\n\n  // Extract audio files to pack root (flat — no subdirectories)\n  for (const [relativePath, file] of Object.entries(zip.files)) {\n    if (file.dir) continue;\n    let effectivePath = relativePath;\n    if (stripPrefix && effectivePath.startsWith(stripPrefix)) {\n      effectivePath = effectivePath.slice(stripPrefix.length);\n    }\n    if (effectivePath === 'manifest.json') continue;\n    // Only extract files at the root level (no subdirectories)\n    if (effectivePath.includes('/')) continue;\n    const data = await file.async('uint8array');\n    await writeFile(`${packPath}/${effectivePath}`, data);\n  }\n\n  await soundStore.scanPacks();\n  selectedPack.value = packName;\n}\n\nasync function openImportPicker() {\n  const result = await open({\n    filters: [{ name: 'ZIP', extensions: ['zip'] }],\n    multiple: false,\n  });\n  if (!result) return;\n  const filePath = typeof result === 'string' ? result : result;\n  if (!filePath) return;\n  try {\n    const bytes = await readFile(filePath);\n    const filename = (filePath as string).split('/').pop() ?? 'pack.zip';\n    await importZipBytes(filename, bytes);\n  } catch (err) {\n    console.error('[SoundsDialog] import failed', err);\n  }\n}\n\nfunction onDragOver(e: DragEvent) {\n  e.preventDefault();\n  dragOver.value = true;\n}\n\nfunction onDragLeave() {\n  dragOver.value = false;\n}\n\nasync function onDrop(e: DragEvent) {\n  e.preventDefault();\n  dragOver.value = false;\n  const file = e.dataTransfer?.files[0];\n  if (!file) return;\n  try {\n    const arrayBuffer = await file.arrayBuffer();\n    await importZipBytes(file.name, new Uint8Array(arrayBuffer));\n  } catch (err) {\n    console.error('[SoundsDialog] drop import failed', err);\n  }\n}\n\n// ---- Event descriptions ----\nconst EVENT_DESCRIPTIONS: Record<string, string> = {\n  session_start: 'Agent session begins.',\n  session_end: 'Agent session ends or is interrupted.',\n  prompt_submit: 'User submits a prompt to the agent.',\n  tool_start: 'Agent begins executing a tool (e.g. Bash, Read, Edit).',\n  tool_end: 'Agent finishes executing a tool.',\n  turn_end: 'Agent completes a full response turn.',\n  permission_wait: 'Agent pauses waiting for the user to approve a tool call.',\n  subagent_start: 'A subagent is spawned by the parent agent.',\n  subagent_end: 'A subagent finishes its work.',\n  idle_notification: 'Agent has been idle and sends a nudge notification.',\n  elicitation_wait: 'Agent pauses waiting for user input.',\n  auth_success: 'Authentication to an external service succeeds.',\n  worktree_create: 'A new git worktree is created.',\n  worktree_remove: 'A git worktree is removed.',\n  teammate_idle: \"A teammate's agent session goes idle.\",\n  task_completed: 'Agent marks a task as completed.',\n};\n\nconst activeInfoPopover = ref<string | null>(null);\n\nfunction toggleInfoPopover(eventType: string) {\n  activeInfoPopover.value = activeInfoPopover.value === eventType ? null : eventType;\n}\n\n// ---- Patchbay data ----\nconst selectedPackInfo = computed(() =>\n  soundStore.packs.find((p) => p.name === selectedPack.value) ?? null,\n);\n\nfunction hasAssignments(eventType: AgentEventType): boolean {\n  if (!selectedPackInfo.value) return false;\n  return selectedPackInfo.value.manifest.assignments.some((a) => a.event === eventType);\n}\n\n// ---- Sound preview (left column) ----\nlet previewSource: AudioBufferSourceNode | null = null;\nconst previewFile = ref<string | null>(null);\nconst soundFileExists = ref<Map<string, boolean>>(new Map());\nconst hoveredSoundFile = ref<string | null>(null);\n\nasync function checkSoundFileExistence(packName: string): Promise<void> {\n  const sounds = selectedPackInfo.value?.manifest.sounds ?? [];\n  const baseDir = soundStore.getSoundPacksDir();\n  const newMap = new Map<string, boolean>();\n  await Promise.all(\n    sounds.map(async (sound) => {\n      const filePath = `${baseDir}/${packName}/${sound.file}`;\n      const fileExists = await exists(filePath);\n      newMap.set(sound.file, fileExists);\n    }),\n  );\n  soundFileExists.value = newMap;\n}\n\nfunction stopPreview(): void {\n  if (previewSource) {\n    try { previewSource.stop(); } catch { /* already stopped */ }\n    previewSource = null;\n  }\n  previewFile.value = null;\n}\n\nasync function playPreview(filename: string): Promise<void> {\n  if (!selectedPack.value) return;\n  stopPreview();\n  const baseDir = soundStore.getSoundPacksDir();\n  const filePath = `${baseDir}/${selectedPack.value}/${filename}`;\n  const buffer = await soundStore.loadBuffer(filePath);\n  if (!buffer) return;\n  const ctx = soundStore.getOrCreateAudioContext();\n  const sound = selectedPackInfo.value?.manifest.sounds.find((s) => s.file === filename);\n  const gainNode = ctx.createGain();\n  gainNode.gain.value =\n    soundStore.config.globalVolume * soundStore.effectiveVolume(selectedPack.value, filename, sound);\n  gainNode.connect(ctx.destination);\n  const source = ctx.createBufferSource();\n  source.buffer = buffer;\n  source.connect(gainNode);\n  previewFile.value = filename;\n  previewSource = source;\n  source.onended = () => {\n    if (previewFile.value === filename) {\n      previewFile.value = null;\n      previewSource = null;\n    }\n  };\n  source.start();\n}\n\nasync function updateSoundVolume(sound: PackManifestSound, volume: number): Promise<void> {\n  if (!selectedPack.value || !selectedPackInfo.value) return;\n  sound.volume = volume;\n  await soundStore.savePackManifest(selectedPack.value, selectedPackInfo.value.manifest);\n}\n\nasync function updateSoundEnabled(sound: PackManifestSound, enabled: boolean): Promise<void> {\n  if (!selectedPack.value || !selectedPackInfo.value) return;\n  sound.enabled = enabled;\n  await soundStore.savePackManifest(selectedPack.value, selectedPackInfo.value.manifest);\n}\n\n// ---- Assignment chips (right column) ----\nfunction assignmentsForEvent(eventType: AgentEventType): string[] {\n  if (!selectedPackInfo.value) return [];\n  return selectedPackInfo.value.manifest.assignments\n    .filter((a) => a.event === eventType)\n    .map((a) => a.file);\n}\n\nfunction truncateFilename(name: string, max = 20): string {\n  if (name.length <= max) return name;\n  return name.slice(0, max - 1) + '\\u2026';\n}\n\nasync function removeAssignment(\n  file: string,\n  eventType: AgentEventType,\n): Promise<void> {\n  if (!selectedPack.value || !selectedPackInfo.value) return;\n  const manifest = selectedPackInfo.value.manifest;\n  manifest.assignments = manifest.assignments.filter(\n    (a) => !(a.file === file && a.event === eventType),\n  );\n  await soundStore.savePackManifest(selectedPack.value, manifest);\n}\n\n// ---- Drag-and-drop: sound → event row ----\nconst draggingSoundFile = ref<string | null>(null);\nconst dragOverEventType = ref<AgentEventType | null>(null);\n\n// ---- Drag-and-drop: chip → sound row (re-assign) ----\nconst draggingChip = ref<{ file: string; event: AgentEventType } | null>(null);\nconst dragOverSoundFile = ref<string | null>(null);\n\nfunction onSoundDragStart(e: DragEvent, filename: string): void {\n  draggingSoundFile.value = filename;\n  if (e.dataTransfer) {\n    e.dataTransfer.effectAllowed = 'copy';\n    e.dataTransfer.setData('text/plain', filename);\n  }\n}\n\nfunction onSoundDragEnd(): void {\n  draggingSoundFile.value = null;\n  dragOverEventType.value = null;\n}\n\nfunction onEventDragOver(e: DragEvent, eventType: AgentEventType): void {\n  if (!draggingSoundFile.value) return;\n  e.preventDefault();\n  if (e.dataTransfer) e.dataTransfer.dropEffect = 'copy';\n  dragOverEventType.value = eventType;\n}\n\nfunction onEventDragLeaveRow(): void {\n  dragOverEventType.value = null;\n}\n\nasync function onEventDrop(\n  e: DragEvent,\n  eventType: AgentEventType,\n): Promise<void> {\n  e.preventDefault();\n  dragOverEventType.value = null;\n  const file = draggingSoundFile.value;\n  draggingSoundFile.value = null;\n  if (!file) return;\n  await addAssignment(file, eventType);\n}\n\nasync function addAssignment(\n  file: string,\n  eventType: AgentEventType,\n): Promise<void> {\n  if (!selectedPack.value || !selectedPackInfo.value) return;\n  const manifest = selectedPackInfo.value.manifest;\n  const alreadyExists = manifest.assignments.some(\n    (a) => a.file === file && a.event === eventType,\n  );\n  if (alreadyExists) return;\n  manifest.assignments.push({ file, event: eventType });\n  await soundStore.savePackManifest(selectedPack.value, manifest);\n}\n\n// ---- Chip drag handlers (re-assign chip to different sound) ----\nfunction onChipDragStart(\n  e: DragEvent,\n  file: string,\n  eventType: AgentEventType,\n): void {\n  draggingChip.value = { file, event: eventType };\n  if (e.dataTransfer) {\n    e.dataTransfer.effectAllowed = 'move';\n    e.dataTransfer.setData('text/plain', file);\n  }\n}\n\nfunction onChipDragEnd(): void {\n  draggingChip.value = null;\n  dragOverSoundFile.value = null;\n}\n\nfunction onSoundRowDragOver(e: DragEvent, filename: string): void {\n  if (!draggingChip.value) return;\n  e.preventDefault();\n  if (e.dataTransfer) e.dataTransfer.dropEffect = 'move';\n  dragOverSoundFile.value = filename;\n}\n\nfunction onSoundRowDragLeave(): void {\n  dragOverSoundFile.value = null;\n}\n\nasync function onSoundRowDrop(\n  e: DragEvent,\n  newFile: string,\n): Promise<void> {\n  e.preventDefault();\n  dragOverSoundFile.value = null;\n  const chip = draggingChip.value;\n  draggingChip.value = null;\n  if (!chip || !selectedPack.value || !selectedPackInfo.value) return;\n  if (chip.file === newFile) return;\n  const manifest = selectedPackInfo.value.manifest;\n  manifest.assignments = manifest.assignments.filter(\n    (a) => !(a.file === chip.file && a.event === chip.event),\n  );\n  const alreadyExists = manifest.assignments.some(\n    (a) => a.file === newFile && a.event === chip.event,\n  );\n  if (!alreadyExists) {\n    manifest.assignments.push({ file: newFile, event: chip.event });\n  }\n  await soundStore.savePackManifest(selectedPack.value, manifest);\n}\n\n// ---- Live highlight on incoming agent events ----\nconst flashingEvent = ref<AgentEventType | null>(null);\nlet flashTimeout: ReturnType<typeof setTimeout> | null = null;\nlet agentEventUnlisten: UnlistenFn | null = null;\n\nfunction flashEventRow(eventType: AgentEventType): void {\n  flashingEvent.value = eventType;\n  if (flashTimeout) clearTimeout(flashTimeout);\n  flashTimeout = setTimeout(() => {\n    flashingEvent.value = null;\n    flashTimeout = null;\n  }, 200);\n}\n\n// ---- Add audio files to pack (OS drag + file picker) ----\nconst AUDIO_EXTENSIONS = new Set(['.wav', '.mp3', '.ogg', '.flac', '.m4a', '.webm']);\nconst audioDragOver = ref(false);\n\nfunction isAudioFile(filename: string): boolean {\n  const dot = filename.lastIndexOf('.');\n  if (dot < 0) return false;\n  return AUDIO_EXTENSIONS.has(filename.slice(dot).toLowerCase());\n}\n\nasync function addAudioFilesFromBlobs(\n  files: { name: string; bytes: Uint8Array }[],\n): Promise<void> {\n  if (!selectedPack.value || !selectedPackInfo.value) return;\n  const baseDir = soundStore.getSoundPacksDir();\n  const packPath = `${baseDir}/${selectedPack.value}`;\n  const manifest = selectedPackInfo.value.manifest;\n  let changed = false;\n\n  for (const file of files) {\n    if (!isAudioFile(file.name)) continue;\n    await writeFile(`${packPath}/${file.name}`, file.bytes);\n    const alreadyInManifest = manifest.sounds.some(\n      (s) => s.file === file.name,\n    );\n    if (!alreadyInManifest) {\n      manifest.sounds.push({\n        file: file.name,\n        volume: 1.0,\n        enabled: true,\n      });\n      changed = true;\n    }\n  }\n\n  if (changed) {\n    await soundStore.savePackManifest(selectedPack.value, manifest);\n  }\n  if (selectedPack.value) {\n    void checkSoundFileExistence(selectedPack.value);\n  }\n}\n\nfunction onAudioDragOver(e: DragEvent): void {\n  if (!selectedPack.value) return;\n  e.preventDefault();\n  e.stopPropagation();\n  audioDragOver.value = true;\n}\n\nfunction onAudioDragLeave(): void {\n  audioDragOver.value = false;\n}\n\nasync function onAudioDrop(e: DragEvent): Promise<void> {\n  e.preventDefault();\n  e.stopPropagation();\n  audioDragOver.value = false;\n  if (!selectedPack.value) return;\n  const dataFiles = e.dataTransfer?.files;\n  if (!dataFiles || dataFiles.length === 0) return;\n\n  const blobs: { name: string; bytes: Uint8Array }[] = [];\n  for (let i = 0; i < dataFiles.length; i++) {\n    const f = dataFiles[i];\n    if (!f || !isAudioFile(f.name)) continue;\n    const buf = await f.arrayBuffer();\n    blobs.push({ name: f.name, bytes: new Uint8Array(buf) });\n  }\n  if (blobs.length > 0) {\n    await addAudioFilesFromBlobs(blobs);\n  }\n}\n\nasync function openAddFilePicker(): Promise<void> {\n  if (!selectedPack.value) return;\n  const result = await open({\n    filters: [{\n      name: 'Audio',\n      extensions: ['wav', 'mp3', 'ogg', 'flac', 'm4a', 'webm'],\n    }],\n    multiple: true,\n  });\n  if (!result) return;\n  const paths = Array.isArray(result) ? result : [result];\n  const blobs: { name: string; bytes: Uint8Array }[] = [];\n  for (const filePath of paths) {\n    if (!filePath) continue;\n    const filename = filePath.split('/').pop() ?? '';\n    if (!isAudioFile(filename)) continue;\n    const bytes = await readFile(filePath);\n    blobs.push({ name: filename, bytes });\n  }\n  if (blobs.length > 0) {\n    await addAudioFilesFromBlobs(blobs);\n  }\n}\n\n// Reset scroll + stop preview + check file existence on pack change\nwatch(selectedPack, async (packName) => {\n  stopPreview();\n  soundFileExists.value = new Map();\n  if (packName) void checkSoundFileExistence(packName);\n  await nextTick(() => {\n    if (rightPanel.value) rightPanel.value.scrollTop = 0;\n  });\n});\n\n</script>\n\n<template>\n  <Teleport to=\"body\">\n    <!-- Backdrop -->\n    <div class=\"fixed inset-0 z-[100] flex items-center justify-center bg-black/50\">\n      <!-- Drop zone wrapper -->\n      <div\n        class=\"relative w-[960px] max-w-[90vw] h-[700px] max-h-[90vh] flex flex-col bg-gray-900 border border-gray-700 rounded-lg shadow-2xl overflow-hidden\"\n        @dragover=\"onDragOver\"\n        @dragleave=\"onDragLeave\"\n        @drop=\"onDrop\"\n      >\n        <!-- Drag overlay -->\n        <div\n          v-if=\"dragOver\"\n          class=\"absolute inset-0 z-[150] flex items-center justify-center bg-indigo-900/80 border-2 border-dashed border-indigo-400 rounded-lg pointer-events-none\"\n        >\n          <span class=\"text-indigo-200 text-lg font-semibold\">Drop sound pack here</span>\n        </div>\n\n        <!-- Import error toast -->\n        <div\n          v-if=\"importError\"\n          class=\"absolute top-3 left-1/2 -translate-x-1/2 z-[160] px-4 py-2 bg-red-900/90 border border-red-500 rounded-lg text-red-200 text-sm max-w-md text-center shadow-lg\"\n        >\n          {{ importError }}\n        </div>\n\n        <!-- Header -->\n        <div class=\"flex items-center gap-4 px-4 py-3 border-b border-gray-700 shrink-0\">\n          <span class=\"text-gray-200 font-semibold text-sm\">Sounds</span>\n\n          <!-- Master enable -->\n          <label class=\"flex items-center gap-1.5 text-xs text-gray-300 cursor-pointer\">\n            <input\n              type=\"checkbox\"\n              :checked=\"globalEnabled\"\n              class=\"w-4 h-4 accent-indigo-400\"\n              @change=\"globalEnabled = ($event.target as HTMLInputElement).checked\"\n            />\n            Enable\n          </label>\n\n          <!-- Global volume -->\n          <label class=\"flex items-center gap-1.5 text-xs text-gray-300\">\n            Vol\n            <input\n              type=\"range\"\n              min=\"0\"\n              max=\"100\"\n              :value=\"globalVolume\"\n              class=\"w-24 accent-indigo-400\"\n              @input=\"globalVolume = parseInt(($event.target as HTMLInputElement).value)\"\n            />\n            <span class=\"w-7 tabular-nums\">{{ globalVolume }}%</span>\n          </label>\n\n          <!-- Cooldown -->\n          <label class=\"flex items-center gap-1.5 text-xs text-gray-300\">\n            Cooldown\n            <input\n              type=\"range\"\n              min=\"0\"\n              max=\"10\"\n              step=\"0.5\"\n              :value=\"cooldown\"\n              class=\"w-20 accent-indigo-400\"\n              @input=\"cooldown = parseFloat(($event.target as HTMLInputElement).value)\"\n            />\n            <span class=\"w-8 tabular-nums\">{{ cooldown }}s</span>\n          </label>\n        </div>\n\n        <!-- Body -->\n        <div class=\"flex flex-1 min-h-0\">\n          <!-- Left panel: pack list -->\n          <div class=\"w-60 shrink-0 border-r border-gray-700 flex flex-col\">\n            <div class=\"px-3 pt-2 pb-1 text-xs font-semibold text-gray-400 uppercase tracking-wide\">\n              Packs\n            </div>\n            <div class=\"flex-1 overflow-y-auto\">\n              <div\n                v-for=\"pack in soundStore.packs\"\n                :key=\"pack.name\"\n                class=\"flex items-center gap-2 px-2 py-1.5 cursor-pointer rounded mx-1\"\n                :class=\"selectedPack === pack.name ? 'bg-gray-700' : 'hover:bg-gray-800'\"\n                @click=\"selectPack(pack.name)\"\n                @contextmenu=\"onPackRightClick($event, pack.name)\"\n              >\n                <input\n                  type=\"checkbox\"\n                  :checked=\"isPackActive(pack.name)\"\n                  class=\"w-4 h-4 accent-indigo-400 cursor-pointer\"\n                  @click.stop\n                  @change=\"togglePackActive(pack.name, ($event.target as HTMLInputElement).checked)\"\n                />\n                <input\n                  v-if=\"editingPackName === pack.name\"\n                  ref=\"editPackInput\"\n                  v-model=\"editPackNameValue\"\n                  class=\"flex-1 min-w-0 px-1 py-0.5 bg-gray-800 border border-indigo-400 rounded text-xs text-gray-200 outline-none\"\n                  @click.stop\n                  @keydown.enter.prevent=\"confirmEditPackName\"\n                  @keydown.escape.prevent=\"cancelEditPackName\"\n                  @blur=\"confirmEditPackName\"\n                />\n                <span v-else class=\"text-sm text-gray-200 truncate flex-1\">{{ pack.name }}</span>\n              </div>\n            </div>\n            <!-- Buttons -->\n            <div class=\"flex gap-1 p-2 border-t border-gray-700\">\n              <button\n                class=\"flex-1 px-2 py-1 bg-gray-700/60 rounded hover:bg-gray-600/70 text-xs text-gray-200\"\n                @click=\"startCreatePack\"\n              >\n                New Pack\n              </button>\n              <button\n                class=\"flex-1 px-2 py-1 bg-gray-700/60 rounded hover:bg-gray-600/70 text-xs text-gray-200\"\n                @click=\"openImportPicker\"\n              >\n                Import\n              </button>\n            </div>\n          </div>\n\n          <!-- Patchbay: Sounds + Events columns -->\n          <div ref=\"rightPanel\" class=\"flex flex-1 min-h-0 overflow-hidden\">\n            <!-- Sounds column -->\n            <div\n              class=\"flex-1 border-r border-gray-700 flex flex-col min-w-0\"\n              @dragover=\"onAudioDragOver\"\n              @dragleave=\"onAudioDragLeave\"\n              @drop=\"onAudioDrop\"\n            >\n              <div class=\"flex items-center gap-2 px-3 py-2 border-b border-gray-700 shrink-0\">\n                <span class=\"text-xs font-semibold text-gray-400 uppercase tracking-wide flex-1\">Sounds</span>\n                <button\n                  v-if=\"selectedPack\"\n                  class=\"px-2 py-0.5 bg-gray-700/60 rounded hover:bg-gray-600/70 text-xs text-gray-300\"\n                  @click=\"openAddFilePicker\"\n                >Add file</button>\n              </div>\n              <div class=\"flex-1 overflow-y-auto relative\">\n                <!-- Audio file drop overlay -->\n                <div\n                  v-if=\"audioDragOver && selectedPack\"\n                  class=\"absolute inset-0 z-10 flex items-center justify-center bg-indigo-900/60 border-2 border-dashed border-indigo-400 rounded pointer-events-none\"\n                >\n                  <span class=\"text-indigo-200 text-sm font-semibold\">Drop audio files here</span>\n                </div>\n                <div\n                  v-if=\"!selectedPackInfo\"\n                  class=\"flex items-center justify-center h-full text-gray-600 text-sm\"\n                >\n                  Select a pack\n                </div>\n                <div\n                  v-else-if=\"selectedPackInfo.manifest.sounds.length === 0\"\n                  class=\"flex items-center justify-center h-full text-gray-600 text-sm\"\n                >\n                  No sounds in this pack\n                </div>\n                <div\n                  v-for=\"sound in selectedPackInfo.manifest.sounds\"\n                  v-else\n                  :key=\"sound.file\"\n                  draggable=\"true\"\n                  class=\"flex items-center gap-2 px-3 py-1.5 border-b border-gray-800 hover:bg-gray-800/40 cursor-grab transition-colors duration-150\"\n                  :class=\"[\n                    draggingSoundFile === sound.file ? 'opacity-50' : '',\n                    dragOverSoundFile === sound.file ? 'bg-indigo-500/20' : '',\n                    draggingChip ? 'opacity-100' : '',\n                  ]\"\n                  @mouseenter=\"hoveredSoundFile = sound.file\"\n                  @mouseleave=\"hoveredSoundFile = null\"\n                  @dragstart=\"onSoundDragStart($event, sound.file)\"\n                  @dragend=\"onSoundDragEnd\"\n                  @dragover=\"onSoundRowDragOver($event, sound.file)\"\n                  @dragleave=\"onSoundRowDragLeave\"\n                  @drop=\"onSoundRowDrop($event, sound.file)\"\n                >\n                  <!-- Play button -->\n                  <button\n                    class=\"shrink-0 w-6 h-6 flex items-center justify-center rounded text-gray-400 hover:text-white hover:bg-gray-700 text-xs\"\n                    title=\"Play preview\"\n                    @click=\"playPreview(sound.file)\"\n                  >▶</button>\n\n                  <!-- Filename -->\n                  <span class=\"flex-1 text-xs font-mono text-gray-200 truncate min-w-0\">{{ sound.file }}</span>\n\n                  <!-- Broken link indicator -->\n                  <span\n                    v-if=\"soundFileExists.get(sound.file) === false\"\n                    class=\"shrink-0 text-red-400 text-xs\"\n                    title=\"File not found on disk\"\n                  >⚠</span>\n\n                  <!-- Volume slider (visible on hover) -->\n                  <input\n                    v-show=\"hoveredSoundFile === sound.file\"\n                    type=\"range\"\n                    min=\"0\"\n                    max=\"1\"\n                    step=\"0.01\"\n                    :value=\"sound.volume\"\n                    class=\"shrink-0 w-16 accent-indigo-400\"\n                    title=\"Volume\"\n                    @input=\"updateSoundVolume(sound, parseFloat(($event.target as HTMLInputElement).value))\"\n                  />\n\n                  <!-- Enabled toggle -->\n                  <input\n                    type=\"checkbox\"\n                    :checked=\"sound.enabled\"\n                    class=\"shrink-0 w-4 h-4 accent-indigo-400 cursor-pointer\"\n                    title=\"Enable/disable this sound\"\n                    @change=\"updateSoundEnabled(sound, ($event.target as HTMLInputElement).checked)\"\n                  />\n\n                  <!-- Stop button -->\n                  <button\n                    class=\"shrink-0 w-6 h-6 flex items-center justify-center rounded text-xs\"\n                    :class=\"previewFile === sound.file\n                      ? 'text-red-400 hover:text-red-300 hover:bg-gray-700'\n                      : 'text-gray-600 cursor-default'\"\n                    title=\"Stop preview\"\n                    @click=\"previewFile === sound.file ? stopPreview() : undefined\"\n                  >■</button>\n                </div>\n              </div>\n            </div>\n\n            <!-- Events column -->\n            <div class=\"flex-1 flex flex-col min-w-0\">\n              <div class=\"px-3 py-2 border-b border-gray-700 shrink-0\">\n                <span class=\"text-xs font-semibold text-gray-400 uppercase tracking-wide\">Events</span>\n              </div>\n              <div class=\"flex-1 overflow-y-auto\">\n                <div\n                  v-for=\"eventType in AGENT_EVENT_TYPES\"\n                  :key=\"eventType\"\n                  class=\"px-3 py-2 border-b border-gray-800 transition-all duration-200\"\n                  :class=\"[\n                    hasAssignments(eventType) ? 'opacity-100' : 'opacity-40',\n                    flashingEvent === eventType ? 'bg-indigo-600/30' : '',\n                    dragOverEventType === eventType ? 'bg-indigo-500/20 opacity-100' : '',\n                    draggingSoundFile ? 'opacity-100' : '',\n                  ]\"\n                  @dragover=\"onEventDragOver($event, eventType)\"\n                  @dragleave=\"onEventDragLeaveRow\"\n                  @drop=\"onEventDrop($event, eventType)\"\n                >\n                  <div class=\"flex items-center gap-2\">\n                    <span class=\"text-sm font-mono text-gray-300 flex-1\">{{ eventType }}</span>\n                    <!-- Info icon + popover -->\n                    <span\n                      v-if=\"EVENT_DESCRIPTIONS[eventType]\"\n                      class=\"relative shrink-0\"\n                      @click.stop\n                    >\n                      <span\n                        class=\"w-4 h-4 flex items-center justify-center rounded-full border text-[10px] leading-none cursor-pointer select-none\"\n                        :class=\"activeInfoPopover === eventType\n                          ? 'border-indigo-400 text-indigo-300 bg-indigo-900/40'\n                          : 'border-gray-500 text-gray-400 hover:border-gray-300 hover:text-gray-200'\"\n                        @click=\"toggleInfoPopover(eventType)\"\n                      >i</span>\n                      <div\n                        v-if=\"activeInfoPopover === eventType\"\n                        class=\"absolute right-0 top-6 z-50 w-56 bg-gray-800 border border-gray-600 rounded shadow-lg px-3 py-2 text-xs text-gray-200 leading-relaxed\"\n                      >\n                        {{ EVENT_DESCRIPTIONS[eventType] }}\n                      </div>\n                    </span>\n                  </div>\n                  <!-- Assignment chips -->\n                  <div\n                    v-if=\"assignmentsForEvent(eventType).length > 0\"\n                    class=\"flex flex-wrap gap-1 mt-1\"\n                  >\n                    <span\n                      v-for=\"file in assignmentsForEvent(eventType)\"\n                      :key=\"file\"\n                      draggable=\"true\"\n                      class=\"inline-flex items-center gap-1 px-2 py-0.5 bg-gray-700/80 rounded text-xs text-gray-200 cursor-grab hover:bg-gray-600/80\"\n                      :class=\"draggingChip?.file === file && draggingChip?.event === eventType ? 'opacity-50' : ''\"\n                      :title=\"file\"\n                      @click=\"playPreview(file)\"\n                      @dragstart.stop=\"onChipDragStart($event, file, eventType)\"\n                      @dragend=\"onChipDragEnd\"\n                    >\n                      {{ truncateFilename(file) }}\n                      <button\n                        class=\"ml-0.5 text-gray-400 hover:text-red-400 leading-none\"\n                        title=\"Remove assignment\"\n                        @click.stop=\"removeAssignment(file, eventType)\"\n                      >&times;</button>\n                    </span>\n                  </div>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        <!-- Footer -->\n        <div class=\"flex justify-end px-4 py-3 border-t border-gray-700 shrink-0\">\n          <button\n            class=\"px-4 py-1.5 bg-gray-700/60 rounded hover:bg-gray-600/70 text-sm text-gray-200\"\n            @click=\"emit('close')\"\n          >\n            Close\n          </button>\n        </div>\n      </div>\n    </div>\n\n    <!-- Context menu -->\n    <PackContextMenu\n      v-if=\"ctxMenu\"\n      :pack-name=\"ctxMenu.packName\"\n      :x=\"ctxMenu.x\"\n      :y=\"ctxMenu.y\"\n      @close=\"closeCtxMenu\"\n      @renamed=\"onPackRenamed\"\n      @duplicated=\"onPackDuplicated\"\n      @deleted=\"onPackDeleted\"\n    />\n  </Teleport>\n</template>\n","numLines":1014,"startLine":1,"totalLines":1014}}}
