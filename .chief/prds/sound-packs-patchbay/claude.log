{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TWsYmuafcRZTEaJFdtWeN8","type":"tool_result","content":"     1→import { defineStore } from 'pinia';\n     2→import { ref } from 'vue';\n     3→import { homeDir } from '@tauri-apps/api/path';\n     4→import {\n     5→  readTextFile,\n     6→  writeTextFile,\n     7→  mkdir,\n     8→  exists,\n     9→  readDir,\n    10→  readFile,\n    11→} from '@tauri-apps/plugin-fs';\n    12→import type { AgentEvent, AgentEventType } from '../drivers/types';\n    13→\n    14→export const AGENT_EVENT_TYPES: AgentEventType[] = [\n    15→  'session_start',\n    16→  'session_end',\n    17→  'prompt_submit',\n    18→  'tool_start',\n    19→  'tool_end',\n    20→  'turn_end',\n    21→  'permission_wait',\n    22→  'subagent_start',\n    23→  'subagent_end',\n    24→  'idle_notification',\n    25→  'elicitation_wait',\n    26→  'auth_success',\n    27→  'worktree_create',\n    28→  'worktree_remove',\n    29→  'teammate_idle',\n    30→  'task_completed',\n    31→];\n    32→\n    33→export interface TrackConfig {\n    34→  enabled: boolean;\n    35→  volume: number;\n    36→}\n    37→\n    38→export interface SoundConfig {\n    39→  enabled: boolean;\n    40→  globalVolume: number;\n    41→  cooldownSeconds: number;\n    42→  activePacks: string[];\n    43→  tracks: Record<string, Record<string, TrackConfig>>;\n    44→}\n    45→\n    46→export interface PackInfo {\n    47→  name: string;\n    48→  categories: Record<string, string[]>;\n    49→}\n    50→\n    51→const DEFAULT_CONFIG: SoundConfig = {\n    52→  enabled: true,\n    53→  globalVolume: 0.8,\n    54→  cooldownSeconds: 2,\n    55→  activePacks: [],\n    56→  tracks: {},\n    57→};\n    58→\n    59→const AUDIO_EXTENSIONS = new Set(['.mp3', '.ogg', '.wav', '.flac', '.m4a', '.webm']);\n    60→\n    61→function hasAudioExtension(filename: string): boolean {\n    62→  const dot = filename.lastIndexOf('.');\n    63→  if (dot < 0) return false;\n    64→  return AUDIO_EXTENSIONS.has(filename.slice(dot).toLowerCase());\n    65→}\n    66→\n    67→export const useSoundStore = defineStore('sound', () => {\n    68→  const config = ref<SoundConfig>({ ...DEFAULT_CONFIG, tracks: {} });\n    69→  const packs = ref<PackInfo[]>([]);\n    70→\n    71→  // Reactive state for sound indicator (US-009)\n    72→  const lastPlayedSessionId = ref<string | null>(null);\n    73→\n    74→  let soundPacksDir = '';\n    75→  let configPath = '';\n    76→\n    77→  // AudioContext — lazy init on first playback\n    78→  let audioCtx: AudioContext | null = null;\n    79→\n    80→  // Buffer cache: absolute file path → AudioBuffer\n    81→  const bufferCache = new Map<string, AudioBuffer>();\n    82→\n    83→  // Per-category cooldown timestamps (category → last played ms)\n    84→  const cooldownMap = new Map<string, number>();\n    85→\n    86→  // Whether any sound is currently playing\n    87→  let playing = false;\n    88→\n    89→  // Per-session pack assignment\n    90→  const sessionPacks = new Map<string, string>();\n    91→\n    92→  // -------------------------------------------------------------------------\n    93→  // Init / persistence\n    94→  // -------------------------------------------------------------------------\n    95→\n    96→  async function init(): Promise<void> {\n    97→    const home = await homeDir();\n    98→    soundPacksDir = `${home}/.agents-in-the-office/sound-packs`;\n    99→    configPath = `${soundPacksDir}/config.json`;\n   100→\n   101→    const dirExists = await exists(soundPacksDir);\n   102→    if (!dirExists) {\n   103→      await mkdir(soundPacksDir, { recursive: true });\n   104→    }\n   105→\n   106→    const cfgExists = await exists(configPath);\n   107→    if (cfgExists) {\n   108→      try {\n   109→        const raw = await readTextFile(configPath);\n   110→        config.value = { ...DEFAULT_CONFIG, ...JSON.parse(raw) as Partial<SoundConfig> };\n   111→      } catch {\n   112→        config.value = { ...DEFAULT_CONFIG, tracks: {} };\n   113→      }\n   114→    } else {\n   115→      config.value = { ...DEFAULT_CONFIG, tracks: {} };\n   116→      await saveConfig();\n   117→    }\n   118→  }\n   119→\n   120→  async function saveConfig(): Promise<void> {\n   121→    await writeTextFile(configPath, JSON.stringify(config.value, null, 2));\n   122→  }\n   123→\n   124→  // -------------------------------------------------------------------------\n   125→  // Pack scanning\n   126→  // -------------------------------------------------------------------------\n   127→\n   128→  async function scanPacks(): Promise<PackInfo[]> {\n   129→    const discovered: PackInfo[] = [];\n   130→\n   131→    const dirExists = await exists(soundPacksDir);\n   132→    if (!dirExists) return discovered;\n   133→\n   134→    const entries = await readDir(soundPacksDir);\n   135→    for (const entry of entries) {\n   136→      if (!entry.isDirectory) continue;\n   137→      if (entry.name === undefined || entry.name.startsWith('.')) continue;\n   138→      const packName = entry.name;\n   139→      const packPath = `${soundPacksDir}/${packName}`;\n   140→      const categories: Record<string, string[]> = {};\n   141→\n   142→      const catEntries = await readDir(packPath);\n   143→      for (const cat of catEntries) {\n   144→        if (!cat.isDirectory) continue;\n   145→        if (cat.name === undefined || cat.name.startsWith('.')) continue;\n   146→        const catName = cat.name;\n   147→        const catPath = `${packPath}/${catName}`;\n   148→        const fileEntries = await readDir(catPath);\n   149→        const audioFiles = fileEntries\n   150→          .filter((f) => !f.isDirectory && f.name !== undefined && hasAudioExtension(f.name))\n   151→          .map((f) => f.name as string);\n   152→        if (audioFiles.length > 0 || AGENT_EVENT_TYPES.includes(catName as AgentEventType)) {\n   153→          categories[catName] = audioFiles.sort();\n   154→        }\n   155→      }\n   156→\n   157→      for (const eventType of AGENT_EVENT_TYPES) {\n   158→        if (!(eventType in categories)) {\n   159→          categories[eventType] = [];\n   160→        }\n   161→      }\n   162→\n   163→      discovered.push({ name: packName, categories });\n   164→    }\n   165→\n   166→    packs.value = discovered;\n   167→    return discovered;\n   168→  }\n   169→\n   170→  // -------------------------------------------------------------------------\n   171→  // Track config helpers\n   172→  // -------------------------------------------------------------------------\n   173→\n   174→  function getTrackConfig(packName: string, categoryAndFile: string): TrackConfig {\n   175→    const packTracks = config.value.tracks[packName];\n   176→    if (packTracks) {\n   177→      const existing = packTracks[categoryAndFile];\n   178→      if (existing !== undefined) return existing;\n   179→    }\n   180→    const defaultTrack: TrackConfig = { enabled: true, volume: 1.0 };\n   181→    if (!config.value.tracks[packName]) {\n   182→      config.value.tracks[packName] = {};\n   183→    }\n   184→    config.value.tracks[packName][categoryAndFile] = defaultTrack;\n   185→    return defaultTrack;\n   186→  }\n   187→\n   188→  function setTrackConfig(packName: string, categoryAndFile: string, track: TrackConfig): void {\n   189→    if (!config.value.tracks[packName]) {\n   190→      config.value.tracks[packName] = {};\n   191→    }\n   192→    config.value.tracks[packName][categoryAndFile] = track;\n   193→  }\n   194→\n   195→  function getSoundPacksDir(): string {\n   196→    return soundPacksDir;\n   197→  }\n   198→\n   199→  function getSessionPack(sessionId: string): string | undefined {\n   200→    return sessionPacks.get(sessionId);\n   201→  }\n   202→\n   203→  function assignSessionPack(sessionId: string, preferredPacks: string[]): void {\n   204→    const pool = preferredPacks.length > 0 ? preferredPacks : config.value.activePacks;\n   205→    if (pool.length === 0) return;\n   206→    const chosen = pool[Math.floor(Math.random() * pool.length)];\n   207→    if (chosen !== undefined) {\n   208→      sessionPacks.set(sessionId, chosen);\n   209→    }\n   210→  }\n   211→\n   212→  // -------------------------------------------------------------------------\n   213→  // AudioContext helpers\n   214→  // -------------------------------------------------------------------------\n   215→\n   216→  function getAudioContext(): AudioContext {\n   217→    if (!audioCtx) {\n   218→      audioCtx = new AudioContext();\n   219→    }\n   220→    return audioCtx;\n   221→  }\n   222→\n   223→  async function loadBuffer(filePath: string): Promise<AudioBuffer | null> {\n   224→    const cached = bufferCache.get(filePath);\n   225→    if (cached !== undefined) return cached;\n   226→\n   227→    try {\n   228→      const bytes = await readFile(filePath);\n   229→      const ctx = getAudioContext();\n   230→      const buffer = await ctx.decodeAudioData(bytes.buffer as ArrayBuffer);\n   231→      bufferCache.set(filePath, buffer);\n   232→      return buffer;\n   233→    } catch (err) {\n   234→      console.warn(`[soundStore] Failed to decode audio: ${filePath}`, err);\n   235→      return null;\n   236→    }\n   237→  }\n   238→\n   239→  // -------------------------------------------------------------------------\n   240→  // Playback engine\n   241→  // -------------------------------------------------------------------------\n   242→\n   243→  async function playForEvent(event: AgentEvent): Promise<void> {\n   244→    if (!config.value.enabled) return;\n   245→\n   246→    // Session pack assignment on session_start\n   247→    if (event.type === 'session_start') {\n   248→      const { activePacks } = config.value;\n   249→      if (activePacks.length > 0) {\n   250→        const randomIdx = Math.floor(Math.random() * activePacks.length);\n   251→        const chosen = activePacks[randomIdx];\n   252→        if (chosen !== undefined) {\n   253→          sessionPacks.set(event.sessionId, chosen);\n   254→        }\n   255→      }\n   256→    }\n   257→\n   258→    const packName = sessionPacks.get(event.sessionId);\n   259→    if (!packName) return;\n   260→\n   261→    const category = event.type;\n   262→    const now = Date.now();\n   263→    const cooldownMs = config.value.cooldownSeconds * 1000;\n   264→    const lastPlayed = cooldownMap.get(category) ?? 0;\n   265→    if (now - lastPlayed < cooldownMs) return;\n   266→\n   267→    if (playing) return;\n   268→\n   269→    // Find the pack info\n   270→    const packInfo = packs.value.find((p) => p.name === packName);\n   271→    const files = packInfo?.categories[category] ?? [];\n   272→\n   273→    // Filter to enabled tracks\n   274→    const enabledFiles = files.filter((filename) => {\n   275→      const key = `${category}/${filename}`;\n   276→      return getTrackConfig(packName, key).enabled;\n   277→    });\n   278→\n   279→    if (enabledFiles.length === 0) return;\n   280→\n   281→    const randomFileIdx = Math.floor(Math.random() * enabledFiles.length);\n   282→    const chosenFile = enabledFiles[randomFileIdx];\n   283→    if (chosenFile === undefined) return;\n   284→\n   285→    const filePath = `${soundPacksDir}/${packName}/${category}/${chosenFile}`;\n   286→    const buffer = await loadBuffer(filePath);\n   287→    if (!buffer) return;\n   288→\n   289→    const trackKey = `${category}/${chosenFile}`;\n   290→    const trackCfg = getTrackConfig(packName, trackKey);\n   291→    const ctx = getAudioContext();\n   292→\n   293→    const gainNode = ctx.createGain();\n   294→    gainNode.gain.value = config.value.globalVolume * trackCfg.volume;\n   295→    gainNode.connect(ctx.destination);\n   296→\n   297→    const source = ctx.createBufferSource();\n   298→    source.buffer = buffer;\n   299→    source.connect(gainNode);\n   300→\n   301→    playing = true;\n   302→    cooldownMap.set(category, now);\n   303→    lastPlayedSessionId.value = event.sessionId;\n   304→\n   305→    source.onended = () => {\n   306→      playing = false;\n   307→    };\n   308→\n   309→    source.start();\n   310→  }\n   311→\n   312→  // -------------------------------------------------------------------------\n   313→  // Public AudioContext access (for AudioPlayer.vue)\n   314→  // -------------------------------------------------------------------------\n   315→\n   316→  function getOrCreateAudioContext(): AudioContext {\n   317→    return getAudioContext();\n   318→  }\n   319→\n   320→  function getBufferCache(): Map<string, AudioBuffer> {\n   321→    return bufferCache;\n   322→  }\n   323→\n   324→  return {\n   325→    config,\n   326→    packs,\n   327→    lastPlayedSessionId,\n   328→    init,\n   329→    saveConfig,\n   330→    scanPacks,\n   331→    getTrackConfig,\n   332→    setTrackConfig,\n   333→    getSoundPacksDir,\n   334→    playForEvent,\n   335→    getOrCreateAudioContext,\n   336→    getBufferCache,\n   337→    loadBuffer,\n   338→    getSessionPack,\n   339→    assignSessionPack,\n   340→  };\n   341→});\n   342→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_01RWwUnJxQVZKQtn5rVdNvEF","session_id":"75b2882c-830d-4bff-b8cd-d257d75432f2","uuid":"b253e0a7-fbca-46ad-a774-4cd685b62a90"}
