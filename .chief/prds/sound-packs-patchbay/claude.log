{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BrHRYQTpb4efQUUXyeMhZo","type":"tool_result","content":"     1→{\n     2→  \"project\": \"Sound Pack Patchbay Editor\",\n     3→  \"description\": \"Redesign the SoundsDialog interior to a patchbay model: a split-view editor where sound files (left column) are explicitly wired to agent events (right column) via drag-and-drop. Replaces the implicit folder-name-to-event-type encoding with an explicit manifest.json per pack. Eliminates the need to copy audio files across event folders when one sound should serve multiple events.\",\n     4→  \"context\": {\n     5→    \"currentProblems\": [\n     6→      \"Folder structure encodes event mapping implicitly (folder name = event type) — the mapping is invisible in the UI\",\n     7→      \"Assigning one sound to multiple events requires duplicating the audio file across folders — wasteful and confusing\",\n     8→      \"The two problems compound: no explicit mapping AND no file sharing\"\n     9→    ],\n    10→    \"keepUnchanged\": [\n    11→      \"Pack list sidebar (left rail showing available packs)\",\n    12→      \"ZIP import flow (drag-and-drop ZIP onto dialog)\",\n    13→      \"Pack context menu (right-click: rename, duplicate, delete)\",\n    14→      \"CharacterSettings.vue preferred packs checkboxes\",\n    15→      \"SoundQuickPanel.vue (session→pack assignment display)\",\n    16→      \"Random playback selection policy\",\n    17→      \"Per-event cooldown behavior\",\n    18→      \"Global enabled toggle and globalVolume\"\n    19→    ]\n    20→  },\n    21→  \"storageFormat\": {\n    22→    \"packManifest\": {\n    23→      \"path\": \"~/.agents-in-the-office/sound-packs/<pack-name>/manifest.json\",\n    24→      \"description\": \"Single source of truth for event→sound assignments within a pack. Replaces the folder-per-event-type structure.\",\n    25→      \"schema\": {\n    26→        \"sounds\": [\n    27→          {\n    28→            \"file\": \"notification.mp3\",\n    29→            \"volume\": 1.0,\n    30→            \"enabled\": true\n    31→          }\n    32→        ],\n    33→        \"assignments\": [\n    34→          {\n    35→            \"file\": \"notification.mp3\",\n    36→            \"event\": \"session_start\"\n    37→          },\n    38→          {\n    39→            \"file\": \"notification.mp3\",\n    40→            \"event\": \"tool_end\"\n    41→          }\n    42→        ]\n    43→      },\n    44→      \"notes\": [\n    45→        \"sounds[] lists all audio files in the pack with authored defaults for volume and enabled\",\n    46→        \"assignments[] is many-to-many: one file can appear in multiple assignments, one event can have multiple files\",\n    47→        \"Audio files live flat in the pack root directory (no subdirectories required)\",\n    48→        \"Files present on disk but not in sounds[] are ignored\"\n    49→      ]\n    50→    },\n    51→    \"globalConfig\": {\n    52→      \"path\": \"~/.agents-in-the-office/sound-packs/config.json\",\n    53→      \"description\": \"User overrides for per-sound settings. Layered on top of manifest defaults.\",\n    54→      \"schema\": {\n    55→        \"enabled\": true,\n    56→        \"globalVolume\": 0.8,\n    57→        \"cooldownSeconds\": 2,\n    58→        \"activePacks\": [\"pack-name\"],\n    59→        \"soundOverrides\": {\n    60→          \"<pack-name>/<filename>\": {\n    61→            \"volume\": 0.9,\n    62→            \"enabled\": true\n    63→          }\n    64→        }\n    65→      },\n    66→      \"notes\": [\n    67→        \"soundOverrides keys are '<packName>/<filename>'\",\n    68→        \"If a key is present, its values override the manifest defaults\",\n    69→        \"If absent, manifest values are used\",\n    70→        \"The old 'tracks' key (using 'category/filename' paths) is replaced by 'soundOverrides' (using 'packName/filename')\"\n    71→      ]\n    72→    },\n    73→    \"zipFormat\": {\n    74→      \"requirement\": \"ZIP archives must include a manifest.json at the pack root\",\n    75→      \"structure\": \"pack-name/\\n  manifest.json\\n  sound1.mp3\\n  sound2.wav\\n  ...\",\n    76→      \"noFallback\": \"Old folder-structured ZIPs (without manifest.json) are rejected with a clear error message explaining the new format requirement\"\n    77→    }\n    78→  },\n    79→  \"playbackBehavior\": {\n    80→    \"eventFiring\": \"On AgentEvent, look up active pack for session → read manifest.assignments where event matches → collect all enabled sound files → pick one at random → play\",\n    81→    \"cooldown\": \"Per event type, same as current. Cooldown timer is per event type string.\",\n    82→    \"volumeResolution\": \"effectiveVolume = globalVolume × (soundOverrides[pack/file].volume ?? manifest.sounds[file].volume)\",\n    83→    \"enabledResolution\": \"isEnabled = soundOverrides[pack/file].enabled ?? manifest.sounds[file].enabled\"\n    84→  },\n    85→  \"ui\": {\n    86→    \"dialogLayout\": {\n    87→      \"description\": \"Full replacement of SoundsDialog interior. Modal dialog stays. Pack list sidebar stays unchanged. The content area (right of pack sidebar) becomes a patchbay split view.\",\n    88→      \"splitView\": {\n    89→        \"leftColumn\": {\n    90→          \"label\": \"Sounds\",\n    91→          \"content\": \"List of audio files in the selected pack\",\n    92→          \"addMethods\": [\n    93→            \"Drag audio files from Finder onto the column → copies to pack directory + adds to manifest\",\n    94→            \"'Add file' button → opens system file picker → copies selected files to pack directory + adds to manifest\"\n    95→          ],\n    96→          \"itemDisplay\": {\n    97→            \"name\": \"Raw filename including extension (no aliasing, no auto-prettify)\",\n    98→            \"controls\": \"Inline play button (left of name) — click plays from start, re-click restarts; Stop button (right of name) — stops current playback\",\n    99→            \"volumeControl\": \"Per-sound volume slider, visible on hover or when row is selected\",\n   100→            \"enabledToggle\": \"Per-sound enabled checkbox/toggle\",\n   101→            \"missingIndicator\": \"If file is in manifest but not found on disk, show a red broken-link icon on the row\",\n   102→            \"noUnassignedVisualDistinction\": \"Unassigned sounds look identical to assigned ones in the left column\"\n   103→          },\n   104→          \"dragBehavior\": \"Each sound row is draggable. During drag, a ghost chip follows the cursor.\"\n   105→        },\n   106→        \"rightColumn\": {\n   107→          \"label\": \"Events\",\n   108→          \"content\": \"Fixed list of all 16 AgentEventType values\",\n   109→          \"emptyEventDisplay\": \"All 16 events always visible. Events with no assigned sounds are visually de-emphasized (dimmed text, lighter background).\",\n   110→          \"eventRow\": {\n   111→            \"layout\": \"Event name label on left, chip area on right showing assigned sounds\",\n   112→            \"chips\": \"Each assigned sound appears as a small removable chip with the filename. Click chip to preview that sound. × button to remove assignment (unlinks only — does not delete file).\",\n   113→            \"liveHighlight\": \"When a real agent event fires while the dialog is open, the corresponding event row briefly flashes/highlights\"\n   114→          },\n   115→          \"dropTarget\": \"Each event row is a valid drop target for sound items from the left column. Highlights on hover during drag.\"\n   116→        }\n   117→      }\n   118→    },\n   119→    \"assignmentInteraction\": {\n   120→      \"addAssignment\": [\n   121→        \"Drag sound from left column → drop onto event row in right column\",\n   122→        \"Drag chip from event row → drop onto a different sound in left column (re-assignment: removes from old sound, adds new)\"\n   123→      ],\n   124→      \"removeAssignment\": \"Click × on chip in event row. File stays in pack, only the assignment is removed.\",\n   125→      \"duplicateAssignment\": \"Silently ignored — if (file, event) pair already exists, do nothing.\",\n   126→      \"dragFeedback\": \"Ghost chip follows cursor during drag. Valid drop targets highlight on hover. Invalid drop zones show no highlight.\"\n   127→    },\n   128→    \"packCreation\": {\n   129→      \"flow\": \"Click + button in pack sidebar → pack created immediately with generated name (e.g. 'New Pack') → name field enters inline edit mode, cursor placed in field → user types name → Enter or blur confirms\",\n   130→      \"manifestInit\": \"New pack gets an empty manifest.json written immediately on creation\"\n   131→    },\n   132→    \"autosave\": \"Every change (assignment add/remove, volume change, enabled toggle, file add) triggers an immediate write to manifest.json and/or config.json. No save button. No confirmation.\"\n   133→  },\n   134→  \"migration\": {\n   135→    \"oldPacksOnDisk\": \"Packs with the old folder-per-event-type structure (no manifest.json) remain readable but are not automatically migrated. The UI shows a 'Migrate to new format' button in the pack list context menu for such packs, which generates a manifest.json from the folder structure and moves audio files to the pack root.\",\n   136→    \"configMigration\": \"On first load, if config.json contains the old 'tracks' key, it is read as-is for backward compatibility. When any write occurs, it is migrated to 'soundOverrides' format automatically.\"\n   137→  },\n   138→  \"userStories\": [\n   139→    {\n   140→      \"id\": \"US-001\",\n   141→      \"title\": \"manifest.json schema + read/write in soundStore\",\n   142→      \"description\": \"As a developer, I need the soundStore to read and write manifest.json from each pack directory so the patchbay has a persistent source of truth.\",\n   143→      \"acceptanceCriteria\": [\n   144→        \"PackManifest TypeScript interface: { sounds: Array<{ file: string, volume: number, enabled: boolean }>, assignments: Array<{ file: string, event: AgentEventType }> }\",\n   145→        \"soundStore.loadPackManifest(packName) reads manifest.json from pack directory; returns empty manifest if file missing\",\n   146→        \"soundStore.savePackManifest(packName, manifest) writes manifest.json to pack directory\",\n   147→        \"soundStore.scanPacks() updated: scans pack directories for audio files AND reads manifest.json; PackInfo includes manifest data\",\n   148→        \"vue-tsc -b passes\"\n   149→      ],\n   150→      \"priority\": 1\n   151→    },\n   152→    {\n   153→      \"id\": \"US-002\",\n   154→      \"title\": \"config.json migration — soundOverrides replaces tracks\",\n   155→      \"description\": \"As a developer, I need the config schema updated to store per-sound overrides by pack/filename key instead of category/filename.\",\n   156→      \"acceptanceCriteria\": [\n   157→        \"SoundConfig.soundOverrides: Record<string, { volume: number, enabled: boolean }> where key is '<packName>/<filename>'\",\n   158→        \"Old SoundConfig.tracks key still accepted on read (backward compat); migrated to soundOverrides on next write\",\n   159→        \"effectiveVolume and isEnabled resolution follows the two-layer rule: soundOverrides → manifest default\",\n   160→        \"vue-tsc -b passes\"\n   161→      ],\n   162→      \"priority\": 1\n   163→    },\n   164→    {\n   165→      \"id\": \"US-003\",\n   166→      \"title\": \"playForEvent updated for manifest-based lookup\",\n   167→      \"description\": \"As a user, I want sounds to play based on manifest assignments so my patchbay configuration is reflected in runtime audio.\",\n   168→      \"acceptanceCriteria\": [\n   169→        \"playForEvent(event) looks up active pack for session → reads manifest.assignments filtered by event.type → collects enabled files → picks random → plays\",\n   170→        \"Volume resolved via two-layer rule (US-002)\",\n   171→        \"Missing file (in manifest but not on disk) is skipped with a console warning — no crash\",\n   172→        \"Per-event cooldown still applies\",\n   173→        \"vue-tsc -b passes\"\n   174→      ],\n   175→      \"priority\": 2\n   176→    },\n   177→    {\n   178→      \"id\": \"US-004\",\n   179→      \"title\": \"SoundsDialog — patchbay split view layout\",\n   180→      \"description\": \"As a user, I want the SoundsDialog content area to show a two-column patchbay so I can see sounds and events side by side.\",\n   181→      \"acceptanceCriteria\": [\n   182→        \"Dialog content area (right of pack sidebar) splits into two equal columns\",\n   183→        \"Left column header: 'Sounds', right column header: 'Events'\",\n   184→        \"Right column shows all 16 AgentEventType values as rows\",\n   185→        \"Event rows with no assignments are visually dimmed (reduced opacity or lighter text)\",\n   186→        \"Event rows with assignments are full-opacity\",\n   187→        \"Pack sidebar and context menu unchanged\",\n   188→        \"vue-tsc -b passes\"\n   189→      ],\n   190→      \"priority\": 3\n   191→    },\n   192→    {\n   193→      \"id\": \"US-005\",\n   194→      \"title\": \"Left column — sound file list with inline preview\",\n   195→      \"description\": \"As a user, I want to see all audio files in the selected pack and preview them inline.\",\n   196→      \"acceptanceCriteria\": [\n   197→        \"Left column lists all files from manifest.sounds for selected pack\",\n   198→        \"Each row shows: play button (left), raw filename, stop button (right)\",\n   199→        \"Click play: loads and plays audio from start; if already playing, restarts from start\",\n   200→        \"Click stop: stops current playback\",\n   201→        \"Per-sound volume slider visible on hover\",\n   202→        \"Per-sound enabled toggle (checkbox or switch) on each row\",\n   203→        \"Changes to volume/enabled autosave: update manifest.sounds entry + write manifest.json\",\n   204→        \"Missing file (in manifest but not on disk) shows red broken-link icon on row\",\n   205→        \"vue-tsc -b passes\"\n   206→      ],\n   207→      \"priority\": 3\n   208→    },\n   209→    {\n   210→      \"id\": \"US-006\",\n   211→      \"title\": \"Right column — event rows with sound chips\",\n   212→      \"description\": \"As a user, I want each event row to show which sounds are assigned as removable chips.\",\n   213→      \"acceptanceCriteria\": [\n   214→        \"Each event row shows chips for all assigned sound files\",\n   215→        \"Chip label: truncated filename (max ~20 chars with ellipsis)\",\n   216→        \"Chip has × button; click × removes the (file, event) assignment from manifest and autosaves\",\n   217→        \"Click chip body (not ×) plays a preview of that sound inline\",\n   218→        \"Live highlight: when AgentEvent fires matching an event type while dialog is open, that event row briefly flashes (200ms highlight animation)\",\n   219→        \"vue-tsc -b passes\"\n   220→      ],\n   221→      \"priority\": 4\n   222→    },\n   223→    {\n   224→      \"id\": \"US-007\",\n   225→      \"title\": \"Drag sound from left column to event row\",\n   226→      \"description\": \"As a user, I want to drag a sound file and drop it onto an event row to create an assignment.\",\n   227→      \"acceptanceCriteria\": [\n   228→        \"Sound rows in left column are draggable (HTML5 drag API or equivalent)\",\n   229→        \"During drag: ghost chip (translucent copy of filename chip) follows cursor\",\n   230→        \"During drag: valid drop targets (event rows) highlight on hover\",\n   231→        \"Drop onto event row: adds (file, event) to manifest.assignments if not already present; autosaves\",\n   232→        \"Drop on duplicate (same file already assigned to same event): silently ignored, no feedback\",\n   233→        \"Drop outside valid target: no change\",\n   234→        \"vue-tsc -b passes\"\n   235→      ],\n   236→      \"priority\": 4\n   237→    },\n   238→    {\n   239→      \"id\": \"US-008\",\n   240→      \"title\": \"Drag chip from event row to re-assign to different sound\",\n   241→      \"description\": \"As a user, I want to drag an assignment chip from an event row and drop it onto a different sound in the left column to re-assign it.\",\n   242→      \"acceptanceCriteria\": [\n   243→        \"Assignment chips in right column are draggable\",\n   244→        \"During drag: ghost chip follows cursor; left column sound rows highlight as valid targets\",\n   245→        \"Drop onto sound row: removes old (originalFile, event) assignment, adds (newFile, event) assignment; autosaves\",\n   246→        \"Drop onto same sound row (no-op): silently ignored\",\n   247→        \"Drop outside valid target: no change, assignment remains\",\n   248→        \"vue-tsc -b passes\"\n   249→      ],\n   250→      \"priority\": 5\n   251→    },\n   252→    {\n   253→      \"id\": \"US-009\",\n   254→      \"title\": \"Add audio files to pack — drag from Finder + file picker\",\n   255→      \"description\": \"As a user, I want to add new audio files to a pack via drag-and-drop or file picker.\",\n   256→      \"acceptanceCriteria\": [\n   257→        \"Left column accepts file drag from OS (dragover + drop on column area)\",\n   258→        \"Dropped audio files (wav/mp3/ogg/flac/m4a/webm) are copied to pack directory root\",\n   259→        \"Dropped files are added to manifest.sounds with defaults: volume 1.0, enabled true\",\n   260→        \"Manifest autosaved after file add\",\n   261→        \"'Add file' button above left column opens Tauri file picker (dialog plugin); selected files go through same flow\",\n   262→        \"Non-audio files dropped/selected are silently ignored or shown a brief error\",\n   263→        \"vue-tsc -b passes\"\n   264→      ],\n   265→      \"priority\": 5\n   266→    },\n   267→    {\n   268→      \"id\": \"US-010\",\n   269→      \"title\": \"Pack creation — immediate create with inline rename\",\n   270→      \"description\": \"As a user, I want to create a new pack that appears immediately with an editable name.\",\n   271→      \"acceptanceCriteria\": [\n   272→        \"Clicking + in pack sidebar creates a pack directory with generated name ('New Pack', 'New Pack 2', etc.)\",\n   273→        \"Empty manifest.json written to new pack directory immediately\",\n   274→        \"Pack name field enters inline edit mode with cursor focused\",\n   275→        \"Enter or blur confirms name; renames directory on disk\",\n   276→        \"Escape cancels and deletes the newly created pack (since it's empty and user aborted naming)\",\n   277→        \"vue-tsc -b passes\"\n   278→      ],\n   279→      \"priority\": 5\n   280→    },\n   281→    {\n   282→      \"id\": \"US-011\",\n   283→      \"title\": \"ZIP import — manifest.json required\",\n   284→      \"description\": \"As a user, I want to import sound packs from ZIP files that use the new manifest format.\",\n   285→      \"acceptanceCriteria\": [\n   286→        \"ZIP import reads manifest.json from pack root inside ZIP\",\n   287→        \"If manifest.json is absent, import fails with error message: 'This ZIP does not contain a manifest.json. Please use the new pack format.'\",\n   288→        \"Audio files are extracted to pack directory root (not into subdirectories)\",\n   289→        \"manifest.json is written to pack directory\",\n   290→        \"Pack appears in sidebar after import\",\n   291→        \"vue-tsc -b passes\"\n   292→      ],\n   293→      \"priority\": 6\n   294→    },\n   295→    {\n   296→      \"id\": \"US-012\",\n   297→      \"title\": \"Old pack migration — 'Migrate to new format' in context menu\",\n   298→      \"description\": \"As a user, I want to migrate old folder-structured packs to the new manifest format without losing my configuration.\",\n   299→      \"acceptanceCriteria\": [\n   300→        \"Packs without manifest.json detected on scan; labeled with a migration indicator in the sidebar\",\n   301→        \"Pack context menu shows 'Migrate to new format' option for old-style packs\",\n   302→        \"Migration: reads all audio files from subdirectories, creates assignments from folder names (folder name → event type), moves files to pack root, writes manifest.json, removes old subdirectories\",\n   303→        \"After migration, indicator removed and pack is fully functional in patchbay\",\n   304→        \"vue-tsc -b passes\"\n   305→      ],\n   306→      \"priority\": 6\n   307→    }\n   308→  ]\n   309→}\n   310→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"75b2882c-830d-4bff-b8cd-d257d75432f2","uuid":"e3e33247-cc0e-4dfb-a9c3-9eebb2971423","tool_use_result":{"type":"text","file":{"filePath":"/Users/markus/baustelle/projects/agents-in-the-office/agents-in-the-office/.chief/prds/sound-packs-patchbay/prd.json","content":"{\n  \"project\": \"Sound Pack Patchbay Editor\",\n  \"description\": \"Redesign the SoundsDialog interior to a patchbay model: a split-view editor where sound files (left column) are explicitly wired to agent events (right column) via drag-and-drop. Replaces the implicit folder-name-to-event-type encoding with an explicit manifest.json per pack. Eliminates the need to copy audio files across event folders when one sound should serve multiple events.\",\n  \"context\": {\n    \"currentProblems\": [\n      \"Folder structure encodes event mapping implicitly (folder name = event type) — the mapping is invisible in the UI\",\n      \"Assigning one sound to multiple events requires duplicating the audio file across folders — wasteful and confusing\",\n      \"The two problems compound: no explicit mapping AND no file sharing\"\n    ],\n    \"keepUnchanged\": [\n      \"Pack list sidebar (left rail showing available packs)\",\n      \"ZIP import flow (drag-and-drop ZIP onto dialog)\",\n      \"Pack context menu (right-click: rename, duplicate, delete)\",\n      \"CharacterSettings.vue preferred packs checkboxes\",\n      \"SoundQuickPanel.vue (session→pack assignment display)\",\n      \"Random playback selection policy\",\n      \"Per-event cooldown behavior\",\n      \"Global enabled toggle and globalVolume\"\n    ]\n  },\n  \"storageFormat\": {\n    \"packManifest\": {\n      \"path\": \"~/.agents-in-the-office/sound-packs/<pack-name>/manifest.json\",\n      \"description\": \"Single source of truth for event→sound assignments within a pack. Replaces the folder-per-event-type structure.\",\n      \"schema\": {\n        \"sounds\": [\n          {\n            \"file\": \"notification.mp3\",\n            \"volume\": 1.0,\n            \"enabled\": true\n          }\n        ],\n        \"assignments\": [\n          {\n            \"file\": \"notification.mp3\",\n            \"event\": \"session_start\"\n          },\n          {\n            \"file\": \"notification.mp3\",\n            \"event\": \"tool_end\"\n          }\n        ]\n      },\n      \"notes\": [\n        \"sounds[] lists all audio files in the pack with authored defaults for volume and enabled\",\n        \"assignments[] is many-to-many: one file can appear in multiple assignments, one event can have multiple files\",\n        \"Audio files live flat in the pack root directory (no subdirectories required)\",\n        \"Files present on disk but not in sounds[] are ignored\"\n      ]\n    },\n    \"globalConfig\": {\n      \"path\": \"~/.agents-in-the-office/sound-packs/config.json\",\n      \"description\": \"User overrides for per-sound settings. Layered on top of manifest defaults.\",\n      \"schema\": {\n        \"enabled\": true,\n        \"globalVolume\": 0.8,\n        \"cooldownSeconds\": 2,\n        \"activePacks\": [\"pack-name\"],\n        \"soundOverrides\": {\n          \"<pack-name>/<filename>\": {\n            \"volume\": 0.9,\n            \"enabled\": true\n          }\n        }\n      },\n      \"notes\": [\n        \"soundOverrides keys are '<packName>/<filename>'\",\n        \"If a key is present, its values override the manifest defaults\",\n        \"If absent, manifest values are used\",\n        \"The old 'tracks' key (using 'category/filename' paths) is replaced by 'soundOverrides' (using 'packName/filename')\"\n      ]\n    },\n    \"zipFormat\": {\n      \"requirement\": \"ZIP archives must include a manifest.json at the pack root\",\n      \"structure\": \"pack-name/\\n  manifest.json\\n  sound1.mp3\\n  sound2.wav\\n  ...\",\n      \"noFallback\": \"Old folder-structured ZIPs (without manifest.json) are rejected with a clear error message explaining the new format requirement\"\n    }\n  },\n  \"playbackBehavior\": {\n    \"eventFiring\": \"On AgentEvent, look up active pack for session → read manifest.assignments where event matches → collect all enabled sound files → pick one at random → play\",\n    \"cooldown\": \"Per event type, same as current. Cooldown timer is per event type string.\",\n    \"volumeResolution\": \"effectiveVolume = globalVolume × (soundOverrides[pack/file].volume ?? manifest.sounds[file].volume)\",\n    \"enabledResolution\": \"isEnabled = soundOverrides[pack/file].enabled ?? manifest.sounds[file].enabled\"\n  },\n  \"ui\": {\n    \"dialogLayout\": {\n      \"description\": \"Full replacement of SoundsDialog interior. Modal dialog stays. Pack list sidebar stays unchanged. The content area (right of pack sidebar) becomes a patchbay split view.\",\n      \"splitView\": {\n        \"leftColumn\": {\n          \"label\": \"Sounds\",\n          \"content\": \"List of audio files in the selected pack\",\n          \"addMethods\": [\n            \"Drag audio files from Finder onto the column → copies to pack directory + adds to manifest\",\n            \"'Add file' button → opens system file picker → copies selected files to pack directory + adds to manifest\"\n          ],\n          \"itemDisplay\": {\n            \"name\": \"Raw filename including extension (no aliasing, no auto-prettify)\",\n            \"controls\": \"Inline play button (left of name) — click plays from start, re-click restarts; Stop button (right of name) — stops current playback\",\n            \"volumeControl\": \"Per-sound volume slider, visible on hover or when row is selected\",\n            \"enabledToggle\": \"Per-sound enabled checkbox/toggle\",\n            \"missingIndicator\": \"If file is in manifest but not found on disk, show a red broken-link icon on the row\",\n            \"noUnassignedVisualDistinction\": \"Unassigned sounds look identical to assigned ones in the left column\"\n          },\n          \"dragBehavior\": \"Each sound row is draggable. During drag, a ghost chip follows the cursor.\"\n        },\n        \"rightColumn\": {\n          \"label\": \"Events\",\n          \"content\": \"Fixed list of all 16 AgentEventType values\",\n          \"emptyEventDisplay\": \"All 16 events always visible. Events with no assigned sounds are visually de-emphasized (dimmed text, lighter background).\",\n          \"eventRow\": {\n            \"layout\": \"Event name label on left, chip area on right showing assigned sounds\",\n            \"chips\": \"Each assigned sound appears as a small removable chip with the filename. Click chip to preview that sound. × button to remove assignment (unlinks only — does not delete file).\",\n            \"liveHighlight\": \"When a real agent event fires while the dialog is open, the corresponding event row briefly flashes/highlights\"\n          },\n          \"dropTarget\": \"Each event row is a valid drop target for sound items from the left column. Highlights on hover during drag.\"\n        }\n      }\n    },\n    \"assignmentInteraction\": {\n      \"addAssignment\": [\n        \"Drag sound from left column → drop onto event row in right column\",\n        \"Drag chip from event row → drop onto a different sound in left column (re-assignment: removes from old sound, adds new)\"\n      ],\n      \"removeAssignment\": \"Click × on chip in event row. File stays in pack, only the assignment is removed.\",\n      \"duplicateAssignment\": \"Silently ignored — if (file, event) pair already exists, do nothing.\",\n      \"dragFeedback\": \"Ghost chip follows cursor during drag. Valid drop targets highlight on hover. Invalid drop zones show no highlight.\"\n    },\n    \"packCreation\": {\n      \"flow\": \"Click + button in pack sidebar → pack created immediately with generated name (e.g. 'New Pack') → name field enters inline edit mode, cursor placed in field → user types name → Enter or blur confirms\",\n      \"manifestInit\": \"New pack gets an empty manifest.json written immediately on creation\"\n    },\n    \"autosave\": \"Every change (assignment add/remove, volume change, enabled toggle, file add) triggers an immediate write to manifest.json and/or config.json. No save button. No confirmation.\"\n  },\n  \"migration\": {\n    \"oldPacksOnDisk\": \"Packs with the old folder-per-event-type structure (no manifest.json) remain readable but are not automatically migrated. The UI shows a 'Migrate to new format' button in the pack list context menu for such packs, which generates a manifest.json from the folder structure and moves audio files to the pack root.\",\n    \"configMigration\": \"On first load, if config.json contains the old 'tracks' key, it is read as-is for backward compatibility. When any write occurs, it is migrated to 'soundOverrides' format automatically.\"\n  },\n  \"userStories\": [\n    {\n      \"id\": \"US-001\",\n      \"title\": \"manifest.json schema + read/write in soundStore\",\n      \"description\": \"As a developer, I need the soundStore to read and write manifest.json from each pack directory so the patchbay has a persistent source of truth.\",\n      \"acceptanceCriteria\": [\n        \"PackManifest TypeScript interface: { sounds: Array<{ file: string, volume: number, enabled: boolean }>, assignments: Array<{ file: string, event: AgentEventType }> }\",\n        \"soundStore.loadPackManifest(packName) reads manifest.json from pack directory; returns empty manifest if file missing\",\n        \"soundStore.savePackManifest(packName, manifest) writes manifest.json to pack directory\",\n        \"soundStore.scanPacks() updated: scans pack directories for audio files AND reads manifest.json; PackInfo includes manifest data\",\n        \"vue-tsc -b passes\"\n      ],\n      \"priority\": 1\n    },\n    {\n      \"id\": \"US-002\",\n      \"title\": \"config.json migration — soundOverrides replaces tracks\",\n      \"description\": \"As a developer, I need the config schema updated to store per-sound overrides by pack/filename key instead of category/filename.\",\n      \"acceptanceCriteria\": [\n        \"SoundConfig.soundOverrides: Record<string, { volume: number, enabled: boolean }> where key is '<packName>/<filename>'\",\n        \"Old SoundConfig.tracks key still accepted on read (backward compat); migrated to soundOverrides on next write\",\n        \"effectiveVolume and isEnabled resolution follows the two-layer rule: soundOverrides → manifest default\",\n        \"vue-tsc -b passes\"\n      ],\n      \"priority\": 1\n    },\n    {\n      \"id\": \"US-003\",\n      \"title\": \"playForEvent updated for manifest-based lookup\",\n      \"description\": \"As a user, I want sounds to play based on manifest assignments so my patchbay configuration is reflected in runtime audio.\",\n      \"acceptanceCriteria\": [\n        \"playForEvent(event) looks up active pack for session → reads manifest.assignments filtered by event.type → collects enabled files → picks random → plays\",\n        \"Volume resolved via two-layer rule (US-002)\",\n        \"Missing file (in manifest but not on disk) is skipped with a console warning — no crash\",\n        \"Per-event cooldown still applies\",\n        \"vue-tsc -b passes\"\n      ],\n      \"priority\": 2\n    },\n    {\n      \"id\": \"US-004\",\n      \"title\": \"SoundsDialog — patchbay split view layout\",\n      \"description\": \"As a user, I want the SoundsDialog content area to show a two-column patchbay so I can see sounds and events side by side.\",\n      \"acceptanceCriteria\": [\n        \"Dialog content area (right of pack sidebar) splits into two equal columns\",\n        \"Left column header: 'Sounds', right column header: 'Events'\",\n        \"Right column shows all 16 AgentEventType values as rows\",\n        \"Event rows with no assignments are visually dimmed (reduced opacity or lighter text)\",\n        \"Event rows with assignments are full-opacity\",\n        \"Pack sidebar and context menu unchanged\",\n        \"vue-tsc -b passes\"\n      ],\n      \"priority\": 3\n    },\n    {\n      \"id\": \"US-005\",\n      \"title\": \"Left column — sound file list with inline preview\",\n      \"description\": \"As a user, I want to see all audio files in the selected pack and preview them inline.\",\n      \"acceptanceCriteria\": [\n        \"Left column lists all files from manifest.sounds for selected pack\",\n        \"Each row shows: play button (left), raw filename, stop button (right)\",\n        \"Click play: loads and plays audio from start; if already playing, restarts from start\",\n        \"Click stop: stops current playback\",\n        \"Per-sound volume slider visible on hover\",\n        \"Per-sound enabled toggle (checkbox or switch) on each row\",\n        \"Changes to volume/enabled autosave: update manifest.sounds entry + write manifest.json\",\n        \"Missing file (in manifest but not on disk) shows red broken-link icon on row\",\n        \"vue-tsc -b passes\"\n      ],\n      \"priority\": 3\n    },\n    {\n      \"id\": \"US-006\",\n      \"title\": \"Right column — event rows with sound chips\",\n      \"description\": \"As a user, I want each event row to show which sounds are assigned as removable chips.\",\n      \"acceptanceCriteria\": [\n        \"Each event row shows chips for all assigned sound files\",\n        \"Chip label: truncated filename (max ~20 chars with ellipsis)\",\n        \"Chip has × button; click × removes the (file, event) assignment from manifest and autosaves\",\n        \"Click chip body (not ×) plays a preview of that sound inline\",\n        \"Live highlight: when AgentEvent fires matching an event type while dialog is open, that event row briefly flashes (200ms highlight animation)\",\n        \"vue-tsc -b passes\"\n      ],\n      \"priority\": 4\n    },\n    {\n      \"id\": \"US-007\",\n      \"title\": \"Drag sound from left column to event row\",\n      \"description\": \"As a user, I want to drag a sound file and drop it onto an event row to create an assignment.\",\n      \"acceptanceCriteria\": [\n        \"Sound rows in left column are draggable (HTML5 drag API or equivalent)\",\n        \"During drag: ghost chip (translucent copy of filename chip) follows cursor\",\n        \"During drag: valid drop targets (event rows) highlight on hover\",\n        \"Drop onto event row: adds (file, event) to manifest.assignments if not already present; autosaves\",\n        \"Drop on duplicate (same file already assigned to same event): silently ignored, no feedback\",\n        \"Drop outside valid target: no change\",\n        \"vue-tsc -b passes\"\n      ],\n      \"priority\": 4\n    },\n    {\n      \"id\": \"US-008\",\n      \"title\": \"Drag chip from event row to re-assign to different sound\",\n      \"description\": \"As a user, I want to drag an assignment chip from an event row and drop it onto a different sound in the left column to re-assign it.\",\n      \"acceptanceCriteria\": [\n        \"Assignment chips in right column are draggable\",\n        \"During drag: ghost chip follows cursor; left column sound rows highlight as valid targets\",\n        \"Drop onto sound row: removes old (originalFile, event) assignment, adds (newFile, event) assignment; autosaves\",\n        \"Drop onto same sound row (no-op): silently ignored\",\n        \"Drop outside valid target: no change, assignment remains\",\n        \"vue-tsc -b passes\"\n      ],\n      \"priority\": 5\n    },\n    {\n      \"id\": \"US-009\",\n      \"title\": \"Add audio files to pack — drag from Finder + file picker\",\n      \"description\": \"As a user, I want to add new audio files to a pack via drag-and-drop or file picker.\",\n      \"acceptanceCriteria\": [\n        \"Left column accepts file drag from OS (dragover + drop on column area)\",\n        \"Dropped audio files (wav/mp3/ogg/flac/m4a/webm) are copied to pack directory root\",\n        \"Dropped files are added to manifest.sounds with defaults: volume 1.0, enabled true\",\n        \"Manifest autosaved after file add\",\n        \"'Add file' button above left column opens Tauri file picker (dialog plugin); selected files go through same flow\",\n        \"Non-audio files dropped/selected are silently ignored or shown a brief error\",\n        \"vue-tsc -b passes\"\n      ],\n      \"priority\": 5\n    },\n    {\n      \"id\": \"US-010\",\n      \"title\": \"Pack creation — immediate create with inline rename\",\n      \"description\": \"As a user, I want to create a new pack that appears immediately with an editable name.\",\n      \"acceptanceCriteria\": [\n        \"Clicking + in pack sidebar creates a pack directory with generated name ('New Pack', 'New Pack 2', etc.)\",\n        \"Empty manifest.json written to new pack directory immediately\",\n        \"Pack name field enters inline edit mode with cursor focused\",\n        \"Enter or blur confirms name; renames directory on disk\",\n        \"Escape cancels and deletes the newly created pack (since it's empty and user aborted naming)\",\n        \"vue-tsc -b passes\"\n      ],\n      \"priority\": 5\n    },\n    {\n      \"id\": \"US-011\",\n      \"title\": \"ZIP import — manifest.json required\",\n      \"description\": \"As a user, I want to import sound packs from ZIP files that use the new manifest format.\",\n      \"acceptanceCriteria\": [\n        \"ZIP import reads manifest.json from pack root inside ZIP\",\n        \"If manifest.json is absent, import fails with error message: 'This ZIP does not contain a manifest.json. Please use the new pack format.'\",\n        \"Audio files are extracted to pack directory root (not into subdirectories)\",\n        \"manifest.json is written to pack directory\",\n        \"Pack appears in sidebar after import\",\n        \"vue-tsc -b passes\"\n      ],\n      \"priority\": 6\n    },\n    {\n      \"id\": \"US-012\",\n      \"title\": \"Old pack migration — 'Migrate to new format' in context menu\",\n      \"description\": \"As a user, I want to migrate old folder-structured packs to the new manifest format without losing my configuration.\",\n      \"acceptanceCriteria\": [\n        \"Packs without manifest.json detected on scan; labeled with a migration indicator in the sidebar\",\n        \"Pack context menu shows 'Migrate to new format' option for old-style packs\",\n        \"Migration: reads all audio files from subdirectories, creates assignments from folder names (folder name → event type), moves files to pack root, writes manifest.json, removes old subdirectories\",\n        \"After migration, indicator removed and pack is fully functional in patchbay\",\n        \"vue-tsc -b passes\"\n      ],\n      \"priority\": 6\n    }\n  ]\n}\n","numLines":310,"startLine":1,"totalLines":310}}}
