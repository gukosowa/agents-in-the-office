→\n   202→    const dirExists = await exists(soundPacksDir);\n   203→    if (!dirExists) return discovered;\n   204→\n   205→    const entries = await readDir(soundPacksDir);\n   206→    for (const entry of entries) {\n   207→      if (!entry.isDirectory) continue;\n   208→      if (entry.name === undefined || entry.name.startsWith('.')) continue;\n   209→      const packName = entry.name;\n   210→      const packPath = `${soundPacksDir}/${packName}`;\n   211→      const categories: Record<string, string[]> = {};\n   212→\n   213→      const manifest = await loadPackManifest(packName);\n   214→      const hasManifest = await exists(`${packPath}/manifest.json`);\n   215→\n   216→      const catEntries = await readDir(packPath);\n   217→      for (const cat of catEntries) {\n   218→        if (!cat.isDirectory) continue;\n   219→        if (cat.name === undefined || cat.name.startsWith('.')) continue;\n   220→        const catName = cat.name;\n   221→        const catPath = `${packPath}/${catName}`;\n   222→        const fileEntries = await readDir(catPath);\n   223→        const audioFiles = fileEntries\n   224→          .filter((f) => !f.isDirectory && f.name !== undefined && hasAudioExtension(f.name))\n   225→          .map((f) => f.name as string);\n   226→        if (audioFiles.length > 0 || AGENT_EVENT_TYPES.includes(catName as AgentEventType)) {\n   227→          categories[catName] = audioFiles.sort();\n   228→        }\n   229→      }\n   230→\n   231→      for (const eventType of AGENT_EVENT_TYPES) {\n   232→        if (!(eventType in categories)) {\n   233→          categories[eventType] = [];\n   234→        }\n   235→      }\n   236→\n   237→      discovered.push({ name: packName, categories, manifest, hasManifest });\n   238→    }\n   239→\n   240→    packs.value = discovered;\n   241→    return discovered;\n   242→  }\n   243→\n   244→  // -------------------------------------------------------------------------\n   245→  // Sound override helpers (two-layer: soundOverrides → manifest default)\n   246→  // -------------------------------------------------------------------------\n   247→\n   248→  /** Extract filename from \"category/filename\" or plain \"filename\" key. */\n   249→  function extractFilename(categoryAndFile: string): string {\n   250→    const slashIdx = categoryAndFile.indexOf('/');\n   251→    return slashIdx >= 0 ? categoryAndFile.slice(slashIdx + 1) : categoryAndFile;\n   252→  }\n   253→\n   254→  /**\n   255→   * Effective volume for a sound: soundOverrides → manifest default → 1.0\n   256→   */\n   257→  function effectiveVolume(packName: string, filename: string, manifestSound?: PackManifestSound): number {\n   258→    const override = config.value.soundOverrides[`${packName}/${filename}`];\n   259→    if (override !== undefined) return override.volume;\n   260→    return manifestSound?.volume ?? 1.0;\n   261→  }\n   262→\n   263→  /**\n   264→   * Effective enabled state: soundOverrides → manifest default → true\n   265→   */\n   266→  function isEnabled(packName: string, filename: string, manifestSound?: PackManifestSound): boolean {\n   267→    const override = config.value.soundOverrides[`${packName}/${filename}`];\n   268→    if (override !== undefined) return override.enabled;\n   269→    return manifestSound?.enabled ?? true;\n   270→  }\n   271→\n   272→  /**\n   273→   * Get track config for a sound. Accepts legacy \"category/filename\" key format.\n   274→   * Reads from soundOverrides using packName/filename key.\n   275→   */\n   276→  function getTrackConfig(packName: string, categoryAndFile: string): TrackConfig {\n   277→    const filename = extractFilename(categoryAndFile);\n   278→    const override = config.value.soundOverrides[`${packName}/${filename}`];\n   279→    return override ?? { enabled: true, volume: 1.0 };\n   280→  }\n   281→\n   282→  /**\n   283→   * Set track config for a sound. Accepts legacy \"category/filename\" key format.\n   284→   * Writes to soundOverrides using packName/filename key.\n   285→   */\n   286→  function setTrackConfig(packName: string, categoryAndFile: string, track: TrackConfig): void {\n   287→    const filename = extractFilename(categoryAndFile);\n   288→    config.value.soundOverrides[`${packName}/${filename}`] = track;\n   289→  }\n   290→\n   291→  function getSoundPacksDir(): string {\n   292→    return soundPacksDir;\n   293→  }\n   294→\n   295→  function getSessionPack(sessionId: string): string | undefined {\n   296→    return sessionPacks.get(sessionId);\n   297→  }\n   298→\n   299→  function assignSessionPack(sessionId: string, preferredPacks: string[]): void {\n   300→    const pool = preferredPacks.length > 0 ? preferredPacks : config.value.activePacks;\n   301→    if (pool.length === 0) return;\n   302→    const chosen = pool[Math.floor(Math.random() * pool.length)];\n   303→    if (chosen !== undefined) {\n   304→      sessionPacks.set(sessionId, chosen);\n   305→    }\n   306→  }\n   307→\n   308→  // -------------------------------------------------------------------------\n   309→  // AudioContext helpers\n   310→  // -------------------------------------------------------------------------\n   311→\n   312→  function getAudioContext(): AudioContext {\n   313→    if (!audioCtx) {\n   314→      audioCtx = new AudioContext();\n   315→    }\n   316→    return audioCtx;\n   317→  }\n   318→\n   319→  async function loadBuffer(filePath: string): Promise<AudioBuffer | null> {\n   320→    const cached = bufferCache.get(filePath);\n   321→    if (cached !== undefined) return cached;\n   322→\n   323→    try {\n   324→      const bytes = await readFile(filePath);\n   325→      const ctx = getAudioContext();\n   326→      const buffer = await ctx.decodeAudioData(bytes.buffer as ArrayBuffer);\n   327→      bufferCache.set(filePath, buffer);\n   328→      return buffer;\n   329→    } catch (err) {\n   330→      console.warn(`[soundStore] Failed to decode audio: ${filePath}`, err);\n   331→      return null;\n   332→    }\n   333→  }\n   334→\n   335→  // -------------------------------------------------------------------------\n   336→  // Playback engine\n   337→  // -------------------------------------------------------------------------\n   338→\n   339→  async function playForEvent(event: AgentEvent): Promise<void> {\n   340→    if (!config.value.enabled) return;\n   341→\n   342→    // Session pack assignment on session_start\n   343→    if (event.type === 'session_start') {\n   344→      const { activePacks } = config.value;\n   345→      if (activePacks.length > 0) {\n   346→        const randomIdx = Math.floor(Math.random() * activePacks.length);\n   347→        const chosen = activePacks[randomIdx];\n   348→        if (chosen !== undefined) {\n   349→          sessionPacks.set(event.sessionId, chosen);\n   350→        }\n   351→      }\n   352→    }\n   353→\n   354→    const packName = sessionPacks.get(event.sessionId);\n   355→    if (!packName) return;\n   356→\n   357→    const category = event.type;\n   358→    const now = Date.now();\n   359→    const cooldownMs = config.value.cooldownSeconds * 1000;\n   360→    const lastPlayed = cooldownMap.get(category) ?? 0;\n   361→    if (now - lastPlayed < cooldownMs) return;\n   362→\n   363→    if (playing) return;\n   364→\n   365→    // Find the pack info\n   366→    const packInfo = packs.value.find((p) => p.name === packName);\n   367→    const files = packInfo?.categories[category] ?? [];\n   368→\n   369→    // Filter to enabled tracks\n   370→    const enabledFiles = files.filter((filename) => {\n   371→      const key = `${category}/${filename}`;\n   372→      return getTrackConfig(packName, key).enabled;\n   373→    });\n   374→\n   375→    if (enabledFiles.length === 0) return;\n   376→\n   377→    const randomFileIdx = Math.floor(Math.random() * enabledFiles.length);\n   378→    const chosenFile = enabledFiles[randomFileIdx];\n   379→    if (chosenFile === undefined) return;\n   380→\n   381→    const filePath = `${soundPacksDir}/${packName}/${category}/${chosenFile}`;\n   382→    const buffer = await loadBuffer(filePath);\n   383→    if (!buffer) return;\n   384→\n   385→    const trackKey = `${category}/${chosenFile}`;\n   386→    const trackCfg = getTrackConfig(packName, trackKey);\n   387→    const ctx = getAudioContext();\n   388→\n   389→    const gainNode = ctx.createGain();\n   390→    gainNode.gain.value = config.value.globalVolume * trackCfg.volume;\n   391→    gainNode.connect(ctx.destination);\n   392→\n   393→    const source = ctx.createBufferSource();\n   394→    source.buffer = buffer;\n   395→    source.connect(gainNode);\n   396→\n   397→    playing = true;\n   398→    cooldownMap.set(category, now);\n   399→    lastPlayedSessionId.value = event.sessionId;\n   400→\n   401→    source.onended = () => {\n   402→      playing = false;\n   403→    };\n   404→\n   405→    source.start();\n   406→  }\n   407→\n   408→  // -------------------------------------------------------------------------\n   409→  // Public AudioContext access (for AudioPlayer.vue)\n   410→  // -------------------------------------------------------------------------\n   411→\n   412→  function getOrCreateAudioContext(): AudioContext {\n   413→    return getAudioContext();\n   414→  }\n   415→\n   416→  function getBufferCache(): Map<string, AudioBuffer> {\n   417→    return bufferCache;\n   418→  }\n   419→\n   420→  return {\n   421→    config,\n   422→    packs,\n   423→    lastPlayedSessionId,\n   424→    init,\n   425→    saveConfig,\n   426→    scanPacks,\n   427→    loadPackManifest,\n   428→    savePackManifest,\n   429→    getTrackConfig,\n   430→    setTrackConfig,\n   431→    effectiveVolume,\n   432→    isEnabled,\n   433→    getSoundPacksDir,\n   434→    playForEvent,\n   435→    getOrCreateAudioContext,\n   436→    getBufferCache,\n   437→    loadBuffer,\n   438→    getSessionPack,\n   439→    assignSessionPack,\n   440→  };\n   441→});\n   