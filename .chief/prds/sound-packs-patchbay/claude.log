{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01MNP7Hk8p3iMJ1afGbnicsA","type":"tool_result","content":"     1→<script setup lang=\"ts\">\n     2→import {\n     3→  ref,\n     4→  computed,\n     5→  watch,\n     6→  nextTick,\n     7→  onMounted,\n     8→  onUnmounted,\n     9→} from 'vue';\n    10→import { listen } from '@tauri-apps/api/event';\n    11→import type { UnlistenFn } from '@tauri-apps/api/event';\n    12→import { open } from '@tauri-apps/plugin-dialog';\n    13→import {\n    14→  mkdir,\n    15→  readFile,\n    16→  writeFile,\n    17→  exists,\n    18→} from '@tauri-apps/plugin-fs';\n    19→import JSZip from 'jszip';\n    20→import { useSoundStore, AGENT_EVENT_TYPES } from '../stores/soundStore';\n    21→import type { PackManifestSound } from '../stores/soundStore';\n    22→import type { AgentEvent, AgentEventType } from '../drivers/types';\n    23→import PackContextMenu from './PackContextMenu.vue';\n    24→\n    25→const emit = defineEmits<{ close: [] }>();\n    26→\n    27→const soundStore = useSoundStore();\n    28→\n    29→// ---- Global settings ----\n    30→const globalEnabled = computed({\n    31→  get: () => soundStore.config.enabled,\n    32→  set: (v: boolean) => { soundStore.config.enabled = v; void soundStore.saveConfig(); },\n    33→});\n    34→const globalVolume = computed({\n    35→  get: () => Math.round(soundStore.config.globalVolume * 100),\n    36→  set: (v: number) => { soundStore.config.globalVolume = v / 100; void soundStore.saveConfig(); },\n    37→});\n    38→const cooldown = computed({\n    39→  get: () => soundStore.config.cooldownSeconds,\n    40→  set: (v: number) => { soundStore.config.cooldownSeconds = v; void soundStore.saveConfig(); },\n    41→});\n    42→\n    43→// ---- Pack list ----\n    44→const selectedPack = ref<string | null>(null);\n    45→const rightPanel = ref<HTMLElement | null>(null);\n    46→\n    47→onMounted(async () => {\n    48→  await soundStore.init();\n    49→  await soundStore.scanPacks();\n    50→  if (soundStore.packs.length > 0 && soundStore.packs[0]) {\n    51→    selectedPack.value = soundStore.packs[0].name;\n    52→  }\n    53→  agentEventUnlisten = await listen<string>(\n    54→    'agent-event',\n    55→    (e) => {\n    56→      try {\n    57→        const parsed = JSON.parse(e.payload) as AgentEvent;\n    58→        flashEventRow(parsed.type);\n    59→      } catch { /* ignore parse errors */ }\n    60→    },\n    61→  );\n    62→});\n    63→\n    64→onUnmounted(() => {\n    65→  if (agentEventUnlisten) agentEventUnlisten();\n    66→  if (flashTimeout) clearTimeout(flashTimeout);\n    67→});\n    68→\n    69→function isPackActive(packName: string): boolean {\n    70→  return soundStore.config.activePacks.includes(packName);\n    71→}\n    72→\n    73→function togglePackActive(packName: string, active: boolean) {\n    74→  if (active) {\n    75→    if (!soundStore.config.activePacks.includes(packName)) {\n    76→      soundStore.config.activePacks.push(packName);\n    77→    }\n    78→  } else {\n    79→    soundStore.config.activePacks = soundStore.config.activePacks.filter(\n    80→      (p) => p !== packName,\n    81→    );\n    82→  }\n    83→  void soundStore.saveConfig();\n    84→}\n    85→\n    86→function selectPack(name: string) {\n    87→  selectedPack.value = name;\n    88→  void nextTick(() => {\n    89→    if (rightPanel.value) rightPanel.value.scrollTop = 0;\n    90→  });\n    91→}\n    92→\n    93→// ---- Context menu ----\n    94→const ctxMenu = ref<{ packName: string; x: number; y: number } | null>(null);\n    95→\n    96→function onPackRightClick(e: MouseEvent, packName: string) {\n    97→  e.preventDefault();\n    98→  ctxMenu.value = { packName, x: e.clientX, y: e.clientY };\n    99→}\n   100→\n   101→function closeCtxMenu() {\n   102→  ctxMenu.value = null;\n   103→}\n   104→\n   105→async function onPackRenamed(oldName: string, newName: string) {\n   106→  await soundStore.scanPacks();\n   107→  if (selectedPack.value === oldName) selectedPack.value = newName;\n   108→  closeCtxMenu();\n   109→}\n   110→\n   111→async function onPackDuplicated() {\n   112→  await soundStore.scanPacks();\n   113→  closeCtxMenu();\n   114→}\n   115→\n   116→async function onPackDeleted(name: string) {\n   117→  await soundStore.scanPacks();\n   118→  if (selectedPack.value === name) {\n   119→    selectedPack.value = soundStore.packs[0]?.name ?? null;\n   120→  }\n   121→  closeCtxMenu();\n   122→}\n   123→\n   124→// ---- New pack ----\n   125→const newPackName = ref('');\n   126→const creatingPack = ref(false);\n   127→const newPackInput = ref<HTMLInputElement | null>(null);\n   128→\n   129→function startCreatePack() {\n   130→  creatingPack.value = true;\n   131→  newPackName.value = '';\n   132→  void nextTick(() => newPackInput.value?.focus());\n   133→}\n   134→\n   135→function cancelCreatePack() {\n   136→  creatingPack.value = false;\n   137→  newPackName.value = '';\n   138→}\n   139→\n   140→async function confirmCreatePack() {\n   141→  const packName = newPackName.value.trim();\n   142→  if (!packName) return;\n   143→  creatingPack.value = false;\n   144→  newPackName.value = '';\n   145→  const baseDir = soundStore.getSoundPacksDir();\n   146→  const packPath = `${baseDir}/${packName}`;\n   147→  try {\n   148→    await mkdir(packPath, { recursive: true });\n   149→    for (const eventType of AGENT_EVENT_TYPES) {\n   150→      await mkdir(`${packPath}/${eventType}`, { recursive: true });\n   151→    }\n   152→    await soundStore.scanPacks();\n   153→    selectedPack.value = packName;\n   154→  } catch (err) {\n   155→    console.error('[SoundsDialog] createNewPack failed', err);\n   156→  }\n   157→}\n   158→\n   159→// ---- Import zip ----\n   160→const dragOver = ref(false);\n   161→\n   162→async function importZipBytes(filename: string, bytes: Uint8Array): Promise<void> {\n   163→  const dotIdx = filename.lastIndexOf('.');\n   164→  const packName = dotIdx > 0 ? filename.slice(0, dotIdx) : filename;\n   165→  const baseDir = soundStore.getSoundPacksDir();\n   166→  const packPath = `${baseDir}/${packName}`;\n   167→\n   168→  const zip = await JSZip.loadAsync(bytes);\n   169→  for (const [relativePath, file] of Object.entries(zip.files)) {\n   170→    if (file.dir) {\n   171→      await mkdir(`${packPath}/${relativePath}`, { recursive: true });\n   172→    } else {\n   173→      const data = await file.async('uint8array');\n   174→      const dirPart = relativePath.includes('/')\n   175→        ? relativePath.slice(0, relativePath.lastIndexOf('/'))\n   176→        : '';\n   177→      if (dirPart) {\n   178→        await mkdir(`${packPath}/${dirPart}`, { recursive: true });\n   179→      }\n   180→      await writeFile(`${packPath}/${relativePath}`, data);\n   181→    }\n   182→  }\n   183→\n   184→  await soundStore.scanPacks();\n   185→  selectedPack.value = packName;\n   186→}\n   187→\n   188→async function openImportPicker() {\n   189→  const result = await open({\n   190→    filters: [{ name: 'ZIP', extensions: ['zip'] }],\n   191→    multiple: false,\n   192→  });\n   193→  if (!result) return;\n   194→  const filePath = typeof result === 'string' ? result : result;\n   195→  if (!filePath) return;\n   196→  try {\n   197→    const bytes = await readFile(filePath);\n   198→    const filename = (filePath as string).split('/').pop() ?? 'pack.zip';\n   199→    await importZipBytes(filename, bytes);\n   200→  } catch (err) {\n   201→    console.error('[SoundsDialog] import failed', err);\n   202→  }\n   203→}\n   204→\n   205→function onDragOver(e: DragEvent) {\n   206→  e.preventDefault();\n   207→  dragOver.value = true;\n   208→}\n   209→\n   210→function onDragLeave() {\n   211→  dragOver.value = false;\n   212→}\n   213→\n   214→async function onDrop(e: DragEvent) {\n   215→  e.preventDefault();\n   216→  dragOver.value = false;\n   217→  const file = e.dataTransfer?.files[0];\n   218→  if (!file) return;\n   219→  try {\n   220→    const arrayBuffer = await file.arrayBuffer();\n   221→    await importZipBytes(file.name, new Uint8Array(arrayBuffer));\n   222→  } catch (err) {\n   223→    console.error('[SoundsDialog] drop import failed', err);\n   224→  }\n   225→}\n   226→\n   227→// ---- Event descriptions ----\n   228→const EVENT_DESCRIPTIONS: Record<string, string> = {\n   229→  session_start: 'Agent session begins.',\n   230→  session_end: 'Agent session ends or is interrupted.',\n   231→  prompt_submit: 'User submits a prompt to the agent.',\n   232→  tool_start: 'Agent begins executing a tool (e.g. Bash, Read, Edit).',\n   233→  tool_end: 'Agent finishes executing a tool.',\n   234→  turn_end: 'Agent completes a full response turn.',\n   235→  permission_wait: 'Agent pauses waiting for the user to approve a tool call.',\n   236→  subagent_start: 'A subagent is spawned by the parent agent.',\n   237→  subagent_end: 'A subagent finishes its work.',\n   238→  idle_notification: 'Agent has been idle and sends a nudge notification.',\n   239→  elicitation_wait: 'Agent pauses waiting for user input.',\n   240→  auth_success: 'Authentication to an external service succeeds.',\n   241→  worktree_create: 'A new git worktree is created.',\n   242→  worktree_remove: 'A git worktree is removed.',\n   243→  teammate_idle: \"A teammate's agent session goes idle.\",\n   244→  task_completed: 'Agent marks a task as completed.',\n   245→};\n   246→\n   247→const activeInfoPopover = ref<string | null>(null);\n   248→\n   249→function toggleInfoPopover(eventType: string) {\n   250→  activeInfoPopover.value = activeInfoPopover.value === eventType ? null : eventType;\n   251→}\n   252→\n   253→// ---- Patchbay data ----\n   254→const selectedPackInfo = computed(() =>\n   255→  soundStore.packs.find((p) => p.name === selectedPack.value) ?? null,\n   256→);\n   257→\n   258→function hasAssignments(eventType: AgentEventType): boolean {\n   259→  if (!selectedPackInfo.value) return false;\n   260→  return selectedPackInfo.value.manifest.assignments.some((a) => a.event === eventType);\n   261→}\n   262→\n   263→// ---- Sound preview (left column) ----\n   264→let previewSource: AudioBufferSourceNode | null = null;\n   265→const previewFile = ref<string | null>(null);\n   266→const soundFileExists = ref<Map<string, boolean>>(new Map());\n   267→const hoveredSoundFile = ref<string | null>(null);\n   268→\n   269→async function checkSoundFileExistence(packName: string): Promise<void> {\n   270→  const sounds = selectedPackInfo.value?.manifest.sounds ?? [];\n   271→  const baseDir = soundStore.getSoundPacksDir();\n   272→  const newMap = new Map<string, boolean>();\n   273→  await Promise.all(\n   274→    sounds.map(async (sound) => {\n   275→      const filePath = `${baseDir}/${packName}/${sound.file}`;\n   276→      const fileExists = await exists(filePath);\n   277→      newMap.set(sound.file, fileExists);\n   278→    }),\n   279→  );\n   280→  soundFileExists.value = newMap;\n   281→}\n   282→\n   283→function stopPreview(): void {\n   284→  if (previewSource) {\n   285→    try { previewSource.stop(); } catch { /* already stopped */ }\n   286→    previewSource = null;\n   287→  }\n   288→  previewFile.value = null;\n   289→}\n   290→\n   291→async function playPreview(filename: string): Promise<void> {\n   292→  if (!selectedPack.value) return;\n   293→  stopPreview();\n   294→  const baseDir = soundStore.getSoundPacksDir();\n   295→  const filePath = `${baseDir}/${selectedPack.value}/${filename}`;\n   296→  const buffer = await soundStore.loadBuffer(filePath);\n   297→  if (!buffer) return;\n   298→  const ctx = soundStore.getOrCreateAudioContext();\n   299→  const sound = selectedPackInfo.value?.manifest.sounds.find((s) => s.file === filename);\n   300→  const gainNode = ctx.createGain();\n   301→  gainNode.gain.value =\n   302→    soundStore.config.globalVolume * soundStore.effectiveVolume(selectedPack.value, filename, sound);\n   303→  gainNode.connect(ctx.destination);\n   304→  const source = ctx.createBufferSource();\n   305→  source.buffer = buffer;\n   306→  source.connect(gainNode);\n   307→  previewFile.value = filename;\n   308→  previewSource = source;\n   309→  source.onended = () => {\n   310→    if (previewFile.value === filename) {\n   311→      previewFile.value = null;\n   312→      previewSource = null;\n   313→    }\n   314→  };\n   315→  source.start();\n   316→}\n   317→\n   318→async function updateSoundVolume(sound: PackManifestSound, volume: number): Promise<void> {\n   319→  if (!selectedPack.value || !selectedPackInfo.value) return;\n   320→  sound.volume = volume;\n   321→  await soundStore.savePackManifest(selectedPack.value, selectedPackInfo.value.manifest);\n   322→}\n   323→\n   324→async function updateSoundEnabled(sound: PackManifestSound, enabled: boolean): Promise<void> {\n   325→  if (!selectedPack.value || !selectedPackInfo.value) return;\n   326→  sound.enabled = enabled;\n   327→  await soundStore.savePackManifest(selectedPack.value, selectedPackInfo.value.manifest);\n   328→}\n   329→\n   330→// ---- Assignment chips (right column) ----\n   331→function assignmentsForEvent(eventType: AgentEventType): string[] {\n   332→  if (!selectedPackInfo.value) return [];\n   333→  return selectedPackInfo.value.manifest.assignments\n   334→    .filter((a) => a.event === eventType)\n   335→    .map((a) => a.file);\n   336→}\n   337→\n   338→function truncateFilename(name: string, max = 20): string {\n   339→  if (name.length <= max) return name;\n   340→  return name.slice(0, max - 1) + '\\u2026';\n   341→}\n   342→\n   343→async function removeAssignment(\n   344→  file: string,\n   345→  eventType: AgentEventType,\n   346→): Promise<void> {\n   347→  if (!selectedPack.value || !selectedPackInfo.value) return;\n   348→  const manifest = selectedPackInfo.value.manifest;\n   349→  manifest.assignments = manifest.assignments.filter(\n   350→    (a) => !(a.file === file && a.event === eventType),\n   351→  );\n   352→  await soundStore.savePackManifest(selectedPack.value, manifest);\n   353→}\n   354→\n   355→// ---- Drag-and-drop: sound → event row ----\n   356→const draggingSoundFile = ref<string | null>(null);\n   357→const dragOverEventType = ref<AgentEventType | null>(null);\n   358→\n   359→// ---- Drag-and-drop: chip → sound row (re-assign) ----\n   360→const draggingChip = ref<{ file: string; event: AgentEventType } | null>(null);\n   361→const dragOverSoundFile = ref<string | null>(null);\n   362→\n   363→function onSoundDragStart(e: DragEvent, filename: string): void {\n   364→  draggingSoundFile.value = filename;\n   365→  if (e.dataTransfer) {\n   366→    e.dataTransfer.effectAllowed = 'copy';\n   367→    e.dataTransfer.setData('text/plain', filename);\n   368→  }\n   369→}\n   370→\n   371→function onSoundDragEnd(): void {\n   372→  draggingSoundFile.value = null;\n   373→  dragOverEventType.value = null;\n   374→}\n   375→\n   376→function onEventDragOver(e: DragEvent, eventType: AgentEventType): void {\n   377→  if (!draggingSoundFile.value) return;\n   378→  e.preventDefault();\n   379→  if (e.dataTransfer) e.dataTransfer.dropEffect = 'copy';\n   380→  dragOverEventType.value = eventType;\n   381→}\n   382→\n   383→function onEventDragLeaveRow(): void {\n   384→  dragOverEventType.value = null;\n   385→}\n   386→\n   387→async function onEventDrop(\n   388→  e: DragEvent,\n   389→  eventType: AgentEventType,\n   390→): Promise<void> {\n   391→  e.preventDefault();\n   392→  dragOverEventType.value = null;\n   393→  const file = draggingSoundFile.value;\n   394→  draggingSoundFile.value = null;\n   395→  if (!file) return;\n   396→  await addAssignment(file, eventType);\n   397→}\n   398→\n   399→async function addAssignment(\n   400→  file: string,\n   401→  eventType: AgentEventType,\n   402→): Promise<void> {\n   403→  if (!selectedPack.value || !selectedPackInfo.value) return;\n   404→  const manifest = selectedPackInfo.value.manifest;\n   405→  const alreadyExists = manifest.assignments.some(\n   406→    (a) => a.file === file && a.event === eventType,\n   407→  );\n   408→  if (alreadyExists) return;\n   409→  manifest.assignments.push({ file, event: eventType });\n   410→  await soundStore.savePackManifest(selectedPack.value, manifest);\n   411→}\n   412→\n   413→// ---- Chip drag handlers (re-assign chip to different sound) ----\n   414→function onChipDragStart(\n   415→  e: DragEvent,\n   416→  file: string,\n   417→  eventType: AgentEventType,\n   418→): void {\n   419→  draggingChip.value = { file, event: eventType };\n   420→  if (e.dataTransfer) {\n   421→    e.dataTransfer.effectAllowed = 'move';\n   422→    e.dataTransfer.setData('text/plain', file);\n   423→  }\n   424→}\n   425→\n   426→function onChipDragEnd(): void {\n   427→  draggingChip.value = null;\n   428→  dragOverSoundFile.value = null;\n   429→}\n   430→\n   431→function onSoundRowDragOver(e: DragEvent, filename: string): void {\n   432→  if (!draggingChip.value) return;\n   433→  e.preventDefault();\n   434→  if (e.dataTransfer) e.dataTransfer.dropEffect = 'move';\n   435→  dragOverSoundFile.value = filename;\n   436→}\n   437→\n   438→function onSoundRowDragLeave(): void {\n   439→  dragOverSoundFile.value = null;\n   440→}\n   441→\n   442→async function onSoundRowDrop(\n   443→  e: DragEvent,\n   444→  newFile: string,\n   445→): Promise<void> {\n   446→  e.preventDefault();\n   447→  dragOverSoundFile.value = null;\n   448→  const chip = draggingChip.value;\n   449→  draggingChip.value = null;\n   450→  if (!chip || !selectedPack.value || !selectedPackInfo.value) return;\n   451→  if (chip.file === newFile) return;\n   452→  const manifest = selectedPackInfo.value.manifest;\n   453→  manifest.assignments = manifest.assignments.filter(\n   454→    (a) => !(a.file === chip.file && a.event === chip.event),\n   455→  );\n   456→  const alreadyExists = manifest.assignments.some(\n   457→    (a) => a.file === newFile && a.event === chip.event,\n   458→  );\n   459→  if (!alreadyExists) {\n   460→    manifest.assignments.push({ file: newFile, event: chip.event });\n   461→  }\n   462→  await soundStore.savePackManifest(selectedPack.value, manifest);\n   463→}\n   464→\n   465→// ---- Live highlight on incoming agent events ----\n   466→const flashingEvent = ref<AgentEventType | null>(null);\n   467→let flashTimeout: ReturnType<typeof setTimeout> | null = null;\n   468→let agentEventUnlisten: UnlistenFn | null = null;\n   469→\n   470→function flashEventRow(eventType: AgentEventType): void {\n   471→  flashingEvent.value = eventType;\n   472→  if (flashTimeout) clearTimeout(flashTimeout);\n   473→  flashTimeout = setTimeout(() => {\n   474→    flashingEvent.value = null;\n   475→    flashTimeout = null;\n   476→  }, 200);\n   477→}\n   478→\n   479→// ---- Add audio files to pack (OS drag + file picker) ----\n   480→const AUDIO_EXTENSIONS = new Set(['.wav', '.mp3', '.ogg', '.flac', '.m4a', '.webm']);\n   481→const audioDragOver = ref(false);\n   482→\n   483→function isAudioFile(filename: string): boolean {\n   484→  const dot = filename.lastIndexOf('.');\n   485→  if (dot < 0) return false;\n   486→  return AUDIO_EXTENSIONS.has(filename.slice(dot).toLowerCase());\n   487→}\n   488→\n   489→async function addAudioFilesFromBlobs(\n   490→  files: { name: string; bytes: Uint8Array }[],\n   491→): Promise<void> {\n   492→  if (!selectedPack.value || !selectedPackInfo.value) return;\n   493→  const baseDir = soundStore.getSoundPacksDir();\n   494→  const packPath = `${baseDir}/${selectedPack.value}`;\n   495→  const manifest = selectedPackInfo.value.manifest;\n   496→  let changed = false;\n   497→\n   498→  for (const file of files) {\n   499→    if (!isAudioFile(file.name)) continue;\n   500→    await writeFile(`${packPath}/${file.name}`, file.bytes);\n   501→    const alreadyInManifest = manifest.sounds.some(\n   502→      (s) => s.file === file.name,\n   503→    );\n   504→    if (!alreadyInManifest) {\n   505→      manifest.sounds.push({\n   506→        file: file.name,\n   507→        volume: 1.0,\n   508→        enabled: true,\n   509→      });\n   510→      changed = true;\n   511→    }\n   512→  }\n   513→\n   514→  if (changed) {\n   515→    await soundStore.savePackManifest(selectedPack.value, manifest);\n   516→  }\n   517→  if (selectedPack.value) {\n   518→    void checkSoundFileExistence(selectedPack.value);\n   519→  }\n   520→}\n   521→\n   522→function onAudioDragOver(e: DragEvent): void {\n   523→  if (!selectedPack.value) return;\n   524→  e.preventDefault();\n   525→  e.stopPropagation();\n   526→  audioDragOver.value = true;\n   527→}\n   528→\n   529→function onAudioDragLeave(): void {\n   530→  audioDragOver.value = false;\n   531→}\n   532→\n   533→async function onAudioDrop(e: DragEvent): Promise<void> {\n   534→  e.preventDefault();\n   535→  e.stopPropagation();\n   536→  audioDragOver.value = false;\n   537→  if (!selectedPack.value) return;\n   538→  const dataFiles = e.dataTransfer?.files;\n   539→  if (!dataFiles || dataFiles.length === 0) return;\n   540→\n   541→  const blobs: { name: string; bytes: Uint8Array }[] = [];\n   542→  for (let i = 0; i < dataFiles.length; i++) {\n   543→    const f = dataFiles[i];\n   544→    if (!f || !isAudioFile(f.name)) continue;\n   545→    const buf = await f.arrayBuffer();\n   546→    blobs.push({ name: f.name, bytes: new Uint8Array(buf) });\n   547→  }\n   548→  if (blobs.length > 0) {\n   549→    await addAudioFilesFromBlobs(blobs);\n   550→  }\n   551→}\n   552→\n   553→async function openAddFilePicker(): Promise<void> {\n   554→  if (!selectedPack.value) return;\n   555→  const result = await open({\n   556→    filters: [{\n   557→      name: 'Audio',\n   558→      extensions: ['wav', 'mp3', 'ogg', 'flac', 'm4a', 'webm'],\n   559→    }],\n   560→    multiple: true,\n   561→  });\n   562→  if (!result) return;\n   563→  const paths = Array.isArray(result) ? result : [result];\n   564→  const blobs: { name: string; bytes: Uint8Array }[] = [];\n   565→  for (const filePath of paths) {\n   566→    if (!filePath) continue;\n   567→    const filename = filePath.split('/').pop() ?? '';\n   568→    if (!isAudioFile(filename)) continue;\n   569→    const bytes = await readFile(filePath);\n   570→    blobs.push({ name: filename, bytes });\n   571→  }\n   572→  if (blobs.length > 0) {\n   573→    await addAudioFilesFromBlobs(blobs);\n   574→  }\n   575→}\n   576→\n   577→// Reset scroll + stop preview + check file existence on pack change\n   578→watch(selectedPack, async (packName) => {\n   579→  stopPreview();\n   580→  soundFileExists.value = new Map();\n   581→  if (packName) void checkSoundFileExistence(packName);\n   582→  await nextTick(() => {\n   583→    if (rightPanel.value) rightPanel.value.scrollTop = 0;\n   584→  });\n   585→});\n   586→\n   587→</script>\n   588→\n   589→<template>\n   590→  <Teleport to=\"body\">\n   591→    <!-- Backdrop -->\n   592→    <div class=\"fixed inset-0 z-[100] flex items-center justify-center bg-black/50\">\n   593→      <!-- Drop zone wrapper -->\n   594→      <div\n   595→        class=\"relative w-[960px] max-w-[90vw] h-[700px] max-h-[90vh] flex flex-col bg-gray-900 border border-gray-700 rounded-lg shadow-2xl overflow-hidden\"\n   596→        @dragover=\"onDragOver\"\n   597→        @dragleave=\"onDragLeave\"\n   598→        @drop=\"onDrop\"\n   599→      >\n   600→        <!-- Drag overlay -->\n   601→        <div\n   602→          v-if=\"dragOver\"\n   603→          class=\"absolute inset-0 z-[150] flex items-center justify-center bg-indigo-900/80 border-2 border-dashed border-indigo-400 rounded-lg pointer-events-none\"\n   604→        >\n   605→          <span class=\"text-indigo-200 text-lg font-semibold\">Drop sound pack here</span>\n   606→        </div>\n   607→\n   608→        <!-- Header -->\n   609→        <div class=\"flex items-center gap-4 px-4 py-3 border-b border-gray-700 shrink-0\">\n   610→          <span class=\"text-gray-200 font-semibold text-sm\">Sounds</span>\n   611→\n   612→          <!-- Master enable -->\n   613→          <label class=\"flex items-center gap-1.5 text-xs text-gray-300 cursor-pointer\">\n   614→            <input\n   615→              type=\"checkbox\"\n   616→              :checked=\"globalEnabled\"\n   617→              class=\"w-4 h-4 accent-indigo-400\"\n   618→              @change=\"globalEnabled = ($event.target as HTMLInputElement).checked\"\n   619→            />\n   620→            Enable\n   621→          </label>\n   622→\n   623→          <!-- Global volume -->\n   624→          <label class=\"flex items-center gap-1.5 text-xs text-gray-300\">\n   625→            Vol\n   626→            <input\n   627→              type=\"range\"\n   628→              min=\"0\"\n   629→              max=\"100\"\n   630→              :value=\"globalVolume\"\n   631→              class=\"w-24 accent-indigo-400\"\n   632→              @input=\"globalVolume = parseInt(($event.target as HTMLInputElement).value)\"\n   633→            />\n   634→            <span class=\"w-7 tabular-nums\">{{ globalVolume }}%</span>\n   635→          </label>\n   636→\n   637→          <!-- Cooldown -->\n   638→          <label class=\"flex items-center gap-1.5 text-xs text-gray-300\">\n   639→            Cooldown\n   640→            <input\n   641→              type=\"range\"\n   642→              min=\"0\"\n   643→              max=\"10\"\n   644→              step=\"0.5\"\n   645→              :value=\"cooldown\"\n   646→              class=\"w-20 accent-indigo-400\"\n   647→              @input=\"cooldown = parseFloat(($event.target as HTMLInputElement).value)\"\n   648→            />\n   649→            <span class=\"w-8 tabular-nums\">{{ cooldown }}s</span>\n   650→          </label>\n   651→        </div>\n   652→\n   653→        <!-- Body -->\n   654→        <div class=\"flex flex-1 min-h-0\">\n   655→          <!-- Left panel: pack list -->\n   656→          <div class=\"w-60 shrink-0 border-r border-gray-700 flex flex-col\">\n   657→            <div class=\"px-3 pt-2 pb-1 text-xs font-semibold text-gray-400 uppercase tracking-wide\">\n   658→              Packs\n   659→            </div>\n   660→            <div class=\"flex-1 overflow-y-auto\">\n   661→              <div\n   662→                v-for=\"pack in soundStore.packs\"\n   663→                :key=\"pack.name\"\n   664→                class=\"flex items-center gap-2 px-2 py-1.5 cursor-pointer rounded mx-1\"\n   665→                :class=\"selectedPack === pack.name ? 'bg-gray-700' : 'hover:bg-gray-800'\"\n   666→                @click=\"selectPack(pack.name)\"\n   667→                @contextmenu=\"onPackRightClick($event, pack.name)\"\n   668→              >\n   669→                <input\n   670→                  type=\"checkbox\"\n   671→                  :checked=\"isPackActive(pack.name)\"\n   672→                  class=\"w-4 h-4 accent-indigo-400 cursor-pointer\"\n   673→                  @click.stop\n   674→                  @change=\"togglePackActive(pack.name, ($event.target as HTMLInputElement).checked)\"\n   675→                />\n   676→                <span class=\"text-sm text-gray-200 truncate flex-1\">{{ pack.name }}</span>\n   677→              </div>\n   678→            </div>\n   679→            <!-- Buttons / new pack input -->\n   680→            <div class=\"flex flex-col gap-1 p-2 border-t border-gray-700\">\n   681→              <div v-if=\"creatingPack\" class=\"flex gap-1\">\n   682→                <input\n   683→                  ref=\"newPackInput\"\n   684→                  v-model=\"newPackName\"\n   685→                  class=\"flex-1 px-2 py-1 bg-gray-800 border border-gray-600 rounded text-xs text-gray-200 outline-none focus:border-indigo-400\"\n   686→                  placeholder=\"Pack name…\"\n   687→                  @keydown.enter=\"confirmCreatePack\"\n   688→                  @keydown.escape=\"cancelCreatePack\"\n   689→                />\n   690→                <button\n   691→                  class=\"px-2 py-1 bg-indigo-600/80 rounded hover:bg-indigo-500 text-xs text-white\"\n   692→                  @click=\"confirmCreatePack\"\n   693→                >OK</button>\n   694→              </div>\n   695→              <div class=\"flex gap-1\">\n   696→                <button\n   697→                  class=\"flex-1 px-2 py-1 bg-gray-700/60 rounded hover:bg-gray-600/70 text-xs text-gray-200\"\n   698→                  @click=\"startCreatePack\"\n   699→                >\n   700→                  New Pack\n   701→                </button>\n   702→                <button\n   703→                  class=\"flex-1 px-2 py-1 bg-gray-700/60 rounded hover:bg-gray-600/70 text-xs text-gray-200\"\n   704→                  @click=\"openImportPicker\"\n   705→                >\n   706→                  Import\n   707→                </button>\n   708→              </div>\n   709→            </div>\n   710→          </div>\n   711→\n   712→          <!-- Patchbay: Sounds + Events columns -->\n   713→          <div ref=\"rightPanel\" class=\"flex flex-1 min-h-0 overflow-hidden\">\n   714→            <!-- Sounds column -->\n   715→            <div\n   716→              class=\"flex-1 border-r border-gray-700 flex flex-col min-w-0\"\n   717→              @dragover=\"onAudioDragOver\"\n   718→              @dragleave=\"onAudioDragLeave\"\n   719→              @drop=\"onAudioDrop\"\n   720→            >\n   721→              <div class=\"flex items-center gap-2 px-3 py-2 border-b border-gray-700 shrink-0\">\n   722→                <span class=\"text-xs font-semibold text-gray-400 uppercase tracking-wide flex-1\">Sounds</span>\n   723→                <button\n   724→                  v-if=\"selectedPack\"\n   725→                  class=\"px-2 py-0.5 bg-gray-700/60 rounded hover:bg-gray-600/70 text-xs text-gray-300\"\n   726→                  @click=\"openAddFilePicker\"\n   727→                >Add file</button>\n   728→              </div>\n   729→              <div class=\"flex-1 overflow-y-auto relative\">\n   730→                <!-- Audio file drop overlay -->\n   731→                <div\n   732→                  v-if=\"audioDragOver && selectedPack\"\n   733→                  class=\"absolute inset-0 z-10 flex items-center justify-center bg-indigo-900/60 border-2 border-dashed border-indigo-400 rounded pointer-events-none\"\n   734→                >\n   735→                  <span class=\"text-indigo-200 text-sm font-semibold\">Drop audio files here</span>\n   736→                </div>\n   737→                <div\n   738→                  v-if=\"!selectedPackInfo\"\n   739→                  class=\"flex items-center justify-center h-full text-gray-600 text-sm\"\n   740→                >\n   741→                  Select a pack\n   742→                </div>\n   743→                <div\n   744→                  v-else-if=\"selectedPackInfo.manifest.sounds.length === 0\"\n   745→                  class=\"flex items-center justify-center h-full text-gray-600 text-sm\"\n   746→                >\n   747→                  No sounds in this pack\n   748→                </div>\n   749→                <div\n   750→                  v-for=\"sound in selectedPackInfo.manifest.sounds\"\n   751→                  v-else\n   752→                  :key=\"sound.file\"\n   753→                  draggable=\"true\"\n   754→                  class=\"flex items-center gap-2 px-3 py-1.5 border-b border-gray-800 hover:bg-gray-800/40 cursor-grab transition-colors duration-150\"\n   755→                  :class=\"[\n   756→                    draggingSoundFile === sound.file ? 'opacity-50' : '',\n   757→                    dragOverSoundFile === sound.file ? 'bg-indigo-500/20' : '',\n   758→                    draggingChip ? 'opacity-100' : '',\n   759→                  ]\"\n   760→                  @mouseenter=\"hoveredSoundFile = sound.file\"\n   761→                  @mouseleave=\"hoveredSoundFile = null\"\n   762→                  @dragstart=\"onSoundDragStart($event, sound.file)\"\n   763→                  @dragend=\"onSoundDragEnd\"\n   764→                  @dragover=\"onSoundRowDragOver($event, sound.file)\"\n   765→                  @dragleave=\"onSoundRowDragLeave\"\n   766→                  @drop=\"onSoundRowDrop($event, sound.file)\"\n   767→                >\n   768→                  <!-- Play button -->\n   769→                  <button\n   770→                    class=\"shrink-0 w-6 h-6 flex items-center justify-center rounded text-gray-400 hover:text-white hover:bg-gray-700 text-xs\"\n   771→                    title=\"Play preview\"\n   772→                    @click=\"playPreview(sound.file)\"\n   773→                  >▶</button>\n   774→\n   775→                  <!-- Filename -->\n   776→                  <span class=\"flex-1 text-xs font-mono text-gray-200 truncate min-w-0\">{{ sound.file }}</span>\n   777→\n   778→                  <!-- Broken link indicator -->\n   779→                  <span\n   780→                    v-if=\"soundFileExists.get(sound.file) === false\"\n   781→                    class=\"shrink-0 text-red-400 text-xs\"\n   782→                    title=\"File not found on disk\"\n   783→                  >⚠</span>\n   784→\n   785→                  <!-- Volume slider (visible on hover) -->\n   786→                  <input\n   787→                    v-show=\"hoveredSoundFile === sound.file\"\n   788→                    type=\"range\"\n   789→                    min=\"0\"\n   790→                    max=\"1\"\n   791→                    step=\"0.01\"\n   792→                    :value=\"sound.volume\"\n   793→                    class=\"shrink-0 w-16 accent-indigo-400\"\n   794→                    title=\"Volume\"\n   795→                    @input=\"updateSoundVolume(sound, parseFloat(($event.target as HTMLInputElement).value))\"\n   796→                  />\n   797→\n   798→                  <!-- Enabled toggle -->\n   799→                  <input\n   800→                    type=\"checkbox\"\n   801→                    :checked=\"sound.enabled\"\n   802→                    class=\"shrink-0 w-4 h-4 accent-indigo-400 cursor-pointer\"\n   803→                    title=\"Enable/disable this sound\"\n   804→                    @change=\"updateSoundEnabled(sound, ($event.target as HTMLInputElement).checked)\"\n   805→                  />\n   806→\n   807→                  <!-- Stop button -->\n   808→                  <button\n   809→                    class=\"shrink-0 w-6 h-6 flex items-center justify-center rounded text-xs\"\n   810→                    :class=\"previewFile === sound.file\n   811→                      ? 'text-red-400 hover:text-red-300 hover:bg-gray-700'\n   812→                      : 'text-gray-600 cursor-default'\"\n   813→                    title=\"Stop preview\"\n   814→                    @click=\"previewFile === sound.file ? stopPreview() : undefined\"\n   815→                  >■</button>\n   816→                </div>\n   817→              </div>\n   818→            </div>\n   819→\n   820→            <!-- Events column -->\n   821→            <div class=\"flex-1 flex flex-col min-w-0\">\n   822→              <div class=\"px-3 py-2 border-b border-gray-700 shrink-0\">\n   823→                <span class=\"text-xs font-semibold text-gray-400 uppercase tracking-wide\">Events</span>\n   824→              </div>\n   825→              <div class=\"flex-1 overflow-y-auto\">\n   826→                <div\n   827→                  v-for=\"eventType in AGENT_EVENT_TYPES\"\n   828→                  :key=\"eventType\"\n   829→                  class=\"px-3 py-2 border-b border-gray-800 transition-all duration-200\"\n   830→                  :class=\"[\n   831→                    hasAssignments(eventType) ? 'opacity-100' : 'opacity-40',\n   832→                    flashingEvent === eventType ? 'bg-indigo-600/30' : '',\n   833→                    dragOverEventType === eventType ? 'bg-indigo-500/20 opacity-100' : '',\n   834→                    draggingSoundFile ? 'opacity-100' : '',\n   835→                  ]\"\n   836→                  @dragover=\"onEventDragOver($event, eventType)\"\n   837→                  @dragleave=\"onEventDragLeaveRow\"\n   838→                  @drop=\"onEventDrop($event, eventType)\"\n   839→                >\n   840→                  <div class=\"flex items-center gap-2\">\n   841→                    <span class=\"text-sm font-mono text-gray-300 flex-1\">{{ eventType }}</span>\n   842→                    <!-- Info icon + popover -->\n   843→                    <span\n   844→                      v-if=\"EVENT_DESCRIPTIONS[eventType]\"\n   845→                      class=\"relative shrink-0\"\n   846→                      @click.stop\n   847→                    >\n   848→                      <span\n   849→                        class=\"w-4 h-4 flex items-center justify-center rounded-full border text-[10px] leading-none cursor-pointer select-none\"\n   850→                        :class=\"activeInfoPopover === eventType\n   851→                          ? 'border-indigo-400 text-indigo-300 bg-indigo-900/40'\n   852→                          : 'border-gray-500 text-gray-400 hover:border-gray-300 hover:text-gray-200'\"\n   853→                        @click=\"toggleInfoPopover(eventType)\"\n   854→                      >i</span>\n   855→                      <div\n   856→                        v-if=\"activeInfoPopover === eventType\"\n   857→                        class=\"absolute right-0 top-6 z-50 w-56 bg-gray-800 border border-gray-600 rounded shadow-lg px-3 py-2 text-xs text-gray-200 leading-relaxed\"\n   858→                      >\n   859→                        {{ EVENT_DESCRIPTIONS[eventType] }}\n   860→                      </div>\n   861→                    </span>\n   862→                  </div>\n   863→                  <!-- Assignment chips -->\n   864→                  <div\n   865→                    v-if=\"assignmentsForEvent(eventType).length > 0\"\n   866→                    class=\"flex flex-wrap gap-1 mt-1\"\n   867→                  >\n   868→                    <span\n   869→                      v-for=\"file in assignmentsForEvent(eventType)\"\n   870→                      :key=\"file\"\n   871→                      draggable=\"true\"\n   872→                      class=\"inline-flex items-center gap-1 px-2 py-0.5 bg-gray-700/80 rounded text-xs text-gray-200 cursor-grab hover:bg-gray-600/80\"\n   873→                      :class=\"draggingChip?.file === file && draggingChip?.event === eventType ? 'opacity-50' : ''\"\n   874→                      :title=\"file\"\n   875→                      @click=\"playPreview(file)\"\n   876→                      @dragstart.stop=\"onChipDragStart($event, file, eventType)\"\n   877→                      @dragend=\"onChipDragEnd\"\n   878→                    >\n   879→                      {{ truncateFilename(file) }}\n   880→                      <button\n   881→                        class=\"ml-0.5 text-gray-400 hover:text-red-400 leading-none\"\n   882→                        title=\"Remove assignment\"\n   883→                        @click.stop=\"removeAssignment(file, eventType)\"\n   884→                      >&times;</button>\n   885→                    </span>\n   886→                  </div>\n   887→                </div>\n   888→              </div>\n   889→            </div>\n   890→          </div>\n   891→        </div>\n   892→\n   893→        <!-- Footer -->\n   894→        <div class=\"flex justify-end px-4 py-3 border-t border-gray-700 shrink-0\">\n   895→          <button\n   896→            class=\"px-4 py-1.5 bg-gray-700/60 rounded hover:bg-gray-600/70 text-sm text-gray-200\"\n   897→            @click=\"emit('close')\"\n   898→          >\n   899→            Close\n   900→          </button>\n   901→        </div>\n   902→      </div>\n   903→    </div>\n   904→\n   905→    <!-- Context menu -->\n   906→    <PackContextMenu\n   907→      v-if=\"ctxMenu\"\n   908→      :pack-name=\"ctxMenu.packName\"\n   909→      :x=\"ctxMenu.x\"\n   910→      :y=\"ctxMenu.y\"\n   911→      @close=\"closeCtxMenu\"\n   912→      @renamed=\"onPackRenamed\"\n   913→      @duplicated=\"onPackDuplicated\"\n   914→      @deleted=\"onPackDeleted\"\n   915→    />\n   916→  </Teleport>\n   917→</template>\n   918→"}]},"parent_tool_use_id":null,"session_id":"7a575a68-b11c-4f43-8f6b-b60027dacef9","uuid":"2142ce98-fb8b-489f-935f-ce17add45171","tool_use_result":{"type":"text","file":{"filePath":"/Users/markus/baustelle/projects/agents-in-the-office/agents-in-the-office/.chief/worktrees/sound-packs-patchbay/src/components/SoundsDialog.vue","content":"<script setup lang=\"ts\">\nimport {\n  ref,\n  computed,\n  watch,\n  nextTick,\n  onMounted,\n  onUnmounted,\n} from 'vue';\nimport { listen } from '@tauri-apps/api/event';\nimport type { UnlistenFn } from '@tauri-apps/api/event';\nimport { open } from '@tauri-apps/plugin-dialog';\nimport {\n  mkdir,\n  readFile,\n  writeFile,\n  exists,\n} from '@tauri-apps/plugin-fs';\nimport JSZip from 'jszip';\nimport { useSoundStore, AGENT_EVENT_TYPES } from '../stores/soundStore';\nimport type { PackManifestSound } from '../stores/soundStore';\nimport type { AgentEvent, AgentEventType } from '../drivers/types';\nimport PackContextMenu from './PackContextMenu.vue';\n\nconst emit = defineEmits<{ close: [] }>();\n\nconst soundStore = useSoundStore();\n\n// ---- Global settings ----\nconst globalEnabled = computed({\n  get: () => soundStore.config.enabled,\n  set: (v: boolean) => { soundStore.config.enabled = v; void soundStore.saveConfig(); },\n});\nconst globalVolume = computed({\n  get: () => Math.round(soundStore.config.globalVolume * 100),\n  set: (v: number) => { soundStore.config.globalVolume = v / 100; void soundStore.saveConfig(); },\n});\nconst cooldown = computed({\n  get: () => soundStore.config.cooldownSeconds,\n  set: (v: number) => { soundStore.config.cooldownSeconds = v; void soundStore.saveConfig(); },\n});\n\n// ---- Pack list ----\nconst selectedPack = ref<string | null>(null);\nconst rightPanel = ref<HTMLElement | null>(null);\n\nonMounted(async () => {\n  await soundStore.init();\n  await soundStore.scanPacks();\n  if (soundStore.packs.length > 0 && soundStore.packs[0]) {\n    selectedPack.value = soundStore.packs[0].name;\n  }\n  agentEventUnlisten = await listen<string>(\n    'agent-event',\n    (e) => {\n      try {\n        const parsed = JSON.parse(e.payload) as AgentEvent;\n        flashEventRow(parsed.type);\n      } catch { /* ignore parse errors */ }\n    },\n  );\n});\n\nonUnmounted(() => {\n  if (agentEventUnlisten) agentEventUnlisten();\n  if (flashTimeout) clearTimeout(flashTimeout);\n});\n\nfunction isPackActive(packName: string): boolean {\n  return soundStore.config.activePacks.includes(packName);\n}\n\nfunction togglePackActive(packName: string, active: boolean) {\n  if (active) {\n    if (!soundStore.config.activePacks.includes(packName)) {\n      soundStore.config.activePacks.push(packName);\n    }\n  } else {\n    soundStore.config.activePacks = soundStore.config.activePacks.filter(\n      (p) => p !== packName,\n    );\n  }\n  void soundStore.saveConfig();\n}\n\nfunction selectPack(name: string) {\n  selectedPack.value = name;\n  void nextTick(() => {\n    if (rightPanel.value) rightPanel.value.scrollTop = 0;\n  });\n}\n\n// ---- Context menu ----\nconst ctxMenu = ref<{ packName: string; x: number; y: number } | null>(null);\n\nfunction onPackRightClick(e: MouseEvent, packName: string) {\n  e.preventDefault();\n  ctxMenu.value = { packName, x: e.clientX, y: e.clientY };\n}\n\nfunction closeCtxMenu() {\n  ctxMenu.value = null;\n}\n\nasync function onPackRenamed(oldName: string, newName: string) {\n  await soundStore.scanPacks();\n  if (selectedPack.value === oldName) selectedPack.value = newName;\n  closeCtxMenu();\n}\n\nasync function onPackDuplicated() {\n  await soundStore.scanPacks();\n  closeCtxMenu();\n}\n\nasync function onPackDeleted(name: string) {\n  await soundStore.scanPacks();\n  if (selectedPack.value === name) {\n    selectedPack.value = soundStore.packs[0]?.name ?? null;\n  }\n  closeCtxMenu();\n}\n\n// ---- New pack ----\nconst newPackName = ref('');\nconst creatingPack = ref(false);\nconst newPackInput = ref<HTMLInputElement | null>(null);\n\nfunction startCreatePack() {\n  creatingPack.value = true;\n  newPackName.value = '';\n  void nextTick(() => newPackInput.value?.focus());\n}\n\nfunction cancelCreatePack() {\n  creatingPack.value = false;\n  newPackName.value = '';\n}\n\nasync function confirmCreatePack() {\n  const packName = newPackName.value.trim();\n  if (!packName) return;\n  creatingPack.value = false;\n  newPackName.value = '';\n  const baseDir = soundStore.getSoundPacksDir();\n  const packPath = `${baseDir}/${packName}`;\n  try {\n    await mkdir(packPath, { recursive: true });\n    for (const eventType of AGENT_EVENT_TYPES) {\n      await mkdir(`${packPath}/${eventType}`, { recursive: true });\n    }\n    await soundStore.scanPacks();\n    selectedPack.value = packName;\n  } catch (err) {\n    console.error('[SoundsDialog] createNewPack failed', err);\n  }\n}\n\n// ---- Import zip ----\nconst dragOver = ref(false);\n\nasync function importZipBytes(filename: string, bytes: Uint8Array): Promise<void> {\n  const dotIdx = filename.lastIndexOf('.');\n  const packName = dotIdx > 0 ? filename.slice(0, dotIdx) : filename;\n  const baseDir = soundStore.getSoundPacksDir();\n  const packPath = `${baseDir}/${packName}`;\n\n  const zip = await JSZip.loadAsync(bytes);\n  for (const [relativePath, file] of Object.entries(zip.files)) {\n    if (file.dir) {\n      await mkdir(`${packPath}/${relativePath}`, { recursive: true });\n    } else {\n      const data = await file.async('uint8array');\n      const dirPart = relativePath.includes('/')\n        ? relativePath.slice(0, relativePath.lastIndexOf('/'))\n        : '';\n      if (dirPart) {\n        await mkdir(`${packPath}/${dirPart}`, { recursive: true });\n      }\n      await writeFile(`${packPath}/${relativePath}`, data);\n    }\n  }\n\n  await soundStore.scanPacks();\n  selectedPack.value = packName;\n}\n\nasync function openImportPicker() {\n  const result = await open({\n    filters: [{ name: 'ZIP', extensions: ['zip'] }],\n    multiple: false,\n  });\n  if (!result) return;\n  const filePath = typeof result === 'string' ? result : result;\n  if (!filePath) return;\n  try {\n    const bytes = await readFile(filePath);\n    const filename = (filePath as string).split('/').pop() ?? 'pack.zip';\n    await importZipBytes(filename, bytes);\n  } catch (err) {\n    console.error('[SoundsDialog] import failed', err);\n  }\n}\n\nfunction onDragOver(e: DragEvent) {\n  e.preventDefault();\n  dragOver.value = true;\n}\n\nfunction onDragLeave() {\n  dragOver.value = false;\n}\n\nasync function onDrop(e: DragEvent) {\n  e.preventDefault();\n  dragOver.value = false;\n  const file = e.dataTransfer?.files[0];\n  if (!file) return;\n  try {\n    const arrayBuffer = await file.arrayBuffer();\n    await importZipBytes(file.name, new Uint8Array(arrayBuffer));\n  } catch (err) {\n    console.error('[SoundsDialog] drop import failed', err);\n  }\n}\n\n// ---- Event descriptions ----\nconst EVENT_DESCRIPTIONS: Record<string, string> = {\n  session_start: 'Agent session begins.',\n  session_end: 'Agent session ends or is interrupted.',\n  prompt_submit: 'User submits a prompt to the agent.',\n  tool_start: 'Agent begins executing a tool (e.g. Bash, Read, Edit).',\n  tool_end: 'Agent finishes executing a tool.',\n  turn_end: 'Agent completes a full response turn.',\n  permission_wait: 'Agent pauses waiting for the user to approve a tool call.',\n  subagent_start: 'A subagent is spawned by the parent agent.',\n  subagent_end: 'A subagent finishes its work.',\n  idle_notification: 'Agent has been idle and sends a nudge notification.',\n  elicitation_wait: 'Agent pauses waiting for user input.',\n  auth_success: 'Authentication to an external service succeeds.',\n  worktree_create: 'A new git worktree is created.',\n  worktree_remove: 'A git worktree is removed.',\n  teammate_idle: \"A teammate's agent session goes idle.\",\n  task_completed: 'Agent marks a task as completed.',\n};\n\nconst activeInfoPopover = ref<string | null>(null);\n\nfunction toggleInfoPopover(eventType: string) {\n  activeInfoPopover.value = activeInfoPopover.value === eventType ? null : eventType;\n}\n\n// ---- Patchbay data ----\nconst selectedPackInfo = computed(() =>\n  soundStore.packs.find((p) => p.name === selectedPack.value) ?? null,\n);\n\nfunction hasAssignments(eventType: AgentEventType): boolean {\n  if (!selectedPackInfo.value) return false;\n  return selectedPackInfo.value.manifest.assignments.some((a) => a.event === eventType);\n}\n\n// ---- Sound preview (left column) ----\nlet previewSource: AudioBufferSourceNode | null = null;\nconst previewFile = ref<string | null>(null);\nconst soundFileExists = ref<Map<string, boolean>>(new Map());\nconst hoveredSoundFile = ref<string | null>(null);\n\nasync function checkSoundFileExistence(packName: string): Promise<void> {\n  const sounds = selectedPackInfo.value?.manifest.sounds ?? [];\n  const baseDir = soundStore.getSoundPacksDir();\n  const newMap = new Map<string, boolean>();\n  await Promise.all(\n    sounds.map(async (sound) => {\n      const filePath = `${baseDir}/${packName}/${sound.file}`;\n      const fileExists = await exists(filePath);\n      newMap.set(sound.file, fileExists);\n    }),\n  );\n  soundFileExists.value = newMap;\n}\n\nfunction stopPreview(): void {\n  if (previewSource) {\n    try { previewSource.stop(); } catch { /* already stopped */ }\n    previewSource = null;\n  }\n  previewFile.value = null;\n}\n\nasync function playPreview(filename: string): Promise<void> {\n  if (!selectedPack.value) return;\n  stopPreview();\n  const baseDir = soundStore.getSoundPacksDir();\n  const filePath = `${baseDir}/${selectedPack.value}/${filename}`;\n  const buffer = await soundStore.loadBuffer(filePath);\n  if (!buffer) return;\n  const ctx = soundStore.getOrCreateAudioContext();\n  const sound = selectedPackInfo.value?.manifest.sounds.find((s) => s.file === filename);\n  const gainNode = ctx.createGain();\n  gainNode.gain.value =\n    soundStore.config.globalVolume * soundStore.effectiveVolume(selectedPack.value, filename, sound);\n  gainNode.connect(ctx.destination);\n  const source = ctx.createBufferSource();\n  source.buffer = buffer;\n  source.connect(gainNode);\n  previewFile.value = filename;\n  previewSource = source;\n  source.onended = () => {\n    if (previewFile.value === filename) {\n      previewFile.value = null;\n      previewSource = null;\n    }\n  };\n  source.start();\n}\n\nasync function updateSoundVolume(sound: PackManifestSound, volume: number): Promise<void> {\n  if (!selectedPack.value || !selectedPackInfo.value) return;\n  sound.volume = volume;\n  await soundStore.savePackManifest(selectedPack.value, selectedPackInfo.value.manifest);\n}\n\nasync function updateSoundEnabled(sound: PackManifestSound, enabled: boolean): Promise<void> {\n  if (!selectedPack.value || !selectedPackInfo.value) return;\n  sound.enabled = enabled;\n  await soundStore.savePackManifest(selectedPack.value, selectedPackInfo.value.manifest);\n}\n\n// ---- Assignment chips (right column) ----\nfunction assignmentsForEvent(eventType: AgentEventType): string[] {\n  if (!selectedPackInfo.value) return [];\n  return selectedPackInfo.value.manifest.assignments\n    .filter((a) => a.event === eventType)\n    .map((a) => a.file);\n}\n\nfunction truncateFilename(name: string, max = 20): string {\n  if (name.length <= max) return name;\n  return name.slice(0, max - 1) + '\\u2026';\n}\n\nasync function removeAssignment(\n  file: string,\n  eventType: AgentEventType,\n): Promise<void> {\n  if (!selectedPack.value || !selectedPackInfo.value) return;\n  const manifest = selectedPackInfo.value.manifest;\n  manifest.assignments = manifest.assignments.filter(\n    (a) => !(a.file === file && a.event === eventType),\n  );\n  await soundStore.savePackManifest(selectedPack.value, manifest);\n}\n\n// ---- Drag-and-drop: sound → event row ----\nconst draggingSoundFile = ref<string | null>(null);\nconst dragOverEventType = ref<AgentEventType | null>(null);\n\n// ---- Drag-and-drop: chip → sound row (re-assign) ----\nconst draggingChip = ref<{ file: string; event: AgentEventType } | null>(null);\nconst dragOverSoundFile = ref<string | null>(null);\n\nfunction onSoundDragStart(e: DragEvent, filename: string): void {\n  draggingSoundFile.value = filename;\n  if (e.dataTransfer) {\n    e.dataTransfer.effectAllowed = 'copy';\n    e.dataTransfer.setData('text/plain', filename);\n  }\n}\n\nfunction onSoundDragEnd(): void {\n  draggingSoundFile.value = null;\n  dragOverEventType.value = null;\n}\n\nfunction onEventDragOver(e: DragEvent, eventType: AgentEventType): void {\n  if (!draggingSoundFile.value) return;\n  e.preventDefault();\n  if (e.dataTransfer) e.dataTransfer.dropEffect = 'copy';\n  dragOverEventType.value = eventType;\n}\n\nfunction onEventDragLeaveRow(): void {\n  dragOverEventType.value = null;\n}\n\nasync function onEventDrop(\n  e: DragEvent,\n  eventType: AgentEventType,\n): Promise<void> {\n  e.preventDefault();\n  dragOverEventType.value = null;\n  const file = draggingSoundFile.value;\n  draggingSoundFile.value = null;\n  if (!file) return;\n  await addAssignment(file, eventType);\n}\n\nasync function addAssignment(\n  file: string,\n  eventType: AgentEventType,\n): Promise<void> {\n  if (!selectedPack.value || !selectedPackInfo.value) return;\n  const manifest = selectedPackInfo.value.manifest;\n  const alreadyExists = manifest.assignments.some(\n    (a) => a.file === file && a.event === eventType,\n  );\n  if (alreadyExists) return;\n  manifest.assignments.push({ file, event: eventType });\n  await soundStore.savePackManifest(selectedPack.value, manifest);\n}\n\n// ---- Chip drag handlers (re-assign chip to different sound) ----\nfunction onChipDragStart(\n  e: DragEvent,\n  file: string,\n  eventType: AgentEventType,\n): void {\n  draggingChip.value = { file, event: eventType };\n  if (e.dataTransfer) {\n    e.dataTransfer.effectAllowed = 'move';\n    e.dataTransfer.setData('text/plain', file);\n  }\n}\n\nfunction onChipDragEnd(): void {\n  draggingChip.value = null;\n  dragOverSoundFile.value = null;\n}\n\nfunction onSoundRowDragOver(e: DragEvent, filename: string): void {\n  if (!draggingChip.value) return;\n  e.preventDefault();\n  if (e.dataTransfer) e.dataTransfer.dropEffect = 'move';\n  dragOverSoundFile.value = filename;\n}\n\nfunction onSoundRowDragLeave(): void {\n  dragOverSoundFile.value = null;\n}\n\nasync function onSoundRowDrop(\n  e: DragEvent,\n  newFile: string,\n): Promise<void> {\n  e.preventDefault();\n  dragOverSoundFile.value = null;\n  const chip = draggingChip.value;\n  draggingChip.value = null;\n  if (!chip || !selectedPack.value || !selectedPackInfo.value) return;\n  if (chip.file === newFile) return;\n  const manifest = selectedPackInfo.value.manifest;\n  manifest.assignments = manifest.assignments.filter(\n    (a) => !(a.file === chip.file && a.event === chip.event),\n  );\n  const alreadyExists = manifest.assignments.some(\n    (a) => a.file === newFile && a.event === chip.event,\n  );\n  if (!alreadyExists) {\n    manifest.assignments.push({ file: newFile, event: chip.event });\n  }\n  await soundStore.savePackManifest(selectedPack.value, manifest);\n}\n\n// ---- Live highlight on incoming agent events ----\nconst flashingEvent = ref<AgentEventType | null>(null);\nlet flashTimeout: ReturnType<typeof setTimeout> | null = null;\nlet agentEventUnlisten: UnlistenFn | null = null;\n\nfunction flashEventRow(eventType: AgentEventType): void {\n  flashingEvent.value = eventType;\n  if (flashTimeout) clearTimeout(flashTimeout);\n  flashTimeout = setTimeout(() => {\n    flashingEvent.value = null;\n    flashTimeout = null;\n  }, 200);\n}\n\n// ---- Add audio files to pack (OS drag + file picker) ----\nconst AUDIO_EXTENSIONS = new Set(['.wav', '.mp3', '.ogg', '.flac', '.m4a', '.webm']);\nconst audioDragOver = ref(false);\n\nfunction isAudioFile(filename: string): boolean {\n  const dot = filename.lastIndexOf('.');\n  if (dot < 0) return false;\n  return AUDIO_EXTENSIONS.has(filename.slice(dot).toLowerCase());\n}\n\nasync function addAudioFilesFromBlobs(\n  files: { name: string; bytes: Uint8Array }[],\n): Promise<void> {\n  if (!selectedPack.value || !selectedPackInfo.value) return;\n  const baseDir = soundStore.getSoundPacksDir();\n  const packPath = `${baseDir}/${selectedPack.value}`;\n  const manifest = selectedPackInfo.value.manifest;\n  let changed = false;\n\n  for (const file of files) {\n    if (!isAudioFile(file.name)) continue;\n    await writeFile(`${packPath}/${file.name}`, file.bytes);\n    const alreadyInManifest = manifest.sounds.some(\n      (s) => s.file === file.name,\n    );\n    if (!alreadyInManifest) {\n      manifest.sounds.push({\n        file: file.name,\n        volume: 1.0,\n        enabled: true,\n      });\n      changed = true;\n    }\n  }\n\n  if (changed) {\n    await soundStore.savePackManifest(selectedPack.value, manifest);\n  }\n  if (selectedPack.value) {\n    void checkSoundFileExistence(selectedPack.value);\n  }\n}\n\nfunction onAudioDragOver(e: DragEvent): void {\n  if (!selectedPack.value) return;\n  e.preventDefault();\n  e.stopPropagation();\n  audioDragOver.value = true;\n}\n\nfunction onAudioDragLeave(): void {\n  audioDragOver.value = false;\n}\n\nasync function onAudioDrop(e: DragEvent): Promise<void> {\n  e.preventDefault();\n  e.stopPropagation();\n  audioDragOver.value = false;\n  if (!selectedPack.value) return;\n  const dataFiles = e.dataTransfer?.files;\n  if (!dataFiles || dataFiles.length === 0) return;\n\n  const blobs: { name: string; bytes: Uint8Array }[] = [];\n  for (let i = 0; i < dataFiles.length; i++) {\n    const f = dataFiles[i];\n    if (!f || !isAudioFile(f.name)) continue;\n    const buf = await f.arrayBuffer();\n    blobs.push({ name: f.name, bytes: new Uint8Array(buf) });\n  }\n  if (blobs.length > 0) {\n    await addAudioFilesFromBlobs(blobs);\n  }\n}\n\nasync function openAddFilePicker(): Promise<void> {\n  if (!selectedPack.value) return;\n  const result = await open({\n    filters: [{\n      name: 'Audio',\n      extensions: ['wav', 'mp3', 'ogg', 'flac', 'm4a', 'webm'],\n    }],\n    multiple: true,\n  });\n  if (!result) return;\n  const paths = Array.isArray(result) ? result : [result];\n  const blobs: { name: string; bytes: Uint8Array }[] = [];\n  for (const filePath of paths) {\n    if (!filePath) continue;\n    const filename = filePath.split('/').pop() ?? '';\n    if (!isAudioFile(filename)) continue;\n    const bytes = await readFile(filePath);\n    blobs.push({ name: filename, bytes });\n  }\n  if (blobs.length > 0) {\n    await addAudioFilesFromBlobs(blobs);\n  }\n}\n\n// Reset scroll + stop preview + check file existence on pack change\nwatch(selectedPack, async (packName) => {\n  stopPreview();\n  soundFileExists.value = new Map();\n  if (packName) void checkSoundFileExistence(packName);\n  await nextTick(() => {\n    if (rightPanel.value) rightPanel.value.scrollTop = 0;\n  });\n});\n\n</script>\n\n<template>\n  <Teleport to=\"body\">\n    <!-- Backdrop -->\n    <div class=\"fixed inset-0 z-[100] flex items-center justify-center bg-black/50\">\n      <!-- Drop zone wrapper -->\n      <div\n        class=\"relative w-[960px] max-w-[90vw] h-[700px] max-h-[90vh] flex flex-col bg-gray-900 border border-gray-700 rounded-lg shadow-2xl overflow-hidden\"\n        @dragover=\"onDragOver\"\n        @dragleave=\"onDragLeave\"\n        @drop=\"onDrop\"\n      >\n        <!-- Drag overlay -->\n        <div\n          v-if=\"dragOver\"\n          class=\"absolute inset-0 z-[150] flex items-center justify-center bg-indigo-900/80 border-2 border-dashed border-indigo-400 rounded-lg pointer-events-none\"\n        >\n          <span class=\"text-indigo-200 text-lg font-semibold\">Drop sound pack here</span>\n        </div>\n\n        <!-- Header -->\n        <div class=\"flex items-center gap-4 px-4 py-3 border-b border-gray-700 shrink-0\">\n          <span class=\"text-gray-200 font-semibold text-sm\">Sounds</span>\n\n          <!-- Master enable -->\n          <label class=\"flex items-center gap-1.5 text-xs text-gray-300 cursor-pointer\">\n            <input\n              type=\"checkbox\"\n              :checked=\"globalEnabled\"\n              class=\"w-4 h-4 accent-indigo-400\"\n              @change=\"globalEnabled = ($event.target as HTMLInputElement).checked\"\n            />\n            Enable\n          </label>\n\n          <!-- Global volume -->\n          <label class=\"flex items-center gap-1.5 text-xs text-gray-300\">\n            Vol\n            <input\n              type=\"range\"\n              min=\"0\"\n              max=\"100\"\n              :value=\"globalVolume\"\n              class=\"w-24 accent-indigo-400\"\n              @input=\"globalVolume = parseInt(($event.target as HTMLInputElement).value)\"\n            />\n            <span class=\"w-7 tabular-nums\">{{ globalVolume }}%</span>\n          </label>\n\n          <!-- Cooldown -->\n          <label class=\"flex items-center gap-1.5 text-xs text-gray-300\">\n            Cooldown\n            <input\n              type=\"range\"\n              min=\"0\"\n              max=\"10\"\n              step=\"0.5\"\n              :value=\"cooldown\"\n              class=\"w-20 accent-indigo-400\"\n              @input=\"cooldown = parseFloat(($event.target as HTMLInputElement).value)\"\n            />\n            <span class=\"w-8 tabular-nums\">{{ cooldown }}s</span>\n          </label>\n        </div>\n\n        <!-- Body -->\n        <div class=\"flex flex-1 min-h-0\">\n          <!-- Left panel: pack list -->\n          <div class=\"w-60 shrink-0 border-r border-gray-700 flex flex-col\">\n            <div class=\"px-3 pt-2 pb-1 text-xs font-semibold text-gray-400 uppercase tracking-wide\">\n              Packs\n            </div>\n            <div class=\"flex-1 overflow-y-auto\">\n              <div\n                v-for=\"pack in soundStore.packs\"\n                :key=\"pack.name\"\n                class=\"flex items-center gap-2 px-2 py-1.5 cursor-pointer rounded mx-1\"\n                :class=\"selectedPack === pack.name ? 'bg-gray-700' : 'hover:bg-gray-800'\"\n                @click=\"selectPack(pack.name)\"\n                @contextmenu=\"onPackRightClick($event, pack.name)\"\n              >\n                <input\n                  type=\"checkbox\"\n                  :checked=\"isPackActive(pack.name)\"\n                  class=\"w-4 h-4 accent-indigo-400 cursor-pointer\"\n                  @click.stop\n                  @change=\"togglePackActive(pack.name, ($event.target as HTMLInputElement).checked)\"\n                />\n                <span class=\"text-sm text-gray-200 truncate flex-1\">{{ pack.name }}</span>\n              </div>\n            </div>\n            <!-- Buttons / new pack input -->\n            <div class=\"flex flex-col gap-1 p-2 border-t border-gray-700\">\n              <div v-if=\"creatingPack\" class=\"flex gap-1\">\n                <input\n                  ref=\"newPackInput\"\n                  v-model=\"newPackName\"\n                  class=\"flex-1 px-2 py-1 bg-gray-800 border border-gray-600 rounded text-xs text-gray-200 outline-none focus:border-indigo-400\"\n                  placeholder=\"Pack name…\"\n                  @keydown.enter=\"confirmCreatePack\"\n                  @keydown.escape=\"cancelCreatePack\"\n                />\n                <button\n                  class=\"px-2 py-1 bg-indigo-600/80 rounded hover:bg-indigo-500 text-xs text-white\"\n                  @click=\"confirmCreatePack\"\n                >OK</button>\n              </div>\n              <div class=\"flex gap-1\">\n                <button\n                  class=\"flex-1 px-2 py-1 bg-gray-700/60 rounded hover:bg-gray-600/70 text-xs text-gray-200\"\n                  @click=\"startCreatePack\"\n                >\n                  New Pack\n                </button>\n                <button\n                  class=\"flex-1 px-2 py-1 bg-gray-700/60 rounded hover:bg-gray-600/70 text-xs text-gray-200\"\n                  @click=\"openImportPicker\"\n                >\n                  Import\n                </button>\n              </div>\n            </div>\n          </div>\n\n          <!-- Patchbay: Sounds + Events columns -->\n          <div ref=\"rightPanel\" class=\"flex flex-1 min-h-0 overflow-hidden\">\n            <!-- Sounds column -->\n            <div\n              class=\"flex-1 border-r border-gray-700 flex flex-col min-w-0\"\n              @dragover=\"onAudioDragOver\"\n              @dragleave=\"onAudioDragLeave\"\n              @drop=\"onAudioDrop\"\n            >\n              <div class=\"flex items-center gap-2 px-3 py-2 border-b border-gray-700 shrink-0\">\n                <span class=\"text-xs font-semibold text-gray-400 uppercase tracking-wide flex-1\">Sounds</span>\n                <button\n                  v-if=\"selectedPack\"\n                  class=\"px-2 py-0.5 bg-gray-700/60 rounded hover:bg-gray-600/70 text-xs text-gray-300\"\n                  @click=\"openAddFilePicker\"\n                >Add file</button>\n              </div>\n              <div class=\"flex-1 overflow-y-auto relative\">\n                <!-- Audio file drop overlay -->\n                <div\n                  v-if=\"audioDragOver && selectedPack\"\n                  class=\"absolute inset-0 z-10 flex items-center justify-center bg-indigo-900/60 border-2 border-dashed border-indigo-400 rounded pointer-events-none\"\n                >\n                  <span class=\"text-indigo-200 text-sm font-semibold\">Drop audio files here</span>\n                </div>\n                <div\n                  v-if=\"!selectedPackInfo\"\n                  class=\"flex items-center justify-center h-full text-gray-600 text-sm\"\n                >\n                  Select a pack\n                </div>\n                <div\n                  v-else-if=\"selectedPackInfo.manifest.sounds.length === 0\"\n                  class=\"flex items-center justify-center h-full text-gray-600 text-sm\"\n                >\n                  No sounds in this pack\n                </div>\n                <div\n                  v-for=\"sound in selectedPackInfo.manifest.sounds\"\n                  v-else\n                  :key=\"sound.file\"\n                  draggable=\"true\"\n                  class=\"flex items-center gap-2 px-3 py-1.5 border-b border-gray-800 hover:bg-gray-800/40 cursor-grab transition-colors duration-150\"\n                  :class=\"[\n                    draggingSoundFile === sound.file ? 'opacity-50' : '',\n                    dragOverSoundFile === sound.file ? 'bg-indigo-500/20' : '',\n                    draggingChip ? 'opacity-100' : '',\n                  ]\"\n                  @mouseenter=\"hoveredSoundFile = sound.file\"\n                  @mouseleave=\"hoveredSoundFile = null\"\n                  @dragstart=\"onSoundDragStart($event, sound.file)\"\n                  @dragend=\"onSoundDragEnd\"\n                  @dragover=\"onSoundRowDragOver($event, sound.file)\"\n                  @dragleave=\"onSoundRowDragLeave\"\n                  @drop=\"onSoundRowDrop($event, sound.file)\"\n                >\n                  <!-- Play button -->\n                  <button\n                    class=\"shrink-0 w-6 h-6 flex items-center justify-center rounded text-gray-400 hover:text-white hover:bg-gray-700 text-xs\"\n                    title=\"Play preview\"\n                    @click=\"playPreview(sound.file)\"\n                  >▶</button>\n\n                  <!-- Filename -->\n                  <span class=\"flex-1 text-xs font-mono text-gray-200 truncate min-w-0\">{{ sound.file }}</span>\n\n                  <!-- Broken link indicator -->\n                  <span\n                    v-if=\"soundFileExists.get(sound.file) === false\"\n                    class=\"shrink-0 text-red-400 text-xs\"\n                    title=\"File not found on disk\"\n                  >⚠</span>\n\n                  <!-- Volume slider (visible on hover) -->\n                  <input\n                    v-show=\"hoveredSoundFile === sound.file\"\n                    type=\"range\"\n                    min=\"0\"\n                    max=\"1\"\n                    step=\"0.01\"\n                    :value=\"sound.volume\"\n                    class=\"shrink-0 w-16 accent-indigo-400\"\n                    title=\"Volume\"\n                    @input=\"updateSoundVolume(sound, parseFloat(($event.target as HTMLInputElement).value))\"\n                  />\n\n                  <!-- Enabled toggle -->\n                  <input\n                    type=\"checkbox\"\n                    :checked=\"sound.enabled\"\n                    class=\"shrink-0 w-4 h-4 accent-indigo-400 cursor-pointer\"\n                    title=\"Enable/disable this sound\"\n                    @change=\"updateSoundEnabled(sound, ($event.target as HTMLInputElement).checked)\"\n                  />\n\n                  <!-- Stop button -->\n                  <button\n                    class=\"shrink-0 w-6 h-6 flex items-center justify-center rounded text-xs\"\n                    :class=\"previewFile === sound.file\n                      ? 'text-red-400 hover:text-red-300 hover:bg-gray-700'\n                      : 'text-gray-600 cursor-default'\"\n                    title=\"Stop preview\"\n                    @click=\"previewFile === sound.file ? stopPreview() : undefined\"\n                  >■</button>\n                </div>\n              </div>\n            </div>\n\n            <!-- Events column -->\n            <div class=\"flex-1 flex flex-col min-w-0\">\n              <div class=\"px-3 py-2 border-b border-gray-700 shrink-0\">\n                <span class=\"text-xs font-semibold text-gray-400 uppercase tracking-wide\">Events</span>\n              </div>\n              <div class=\"flex-1 overflow-y-auto\">\n                <div\n                  v-for=\"eventType in AGENT_EVENT_TYPES\"\n                  :key=\"eventType\"\n                  class=\"px-3 py-2 border-b border-gray-800 transition-all duration-200\"\n                  :class=\"[\n                    hasAssignments(eventType) ? 'opacity-100' : 'opacity-40',\n                    flashingEvent === eventType ? 'bg-indigo-600/30' : '',\n                    dragOverEventType === eventType ? 'bg-indigo-500/20 opacity-100' : '',\n                    draggingSoundFile ? 'opacity-100' : '',\n                  ]\"\n                  @dragover=\"onEventDragOver($event, eventType)\"\n                  @dragleave=\"onEventDragLeaveRow\"\n                  @drop=\"onEventDrop($event, eventType)\"\n                >\n                  <div class=\"flex items-center gap-2\">\n                    <span class=\"text-sm font-mono text-gray-300 flex-1\">{{ eventType }}</span>\n                    <!-- Info icon + popover -->\n                    <span\n                      v-if=\"EVENT_DESCRIPTIONS[eventType]\"\n                      class=\"relative shrink-0\"\n                      @click.stop\n                    >\n                      <span\n                        class=\"w-4 h-4 flex items-center justify-center rounded-full border text-[10px] leading-none cursor-pointer select-none\"\n                        :class=\"activeInfoPopover === eventType\n                          ? 'border-indigo-400 text-indigo-300 bg-indigo-900/40'\n                          : 'border-gray-500 text-gray-400 hover:border-gray-300 hover:text-gray-200'\"\n                        @click=\"toggleInfoPopover(eventType)\"\n                      >i</span>\n                      <div\n                        v-if=\"activeInfoPopover === eventType\"\n                        class=\"absolute right-0 top-6 z-50 w-56 bg-gray-800 border border-gray-600 rounded shadow-lg px-3 py-2 text-xs text-gray-200 leading-relaxed\"\n                      >\n                        {{ EVENT_DESCRIPTIONS[eventType] }}\n                      </div>\n                    </span>\n                  </div>\n                  <!-- Assignment chips -->\n                  <div\n                    v-if=\"assignmentsForEvent(eventType).length > 0\"\n                    class=\"flex flex-wrap gap-1 mt-1\"\n                  >\n                    <span\n                      v-for=\"file in assignmentsForEvent(eventType)\"\n                      :key=\"file\"\n                      draggable=\"true\"\n                      class=\"inline-flex items-center gap-1 px-2 py-0.5 bg-gray-700/80 rounded text-xs text-gray-200 cursor-grab hover:bg-gray-600/80\"\n                      :class=\"draggingChip?.file === file && draggingChip?.event === eventType ? 'opacity-50' : ''\"\n                      :title=\"file\"\n                      @click=\"playPreview(file)\"\n                      @dragstart.stop=\"onChipDragStart($event, file, eventType)\"\n                      @dragend=\"onChipDragEnd\"\n                    >\n                      {{ truncateFilename(file) }}\n                      <button\n                        class=\"ml-0.5 text-gray-400 hover:text-red-400 leading-none\"\n                        title=\"Remove assignment\"\n                        @click.stop=\"removeAssignment(file, eventType)\"\n                      >&times;</button>\n                    </span>\n                  </div>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        <!-- Footer -->\n        <div class=\"flex justify-end px-4 py-3 border-t border-gray-700 shrink-0\">\n          <button\n            class=\"px-4 py-1.5 bg-gray-700/60 rounded hover:bg-gray-600/70 text-sm text-gray-200\"\n            @click=\"emit('close')\"\n          >\n            Close\n          </button>\n        </div>\n      </div>\n    </div>\n\n    <!-- Context menu -->\n    <PackContextMenu\n      v-if=\"ctxMenu\"\n      :pack-name=\"ctxMenu.packName\"\n      :x=\"ctxMenu.x\"\n      :y=\"ctxMenu.y\"\n      @close=\"closeCtxMenu\"\n      @renamed=\"onPackRenamed\"\n      @duplicated=\"onPackDuplicated\"\n      @deleted=\"onPackDeleted\"\n    />\n  </Teleport>\n</template>\n","numLines":918,"startLine":1,"totalLines":918}}}
