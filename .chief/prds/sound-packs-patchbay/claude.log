irmRename() {\n    62→  const newName = renameValue.value.trim();\n    63→  if (!newName || newName === props.packName) {\n    64→    renaming.value = false;\n    65→    close();\n    66→    return;\n    67→  }\n    68→\n    69→  const baseDir = soundStore.getSoundPacksDir();\n    70→  const oldPath = `${baseDir}/${props.packName}`;\n    71→  const newPath = `${baseDir}/${newName}`;\n    72→\n    73→  try {\n    74→    await rename(oldPath, newPath);\n    75→\n    76→    // Update activePacks in config\n    77→    const idx = soundStore.config.activePacks.indexOf(props.packName);\n    78→    if (idx >= 0) {\n    79→      soundStore.config.activePacks[idx] = newName;\n    80→    }\n    81→\n    82→    // Move soundOverrides entries to new pack name\n    83→    const oldPrefix = `${props.packName}/`;\n    84→    const newPrefix = `${newName}/`;\n    85→    for (const key of Object.keys(soundStore.config.soundOverrides)) {\n    86→      if (key.startsWith(oldPrefix)) {\n    87→        const filename = key.slice(oldPrefix.length);\n    88→        soundStore.config.soundOverrides[`${newPrefix}${filename}`] =\n    89→          soundStore.config.soundOverrides[key]!;\n    90→        delete soundStore.config.soundOverrides[key];\n    91→      }\n    92→    }\n    93→\n    94→    await soundStore.saveConfig();\n    95→    emit('renamed', props.packName, newName);\n    96→  } catch (err) {\n    97→    console.error('[PackContextMenu] rename failed', err);\n    98→  }\n    99→\n   100→  close();\n   101→}\n   102→\n   103→async function copyDir(srcPath: string, dstPath: string): Promise<void> {\n   104→  await mkdir(dstPath, { recursive: true });\n   105→  const entries = await readDir(srcPath);\n   106→  for (const entry of entries) {\n   107→    if (entry.name === undefined) continue;\n   108→    const srcEntry = `${srcPath}/${entry.name}`;\n   109→    const dstEntry = `${dstPath}/${entry.name}`;\n   110→    if (entry.isDirectory) {\n   111→      await copyDir(srcEntry, dstEntry);\n   112→    } else {\n   113→      const data = await readFile(srcEntry);\n   114→      await writeFile(dstEntry, data);\n   115→    }\n   116→  }\n   117→}\n   118→\n   119→async function duplicate() {\n   120→  const baseDir = soundStore.getSoundPacksDir();\n   121→  const srcPath = `${baseDir}/${props.packName}`;\n   122→  const copyName = `${props.packName} (copy)`;\n   123→  const dstPath = `${baseDir}/${copyName}`;\n   124→\n   125→  try {\n   126→    await copyDir(srcPath, dstPath);\n   127→    emit('duplicated', copyName);\n   128→  } catch (err) {\n   129→    console.error('[PackContextMenu] duplicate failed', err);\n   130→  }\n   131→\n   132→  close();\n   133→}\n   134→\n   135→async function deletePack() {\n   136→  const baseDir = soundStore.getSoundPacksDir();\n   137→  const packPath = `${baseDir}/${props.packName}`;\n   138→\n   139→  try {\n   140→    await remove(packPath, { recursive: true });\n   141→\n   142→    // Remove from activePacks\n   143→    soundStore.config.activePacks = soundStore.config.activePacks.filter(\n   144→      (p) => p !== props.packName,\n   145→    );\n   146→\n   147→    // Remove soundOverrides entries for this pack\n   148→    const prefix = `${props.packName}/`;\n   149→    for (const key of Object.keys(soundStore.config.soundOverrides)) {\n   150→      if (key.startsWith(prefix)) {\n   151→        delete soundStore.config.soundOverrides[key];\n   152→      }\n   153→    }\n   154→\n   155→    await soundStore.saveConfig();\n   156→    emit('deleted', props.packName);\n   157→  } catch (err) {\n   158→    console.error('[PackContextMenu] delete failed', err);\n   159→  }\n   160→\n   161→  close();\n   162→}\n   163→</script>\n   164→\n   165→<template>\n   166→  <Teleport to=\"body\">\n   167→    <div\n   168→      id=\"pack-context-menu\"\n   169→      class=\"fixed z-[200] bg-gray-800 border border-gray-600 rounded shadow-lg py-1 min-w-[140px] text-sm\"\n   170→      :style=\"{ left: `${x}px`, top: `${y}px` }\"\n   171→    >\n   172→      <template v-if=\"renaming\">\n   173→        <div class=\"px-3 py-1\">\n   174→          <input\n   175→            ref=\"renameInput\"\n   176→            v-model=\"renameValue\"\n   177→            class=\"w-full bg-gray-700 border border-gray-500 rounded px-1 py-0.5 text-gray-200 text-xs outline-none\"\n   178→            @keydown.enter.prevent=\"confirmRename\"\n   179→            @keydown.escape.prevent=\"close\"\n   180→            @blur=\"confirmRename\"\n   181→          />\n   182→        </div>\n   183→      </template>\n   184→      <template v-else>\n   185→        <button\n   186→          class=\"w-full text-left px-3 py-1.5 hover:bg-gray-700 text-gray-200\"\n   187→          @click=\"startRename\"\n   188→        >\n   189→          Rename\n   190→        </button>\n   191→        <button\n   192→          class=\"w-full text-left px-3 py-1.5 hover:bg-gray-700 text-gray-200\"\n   193→          @click=\"duplicate\"\n   194→        >\n   195→          Duplicate\n   196→        </button>\n   197→        <button\n   198→          class=\"w-full text-left px-3 py-1.5 hover:bg-gray-700 text-red-400\"\n   199→          @click=\"deletePack\"\n   200→        >\n   201→          Delete\n   202→        </button>\n   203→      </template>\n   204→    </div>\n   205→  </Teleport>\n   206→</template>\n   207→"}]},"parent_tool_use_id":null,"session_id":"3f33bfd1-2c4e-4a38-8c03-42ac89bc40cd","uuid":"c42c6eb8-9e11-4216-87f1-1a3a22b3f9ea","tool_use_result":{"type":"text","file":{"filePath":"/Users/markus/baustelle/projects/agents-in-the-office/agents-in-the-office/.chief/worktrees/sound-packs-patchbay/src/components/PackContextMenu.vue","content":"<script setup lang=\"ts\">\nimport { ref, onMounted, onBeforeUnmount } from 'vue';\nimport {\n  rename,\n  remove,\n  mkdir,\n  readDir,\n  readFile,\n  writeFile,\n} from '@tauri-apps/plugin-fs';\nimport { useSoundStore } from '../stores/soundStore';\n\nconst props = defineProps<{\n  packName: string;\n  x: number;\n  y: number;\n}>();\n\nconst emit = defineEmits<{\n  close: [];\n  renamed: [oldName: string, newName: string];\n  duplicated: [newName: string];\n  deleted: [name: string];\n}>();\n\nconst soundStore = useSoundStore();\nconst renaming = ref(false);\nconst renameValue = ref(props.packName);\nconst renameInput = ref<HTMLInputElement | null>(null);\n\nfunction close() {\n  emit('close');\n}\n\nfunction onKeydown(e: KeyboardEvent) {\n  if (e.key === 'Escape') close();\n}\n\nfunction onOutsideClick(e: MouseEvent) {\n  const el = document.getElementById('pack-context-menu');\n  if (el && !el.contains(e.target as Node)) close();\n}\n\nonMounted(() => {\n  document.addEventListener('mousedown', onOutsideClick);\n  document.addEventListener('keydown', onKeydown);\n});\n\nonBeforeUnmount(() => {\n  document.removeEventListener('mousedown', onOutsideClick);\n  document.removeEventListener('keydown', onKeydown);\n});\n\nfunction startRename() {\n  renaming.value = true;\n  renameValue.value = props.packName;\n  // Focus the input next tick\n  setTimeout(() => renameInput.value?.select(), 0);\n}\n\nasync function confirmRename() {\n  const newName = renameValue.value.trim();\n  if (!newName || newName === props.packName) {\n    renaming.value = false;\n    close();\n    return;\n  }\n\n  const baseDir = soundStore.getSoundPacksDir();\n  const oldPath = `${baseDir}/${props.packName}`;\n  const newPath = `${baseDir}/${newName}`;\n\n  try {\n    await rename(oldPath, newPath);\n\n    // Update activePacks in config\n    const idx = soundStore.config.activePacks.indexOf(props.packName);\n    if (idx >= 0) {\n      soundStore.config.activePacks[idx] = newName;\n    }\n\n    // Move soundOverrides entries to new pack name\n    const oldPrefix = `${props.packName}/`;\n    const newPrefix = `${newName}/`;\n    for (const key of Object.keys(soundStore.config.soundOverrides)) {\n      if (key.startsWith(oldPrefix)) {\n        const filename = key.slice(oldPrefix.length);\n        soundStore.config.soundOverrides[`${newPrefix}${filename}`] =\n          soundStore.config.soundOverrides[key]!;\n        delete soundStore.config.soundOverrides[key];\n      }\n    }\n\n    await soundStore.saveConfig();\n    emit('renamed', props.packName, newName);\n  } catch (err) {\n    console.error('[PackContextMenu] rename failed', err);\n  }\n\n  close();\n}\n\nasync function copyDir(srcPath: string, dstPath: string): Promise<void> {\n  await mkdir(dstPath, { recursive: true });\n  const entries = await readDir(srcPath);\n  for (const entry of entries) {\n    if (entry.name === undefined) continue;\n    const srcEntry = `${srcPath}/${entry.name}`;\n    const dstEntry = `${dstPath}/${entry.name}`;\n    if (entry.isDirectory) {\n      await copyDir(srcEntry, dstEntry);\n    } else {\n      const data = await readFile(srcEntry);\n      await writeFile(dstEntry, data);\n    }\n  }\n}\n\nasync function duplicate() {\n  const baseDir = soundStore.getSoundPacksDir();\n  const srcPath = `${baseDir}/${props.packName}`;\n  const copyName = `${props.packName} (copy)`;\n  const dstPath = `${baseDir}/${copyName}`;\n\n  try {\n    await copyDir(srcPath, dstPath);\n    emit('duplicated', copyName);\n  } catch (err) {\n    console.error('[PackContextMenu] duplicate failed', err);\n  }\n\n  close();\n}\n\nasync function deletePack() {\n  const baseDir = soundStore.getSoundPacksDir();\n  const packPath = `${baseDir}/${props.packName}`;\n\n  try {\n    await remove(packPath, { recursive: true });\n\n    // Remove from activePacks\n    soundStore.config.activePacks = soundStore.config.activePacks.filter(\n      (p) => p !== props.packName,\n    );\n\n    // Remove soundOverrides entries for this pack\n    const prefix = `${props.packName}/`;\n    for (const key of Object.keys(soundStore.config.soundOverrides)) {\n      if (key.startsWith(prefix)) {\n        delete soundStore.config.soundOverrides[key];\n      }\n    }\n\n    await soundStore.saveConfig();\n    emit('deleted', props.packName);\n  } catch (err) {\n    console.error('[PackContextMenu] delete failed', err);\n  }\n\n  close();\n}\n</script>\n\n<template>\n  <Teleport to=\"body\">\n    <div\n      id=\"pack-context-menu\"\n      class=\"fixed z-[200] bg-gray-800 border border-gray-600 rounded shadow-lg py-1 min-w-[140px] text-sm\"\n      :style=\"{ left: `${x}px`, top: `${y}px` }\"\n    >\n      <template v-if=\"renaming\">\n        <div class=\"px-3 py-1\">\n          <input\n            ref=\"renameInput\"\n            v-model=\"renameValue\"\n            class=\"w-full bg-gray-700 border border-gray-500 rounded px-1 py-0.5 text-gray-200 text-xs outline-none\"\n            @keydown.enter.prevent=\"confirmRename\"\n            @keydown.escape.prevent=\"close\"\n            @blur=\"confirmRename\"\n          />\n        </div>\n      </template>\n      <template v-else>\n        <button\n          class=\"w-full text-left px-3 py-1.5 hover:bg-gray-700 text-gray-200\"\n          @click=\"startRename\"\n        >\n          Rename\n        </button>\n        <button\n          class=\"w-full text-left px-3 py-1.5 hover:bg-gray-700 text-gray-200\"\n          @click=\"duplicate\"\n        >\n          Duplicate\n        </button>\n        <button\n          class=\"w-full text-left px-3 py-1.5 hover:bg-gray-700 text-red-400\"\n          @click=\"deletePack\"\n        >\n          Delete\n        </button>\n      </template>\n    </div>\n  </Teleport>\n</template>\n","numLines":207,"startLine":1,"totalLines":207}}}
