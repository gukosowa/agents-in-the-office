{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019JCjvySGxnsDwAaEwV1QR6","type":"tool_result","content":"     1→export type NpcCommand =\n     2→  | { type: 'goto_object'; objectType: string }\n     3→  | { type: 'enter_room' }\n     4→  | { type: 'leave_room' }\n     5→  | { type: 'wander' }\n     6→  | {\n     7→    type: 'set_interacting';\n     8→    objectType: string;\n     9→    duration?: number;\n    10→  };\n    11→\n    12→const MOVEMENT_COMMANDS = new Set<NpcCommand['type']>([\n    13→  'goto_object', 'wander', 'leave_room',\n    14→]);\n    15→\n    16→export function isMovementCommand(cmd: NpcCommand): boolean {\n    17→  return MOVEMENT_COMMANDS.has(cmd.type);\n    18→}\n    19→\n    20→export type AgentEventType =\n    21→  | 'session_start'\n    22→  | 'session_end'\n    23→  | 'prompt_submit'\n    24→  | 'tool_start'\n    25→  | 'tool_end'\n    26→  | 'turn_end'\n    27→  | 'permission_wait'\n    28→  | 'subagent_start'\n    29→  | 'subagent_end'\n    30→  | 'idle_notification'\n    31→  | 'elicitation_wait'\n    32→  | 'auth_success'\n    33→  | 'worktree_create'\n    34→  | 'worktree_remove'\n    35→  | 'teammate_idle'\n    36→  | 'task_completed';\n    37→\n    38→export type AgentType = 'claude_code' | 'gemini' | 'codex';\n    39→\n    40→export interface AgentEvent {\n    41→  sessionId: string;\n    42→  timestamp: number;\n    43→  type: AgentEventType;\n    44→  agentType: AgentType;\n    45→  payload: Record<string, unknown>;\n    46→}\n    47→\n    48→export interface NpcHandle {\n    49→  gotoObject(type: string): void;\n    50→  enterRoom(): void;\n    51→  leaveRoom(): void;\n    52→  wander(): void;\n    53→  showBubble(\n    54→    text: string,\n    55→    type: 'speech' | 'thought',\n    56→    persist?: boolean,\n    57→  ): void;\n    58→  setToolBubble(walking: string, arrived: string): void;\n    59→  setWaitingForApproval(waiting: boolean): void;\n    60→  setInteracting(\n    61→    objectType: strin