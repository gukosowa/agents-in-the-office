{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HXPLA9JyxcTo3JeSfP99Db","type":"tool_result","content":"     1→<script setup lang=\"ts\">\n     2→import {\n     3→  ref,\n     4→  computed,\n     5→  watch,\n     6→  nextTick,\n     7→  onMounted,\n     8→} from 'vue';\n     9→import { open } from '@tauri-apps/plugin-dialog';\n    10→import {\n    11→  mkdir,\n    12→  readFile,\n    13→  writeFile,\n    14→} from '@tauri-apps/plugin-fs';\n    15→import JSZip from 'jszip';\n    16→import { useSoundStore, AGENT_EVENT_TYPES } from '../stores/soundStore';\n    17→import type { AgentEventType } from '../drivers/types';\n    18→import PackContextMenu from './PackContextMenu.vue';\n    19→\n    20→const emit = defineEmits<{ close: [] }>();\n    21→\n    22→const soundStore = useSoundStore();\n    23→\n    24→// ---- Global settings ----\n    25→const globalEnabled = computed({\n    26→  get: () => soundStore.config.enabled,\n    27→  set: (v: boolean) => { soundStore.config.enabled = v; void soundStore.saveConfig(); },\n    28→});\n    29→const globalVolume = computed({\n    30→  get: () => Math.round(soundStore.config.globalVolume * 100),\n    31→  set: (v: number) => { soundStore.config.globalVolume = v / 100; void soundStore.saveConfig(); },\n    32→});\n    33→const cooldown = computed({\n    34→  get: () => soundStore.config.cooldownSeconds,\n    35→  set: (v: number) => { soundStore.config.cooldownSeconds = v; void soundStore.saveConfig(); },\n    36→});\n    37→\n    38→// ---- Pack list ----\n    39→const selectedPack = ref<string | null>(null);\n    40→const rightPanel = ref<HTMLElement | null>(null);\n    41→\n    42→onMounted(async () => {\n    43→  await soundStore.init();\n    44→  await soundStore.scanPacks();\n    45→  if (soundStore.packs.length > 0 && soundStore.packs[0]) {\n    46→    selectedPack.value = soundStore.packs[0].name;\n    47→  }\n    48→});\n    49→\n    50→function isPackActive(packName: string): boolean {\n    51→  return soundStore.config.activePacks.includes(packName);\n    52→}\n    53→\n    54→function togglePackActive(packName: string, active: boolean) {\n    55→  if (active) {\n    56→    if (!soundStore.config.activePacks.includes(packName)) {\n    57→      soundStore.config.activePacks.push(packName);\n    58→    }\n    59→  } else {\n    60→    soundStore.config.activePacks = soundStore.config.activePacks.filter(\n    61→      (p) => p !== packName,\n    62→    );\n    63→  }\n    64→  void soundStore.saveConfig();\n    65→}\n    66→\n    67→function selectPack(name: string) {\n    68→  selectedPack.value = name;\n    69→  void nextTick(() => {\n    70→    if (rightPanel.value) rightPanel.value.scrollTop = 0;\n    71→  });\n    72→}\n    73→\n    74→// ---- Context menu ----\n    75→const ctxMenu = ref<{ packName: string; x: number; y: number } | null>(null);\n    76→\n    77→function onPackRightClick(e: MouseEvent, packName: string) {\n    78→  e.preventDefault();\n    79→  ctxMenu.value = { packName, x: e.clientX, y: e.clientY };\n    80→}\n    81→\n    82→function closeCtxMenu() {\n    83→  ctxMenu.value = null;\n    84→}\n    85→\n    86→async function onPackRenamed(oldName: string, newName: string) {\n    87→  await soundStore.scanPacks();\n    88→  if (selectedPack.value === oldName) selectedPack.value = newName;\n    89→  closeCtxMenu();\n    90→}\n    91→\n    92→async function onPackDuplicated() {\n    93→  await soundStore.scanPacks();\n    94→  closeCtxMenu();\n    95→}\n    96→\n    97→async function onPackDeleted(name: string) {\n    98→  await soundStore.scanPacks();\n    99→  if (selectedPack.value === name) {\n   100→    selectedPack.value = soundStore.packs[0]?.name ?? null;\n   101→  }\n   102→  closeCtxMenu();\n   103→}\n   104→\n   105→// ---- New pack ----\n   106→const newPackName = ref('');\n   107→const creatingPack = ref(false);\n   108→const newPackInput = ref<HTMLInputElement | null>(null);\n   109→\n   110→function startCreatePack() {\n   111→  creatingPack.value = true;\n   112→  newPackName.value = '';\n   113→  void nextTick(() => newPackInput.value?.focus());\n   114→}\n   115→\n   116→function cancelCreatePack() {\n   117→  creatingPack.value = false;\n   118→  newPackName.value = '';\n   119→}\n   120→\n   121→async function confirmCreatePack() {\n   122→  const packName = newPackName.value.trim();\n   123→  if (!packName) return;\n   124→  creatingPack.value = false;\n   125→  newPackName.value = '';\n   126→  const baseDir = soundStore.getSoundPacksDir();\n   127→  const packPath = `${baseDir}/${packName}`;\n   128→  try {\n   129→    await mkdir(packPath, { recursive: true });\n   130→    for (const eventType of AGENT_EVENT_TYPES) {\n   131→      await mkdir(`${packPath}/${eventType}`, { recursive: true });\n   132→    }\n   133→    await soundStore.scanPacks();\n   134→    selectedPack.value = packName;\n   135→  } catch (err) {\n   136→    console.error('[SoundsDialog] createNewPack failed', err);\n   137→  }\n   138→}\n   139→\n   140→// ---- Import zip ----\n   141→const dragOver = ref(false);\n   142→\n   143→async function importZipBytes(filename: string, bytes: Uint8Array): Promise<void> {\n   144→  const dotIdx = filename.lastIndexOf('.');\n   145→  const packName = dotIdx > 0 ? filename.slice(0, dotIdx) : filename;\n   146→  const baseDir = soundStore.getSoundPacksDir();\n   147→  const packPath = `${baseDir}/${packName}`;\n   148→\n   149→  const zip = await JSZip.loadAsync(bytes);\n   150→  for (const [relativePath, file] of Object.entries(zip.files)) {\n   151→    if (file.dir) {\n   152→      await mkdir(`${packPath}/${relativePath}`, { recursive: true });\n   153→    } else {\n   154→      const data = await file.async('uint8array');\n   155→      const dirPart = relativePath.includes('/')\n   156→        ? relativePath.slice(0, relativePath.lastIndexOf('/'))\n   157→        : '';\n   158→      if (dirPart) {\n   159→        await mkdir(`${packPath}/${dirPart}`, { recursive: true });\n   160→      }\n   161→      await writeFile(`${packPath}/${relativePath}`, data);\n   162→    }\n   163→  }\n   164→\n   165→  await soundStore.scanPacks();\n   166→  selectedPack.value = packName;\n   167→}\n   168→\n   169→async function openImportPicker() {\n   170→  const result = await open({\n   171→    filters: [{ name: 'ZIP', extensions: ['zip'] }],\n   172→    multiple: false,\n   173→  });\n   174→  if (!result) return;\n   175→  const filePath = typeof result === 'string' ? result : result;\n   176→  if (!filePath) return;\n   177→  try {\n   178→    const bytes = await readFile(filePath);\n   179→    const filename = (filePath as string).split('/').pop() ?? 'pack.zip';\n   180→    await importZipBytes(filename, bytes);\n   181→  } catch (err) {\n   182→    console.error('[SoundsDialog] import failed', err);\n   183→  }\n   184→}\n   185→\n   186→function onDragOver(e: DragEvent) {\n   187→  e.preventDefault();\n   188→  dragOver.value = true;\n   189→}\n   190→\n   191→function onDragLeave() {\n   192→  dragOver.value = false;\n   193→}\n   194→\n   195→async function onDrop(e: DragEvent) {\n   196→  e.preventDefault();\n   197→  dragOver.value = false;\n   198→  const file = e.dataTransfer?.files[0];\n   199→  if (!file) return;\n   200→  try {\n   201→    const arrayBuffer = await file.arrayBuffer();\n   202→    await importZipBytes(file.name, new Uint8Array(arrayBuffer));\n   203→  } catch (err) {\n   204→    console.error('[SoundsDialog] drop import failed', err);\n   205→  }\n   206→}\n   207→\n   208→// ---- Event descriptions ----\n   209→const EVENT_DESCRIPTIONS: Record<string, string> = {\n   210→  session_start: 'Agent session begins.',\n   211→  session_end: 'Agent session ends or is interrupted.',\n   212→  prompt_submit: 'User submits a prompt to the agent.',\n   213→  tool_start: 'Agent begins executing a tool (e.g. Bash, Read, Edit).',\n   214→  tool_end: 'Agent finishes executing a tool.',\n   215→  turn_end: 'Agent completes a full response turn.',\n   216→  permission_wait: 'Agent pauses waiting for the user to approve a tool call.',\n   217→  subagent_start: 'A subagent is spawned by the parent agent.',\n   218→  subagent_end: 'A subagent finishes its work.',\n   219→  idle_notification: 'Agent has been idle and sends a nudge notification.',\n   220→  elicitation_wait: 'Agent pauses waiting for user input.',\n   221→  auth_success: 'Authentication to an external service succeeds.',\n   222→  worktree_create: 'A new git worktree is created.',\n   223→  worktree_remove: 'A git worktree is removed.',\n   224→  teammate_idle: \"A teammate's agent session goes idle.\",\n   225→  task_completed: 'Agent marks a task as completed.',\n   226→};\n   227→\n   228→const activeInfoPopover = ref<string | null>(null);\n   229→\n   230→function toggleInfoPopover(eventType: string) {\n   231→  activeInfoPopover.value = activeInfoPopover.value === eventType ? null : eventType;\n   232→}\n   233→\n   234→// ---- Patchbay data ----\n   235→const selectedPackInfo = computed(() =>\n   236→  soundStore.packs.find((p) => p.name === selectedPack.value) ?? null,\n   237→);\n   238→\n   239→function hasAssignments(eventType: AgentEventType): boolean {\n   240→  if (!selectedPackInfo.value) return false;\n   241→  return selectedPackInfo.value.manifest.assignments.some((a) => a.event === eventType);\n   242→}\n   243→\n   244→// Reset scroll on pack change\n   245→watch(selectedPack, async () => {\n   246→  await nextTick(() => {\n   247→    if (rightPanel.value) rightPanel.value.scrollTop = 0;\n   248→  });\n   249→});\n   250→\n   251→</script>\n   252→\n   253→<template>\n   254→  <Teleport to=\"body\">\n   255→    <!-- Backdrop -->\n   256→    <div class=\"fixed inset-0 z-[100] flex items-center justify-center bg-black/50\">\n   257→      <!-- Drop zone wrapper -->\n   258→      <div\n   259→        class=\"relative w-[960px] max-w-[90vw] h-[700px] max-h-[90vh] flex flex-col bg-gray-900 border border-gray-700 rounded-lg shadow-2xl overflow-hidden\"\n   260→        @dragover=\"onDragOver\"\n   261→        @dragleave=\"onDragLeave\"\n   262→        @drop=\"onDrop\"\n   263→      >\n   264→        <!-- Drag overlay -->\n   265→        <div\n   266→          v-if=\"dragOver\"\n   267→          class=\"absolute inset-0 z-[150] flex items-center justify-center bg-indigo-900/80 border-2 border-dashed border-indigo-400 rounded-lg pointer-events-none\"\n   268→        >\n   269→          <span class=\"text-indigo-200 text-lg font-semibold\">Drop sound pack here</span>\n   270→        </div>\n   271→\n   272→        <!-- Header -->\n   273→        <div class=\"flex items-center gap-4 px-4 py-3 border-b border-gray-700 shrink-0\">\n   274→          <span class=\"text-gray-200 font-semibold text-sm\">Sounds</span>\n   275→\n   276→          <!-- Master enable -->\n   277→          <label class=\"flex items-center gap-1.5 text-xs text-gray-300 cursor-pointer\">\n   278→            <input\n   279→              type=\"checkbox\"\n   280→              :checked=\"globalEnabled\"\n   281→              class=\"w-4 h-4 accent-indigo-400\"\n   282→              @change=\"globalEnabled = ($event.target as HTMLInputElement).checked\"\n   283→            />\n   284→            Enable\n   285→          </label>\n   286→\n   287→          <!-- Global volume -->\n   288→          <label class=\"flex items-center gap-1.5 text-xs text-gray-300\">\n   289→            Vol\n   290→            <input\n   291→              type=\"range\"\n   292→              min=\"0\"\n   293→              max=\"100\"\n   294→              :value=\"globalVolume\"\n   295→              class=\"w-24 accent-indigo-400\"\n   296→              @input=\"globalVolume = parseInt(($event.target as HTMLInputElement).value)\"\n   297→            />\n   298→            <span class=\"w-7 tabular-nums\">{{ globalVolume }}%</span>\n   299→          </label>\n   300→\n   301→          <!-- Cooldown -->\n   302→          <label class=\"flex items-center gap-1.5 text-xs text-gray-300\">\n   303→            Cooldown\n   304→            <input\n   305→              type=\"range\"\n   306→              min=\"0\"\n   307→              max=\"10\"\n   308→              step=\"0.5\"\n   309→              :value=\"cooldown\"\n   310→              class=\"w-20 accent-indigo-400\"\n   311→              @input=\"cooldown = parseFloat(($event.target as HTMLInputElement).value)\"\n   312→            />\n   313→            <span class=\"w-8 tabular-nums\">{{ cooldown }}s</span>\n   314→          </label>\n   315→        </div>\n   316→\n   317→        <!-- Body -->\n   318→        <div class=\"flex flex-1 min-h-0\">\n   319→          <!-- Left panel: pack list -->\n   320→          <div class=\"w-60 shrink-0 border-r border-gray-700 flex flex-col\">\n   321→            <div class=\"px-3 pt-2 pb-1 text-xs font-semibold text-gray-400 uppercase tracking-wide\">\n   322→              Packs\n   323→            </div>\n   324→            <div class=\"flex-1 overflow-y-auto\">\n   325→              <div\n   326→                v-for=\"pack in soundStore.packs\"\n   327→                :key=\"pack.name\"\n   328→                class=\"flex items-center gap-2 px-2 py-1.5 cursor-pointer rounded mx-1\"\n   329→                :class=\"selectedPack === pack.name ? 'bg-gray-700' : 'hover:bg-gray-800'\"\n   330→                @click=\"selectPack(pack.name)\"\n   331→                @contextmenu=\"onPackRightClick($event, pack.name)\"\n   332→              >\n   333→                <input\n   334→                  type=\"checkbox\"\n   335→                  :checked=\"isPackActive(pack.name)\"\n   336→                  class=\"w-4 h-4 accent-indigo-400 cursor-pointer\"\n   337→                  @click.stop\n   338→                  @change=\"togglePackActive(pack.name, ($event.target as HTMLInputElement).checked)\"\n   339→                />\n   340→                <span class=\"text-sm text-gray-200 truncate flex-1\">{{ pack.name }}</span>\n   341→              </div>\n   342→            </div>\n   343→            <!-- Buttons / new pack input -->\n   344→            <div class=\"flex flex-col gap-1 p-2 border-t border-gray-700\">\n   345→              <div v-if=\"creatingPack\" class=\"flex gap-1\">\n   346→                <input\n   347→                  ref=\"newPackInput\"\n   348→                  v-model=\"newPackName\"\n   349→                  class=\"flex-1 px-2 py-1 bg-gray-800 border border-gray-600 rounded text-xs text-gray-200 outline-none focus:border-indigo-400\"\n   350→                  placeholder=\"Pack name…\"\n   351→                  @keydown.enter=\"confirmCreatePack\"\n   352→                  @keydown.escape=\"cancelCreatePack\"\n   353→                />\n   354→                <button\n   355→                  class=\"px-2 py-1 bg-indigo-600/80 rounded hover:bg-indigo-500 text-xs text-white\"\n   356→                  @click=\"confirmCreatePack\"\n   357→                >OK</button>\n   358→              </div>\n   359→              <div class=\"flex gap-1\">\n   360→                <button\n   361→                  class=\"flex-1 px-2 py-1 bg-gray-700/60 rounded hover:bg-gray-600/70 text-xs text-gray-200\"\n   362→                  @click=\"startCreatePack\"\n   363→                >\n   364→                  New Pack\n   365→                </button>\n   366→                <button\n   367→                  class=\"flex-1 px-2 py-1 bg-gray-700/60 rounded hover:bg-gray-600/70 text-xs text-gray-200\"\n   368→                  @click=\"openImportPicker\"\n   369→                >\n   370→                  Import\n   371→                </button>\n   372→              </div>\n   373→            </div>\n   374→          </div>\n   375→\n   376→          <!-- Patchbay: Sounds + Events columns -->\n   377→          <div ref=\"rightPanel\" class=\"flex flex-1 min-h-0 overflow-hidden\">\n   378→            <!-- Sounds column -->\n   379→            <div class=\"flex-1 border-r border-gray-700 flex flex-col min-w-0\">\n   380→              <div class=\"px-3 py-2 border-b border-gray-700 shrink-0\">\n   381→                <span class=\"text-xs font-semibold text-gray-400 uppercase tracking-wide\">Sounds</span>\n   382→              </div>\n   383→              <div class=\"flex-1 overflow-y-auto\">\n   384→                <div\n   385→                  v-if=\"!selectedPackInfo\"\n   386→                  class=\"flex items-center justify-center h-full text-gray-600 text-sm\"\n   387→                >\n   388→                  Select a pack\n   389→                </div>\n   390→                <!-- US-005 will populate sound file list here -->\n   391→              </div>\n   392→            </div>\n   393→\n   394→            <!-- Events column -->\n   395→            <div class=\"flex-1 flex flex-col min-w-0\">\n   396→              <div class=\"px-3 py-2 border-b border-gray-700 shrink-0\">\n   397→                <span class=\"text-xs font-semibold text-gray-400 uppercase tracking-wide\">Events</span>\n   398→              </div>\n   399→              <div class=\"flex-1 overflow-y-auto\">\n   400→                <div\n   401→                  v-for=\"eventType in AGENT_EVENT_TYPES\"\n   402→                  :key=\"eventType\"\n   403→                  class=\"flex items-center gap-2 px-3 py-2 border-b border-gray-800 transition-opacity\"\n   404→                  :class=\"hasAssignments(eventType) ? 'opacity-100' : 'opacity-40'\"\n   405→                >\n   406→                  <span class=\"text-sm font-mono text-gray-300 flex-1\">{{ eventType }}</span>\n   407→                  <!-- Info icon + popover -->\n   408→                  <span\n   409→                    v-if=\"EVENT_DESCRIPTIONS[eventType]\"\n   410→                    class=\"relative shrink-0\"\n   411→                    @click.stop\n   412→                  >\n   413→                    <span\n   414→                      class=\"w-4 h-4 flex items-center justify-center rounded-full border text-[10px] leading-none cursor-pointer select-none\"\n   415→                      :class=\"activeInfoPopover === eventType\n   416→                        ? 'border-indigo-400 text-indigo-300 bg-indigo-900/40'\n   417→                        : 'border-gray-500 text-gray-400 hover:border-gray-300 hover:text-gray-200'\"\n   418→                      @click=\"toggleInfoPopover(eventType)\"\n   419→                    >i</span>\n   420→                    <div\n   421→                      v-if=\"activeInfoPopover === eventType\"\n   422→                      class=\"absolute right-0 top-6 z-50 w-56 bg-gray-800 border border-gray-600 rounded shadow-lg px-3 py-2 text-xs text-gray-200 leading-relaxed\"\n   423→                    >\n   424→                      {{ EVENT_DESCRIPTIONS[eventType] }}\n   425→                    </div>\n   426→                  </span>\n   427→                  <!-- US-006 will add assignment chips here -->\n   428→                </div>\n   429→              </div>\n   430→            </div>\n   431→          </div>\n   432→        </div>\n   433→\n   434→        <!-- Footer -->\n   435→        <div class=\"flex justify-end px-4 py-3 border-t border-gray-700 shrink-0\">\n   436→          <button\n   437→            class=\"px-4 py-1.5 bg-gray-700/60 rounded hover:bg-gray-600/70 text-sm text-gray-200\"\n   438→            @click=\"emit('close')\"\n   439→          >\n   440→            Close\n   441→          </button>\n   442→        </div>\n   443→      </div>\n   444→    </div>\n   445→\n   446→    <!-- Context menu -->\n   447→    <PackContextMenu\n   448→      v-if=\"ctxMenu\"\n   449→      :pack-name=\"ctxMenu.packName\"\n   450→      :x=\"ctxMenu.x\"\n   451→      :y=\"ctxMenu.y\"\n   452→      @close=\"closeCtxMenu\"\n   453→      @renamed=\"onPackRenamed\"\n   454→      @duplicated=\"onPackDuplicated\"\n   455→      @deleted=\"onPackDeleted\"\n   456→    />\n   457→  </Teleport>\n   458→</template>\n   459→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"eae6a30b-1237-4ce9-9fa6-6067807ffb87","uuid":"819da2b2-210c-4b2a-bb9f-ef3f72294a60","tool_use_result":{"type":"text","file":{"filePath":"/Users/markus/baustelle/projects/agents-in-the-office/agents-in-the-office/.chief/worktrees/sound-packs-patchbay/src/components/SoundsDialog.vue","content":"<script setup lang=\"ts\">\nimport {\n  ref,\n  computed,\n  watch,\n  nextTick,\n  onMounted,\n} from 'vue';\nimport { open } from '@tauri-apps/plugin-dialog';\nimport {\n  mkdir,\n  readFile,\n  writeFile,\n} from '@tauri-apps/plugin-fs';\nimport JSZip from 'jszip';\nimport { useSoundStore, AGENT_EVENT_TYPES } from '../stores/soundStore';\nimport type { AgentEventType } from '../drivers/types';\nimport PackContextMenu from './PackContextMenu.vue';\n\nconst emit = defineEmits<{ close: [] }>();\n\nconst soundStore = useSoundStore();\n\n// ---- Global settings ----\nconst globalEnabled = computed({\n  get: () => soundStore.config.enabled,\n  set: (v: boolean) => { soundStore.config.enabled = v; void soundStore.saveConfig(); },\n});\nconst globalVolume = computed({\n  get: () => Math.round(soundStore.config.globalVolume * 100),\n  set: (v: number) => { soundStore.config.globalVolume = v / 100; void soundStore.saveConfig(); },\n});\nconst cooldown = computed({\n  get: () => soundStore.config.cooldownSeconds,\n  set: (v: number) => { soundStore.config.cooldownSeconds = v; void soundStore.saveConfig(); },\n});\n\n// ---- Pack list ----\nconst selectedPack = ref<string | null>(null);\nconst rightPanel = ref<HTMLElement | null>(null);\n\nonMounted(async () => {\n  await soundStore.init();\n  await soundStore.scanPacks();\n  if (soundStore.packs.length > 0 && soundStore.packs[0]) {\n    selectedPack.value = soundStore.packs[0].name;\n  }\n});\n\nfunction isPackActive(packName: string): boolean {\n  return soundStore.config.activePacks.includes(packName);\n}\n\nfunction togglePackActive(packName: string, active: boolean) {\n  if (active) {\n    if (!soundStore.config.activePacks.includes(packName)) {\n      soundStore.config.activePacks.push(packName);\n    }\n  } else {\n    soundStore.config.activePacks = soundStore.config.activePacks.filter(\n      (p) => p !== packName,\n    );\n  }\n  void soundStore.saveConfig();\n}\n\nfunction selectPack(name: string) {\n  selectedPack.value = name;\n  void nextTick(() => {\n    if (rightPanel.value) rightPanel.value.scrollTop = 0;\n  });\n}\n\n// ---- Context menu ----\nconst ctxMenu = ref<{ packName: string; x: number; y: number } | null>(null);\n\nfunction onPackRightClick(e: MouseEvent, packName: string) {\n  e.preventDefault();\n  ctxMenu.value = { packName, x: e.clientX, y: e.clientY };\n}\n\nfunction closeCtxMenu() {\n  ctxMenu.value = null;\n}\n\nasync function onPackRenamed(oldName: string, newName: string) {\n  await soundStore.scanPacks();\n  if (selectedPack.value === oldName) selectedPack.value = newName;\n  closeCtxMenu();\n}\n\nasync function onPackDuplicated() {\n  await soundStore.scanPacks();\n  closeCtxMenu();\n}\n\nasync function onPackDeleted(name: string) {\n  await soundStore.scanPacks();\n  if (selectedPack.value === name) {\n    selectedPack.value = soundStore.packs[0]?.name ?? null;\n  }\n  closeCtxMenu();\n}\n\n// ---- New pack ----\nconst newPackName = ref('');\nconst creatingPack = ref(false);\nconst newPackInput = ref<HTMLInputElement | null>(null);\n\nfunction startCreatePack() {\n  creatingPack.value = true;\n  newPackName.value = '';\n  void nextTick(() => newPackInput.value?.focus());\n}\n\nfunction cancelCreatePack() {\n  creatingPack.value = false;\n  newPackName.value = '';\n}\n\nasync function confirmCreatePack() {\n  const packName = newPackName.value.trim();\n  if (!packName) return;\n  creatingPack.value = false;\n  newPackName.value = '';\n  const baseDir = soundStore.getSoundPacksDir();\n  const packPath = `${baseDir}/${packName}`;\n  try {\n    await mkdir(packPath, { recursive: true });\n    for (const eventType of AGENT_EVENT_TYPES) {\n      await mkdir(`${packPath}/${eventType}`, { recursive: true });\n    }\n    await soundStore.scanPacks();\n    selectedPack.value = packName;\n  } catch (err) {\n    console.error('[SoundsDialog] createNewPack failed', err);\n  }\n}\n\n// ---- Import zip ----\nconst dragOver = ref(false);\n\nasync function importZipBytes(filename: string, bytes: Uint8Array): Promise<void> {\n  const dotIdx = filename.lastIndexOf('.');\n  const packName = dotIdx > 0 ? filename.slice(0, dotIdx) : filename;\n  const baseDir = soundStore.getSoundPacksDir();\n  const packPath = `${baseDir}/${packName}`;\n\n  const zip = await JSZip.loadAsync(bytes);\n  for (const [relativePath, file] of Object.entries(zip.files)) {\n    if (file.dir) {\n      await mkdir(`${packPath}/${relativePath}`, { recursive: true });\n    } else {\n      const data = await file.async('uint8array');\n      const dirPart = relativePath.includes('/')\n        ? relativePath.slice(0, relativePath.lastIndexOf('/'))\n        : '';\n      if (dirPart) {\n        await mkdir(`${packPath}/${dirPart}`, { recursive: true });\n      }\n      await writeFile(`${packPath}/${relativePath}`, data);\n    }\n  }\n\n  await soundStore.scanPacks();\n  selectedPack.value = packName;\n}\n\nasync function openImportPicker() {\n  const result = await open({\n    filters: [{ name: 'ZIP', extensions: ['zip'] }],\n    multiple: false,\n  });\n  if (!result) return;\n  const filePath = typeof result === 'string' ? result : result;\n  if (!filePath) return;\n  try {\n    const bytes = await readFile(filePath);\n    const filename = (filePath as string).split('/').pop() ?? 'pack.zip';\n    await importZipBytes(filename, bytes);\n  } catch (err) {\n    console.error('[SoundsDialog] import failed', err);\n  }\n}\n\nfunction onDragOver(e: DragEvent) {\n  e.preventDefault();\n  dragOver.value = true;\n}\n\nfunction onDragLeave() {\n  dragOver.value = false;\n}\n\nasync function onDrop(e: DragEvent) {\n  e.preventDefault();\n  dragOver.value = false;\n  const file = e.dataTransfer?.files[0];\n  if (!file) return;\n  try {\n    const arrayBuffer = await file.arrayBuffer();\n    await importZipBytes(file.name, new Uint8Array(arrayBuffer));\n  } catch (err) {\n    console.error('[SoundsDialog] drop import failed', err);\n  }\n}\n\n// ---- Event descriptions ----\nconst EVENT_DESCRIPTIONS: Record<string, string> = {\n  session_start: 'Agent session begins.',\n  session_end: 'Agent session ends or is interrupted.',\n  prompt_submit: 'User submits a prompt to the agent.',\n  tool_start: 'Agent begins executing a tool (e.g. Bash, Read, Edit).',\n  tool_end: 'Agent finishes executing a tool.',\n  turn_end: 'Agent completes a full response turn.',\n  permission_wait: 'Agent pauses waiting for the user to approve a tool call.',\n  subagent_start: 'A subagent is spawned by the parent agent.',\n  subagent_end: 'A subagent finishes its work.',\n  idle_notification: 'Agent has been idle and sends a nudge notification.',\n  elicitation_wait: 'Agent pauses waiting for user input.',\n  auth_success: 'Authentication to an external service succeeds.',\n  worktree_create: 'A new git worktree is created.',\n  worktree_remove: 'A git worktree is removed.',\n  teammate_idle: \"A teammate's agent session goes idle.\",\n  task_completed: 'Agent marks a task as completed.',\n};\n\nconst activeInfoPopover = ref<string | null>(null);\n\nfunction toggleInfoPopover(eventType: string) {\n  activeInfoPopover.value = activeInfoPopover.value === eventType ? null : eventType;\n}\n\n// ---- Patchbay data ----\nconst selectedPackInfo = computed(() =>\n  soundStore.packs.find((p) => p.name === selectedPack.value) ?? null,\n);\n\nfunction hasAssignments(eventType: AgentEventType): boolean {\n  if (!selectedPackInfo.value) return false;\n  return selectedPackInfo.value.manifest.assignments.some((a) => a.event === eventType);\n}\n\n// Reset scroll on pack change\nwatch(selectedPack, async () => {\n  await nextTick(() => {\n    if (rightPanel.value) rightPanel.value.scrollTop = 0;\n  });\n});\n\n</script>\n\n<template>\n  <Teleport to=\"body\">\n    <!-- Backdrop -->\n    <div class=\"fixed inset-0 z-[100] flex items-center justify-center bg-black/50\">\n      <!-- Drop zone wrapper -->\n      <div\n        class=\"relative w-[960px] max-w-[90vw] h-[700px] max-h-[90vh] flex flex-col bg-gray-900 border border-gray-700 rounded-lg shadow-2xl overflow-hidden\"\n        @dragover=\"onDragOver\"\n        @dragleave=\"onDragLeave\"\n        @drop=\"onDrop\"\n      >\n        <!-- Drag overlay -->\n        <div\n          v-if=\"dragOver\"\n          class=\"absolute inset-0 z-[150] flex items-center justify-center bg-indigo-900/80 border-2 border-dashed border-indigo-400 rounded-lg pointer-events-none\"\n        >\n          <span class=\"text-indigo-200 text-lg font-semibold\">Drop sound pack here</span>\n        </div>\n\n        <!-- Header -->\n        <div class=\"flex items-center gap-4 px-4 py-3 border-b border-gray-700 shrink-0\">\n          <span class=\"text-gray-200 font-semibold text-sm\">Sounds</span>\n\n          <!-- Master enable -->\n          <label class=\"flex items-center gap-1.5 text-xs text-gray-300 cursor-pointer\">\n            <input\n              type=\"checkbox\"\n              :checked=\"globalEnabled\"\n              class=\"w-4 h-4 accent-indigo-400\"\n              @change=\"globalEnabled = ($event.target as HTMLInputElement).checked\"\n            />\n            Enable\n          </label>\n\n          <!-- Global volume -->\n          <label class=\"flex items-center gap-1.5 text-xs text-gray-300\">\n            Vol\n            <input\n              type=\"range\"\n              min=\"0\"\n              max=\"100\"\n              :value=\"globalVolume\"\n              class=\"w-24 accent-indigo-400\"\n              @input=\"globalVolume = parseInt(($event.target as HTMLInputElement).value)\"\n            />\n            <span class=\"w-7 tabular-nums\">{{ globalVolume }}%</span>\n          </label>\n\n          <!-- Cooldown -->\n          <label class=\"flex items-center gap-1.5 text-xs text-gray-300\">\n            Cooldown\n            <input\n              type=\"range\"\n              min=\"0\"\n              max=\"10\"\n              step=\"0.5\"\n              :value=\"cooldown\"\n              class=\"w-20 accent-indigo-400\"\n              @input=\"cooldown = parseFloat(($event.target as HTMLInputElement).value)\"\n            />\n            <span class=\"w-8 tabular-nums\">{{ cooldown }}s</span>\n          </label>\n        </div>\n\n        <!-- Body -->\n        <div class=\"flex flex-1 min-h-0\">\n          <!-- Left panel: pack list -->\n          <div class=\"w-60 shrink-0 border-r border-gray-700 flex flex-col\">\n            <div class=\"px-3 pt-2 pb-1 text-xs font-semibold text-gray-400 uppercase tracking-wide\">\n              Packs\n            </div>\n            <div class=\"flex-1 overflow-y-auto\">\n              <div\n                v-for=\"pack in soundStore.packs\"\n                :key=\"pack.name\"\n                class=\"flex items-center gap-2 px-2 py-1.5 cursor-pointer rounded mx-1\"\n                :class=\"selectedPack === pack.name ? 'bg-gray-700' : 'hover:bg-gray-800'\"\n                @click=\"selectPack(pack.name)\"\n                @contextmenu=\"onPackRightClick($event, pack.name)\"\n              >\n                <input\n                  type=\"checkbox\"\n                  :checked=\"isPackActive(pack.name)\"\n                  class=\"w-4 h-4 accent-indigo-400 cursor-pointer\"\n                  @click.stop\n                  @change=\"togglePackActive(pack.name, ($event.target as HTMLInputElement).checked)\"\n                />\n                <span class=\"text-sm text-gray-200 truncate flex-1\">{{ pack.name }}</span>\n              </div>\n            </div>\n            <!-- Buttons / new pack input -->\n            <div class=\"flex flex-col gap-1 p-2 border-t border-gray-700\">\n              <div v-if=\"creatingPack\" class=\"flex gap-1\">\n                <input\n                  ref=\"newPackInput\"\n                  v-model=\"newPackName\"\n                  class=\"flex-1 px-2 py-1 bg-gray-800 border border-gray-600 rounded text-xs text-gray-200 outline-none focus:border-indigo-400\"\n                  placeholder=\"Pack name…\"\n                  @keydown.enter=\"confirmCreatePack\"\n                  @keydown.escape=\"cancelCreatePack\"\n                />\n                <button\n                  class=\"px-2 py-1 bg-indigo-600/80 rounded hover:bg-indigo-500 text-xs text-white\"\n                  @click=\"confirmCreatePack\"\n                >OK</button>\n              </div>\n              <div class=\"flex gap-1\">\n                <button\n                  class=\"flex-1 px-2 py-1 bg-gray-700/60 rounded hover:bg-gray-600/70 text-xs text-gray-200\"\n                  @click=\"startCreatePack\"\n                >\n                  New Pack\n                </button>\n                <button\n                  class=\"flex-1 px-2 py-1 bg-gray-700/60 rounded hover:bg-gray-600/70 text-xs text-gray-200\"\n                  @click=\"openImportPicker\"\n                >\n                  Import\n                </button>\n              </div>\n            </div>\n          </div>\n\n          <!-- Patchbay: Sounds + Events columns -->\n          <div ref=\"rightPanel\" class=\"flex flex-1 min-h-0 overflow-hidden\">\n            <!-- Sounds column -->\n            <div class=\"flex-1 border-r border-gray-700 flex flex-col min-w-0\">\n              <div class=\"px-3 py-2 border-b border-gray-700 shrink-0\">\n                <span class=\"text-xs font-semibold text-gray-400 uppercase tracking-wide\">Sounds</span>\n              </div>\n              <div class=\"flex-1 overflow-y-auto\">\n                <div\n                  v-if=\"!selectedPackInfo\"\n                  class=\"flex items-center justify-center h-full text-gray-600 text-sm\"\n                >\n                  Select a pack\n                </div>\n                <!-- US-005 will populate sound file list here -->\n              </div>\n            </div>\n\n            <!-- Events column -->\n            <div class=\"flex-1 flex flex-col min-w-0\">\n              <div class=\"px-3 py-2 border-b border-gray-700 shrink-0\">\n                <span class=\"text-xs font-semibold text-gray-400 uppercase tracking-wide\">Events</span>\n              </div>\n              <div class=\"flex-1 overflow-y-auto\">\n                <div\n                  v-for=\"eventType in AGENT_EVENT_TYPES\"\n                  :key=\"eventType\"\n                  class=\"flex items-center gap-2 px-3 py-2 border-b border-gray-800 transition-opacity\"\n                  :class=\"hasAssignments(eventType) ? 'opacity-100' : 'opacity-40'\"\n                >\n                  <span class=\"text-sm font-mono text-gray-300 flex-1\">{{ eventType }}</span>\n                  <!-- Info icon + popover -->\n                  <span\n                    v-if=\"EVENT_DESCRIPTIONS[eventType]\"\n                    class=\"relative shrink-0\"\n                    @click.stop\n                  >\n                    <span\n                      class=\"w-4 h-4 flex items-center justify-center rounded-full border text-[10px] leading-none cursor-pointer select-none\"\n                      :class=\"activeInfoPopover === eventType\n                        ? 'border-indigo-400 text-indigo-300 bg-indigo-900/40'\n                        : 'border-gray-500 text-gray-400 hover:border-gray-300 hover:text-gray-200'\"\n                      @click=\"toggleInfoPopover(eventType)\"\n                    >i</span>\n                    <div\n                      v-if=\"activeInfoPopover === eventType\"\n                      class=\"absolute right-0 top-6 z-50 w-56 bg-gray-800 border border-gray-600 rounded shadow-lg px-3 py-2 text-xs text-gray-200 leading-relaxed\"\n                    >\n                      {{ EVENT_DESCRIPTIONS[eventType] }}\n                    </div>\n                  </span>\n                  <!-- US-006 will add assignment chips here -->\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        <!-- Footer -->\n        <div class=\"flex justify-end px-4 py-3 border-t border-gray-700 shrink-0\">\n          <button\n            class=\"px-4 py-1.5 bg-gray-700/60 rounded hover:bg-gray-600/70 text-sm text-gray-200\"\n            @click=\"emit('close')\"\n          >\n            Close\n          </button>\n        </div>\n      </div>\n    </div>\n\n    <!-- Context menu -->\n    <PackContextMenu\n      v-if=\"ctxMenu\"\n      :pack-name=\"ctxMenu.packName\"\n      :x=\"ctxMenu.x\"\n      :y=\"ctxMenu.y\"\n      @close=\"closeCtxMenu\"\n      @renamed=\"onPackRenamed\"\n      @duplicated=\"onPackDuplicated\"\n      @deleted=\"onPackDeleted\"\n    />\n  </Teleport>\n</template>\n","numLines":459,"startLine":1,"totalLines":459}}}
