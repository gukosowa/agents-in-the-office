{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XksUwSn3nRCL8UazBTYaiV","type":"tool_result","content":"     1→<script setup lang=\"ts\">\n     2→import {\n     3→  ref,\n     4→  computed,\n     5→  watch,\n     6→  nextTick,\n     7→  onMounted,\n     8→} from 'vue';\n     9→import { open } from '@tauri-apps/plugin-dialog';\n    10→import {\n    11→  mkdir,\n    12→  readFile,\n    13→  writeFile,\n    14→  exists,\n    15→} from '@tauri-apps/plugin-fs';\n    16→import JSZip from 'jszip';\n    17→import { useSoundStore, AGENT_EVENT_TYPES } from '../stores/soundStore';\n    18→import type { PackManifestSound } from '../stores/soundStore';\n    19→import type { AgentEventType } from '../drivers/types';\n    20→import PackContextMenu from './PackContextMenu.vue';\n    21→\n    22→const emit = defineEmits<{ close: [] }>();\n    23→\n    24→const soundStore = useSoundStore();\n    25→\n    26→// ---- Global settings ----\n    27→const globalEnabled = computed({\n    28→  get: () => soundStore.config.enabled,\n    29→  set: (v: boolean) => { soundStore.config.enabled = v; void soundStore.saveConfig(); },\n    30→});\n    31→const globalVolume = computed({\n    32→  get: () => Math.round(soundStore.config.globalVolume * 100),\n    33→  set: (v: number) => { soundStore.config.globalVolume = v / 100; void soundStore.saveConfig(); },\n    34→});\n    35→const cooldown = computed({\n    36→  get: () => soundStore.config.cooldownSeconds,\n    37→  set: (v: number) => { soundStore.config.cooldownSeconds = v; void soundStore.saveConfig(); },\n    38→});\n    39→\n    40→// ---- Pack list ----\n    41→const selectedPack = ref<string | null>(null);\n    42→const rightPanel = ref<HTMLElement | null>(null);\n    43→\n    44→onMounted(async () => {\n    45→  await soundStore.init();\n    46→  await soundStore.scanPacks();\n    47→  if (soundStore.packs.length > 0 && soundStore.packs[0]) {\n    48→    selectedPack.value = soundStore.packs[0].name;\n    49→  }\n    50→});\n    51→\n    52→function isPackActive(packName: string): boolean {\n    53→  return soundStore.config.activePacks.includes(packName);\n    54→}\n    55→\n    56→function togglePackActive(packName: string, active: boolean) {\n    57→  if (active) {\n    58→    if (!soundStore.config.activePacks.includes(packName)) {\n    59→      soundStore.config.activePacks.push(packName);\n    60→    }\n    61→  } else {\n    62→    soundStore.config.activePacks = soundStore.config.activePacks.filter(\n    63→      (p) => p !== packName,\n    64→    );\n    65→  }\n    66→  void soundStore.saveConfig();\n    67→}\n    68→\n    69→function selectPack(name: string) {\n    70→  selectedPack.value = name;\n    71→  void nextTick(() => {\n    72→    if (rightPanel.value) rightPanel.value.scrollTop = 0;\n    73→  });\n    74→}\n    75→\n    76→// ---- Context menu ----\n    77→const ctxMenu = ref<{ packName: string; x: number; y: number } | null>(null);\n    78→\n    79→function onPackRightClick(e: MouseEvent, packName: string) {\n    80→  e.preventDefault();\n    81→  ctxMenu.value = { packName, x: e.clientX, y: e.clientY };\n    82→}\n    83→\n    84→function closeCtxMenu() {\n    85→  ctxMenu.value = null;\n    86→}\n    87→\n    88→async function onPackRenamed(oldName: string, newName: string) {\n    89→  await soundStore.scanPacks();\n    90→  if (selectedPack.value === oldName) selectedPack.value = newName;\n    91→  closeCtxMenu();\n    92→}\n    93→\n    94→async function onPackDuplicated() {\n    95→  await soundStore.scanPacks();\n    96→  closeCtxMenu();\n    97→}\n    98→\n    99→async function onPackDeleted(name: string) {\n   100→  await soundStore.scanPacks();\n   101→  if (selectedPack.value === name) {\n   102→    selectedPack.value = soundStore.packs[0]?.name ?? null;\n   103→  }\n   104→  closeCtxMenu();\n   105→}\n   106→\n   107→// ---- New pack ----\n   108→const newPackName = ref('');\n   109→const creatingPack = ref(false);\n   110→const newPackInput = ref<HTMLInputElement | null>(null);\n   111→\n   112→function startCreatePack() {\n   113→  creatingPack.value = true;\n   114→  newPackName.value = '';\n   115→  void nextTick(() => newPackInput.value?.focus());\n   116→}\n   117→\n   118→function cancelCreatePack() {\n   119→  creatingPack.value = false;\n   120→  newPackName.value = '';\n   121→}\n   122→\n   123→async function confirmCreatePack() {\n   124→  const packName = newPackName.value.trim();\n   125→  if (!packName) return;\n   126→  creatingPack.value = false;\n   127→  newPackName.value = '';\n   128→  const baseDir = soundStore.getSoundPacksDir();\n   129→  const packPath = `${baseDir}/${packName}`;\n   130→  try {\n   131→    await mkdir(packPath, { recursive: true });\n   132→    for (const eventType of AGENT_EVENT_TYPES) {\n   133→      await mkdir(`${packPath}/${eventType}`, { recursive: true });\n   134→    }\n   135→    await soundStore.scanPacks();\n   136→    selectedPack.value = packName;\n   137→  } catch (err) {\n   138→    console.error('[SoundsDialog] createNewPack failed', err);\n   139→  }\n   140→}\n   141→\n   142→// ---- Import zip ----\n   143→const dragOver = ref(false);\n   144→\n   145→async function importZipBytes(filename: string, bytes: Uint8Array): Promise<void> {\n   146→  const dotIdx = filename.lastIndexOf('.');\n   147→  const packName = dotIdx > 0 ? filename.slice(0, dotIdx) : filename;\n   148→  const baseDir = soundStore.getSoundPacksDir();\n   149→  const packPath = `${baseDir}/${packName}`;\n   150→\n   151→  const zip = await JSZip.loadAsync(bytes);\n   152→  for (const [relativePath, file] of Object.entries(zip.files)) {\n   153→    if (file.dir) {\n   154→      await mkdir(`${packPath}/${relativePath}`, { recursive: true });\n   155→    } else {\n   156→      const data = await file.async('uint8array');\n   157→      const dirPart = relativePath.includes('/')\n   158→        ? relativePath.slice(0, relativePath.lastIndexOf('/'))\n   159→        : '';\n   160→      if (dirPart) {\n   161→        await mkdir(`${packPath}/${dirPart}`, { recursive: true });\n   162→      }\n   163→      await writeFile(`${packPath}/${relativePath}`, data);\n   164→    }\n   165→  }\n   166→\n   167→  await soundStore.scanPacks();\n   168→  selectedPack.value = packName;\n   169→}\n   170→\n   171→async function openImportPicker() {\n   172→  const result = await open({\n   173→    filters: [{ name: 'ZIP', extensions: ['zip'] }],\n   174→    multiple: false,\n   175→  });\n   176→  if (!result) return;\n   177→  const filePath = typeof result === 'string' ? result : result;\n   178→  if (!filePath) return;\n   179→  try {\n   180→    const bytes = await readFile(filePath);\n   181→    const filename = (filePath as string).split('/').pop() ?? 'pack.zip';\n   182→    await importZipBytes(filename, bytes);\n   183→  } catch (err) {\n   184→    console.error('[SoundsDialog] import failed', err);\n   185→  }\n   186→}\n   187→\n   188→function onDragOver(e: DragEvent) {\n   189→  e.preventDefault();\n   190→  dragOver.value = true;\n   191→}\n   192→\n   193→function onDragLeave() {\n   194→  dragOver.value = false;\n   195→}\n   196→\n   197→async function onDrop(e: DragEvent) {\n   198→  e.preventDefault();\n   199→  dragOver.value = false;\n   200→  const file = e.dataTransfer?.files[0];\n   201→  if (!file) return;\n   202→  try {\n   203→    const arrayBuffer = await file.arrayBuffer();\n   204→    await importZipBytes(file.name, new Uint8Array(arrayBuffer));\n   205→  } catch (err) {\n   206→    console.error('[SoundsDialog] drop import failed', err);\n   207→  }\n   208→}\n   209→\n   210→// ---- Event descriptions ----\n   211→const EVENT_DESCRIPTIONS: Record<string, string> = {\n   212→  session_start: 'Agent session begins.',\n   213→  session_end: 'Agent session ends or is interrupted.',\n   214→  prompt_submit: 'User submits a prompt to the agent.',\n   215→  tool_start: 'Agent begins executing a tool (e.g. Bash, Read, Edit).',\n   216→  tool_end: 'Agent finishes executing a tool.',\n   217→  turn_end: 'Agent completes a full response turn.',\n   218→  permission_wait: 'Agent pauses waiting for the user to approve a tool call.',\n   219→  subagent_start: 'A subagent is spawned by the parent agent.',\n   220→  subagent_end: 'A subagent finishes its work.',\n   221→  idle_notification: 'Agent has been idle and sends a nudge notification.',\n   222→  elicitation_wait: 'Agent pauses waiting for user input.',\n   223→  auth_success: 'Authentication to an external service succeeds.',\n   224→  worktree_create: 'A new git worktree is created.',\n   225→  worktree_remove: 'A git worktree is removed.',\n   226→  teammate_idle: \"A teammate's agent session goes idle.\",\n   227→  task_completed: 'Agent marks a task as completed.',\n   228→};\n   229→\n   230→const activeInfoPopover = ref<string | null>(null);\n   231→\n   232→function toggleInfoPopover(eventType: string) {\n   233→  activeInfoPopover.value = activeInfoPopover.value === eventType ? null : eventType;\n   234→}\n   235→\n   236→// ---- Patchbay data ----\n   237→const selectedPackInfo = computed(() =>\n   238→  soundStore.packs.find((p) => p.name === selectedPack.value) ?? null,\n   239→);\n   240→\n   241→function hasAssignments(eventType: AgentEventType): boolean {\n   242→  if (!selectedPackInfo.value) return false;\n   243→  return selectedPackInfo.value.manifest.assignments.some((a) => a.event === eventType);\n   244→}\n   245→\n   246→// ---- Sound preview (left column) ----\n   247→let previewSource: AudioBufferSourceNode | null = null;\n   248→const previewFile = ref<string | null>(null);\n   249→const soundFileExists = ref<Map<string, boolean>>(new Map());\n   250→const hoveredSoundFile = ref<string | null>(null);\n   251→\n   252→async function checkSoundFileExistence(packName: string): Promise<void> {\n   253→  const sounds = selectedPackInfo.value?.manifest.sounds ?? [];\n   254→  const baseDir = soundStore.getSoundPacksDir();\n   255→  const newMap = new Map<string, boolean>();\n   256→  await Promise.all(\n   257→    sounds.map(async (sound) => {\n   258→      const filePath = `${baseDir}/${packName}/${sound.file}`;\n   259→      const fileExists = await exists(filePath);\n   260→      newMap.set(sound.file, fileExists);\n   261→    }),\n   262→  );\n   263→  soundFileExists.value = newMap;\n   264→}\n   265→\n   266→function stopPreview(): void {\n   267→  if (previewSource) {\n   268→    try { previewSource.stop(); } catch { /* already stopped */ }\n   269→    previewSource = null;\n   270→  }\n   271→  previewFile.value = null;\n   272→}\n   273→\n   274→async function playPreview(filename: string): Promise<void> {\n   275→  if (!selectedPack.value) return;\n   276→  stopPreview();\n   277→  const baseDir = soundStore.getSoundPacksDir();\n   278→  const filePath = `${baseDir}/${selectedPack.value}/${filename}`;\n   279→  const buffer = await soundStore.loadBuffer(filePath);\n   280→  if (!buffer) return;\n   281→  const ctx = soundStore.getOrCreateAudioContext();\n   282→  const sound = selectedPackInfo.value?.manifest.sounds.find((s) => s.file === filename);\n   283→  const gainNode = ctx.createGain();\n   284→  gainNode.gain.value =\n   285→    soundStore.config.globalVolume * soundStore.effectiveVolume(selectedPack.value, filename, sound);\n   286→  gainNode.connect(ctx.destination);\n   287→  const source = ctx.createBufferSource();\n   288→  source.buffer = buffer;\n   289→  source.connect(gainNode);\n   290→  previewFile.value = filename;\n   291→  previewSource = source;\n   292→  source.onended = () => {\n   293→    if (previewFile.value === filename) {\n   294→      previewFile.value = null;\n   295→      previewSource = null;\n   296→    }\n   297→  };\n   298→  source.start();\n   299→}\n   300→\n   301→async function updateSoundVolume(sound: PackManifestSound, volume: number): Promise<void> {\n   302→  if (!selectedPack.value || !selectedPackInfo.value) return;\n   303→  sound.volume = volume;\n   304→  await soundStore.savePackManifest(selectedPack.value, selectedPackInfo.value.manifest);\n   305→}\n   306→\n   307→async function updateSoundEnabled(sound: PackManifestSound, enabled: boolean): Promise<void> {\n   308→  if (!selectedPack.value || !selectedPackInfo.value) return;\n   309→  sound.enabled = enabled;\n   310→  await soundStore.savePackManifest(selectedPack.value, selectedPackInfo.value.manifest);\n   311→}\n   312→\n   313→// Reset scroll + stop preview + check file existence on pack change\n   314→watch(selectedPack, async (packName) => {\n   315→  stopPreview();\n   316→  soundFileExists.value = new Map();\n   317→  if (packName) void checkSoundFileExistence(packName);\n   318→  await nextTick(() => {\n   319→    if (rightPanel.value) rightPanel.value.scrollTop = 0;\n   320→  });\n   321→});\n   322→\n   323→</script>\n   324→\n   325→<template>\n   326→  <Teleport to=\"body\">\n   327→    <!-- Backdrop -->\n   328→    <div class=\"fixed inset-0 z-[100] flex items-center justify-center bg-black/50\">\n   329→      <!-- Drop zone wrapper -->\n   330→      <div\n   331→        class=\"relative w-[960px] max-w-[90vw] h-[700px] max-h-[90vh] flex flex-col bg-gray-900 border border-gray-700 rounded-lg shadow-2xl overflow-hidden\"\n   332→        @dragover=\"onDragOver\"\n   333→        @dragleave=\"onDragLeave\"\n   334→        @drop=\"onDrop\"\n   335→      >\n   336→        <!-- Drag overlay -->\n   337→        <div\n   338→          v-if=\"dragOver\"\n   339→          class=\"absolute inset-0 z-[150] flex items-center justify-center bg-indigo-900/80 border-2 border-dashed border-indigo-400 rounded-lg pointer-events-none\"\n   340→        >\n   341→          <span class=\"text-indigo-200 text-lg font-semibold\">Drop sound pack here</span>\n   342→        </div>\n   343→\n   344→        <!-- Header -->\n   345→        <div class=\"flex items-center gap-4 px-4 py-3 border-b border-gray-700 shrink-0\">\n   346→          <span class=\"text-gray-200 font-semibold text-sm\">Sounds</span>\n   347→\n   348→          <!-- Master enable -->\n   349→          <label class=\"flex items-center gap-1.5 text-xs text-gray-300 cursor-pointer\">\n   350→            <input\n   351→              type=\"checkbox\"\n   352→              :checked=\"globalEnabled\"\n   353→              class=\"w-4 h-4 accent-indigo-400\"\n   354→              @change=\"globalEnabled = ($event.target as HTMLInputElement).checked\"\n   355→            />\n   356→            Enable\n   357→          </label>\n   358→\n   359→          <!-- Global volume -->\n   360→          <label class=\"flex items-center gap-1.5 text-xs text-gray-300\">\n   361→            Vol\n   362→            <input\n   363→              type=\"range\"\n   364→              min=\"0\"\n   365→              max=\"100\"\n   366→              :value=\"globalVolume\"\n   367→              class=\"w-24 accent-indigo-400\"\n   368→              @input=\"globalVolume = parseInt(($event.target as HTMLInputElement).value)\"\n   369→            />\n   370→            <span class=\"w-7 tabular-nums\">{{ globalVolume }}%</span>\n   371→          </label>\n   372→\n   373→          <!-- Cooldown -->\n   374→          <label class=\"flex items-center gap-1.5 text-xs text-gray-300\">\n   375→            Cooldown\n   376→            <input\n   377→              type=\"range\"\n   378→              min=\"0\"\n   379→              max=\"10\"\n   380→              step=\"0.5\"\n   381→              :value=\"cooldown\"\n   382→              class=\"w-20 accent-indigo-400\"\n   383→              @input=\"cooldown = parseFloat(($event.target as HTMLInputElement).value)\"\n   384→            />\n   385→            <span class=\"w-8 tabular-nums\">{{ cooldown }}s</span>\n   386→          </label>\n   387→        </div>\n   388→\n   389→        <!-- Body -->\n   390→        <div class=\"flex flex-1 min-h-0\">\n   391→          <!-- Left panel: pack list -->\n   392→          <div class=\"w-60 shrink-0 border-r border-gray-700 flex flex-col\">\n   393→            <div class=\"px-3 pt-2 pb-1 text-xs font-semibold text-gray-400 uppercase tracking-wide\">\n   394→              Packs\n   395→            </div>\n   396→            <div class=\"flex-1 overflow-y-auto\">\n   397→              <div\n   398→                v-for=\"pack in soundStore.packs\"\n   399→                :key=\"pack.name\"\n   400→                class=\"flex items-center gap-2 px-2 py-1.5 cursor-pointer rounded mx-1\"\n   401→                :class=\"selectedPack === pack.name ? 'bg-gray-700' : 'hover:bg-gray-800'\"\n   402→                @click=\"selectPack(pack.name)\"\n   403→                @contextmenu=\"onPackRightClick($event, pack.name)\"\n   404→              >\n   405→                <input\n   406→                  type=\"checkbox\"\n   407→                  :checked=\"isPackActive(pack.name)\"\n   408→                  class=\"w-4 h-4 accent-indigo-400 cursor-pointer\"\n   409→                  @click.stop\n   410→                  @change=\"togglePackActive(pack.name, ($event.target as HTMLInputElement).checked)\"\n   411→                />\n   412→                <span class=\"text-sm text-gray-200 truncate flex-1\">{{ pack.name }}</span>\n   413→              </div>\n   414→            </div>\n   415→            <!-- Buttons / new pack input -->\n   416→            <div class=\"flex flex-col gap-1 p-2 border-t border-gray-700\">\n   417→              <div v-if=\"creatingPack\" class=\"flex gap-1\">\n   418→                <input\n   419→                  ref=\"newPackInput\"\n   420→                  v-model=\"newPackName\"\n   421→                  class=\"flex-1 px-2 py-1 bg-gray-800 border border-gray-600 rounded text-xs text-gray-200 outline-none focus:border-indigo-400\"\n   422→                  placeholder=\"Pack name…\"\n   423→                  @keydown.enter=\"confirmCreatePack\"\n   424→                  @keydown.escape=\"cancelCreatePack\"\n   425→                />\n   426→                <button\n   427→                  class=\"px-2 py-1 bg-indigo-600/80 rounded hover:bg-indigo-500 text-xs text-white\"\n   428→                  @click=\"confirmCreatePack\"\n   429→                >OK</button>\n   430→              </div>\n   431→              <div class=\"flex gap-1\">\n   432→                <button\n   433→                  class=\"flex-1 px-2 py-1 bg-gray-700/60 rounded hover:bg-gray-600/70 text-xs text-gray-200\"\n   434→                  @click=\"startCreatePack\"\n   435→                >\n   436→                  New Pack\n   437→                </button>\n   438→                <button\n   439→                  class=\"flex-1 px-2 py-1 bg-gray-700/60 rounded hover:bg-gray-600/70 text-xs text-gray-200\"\n   440→                  @click=\"openImportPicker\"\n   441→                >\n   442→                  Import\n   443→                </button>\n   444→              </div>\n   445→            </div>\n   446→          </div>\n   447→\n   448→          <!-- Patchbay: Sounds + Events columns -->\n   449→          <div ref=\"rightPanel\" class=\"flex flex-1 min-h-0 overflow-hidden\">\n   450→            <!-- Sounds column -->\n   451→            <div class=\"flex-1 border-r border-gray-700 flex flex-col min-w-0\">\n   452→              <div class=\"px-3 py-2 border-b border-gray-700 shrink-0\">\n   453→                <span class=\"text-xs font-semibold text-gray-400 uppercase tracking-wide\">Sounds</span>\n   454→              </div>\n   455→              <div class=\"flex-1 overflow-y-auto\">\n   456→                <div\n   457→                  v-if=\"!selectedPackInfo\"\n   458→                  class=\"flex items-center justify-center h-full text-gray-600 text-sm\"\n   459→                >\n   460→                  Select a pack\n   461→                </div>\n   462→                <div\n   463→                  v-else-if=\"selectedPackInfo.manifest.sounds.length === 0\"\n   464→                  class=\"flex items-center justify-center h-full text-gray-600 text-sm\"\n   465→                >\n   466→                  No sounds in this pack\n   467→                </div>\n   468→                <div\n   469→                  v-for=\"sound in selectedPackInfo.manifest.sounds\"\n   470→                  v-else\n   471→                  :key=\"sound.file\"\n   472→                  class=\"flex items-center gap-2 px-3 py-1.5 border-b border-gray-800 hover:bg-gray-800/40\"\n   473→                  @mouseenter=\"hoveredSoundFile = sound.file\"\n   474→                  @mouseleave=\"hoveredSoundFile = null\"\n   475→                >\n   476→                  <!-- Play button -->\n   477→                  <button\n   478→                    class=\"shrink-0 w-6 h-6 flex items-center justify-center rounded text-gray-400 hover:text-white hover:bg-gray-700 text-xs\"\n   479→                    title=\"Play preview\"\n   480→                    @click=\"playPreview(sound.file)\"\n   481→                  >▶</button>\n   482→\n   483→                  <!-- Filename -->\n   484→                  <span class=\"flex-1 text-xs font-mono text-gray-200 truncate min-w-0\">{{ sound.file }}</span>\n   485→\n   486→                  <!-- Broken link indicator -->\n   487→                  <span\n   488→                    v-if=\"soundFileExists.get(sound.file) === false\"\n   489→                    class=\"shrink-0 text-red-400 text-xs\"\n   490→                    title=\"File not found on disk\"\n   491→                  >⚠</span>\n   492→\n   493→                  <!-- Volume slider (visible on hover) -->\n   494→                  <input\n   495→                    v-show=\"hoveredSoundFile === sound.file\"\n   496→                    type=\"range\"\n   497→                    min=\"0\"\n   498→                    max=\"1\"\n   499→                    step=\"0.01\"\n   500→                    :value=\"sound.volume\"\n   501→                    class=\"shrink-0 w-16 accent-indigo-400\"\n   502→                    title=\"Volume\"\n   503→                    @input=\"updateSoundVolume(sound, parseFloat(($event.target as HTMLInputElement).value))\"\n   504→                  />\n   505→\n   506→                  <!-- Enabled toggle -->\n   507→                  <input\n   508→                    type=\"checkbox\"\n   509→                    :checked=\"sound.enabled\"\n   510→                    class=\"shrink-0 w-4 h-4 accent-indigo-400 cursor-pointer\"\n   511→                    title=\"Enable/disable this sound\"\n   512→                    @change=\"updateSoundEnabled(sound, ($event.target as HTMLInputElement).checked)\"\n   513→                  />\n   514→\n   515→                  <!-- Stop button -->\n   516→                  <button\n   517→                    class=\"shrink-0 w-6 h-6 flex items-center justify-center rounded text-xs\"\n   518→                    :class=\"previewFile === sound.file\n   519→                      ? 'text-red-400 hover:text-red-300 hover:bg-gray-700'\n   520→                      : 'text-gray-600 cursor-default'\"\n   521→                    title=\"Stop preview\"\n   522→                    @click=\"previewFile === sound.file ? stopPreview() : undefined\"\n   523→                  >■</button>\n   524→                </div>\n   525→              </div>\n   526→            </div>\n   527→\n   528→            <!-- Events column -->\n   529→            <div class=\"flex-1 flex flex-col min-w-0\">\n   530→              <div class=\"px-3 py-2 border-b border-gray-700 shrink-0\">\n   531→                <span class=\"text-xs font-semibold text-gray-400 uppercase tracking-wide\">Events</span>\n   532→              </div>\n   533→              <div class=\"flex-1 overflow-y-auto\">\n   534→                <div\n   535→                  v-for=\"eventType in AGENT_EVENT_TYPES\"\n   536→                  :key=\"eventType\"\n   537→                  class=\"flex items-center gap-2 px-3 py-2 border-b border-gray-800 transition-opacity\"\n   538→                  :class=\"hasAssignments(eventType) ? 'opacity-100' : 'opacity-40'\"\n   539→                >\n   540→                  <span class=\"text-sm font-mono text-gray-300 flex-1\">{{ eventType }}</span>\n   541→                  <!-- Info icon + popover -->\n   542→                  <span\n   543→                    v-if=\"EVENT_DESCRIPTIONS[eventType]\"\n   544→                    class=\"relative shrink-0\"\n   545→                    @click.stop\n   546→                  >\n   547→                    <span\n   548→                      class=\"w-4 h-4 flex items-center justify-center rounded-full border text-[10px] leading-none cursor-pointer select-none\"\n   549→                      :class=\"activeInfoPopover === eventType\n   550→                        ? 'border-indigo-400 text-indigo-300 bg-indigo-900/40'\n   551→                        : 'border-gray-500 text-gray-400 hover:border-gray-300 hover:text-gray-200'\"\n   552→                      @click=\"toggleInfoPopover(eventType)\"\n   553→                    >i</span>\n   554→                    <div\n   555→                      v-if=\"activeInfoPopover === eventType\"\n   556→                      class=\"absolute right-0 top-6 z-50 w-56 bg-gray-800 border border-gray-600 rounded shadow-lg px-3 py-2 text-xs text-gray-200 leading-relaxed\"\n   557→                    >\n   558→                      {{ EVENT_DESCRIPTIONS[eventType] }}\n   559→                    </div>\n   560→                  </span>\n   561→                  <!-- US-006 will add assignment chips here -->\n   562→                </div>\n   563→              </div>\n   564→            </div>\n   565→          </div>\n   566→        </div>\n   567→\n   568→        <!-- Footer -->\n   569→        <div class=\"flex justify-end px-4 py-3 border-t border-gray-700 shrink-0\">\n   570→          <button\n   571→            class=\"px-4 py-1.5 bg-gray-700/60 rounded hover:bg-gray-600/70 text-sm text-gray-200\"\n   572→            @click=\"emit('close')\"\n   573→          >\n   574→            Close\n   575→          </button>\n   576→        </div>\n   577→      </div>\n   578→    </div>\n   579→\n   580→    <!-- Context menu -->\n   581→    <PackContextMenu\n   582→      v-if=\"ctxMenu\"\n   583→      :pack-name=\"ctxMenu.packName\"\n   584→      :x=\"ctxMenu.x\"\n   585→      :y=\"ctxMenu.y\"\n   586→      @close=\"closeCtxMenu\"\n   587→      @renamed=\"onPackRenamed\"\n   588→      @duplicated=\"onPackDuplicated\"\n   589→      @deleted=\"onPackDeleted\"\n   590→    />\n   591→  </Teleport>\n   592→</template>\n   593→"}]},"parent_tool_use_id":null,"session_id":"1314d513-0f86-4cdc-8c19-398084d74c3f","uuid":"bee434d2-35a4-475f-949d-4f08788931eb","tool_use_result":{"type":"text","file":{"filePath":"/Users/markus/baustelle/projects/agents-in-the-office/agents-in-the-office/.chief/worktrees/sound-packs-patchbay/src/components/SoundsDialog.vue","content":"<script setup lang=\"ts\">\nimport {\n  ref,\n  computed,\n  watch,\n  nextTick,\n  onMounted,\n} from 'vue';\nimport { open } from '@tauri-apps/plugin-dialog';\nimport {\n  mkdir,\n  readFile,\n  writeFile,\n  exists,\n} from '@tauri-apps/plugin-fs';\nimport JSZip from 'jszip';\nimport { useSoundStore, AGENT_EVENT_TYPES } from '../stores/soundStore';\nimport type { PackManifestSound } from '../stores/soundStore';\nimport type { AgentEventType } from '../drivers/types';\nimport PackContextMenu from './PackContextMenu.vue';\n\nconst emit = defineEmits<{ close: [] }>();\n\nconst soundStore = useSoundStore();\n\n// ---- Global settings ----\nconst globalEnabled = computed({\n  get: () => soundStore.config.enabled,\n  set: (v: boolean) => { soundStore.config.enabled = v; void soundStore.saveConfig(); },\n});\nconst globalVolume = computed({\n  get: () => Math.round(soundStore.config.globalVolume * 100),\n  set: (v: number) => { soundStore.config.globalVolume = v / 100; void soundStore.saveConfig(); },\n});\nconst cooldown = computed({\n  get: () => soundStore.config.cooldownSeconds,\n  set: (v: number) => { soundStore.config.cooldownSeconds = v; void soundStore.saveConfig(); },\n});\n\n// ---- Pack list ----\nconst selectedPack = ref<string | null>(null);\nconst rightPanel = ref<HTMLElement | null>(null);\n\nonMounted(async () => {\n  await soundStore.init();\n  await soundStore.scanPacks();\n  if (soundStore.packs.length > 0 && soundStore.packs[0]) {\n    selectedPack.value = soundStore.packs[0].name;\n  }\n});\n\nfunction isPackActive(packName: string): boolean {\n  return soundStore.config.activePacks.includes(packName);\n}\n\nfunction togglePackActive(packName: string, active: boolean) {\n  if (active) {\n    if (!soundStore.config.activePacks.includes(packName)) {\n      soundStore.config.activePacks.push(packName);\n    }\n  } else {\n    soundStore.config.activePacks = soundStore.config.activePacks.filter(\n      (p) => p !== packName,\n    );\n  }\n  void soundStore.saveConfig();\n}\n\nfunction selectPack(name: string) {\n  selectedPack.value = name;\n  void nextTick(() => {\n    if (rightPanel.value) rightPanel.value.scrollTop = 0;\n  });\n}\n\n// ---- Context menu ----\nconst ctxMenu = ref<{ packName: string; x: number; y: number } | null>(null);\n\nfunction onPackRightClick(e: MouseEvent, packName: string) {\n  e.preventDefault();\n  ctxMenu.value = { packName, x: e.clientX, y: e.clientY };\n}\n\nfunction closeCtxMenu() {\n  ctxMenu.value = null;\n}\n\nasync function onPackRenamed(oldName: string, newName: string) {\n  await soundStore.scanPacks();\n  if (selectedPack.value === oldName) selectedPack.value = newName;\n  closeCtxMenu();\n}\n\nasync function onPackDuplicated() {\n  await soundStore.scanPacks();\n  closeCtxMenu();\n}\n\nasync function onPackDeleted(name: string) {\n  await soundStore.scanPacks();\n  if (selectedPack.value === name) {\n    selectedPack.value = soundStore.packs[0]?.name ?? null;\n  }\n  closeCtxMenu();\n}\n\n// ---- New pack ----\nconst newPackName = ref('');\nconst creatingPack = ref(false);\nconst newPackInput = ref<HTMLInputElement | null>(null);\n\nfunction startCreatePack() {\n  creatingPack.value = true;\n  newPackName.value = '';\n  void nextTick(() => newPackInput.value?.focus());\n}\n\nfunction cancelCreatePack() {\n  creatingPack.value = false;\n  newPackName.value = '';\n}\n\nasync function confirmCreatePack() {\n  const packName = newPackName.value.trim();\n  if (!packName) return;\n  creatingPack.value = false;\n  newPackName.value = '';\n  const baseDir = soundStore.getSoundPacksDir();\n  const packPath = `${baseDir}/${packName}`;\n  try {\n    await mkdir(packPath, { recursive: true });\n    for (const eventType of AGENT_EVENT_TYPES) {\n      await mkdir(`${packPath}/${eventType}`, { recursive: true });\n    }\n    await soundStore.scanPacks();\n    selectedPack.value = packName;\n  } catch (err) {\n    console.error('[SoundsDialog] createNewPack failed', err);\n  }\n}\n\n// ---- Import zip ----\nconst dragOver = ref(false);\n\nasync function importZipBytes(filename: string, bytes: Uint8Array): Promise<void> {\n  const dotIdx = filename.lastIndexOf('.');\n  const packName = dotIdx > 0 ? filename.slice(0, dotIdx) : filename;\n  const baseDir = soundStore.getSoundPacksDir();\n  const packPath = `${baseDir}/${packName}`;\n\n  const zip = await JSZip.loadAsync(bytes);\n  for (const [relativePath, file] of Object.entries(zip.files)) {\n    if (file.dir) {\n      await mkdir(`${packPath}/${relativePath}`, { recursive: true });\n    } else {\n      const data = await file.async('uint8array');\n      const dirPart = relativePath.includes('/')\n        ? relativePath.slice(0, relativePath.lastIndexOf('/'))\n        : '';\n      if (dirPart) {\n        await mkdir(`${packPath}/${dirPart}`, { recursive: true });\n      }\n      await writeFile(`${packPath}/${relativePath}`, data);\n    }\n  }\n\n  await soundStore.scanPacks();\n  selectedPack.value = packName;\n}\n\nasync function openImportPicker() {\n  const result = await open({\n    filters: [{ name: 'ZIP', extensions: ['zip'] }],\n    multiple: false,\n  });\n  if (!result) return;\n  const filePath = typeof result === 'string' ? result : result;\n  if (!filePath) return;\n  try {\n    const bytes = await readFile(filePath);\n    const filename = (filePath as string).split('/').pop() ?? 'pack.zip';\n    await importZipBytes(filename, bytes);\n  } catch (err) {\n    console.error('[SoundsDialog] import failed', err);\n  }\n}\n\nfunction onDragOver(e: DragEvent) {\n  e.preventDefault();\n  dragOver.value = true;\n}\n\nfunction onDragLeave() {\n  dragOver.value = false;\n}\n\nasync function onDrop(e: DragEvent) {\n  e.preventDefault();\n  dragOver.value = false;\n  const file = e.dataTransfer?.files[0];\n  if (!file) return;\n  try {\n    const arrayBuffer = await file.arrayBuffer();\n    await importZipBytes(file.name, new Uint8Array(arrayBuffer));\n  } catch (err) {\n    console.error('[SoundsDialog] drop import failed', err);\n  }\n}\n\n// ---- Event descriptions ----\nconst EVENT_DESCRIPTIONS: Record<string, string> = {\n  session_start: 'Agent session begins.',\n  session_end: 'Agent session ends or is interrupted.',\n  prompt_submit: 'User submits a prompt to the agent.',\n  tool_start: 'Agent begins executing a tool (e.g. Bash, Read, Edit).',\n  tool_end: 'Agent finishes executing a tool.',\n  turn_end: 'Agent completes a full response turn.',\n  permission_wait: 'Agent pauses waiting for the user to approve a tool call.',\n  subagent_start: 'A subagent is spawned by the parent agent.',\n  subagent_end: 'A subagent finishes its work.',\n  idle_notification: 'Agent has been idle and sends a nudge notification.',\n  elicitation_wait: 'Agent pauses waiting for user input.',\n  auth_success: 'Authentication to an external service succeeds.',\n  worktree_create: 'A new git worktree is created.',\n  worktree_remove: 'A git worktree is removed.',\n  teammate_idle: \"A teammate's agent session goes idle.\",\n  task_completed: 'Agent marks a task as completed.',\n};\n\nconst activeInfoPopover = ref<string | null>(null);\n\nfunction toggleInfoPopover(eventType: string) {\n  activeInfoPopover.value = activeInfoPopover.value === eventType ? null : eventType;\n}\n\n// ---- Patchbay data ----\nconst selectedPackInfo = computed(() =>\n  soundStore.packs.find((p) => p.name === selectedPack.value) ?? null,\n);\n\nfunction hasAssignments(eventType: AgentEventType): boolean {\n  if (!selectedPackInfo.value) return false;\n  return selectedPackInfo.value.manifest.assignments.some((a) => a.event === eventType);\n}\n\n// ---- Sound preview (left column) ----\nlet previewSource: AudioBufferSourceNode | null = null;\nconst previewFile = ref<string | null>(null);\nconst soundFileExists = ref<Map<string, boolean>>(new Map());\nconst hoveredSoundFile = ref<string | null>(null);\n\nasync function checkSoundFileExistence(packName: string): Promise<void> {\n  const sounds = selectedPackInfo.value?.manifest.sounds ?? [];\n  const baseDir = soundStore.getSoundPacksDir();\n  const newMap = new Map<string, boolean>();\n  await Promise.all(\n    sounds.map(async (sound) => {\n      const filePath = `${baseDir}/${packName}/${sound.file}`;\n      const fileExists = await exists(filePath);\n      newMap.set(sound.file, fileExists);\n    }),\n  );\n  soundFileExists.value = newMap;\n}\n\nfunction stopPreview(): void {\n  if (previewSource) {\n    try { previewSource.stop(); } catch { /* already stopped */ }\n    previewSource = null;\n  }\n  previewFile.value = null;\n}\n\nasync function playPreview(filename: string): Promise<void> {\n  if (!selectedPack.value) return;\n  stopPreview();\n  const baseDir = soundStore.getSoundPacksDir();\n  const filePath = `${baseDir}/${selectedPack.value}/${filename}`;\n  const buffer = await soundStore.loadBuffer(filePath);\n  if (!buffer) return;\n  const ctx = soundStore.getOrCreateAudioContext();\n  const sound = selectedPackInfo.value?.manifest.sounds.find((s) => s.file === filename);\n  const gainNode = ctx.createGain();\n  gainNode.gain.value =\n    soundStore.config.globalVolume * soundStore.effectiveVolume(selectedPack.value, filename, sound);\n  gainNode.connect(ctx.destination);\n  const source = ctx.createBufferSource();\n  source.buffer = buffer;\n  source.connect(gainNode);\n  previewFile.value = filename;\n  previewSource = source;\n  source.onended = () => {\n    if (previewFile.value === filename) {\n      previewFile.value = null;\n      previewSource = null;\n    }\n  };\n  source.start();\n}\n\nasync function updateSoundVolume(sound: PackManifestSound, volume: number): Promise<void> {\n  if (!selectedPack.value || !selectedPackInfo.value) return;\n  sound.volume = volume;\n  await soundStore.savePackManifest(selectedPack.value, selectedPackInfo.value.manifest);\n}\n\nasync function updateSoundEnabled(sound: PackManifestSound, enabled: boolean): Promise<void> {\n  if (!selectedPack.value || !selectedPackInfo.value) return;\n  sound.enabled = enabled;\n  await soundStore.savePackManifest(selectedPack.value, selectedPackInfo.value.manifest);\n}\n\n// Reset scroll + stop preview + check file existence on pack change\nwatch(selectedPack, async (packName) => {\n  stopPreview();\n  soundFileExists.value = new Map();\n  if (packName) void checkSoundFileExistence(packName);\n  await nextTick(() => {\n    if (rightPanel.value) rightPanel.value.scrollTop = 0;\n  });\n});\n\n</script>\n\n<template>\n  <Teleport to=\"body\">\n    <!-- Backdrop -->\n    <div class=\"fixed inset-0 z-[100] flex items-center justify-center bg-black/50\">\n      <!-- Drop zone wrapper -->\n      <div\n        class=\"relative w-[960px] max-w-[90vw] h-[700px] max-h-[90vh] flex flex-col bg-gray-900 border border-gray-700 rounded-lg shadow-2xl overflow-hidden\"\n        @dragover=\"onDragOver\"\n        @dragleave=\"onDragLeave\"\n        @drop=\"onDrop\"\n      >\n        <!-- Drag overlay -->\n        <div\n          v-if=\"dragOver\"\n          class=\"absolute inset-0 z-[150] flex items-center justify-center bg-indigo-900/80 border-2 border-dashed border-indigo-400 rounded-lg pointer-events-none\"\n        >\n          <span class=\"text-indigo-200 text-lg font-semibold\">Drop sound pack here</span>\n        </div>\n\n        <!-- Header -->\n        <div class=\"flex items-center gap-4 px-4 py-3 border-b border-gray-700 shrink-0\">\n          <span class=\"text-gray-200 font-semibold text-sm\">Sounds</span>\n\n          <!-- Master enable -->\n          <label class=\"flex items-center gap-1.5 text-xs text-gray-300 cursor-pointer\">\n            <input\n              type=\"checkbox\"\n              :checked=\"globalEnabled\"\n              class=\"w-4 h-4 accent-indigo-400\"\n              @change=\"globalEnabled = ($event.target as HTMLInputElement).checked\"\n            />\n            Enable\n          </label>\n\n          <!-- Global volume -->\n          <label class=\"flex items-center gap-1.5 text-xs text-gray-300\">\n            Vol\n            <input\n              type=\"range\"\n              min=\"0\"\n              max=\"100\"\n              :value=\"globalVolume\"\n              class=\"w-24 accent-indigo-400\"\n              @input=\"globalVolume = parseInt(($event.target as HTMLInputElement).value)\"\n            />\n            <span class=\"w-7 tabular-nums\">{{ globalVolume }}%</span>\n          </label>\n\n          <!-- Cooldown -->\n          <label class=\"flex items-center gap-1.5 text-xs text-gray-300\">\n            Cooldown\n            <input\n              type=\"range\"\n              min=\"0\"\n              max=\"10\"\n              step=\"0.5\"\n              :value=\"cooldown\"\n              class=\"w-20 accent-indigo-400\"\n              @input=\"cooldown = parseFloat(($event.target as HTMLInputElement).value)\"\n            />\n            <span class=\"w-8 tabular-nums\">{{ cooldown }}s</span>\n          </label>\n        </div>\n\n        <!-- Body -->\n        <div class=\"flex flex-1 min-h-0\">\n          <!-- Left panel: pack list -->\n          <div class=\"w-60 shrink-0 border-r border-gray-700 flex flex-col\">\n            <div class=\"px-3 pt-2 pb-1 text-xs font-semibold text-gray-400 uppercase tracking-wide\">\n              Packs\n            </div>\n            <div class=\"flex-1 overflow-y-auto\">\n              <div\n                v-for=\"pack in soundStore.packs\"\n                :key=\"pack.name\"\n                class=\"flex items-center gap-2 px-2 py-1.5 cursor-pointer rounded mx-1\"\n                :class=\"selectedPack === pack.name ? 'bg-gray-700' : 'hover:bg-gray-800'\"\n                @click=\"selectPack(pack.name)\"\n                @contextmenu=\"onPackRightClick($event, pack.name)\"\n              >\n                <input\n                  type=\"checkbox\"\n                  :checked=\"isPackActive(pack.name)\"\n                  class=\"w-4 h-4 accent-indigo-400 cursor-pointer\"\n                  @click.stop\n                  @change=\"togglePackActive(pack.name, ($event.target as HTMLInputElement).checked)\"\n                />\n                <span class=\"text-sm text-gray-200 truncate flex-1\">{{ pack.name }}</span>\n              </div>\n            </div>\n            <!-- Buttons / new pack input -->\n            <div class=\"flex flex-col gap-1 p-2 border-t border-gray-700\">\n              <div v-if=\"creatingPack\" class=\"flex gap-1\">\n                <input\n                  ref=\"newPackInput\"\n                  v-model=\"newPackName\"\n                  class=\"flex-1 px-2 py-1 bg-gray-800 border border-gray-600 rounded text-xs text-gray-200 outline-none focus:border-indigo-400\"\n                  placeholder=\"Pack name…\"\n                  @keydown.enter=\"confirmCreatePack\"\n                  @keydown.escape=\"cancelCreatePack\"\n                />\n                <button\n                  class=\"px-2 py-1 bg-indigo-600/80 rounded hover:bg-indigo-500 text-xs text-white\"\n                  @click=\"confirmCreatePack\"\n                >OK</button>\n              </div>\n              <div class=\"flex gap-1\">\n                <button\n                  class=\"flex-1 px-2 py-1 bg-gray-700/60 rounded hover:bg-gray-600/70 text-xs text-gray-200\"\n                  @click=\"startCreatePack\"\n                >\n                  New Pack\n                </button>\n                <button\n                  class=\"flex-1 px-2 py-1 bg-gray-700/60 rounded hover:bg-gray-600/70 text-xs text-gray-200\"\n                  @click=\"openImportPicker\"\n                >\n                  Import\n                </button>\n              </div>\n            </div>\n          </div>\n\n          <!-- Patchbay: Sounds + Events columns -->\n          <div ref=\"rightPanel\" class=\"flex flex-1 min-h-0 overflow-hidden\">\n            <!-- Sounds column -->\n            <div class=\"flex-1 border-r border-gray-700 flex flex-col min-w-0\">\n              <div class=\"px-3 py-2 border-b border-gray-700 shrink-0\">\n                <span class=\"text-xs font-semibold text-gray-400 uppercase tracking-wide\">Sounds</span>\n              </div>\n              <div class=\"flex-1 overflow-y-auto\">\n                <div\n                  v-if=\"!selectedPackInfo\"\n                  class=\"flex items-center justify-center h-full text-gray-600 text-sm\"\n                >\n                  Select a pack\n                </div>\n                <div\n                  v-else-if=\"selectedPackInfo.manifest.sounds.length === 0\"\n                  class=\"flex items-center justify-center h-full text-gray-600 text-sm\"\n                >\n                  No sounds in this pack\n                </div>\n                <div\n                  v-for=\"sound in selectedPackInfo.manifest.sounds\"\n                  v-else\n                  :key=\"sound.file\"\n                  class=\"flex items-center gap-2 px-3 py-1.5 border-b border-gray-800 hover:bg-gray-800/40\"\n                  @mouseenter=\"hoveredSoundFile = sound.file\"\n                  @mouseleave=\"hoveredSoundFile = null\"\n                >\n                  <!-- Play button -->\n                  <button\n                    class=\"shrink-0 w-6 h-6 flex items-center justify-center rounded text-gray-400 hover:text-white hover:bg-gray-700 text-xs\"\n                    title=\"Play preview\"\n                    @click=\"playPreview(sound.file)\"\n                  >▶</button>\n\n                  <!-- Filename -->\n                  <span class=\"flex-1 text-xs font-mono text-gray-200 truncate min-w-0\">{{ sound.file }}</span>\n\n                  <!-- Broken link indicator -->\n                  <span\n                    v-if=\"soundFileExists.get(sound.file) === false\"\n                    class=\"shrink-0 text-red-400 text-xs\"\n                    title=\"File not found on disk\"\n                  >⚠</span>\n\n                  <!-- Volume slider (visible on hover) -->\n                  <input\n                    v-show=\"hoveredSoundFile === sound.file\"\n                    type=\"range\"\n                    min=\"0\"\n                    max=\"1\"\n                    step=\"0.01\"\n                    :value=\"sound.volume\"\n                    class=\"shrink-0 w-16 accent-indigo-400\"\n                    title=\"Volume\"\n                    @input=\"updateSoundVolume(sound, parseFloat(($event.target as HTMLInputElement).value))\"\n                  />\n\n                  <!-- Enabled toggle -->\n                  <input\n                    type=\"checkbox\"\n                    :checked=\"sound.enabled\"\n                    class=\"shrink-0 w-4 h-4 accent-indigo-400 cursor-pointer\"\n                    title=\"Enable/disable this sound\"\n                    @change=\"updateSoundEnabled(sound, ($event.target as HTMLInputElement).checked)\"\n                  />\n\n                  <!-- Stop button -->\n                  <button\n                    class=\"shrink-0 w-6 h-6 flex items-center justify-center rounded text-xs\"\n                    :class=\"previewFile === sound.file\n                      ? 'text-red-400 hover:text-red-300 hover:bg-gray-700'\n                      : 'text-gray-600 cursor-default'\"\n                    title=\"Stop preview\"\n                    @click=\"previewFile === sound.file ? stopPreview() : undefined\"\n                  >■</button>\n                </div>\n              </div>\n            </div>\n\n            <!-- Events column -->\n            <div class=\"flex-1 flex flex-col min-w-0\">\n              <div class=\"px-3 py-2 border-b border-gray-700 shrink-0\">\n                <span class=\"text-xs font-semibold text-gray-400 uppercase tracking-wide\">Events</span>\n              </div>\n              <div class=\"flex-1 overflow-y-auto\">\n                <div\n                  v-for=\"eventType in AGENT_EVENT_TYPES\"\n                  :key=\"eventType\"\n                  class=\"flex items-center gap-2 px-3 py-2 border-b border-gray-800 transition-opacity\"\n                  :class=\"hasAssignments(eventType) ? 'opacity-100' : 'opacity-40'\"\n                >\n                  <span class=\"text-sm font-mono text-gray-300 flex-1\">{{ eventType }}</span>\n                  <!-- Info icon + popover -->\n                  <span\n                    v-if=\"EVENT_DESCRIPTIONS[eventType]\"\n                    class=\"relative shrink-0\"\n                    @click.stop\n                  >\n                    <span\n                      class=\"w-4 h-4 flex items-center justify-center rounded-full border text-[10px] leading-none cursor-pointer select-none\"\n                      :class=\"activeInfoPopover === eventType\n                        ? 'border-indigo-400 text-indigo-300 bg-indigo-900/40'\n                        : 'border-gray-500 text-gray-400 hover:border-gray-300 hover:text-gray-200'\"\n                      @click=\"toggleInfoPopover(eventType)\"\n                    >i</span>\n                    <div\n                      v-if=\"activeInfoPopover === eventType\"\n                      class=\"absolute right-0 top-6 z-50 w-56 bg-gray-800 border border-gray-600 rounded shadow-lg px-3 py-2 text-xs text-gray-200 leading-relaxed\"\n                    >\n                      {{ EVENT_DESCRIPTIONS[eventType] }}\n                    </div>\n                  </span>\n                  <!-- US-006 will add assignment chips here -->\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        <!-- Footer -->\n        <div class=\"flex justify-end px-4 py-3 border-t border-gray-700 shrink-0\">\n          <button\n            class=\"px-4 py-1.5 bg-gray-700/60 rounded hover:bg-gray-600/70 text-sm text-gray-200\"\n            @click=\"emit('close')\"\n          >\n            Close\n          </button>\n        </div>\n      </div>\n    </div>\n\n    <!-- Context menu -->\n    <PackContextMenu\n      v-if=\"ctxMenu\"\n      :pack-name=\"ctxMenu.packName\"\n      :x=\"ctxMenu.x\"\n      :y=\"ctxMenu.y\"\n      @close=\"closeCtxMenu\"\n      @renamed=\"onPackRenamed\"\n      @duplicated=\"onPackDuplicated\"\n      @deleted=\"onPackDeleted\"\n    />\n  </Teleport>\n</template>\n","numLines":593,"startLine":1,"totalLines":593}}}
{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_018MK7cABJKn4TPJPwSdBtiW","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01NuATNURZxYxaXFJAZhkxcj","name":"Read","input":{"file_path":"/Users/markus/baustelle/projects/agents-in-the-office/agents-in-the-office/.chief/worktrees/sound-packs-patchbay/src/stores/soundStore.ts"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":5058,"cache_read_input_tokens":37503,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":5058},"output_tokens":8,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"1314d513-0f86-4cdc-8c19-398084d74c3f","uuid":"84bae65c-b977-477c-a689-302972e83435"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NuATNURZxYxaXFJAZhkxcj","type":"tool_result","content":"     1→import { defineStore } from 'pinia';\n     2→import { ref } from 'vue';\n     3→import { homeDir } from '@tauri-apps/api/path';\n     4→import {\n     5→  readTextFile,\n     6→  writeTextFile,\n     7→  mkdir,\n     8→  exists,\n     9→  readDir,\n    10→  readFile,\n    11→} from '@tauri-apps/plugin-fs';\n    12→import type { AgentEvent, AgentEventType } from '../drivers/types';\n    13→\n    14→export const AGENT_EVENT_TYPES: AgentEventType[] = [\n    15→  'session_start',\n    16→  'session_end',\n    17→  'prompt_submit',\n    18→  'tool_start',\n    19→  'tool_end',\n    20→  'turn_end',\n    21→  'permission_wait',\n    22→  'subagent_start',\n    23→  'subagent_end',\n    24→  'idle_notification',\n    25→  'elicitation_wait',\n    26→  'auth_success',\n    27→  'worktree_create',\n    28→  'worktree_remove',\n    29→  'teammate_idle',\n    30→  'task_completed',\n    31→];\n    32→\n    33→export interface TrackConfig {\n    34→  enabled: boolean;\n    35→  volume: number;\n    36→}\n    37→\n    38→export interface SoundConfig {\n    39→  enabled: boolean;\n    40→  globalVolume: number;\n    41→  cooldownSeconds: number;\n    42→  activePacks: string[];\n    43→  /** Per-sound overrides, key: \"<packName>/<filename>\" */\n    44→  soundOverrides: Record<string, { volume: number; enabled: boolean }>;\n    45→  /** Legacy field — read for migration only, not written on save */\n    46→  tracks?: Record<string, Record<string, TrackConfig>>;\n    47→}\n    48→\n    49→export interface PackManifestSound {\n    50→  file: string;\n    51→  volume: number;\n    52→  enabled: boolean;\n    53→}\n    54→\n    55→export interface PackManifestAssignment {\n    56→  file: string;\n    57→  event: AgentEventType;\n    58→}\n    59→\n    60→export interface PackManifest {\n    61→  sounds: PackManifestSound[];\n    62→  assignments: PackManifestAssignment[];\n    63→}\n    64→\n    65→export interface PackInfo {\n    66→  name: string;\n    67→  categories: Record<string, string[]>;\n    68→  manifest: PackManifest;\n    69→  hasManifest: boolean;\n    70→}\n    71→\n    72→\n    73→const DEFAULT_CONFIG: SoundConfig = {\n    74→  enabled: true,\n    75→  globalVolume: 0.8,\n    76→  cooldownSeconds: 2,\n    77→  activePacks: [],\n    78→  soundOverrides: {},\n    79→};\n    80→\n    81→function migrateTracksToSoundOverrides(\n    82→  tracks: Record<string, Record<string, TrackConfig>>,\n    83→): Record<string, { volume: number; enabled: boolean }> {\n    84→  const overrides: Record<string, { volume: number; enabled: boolean }> = {};\n    85→  for (const [packName, packTracks] of Object.entries(tracks)) {\n    86→    for (const [categoryAndFile, trackCfg] of Object.entries(packTracks)) {\n    87→      const slashIdx = categoryAndFile.indexOf('/');\n    88→      const filename = slashIdx >= 0 ? categoryAndFile.slice(slashIdx + 1) : categoryAndFile;\n    89→      const overrideKey = `${packName}/${filename}`;\n    90→      if (!(overrideKey in overrides)) {\n    91→        overrides[overrideKey] = { volume: trackCfg.volume, enabled: trackCfg.enabled };\n    92→      }\n    93→    }\n    94→  }\n    95→  return overrides;\n    96→}\n    97→\n    98→const AUDIO_EXTENSIONS = new Set(['.mp3', '.ogg', '.wav', '.flac', '.m4a', '.webm']);\n    99→\n   100→function hasAudioExtension(filename: string): boolean {\n   101→  const dot = filename.lastIndexOf('.');\n   102→  if (dot < 0) return false;\n   103→  return AUDIO_EXTENSIONS.has(filename.slice(dot).toLowerCase());\n   104→}\n   105→\n   106→export const useSoundStore = defineStore('sound', () => {\n   107→  const config = ref<SoundConfig>({ ...DEFAULT_CONFIG, soundOverrides: {} });\n   108→  const packs = ref<PackInfo[]>([]);\n   109→\n   110→  // Reactive state for sound indicator (US-009)\n   111→  const lastPlayedSessionId = ref<string | null>(null);\n   112→\n   113→  let soundPacksDir = '';\n   114→  let configPath = '';\n   115→\n   116→  // AudioContext — lazy init on first playback\n   117→  let audioCtx: AudioContext | null = null;\n   118→\n   119→  // Buffer cache: absolute file path → AudioBuffer\n   120→  const bufferCache = new Map<string, AudioBuffer>();\n   121→\n   122→  // Per-category cooldown timestamps (category → last played ms)\n   123→  const cooldownMap = new Map<string, number>();\n   124→\n   125→  // Whether any sound is currently playing\n   126→  let playing = false;\n   127→\n   128→  // Per-session pack assignment\n   129→  const sessionPacks = new Map<string, string>();\n   130→\n   131→  // -------------------------------------------------------------------------\n   132→  // Init / persistence\n   133→  // -------------------------------------------------------------------------\n   134→\n   135→  async function init(): Promise<void> {\n   136→    const home = await homeDir();\n   137→    soundPacksDir = `${home}/.agents-in-the-office/sound-packs`;\n   138→    configPath = `${soundPacksDir}/config.json`;\n   139→\n   140→    const dirExists = await exists(soundPacksDir);\n   141→    if (!dirExists) {\n   142→      await mkdir(soundPacksDir, { recursive: true });\n   143→    }\n   144→\n   145→    const cfgExists = await exists(configPath);\n   146→    if (cfgExists) {\n   147→      try {\n   148→        const raw = await readTextFile(configPath);\n   149→        const parsed = JSON.parse(raw) as Partial<SoundConfig>;\n   150→        // Migrate legacy tracks field to soundOverrides\n   151→        if (!parsed.soundOverrides && parsed.tracks) {\n   152→          parsed.soundOverrides = migrateTracksToSoundOverrides(parsed.tracks);\n   153→        }\n   154→        const { tracks: _tracks, ...rest } = parsed;\n   155→        void _tracks; // consumed by migration above, drop from config\n   156→        config.value = { ...DEFAULT_CONFIG, ...rest };\n   157→      } catch {\n   158→        config.value = { ...DEFAULT_CONFIG, soundOverrides: {} };\n   159→      }\n   160→    } else {\n   161→      config.value = { ...DEFAULT_CONFIG, soundOverrides: {} };\n   162→      await saveConfig();\n   163→    }\n   164→  }\n   165→\n   166→  async function saveConfig(): Promise<void> {\n   167→    await writeTextFile(configPath, JSON.stringify(config.value, null, 2));\n   168→  }\n   169→\n   170→  // -------------------------------------------------------------------------\n   171→  // Pack manifest read/write\n   172→  // -------------------------------------------------------------------------\n   173→\n   174→  async function loadPackManifest(packName: string): Promise<PackManifest> {\n   175→    const manifestPath = `${soundPacksDir}/${packName}/manifest.json`;\n   176→    const manifestExists = await exists(manifestPath);\n   177→    if (!manifestExists) return { sounds: [], assignments: [] };\n   178→    try {\n   179→      const raw = await readTextFile(manifestPath);\n   180→      const parsed = JSON.parse(raw) as Partial<PackManifest>;\n   181→      return {\n   182→        sounds: Array.isArray(parsed.sounds) ? parsed.sounds : [],\n   183→        assignments: Array.isArray(parsed.assignments) ? parsed.assignments : [],\n   184→      };\n   185→    } catch {\n   186→      return { sounds: [], assignments: [] };\n   187→    }\n   188→  }\n   189→\n   190→  async function savePackManifest(packName: string, manifest: PackManifest): Promise<void> {\n   191→    const manifestPath = `${soundPacksDir}/${packName}/manifest.json`;\n   192→    await writeTextFile(manifestPath, JSON.stringify(manifest, null, 2));\n   193→  }\n   194→\n   195→  // -------------------------------------------------------------------------\n   196→  // Pack scanning\n   197→  // -------------------------------------------------------------------------\n   198→\n   199→  async function scanPacks(): Promise<PackInfo[]> {\n   200→    const discovered: PackInfo[] = [];\n   201→\n   202→    const dirExists = await exists(soundPacksDir);\n   203→    if (!dirExists) return discovered;\n   204→\n   205→    const entries = await readDir(soundPacksDir);\n   206→    for (const entry of entries) {\n   207→      if (!entry.isDirectory) continue;\n   208→      if (entry.name === undefined || entry.name.startsWith('.')) continue;\n   209→      const packName = entry.name;\n   210→      const packPath = `${soundPacksDir}/${packName}`;\n   211→      const categories: Record<string, string[]> = {};\n   212→\n   213→      const manifest = await loadPackManifest(packName);\n   214→      const hasManifest = await exists(`${packPath}/manifest.json`);\n   215→\n   216→      const catEntries = await readDir(packPath);\n   217→      for (const cat of catEntries) {\n   218→        if (!cat.isDirectory) continue;\n   219→        if (cat.name === undefined || cat.name.startsWith('.')) continue;\n   220→        const catName = cat.name;\n   221→        const catPath = `${packPath}/${catName}`;\n   222→        const fileEntries = await readDir(catPath);\n   223→        const audioFiles = fileEntries\n   224→          .filter((f) => !f.isDirectory && f.name !== undefined && hasAudioExtension(f.name))\n   225→          .map((f) => f.name as string);\n   226→        if (audioFiles.length > 0 || AGENT_EVENT_TYPES.includes(catName as AgentEventType)) {\n   227→          categories[catName] = audioFiles.sort();\n   228→        }\n   229→      }\n   230→\n   231→      for (const eventType of AGENT_EVENT_TYPES) {\n   232→        if (!(eventType in categories)) {\n   233→          categories[eventType] = [];\n   234→        }\n   235→      }\n   236→\n   237→      discovered.push({ name: packName, categories, manifest, hasManifest });\n   238→    }\n   239→\n   240→    packs.value = discovered;\n   241→    return discovered;\n   242→  }\n   243→\n   244→  // -------------------------------------------------------------------------\n   245→  // Sound override helpers (two-layer: soundOverrides → manifest default)\n   246→  // -------------------------------------------------------------------------\n   247→\n   248→  /** Extract filename from \"category/filename\" or plain \"filename\" key. */\n   249→  function extractFilename(categoryAndFile: string): string {\n   250→    const slashIdx = categoryAndFile.indexOf('/');\n   251→    return slashIdx >= 0 ? categoryAndFile.slice(slashIdx + 1) : categoryAndFile;\n   252→  }\n   253→\n   254→  /**\n   255→   * Effective volume for a sound: soundOverrides → manifest default → 1.0\n   256→   */\n   257→  function effectiveVolume(packName: string, filename: string, manifestSound?: PackManifestSound): number {\n   258→    const override = config.value.soundOverrides[`${packName}/${filename}`];\n   259→    if (override !== undefined) return override.volume;\n   260→    return manifestSound?.volume ?? 1.0;\n   261→  }\n   262→\n   263→  /**\n   264→   * Effective enabled state: soundOverrides → manifest default → true\n   265→   */\n   266→  function isEnabled(packName: string, filename: string, manifestSound?: PackManifestSound): boolean {\n   267→    const override = config.value.soundOverrides[`${packName}/${filename}`];\n   268→    if (override !== undefined) return override.enabled;\n   269→    return manifestSound?.enabled ?? true;\n   270→  }\n   271→\n   272→  /**\n   273→   * Get track config for a sound. Accepts legacy \"category/filename\" key format.\n   274→   * Reads from soundOverrides using packName/filename key.\n   275→   */\n   276→  function getTrackConfig(packName: string, categoryAndFile: string): TrackConfig {\n   277→    const filename = extractFilename(categoryAndFile);\n   278→    const override = config.value.soundOverrides[`${packName}/${filename}`];\n   279→    return override ?? { enabled: true, volume: 1.0 };\n   280→  }\n   281→\n   282→  /**\n   283→   * Set track config for a sound. Accepts legacy \"category/filename\" key format.\n   284→   * Writes to soundOverrides using packName/filename key.\n   285→   */\n   286→  function setTrackConfig(packName: string, categoryAndFile: string, track: TrackConfig): void {\n   287→    const filename = extractFilename(categoryAndFile);\n   288→    config.value.soundOverrides[`${packName}/${filename}`] = track;\n   289→  }\n   290→\n   291→  function getSoundPacksDir(): string {\n   292→    return soundPacksDir;\n   293→  }\n   294→\n   295→  function getSessionPack(sessionId: string): string | undefined {\n   296→    return sessionPacks.get(sessionId);\n   297→  }\n   298→\n   299→  function assignSessionPack(sessionId: string, preferredPacks: string[]): void {\n   300→    const pool = preferredPacks.length > 0 ? preferredPacks : config.value.activePacks;\n   301→    if (pool.length === 0) return;\n   302→    const chosen = pool[Math.floor(Math.random() * pool.length)];\n   303→    if (chosen !== undefined) {\n   304→      sessionPacks.set(sessionId, chosen);\n   305→    }\n   306→  }\n   307→\n   308→  // -------------------------------------------------------------------------\n   309→  // AudioContext helpers\n   310→  // -------------------------------------------------------------------------\n   311→\n   312→  function getAudioContext(): AudioContext {\n   313→    if (!audioCtx) {\n   314→      audioCtx = new AudioContext();\n   315→    }\n   316→    return audioCtx;\n   317→  }\n   318→\n   319→  async function loadBuffer(filePath: string): Promise<AudioBuffer | null> {\n   320→    const cached = bufferCache.get(filePath);\n   321→    if (cached !== undefined) return cached;\n   322→\n   323→    try {\n   324→      const bytes = await readFile(filePath);\n   325→      const ctx = getAudioContext();\n   326→      const buffer = await ctx.decodeAudioData(bytes.buffer as ArrayBuffer);\n   327→      bufferCache.set(filePath, buffer);\n   328→      return buffer;\n   329→    } catch (err) {\n   330→      console.warn(`[soundStore] Failed to decode audio: ${filePath}`, err);\n   331→      return null;\n   332→    }\n   333→  }\n   334→\n   335→  // -------------------------------------------------------------------------\n   336→  // Playback engine\n   337→  // -------------------------------------------------------------------------\n   338→\n   339→  async function playForEvent(event: AgentEvent): Promise<void> {\n   340→    if (!config.value.enabled) return;\n   341→\n   342→    // Session pack assignment on session_start\n   343→    if (event.type === 'session_start') {\n   344→      const { activePacks } = config.value;\n   345→      if (activePacks.length > 0) {\n   346→        const randomIdx = Math.floor(Math.random() * activePacks.length);\n   347→        const chosen = activePacks[randomIdx];\n   348→        if (chosen !== undefined) {\n   349→          sessionPacks.set(event.sessionId, chosen);\n   350→        }\n   351→      }\n   352→    }\n   353→\n   354→    const packName = sessionPacks.get(event.sessionId);\n   355→    if (!packName) return;\n   356→\n   357→    const category = event.type;\n   358→    const now = Date.now();\n   359→    const cooldownMs = config.value.cooldownSeconds * 1000;\n   360→    const lastPlayed = cooldownMap.get(category) ?? 0;\n   361→    if (now - lastPlayed < cooldownMs) return;\n   362→\n   363→    if (playing) return;\n   364→\n   365→    // Find the pack info\n   366→    const packInfo = packs.value.find((p) => p.name === packName);\n   367→    if (!packInfo) return;\n   368→\n   369→    // Look up manifest assignments for this event type\n   370→    const assignedFiles = packInfo.manifest.assignments\n   371→      .filter((a) => a.event === event.type)\n   372→      .map((a) => a.file);\n   373→\n   374→    // Build a lookup map for manifest sound defaults\n   375→    const manifestSoundMap = new Map(packInfo.manifest.sounds.map((s) => [s.file, s]));\n   376→\n   377→    // Filter to enabled files using two-layer rule (soundOverrides → manifest default)\n   378→    const enabledFiles = assignedFiles.filter((filename) =>\n   379→      isEnabled(packName, filename, manifestSoundMap.get(filename)),\n   380→    );\n   381→\n   382→    if (enabledFiles.length === 0) return;\n   383→\n   384→    const randomFileIdx = Math.floor(Math.random() * enabledFiles.length);\n   385→    const chosenFile = enabledFiles[randomFileIdx];\n   386→    if (chosenFile === undefined) return;\n   387→\n   388→    // Files live at pack root, not in category subdirectories\n   389→    const filePath = `${soundPacksDir}/${packName}/${chosenFile}`;\n   390→\n   391→    // Skip missing file with a warning — no crash\n   392→    const fileOnDisk = await exists(filePath);\n   393→    if (!fileOnDisk) {\n   394→      console.warn(`[soundStore] Sound file not found on disk, skipping: ${filePath}`);\n   395→      return;\n   396→    }\n   397→\n   398→    const buffer = await loadBuffer(filePath);\n   399→    if (!buffer) return;\n   400→\n   401→    const manifestSound = manifestSoundMap.get(chosenFile);\n   402→    const vol = effectiveVolume(packName, chosenFile, manifestSound);\n   403→    const ctx = getAudioContext();\n   404→\n   405→    const gainNode = ctx.createGain();\n   406→    gainNode.gain.value = config.value.globalVolume * vol;\n   407→    gainNode.connect(ctx.destination);\n   408→\n   409→    const source = ctx.createBufferSource();\n   410→    source.buffer = buffer;\n   411→    source.connect(gainNode);\n   412→\n   413→    playing = true;\n   414→    cooldownMap.set(category, now);\n   415→    lastPlayedSessionId.value = event.sessionId;\n   416→\n   417→    source.onended = () => {\n   418→      playing = false;\n   419→    };\n   420→\n   421→    source.start();\n   422→  }\n   423→\n   424→  // -------------------------------------------------------------------------\n   425→  // Public AudioContext access (for AudioPlayer.vue)\n   426→  // -------------------------------------------------------------------------\n   427→\n   428→  function getOrCreateAudioContext(): AudioContext {\n   429→    return getAudioContext();\n   430→  }\n   431→\n   432→  function getBufferCache(): Map<string, AudioBuffer> {\n   433→    return bufferCache;\n   434→  }\n   435→\n   436→  return {\n   437→    config,\n   438→    packs,\n   439→    lastPlayedSessionId,\n   440→    init,\n   441→    saveConfig,\n   442→    scanPacks,\n   443→    loadPackManifest,\n   444→    savePackManifest,\n   445→    getTrackConfig,\n   446→    setTrackConfig,\n   447→    effectiveVolume,\n   448→    isEnabled,\n   449→    getSoundPacksDir,\n   450→    playForEvent,\n   451→    getOrCreateAudioContext,\n   452→    getBufferCache,\n   453→    loadBuffer,\n   454→    getSessionPack,\n   455→    assignSessionPack,\n   456→  };\n   457→});\n   458→"}]},"parent_tool_use_id":null,"session_id":"1314d513-0f86-4cdc-8c19-398084d74c3f","uuid":"6e8e31d0-089b-4cc3-be1b-41168ce37603","tool_use_result":{"type":"text","file":{"filePath":"/Users/markus/baustelle/projects/agents-in-the-office/agents-in-the-office/.chief/worktrees/sound-packs-patchbay/src/stores/soundStore.ts","content":"import { defineStore } from 'pinia';\nimport { ref } from 'vue';\nimport { homeDir } from '@tauri-apps/api/path';\nimport {\n  readTextFile,\n  writeTextFile,\n  mkdir,\n  exists,\n  readDir,\n  readFile,\n} from '@tauri-apps/plugin-fs';\nimport type { AgentEvent, AgentEventType } from '../drivers/types';\n\nexport const AGENT_EVENT_TYPES: AgentEventType[] = [\n  'session_start',\n  'session_end',\n  'prompt_submit',\n  'tool_start',\n  'tool_end',\n  'turn_end',\n  'permission_wait',\n  'subagent_start',\n  'subagent_end',\n  'idle_notification',\n  'elicitation_wait',\n  'auth_success',\n  'worktree_create',\n  'worktree_remove',\n  'teammate_idle',\n  'task_completed',\n];\n\nexport interface TrackConfig {\n  enabled: boolean;\n  volume: number;\n}\n\nexport interface SoundConfig {\n  enabled: boolean;\n  globalVolume: number;\n  cooldownSeconds: number;\n  activePacks: string[];\n  /** Per-sound overrides, key: \"<packName>/<filename>\" */\n  soundOverrides: Record<string, { volume: number; enabled: boolean }>;\n  /** Legacy field — read for migration only, not written on save */\n  tracks?: Record<string, Record<string, TrackConfig>>;\n}\n\nexport interface PackManifestSound {\n  file: string;\n  volume: number;\n  enabled: boolean;\n}\n\nexport interface PackManifestAssignment {\n  file: string;\n  event: AgentEventType;\n}\n\nexport interface PackManifest {\n  sounds: PackManifestSound[];\n  assignments: PackManifestAssignment[];\n}\n\nexport interface PackInfo {\n  name: string;\n  categories: Record<string, string[]>;\n  manifest: PackManifest;\n  hasManifest: boolean;\n}\n\n\nconst DEFAULT_CONFIG: SoundConfig = {\n  enabled: true,\n  globalVolume: 0.8,\n  cooldownSeconds: 2,\n  activePacks: [],\n  soundOverrides: {},\n};\n\nfunction migrateTracksToSoundOverrides(\n  tracks: Record<string, Record<string, TrackConfig>>,\n): Record<string, { volume: number; enabled: boolean }> {\n  const overrides: Record<string, { volume: number; enabled: boolean }> = {};\n  for (const [packName, packTracks] of Object.entries(tracks)) {\n    for (const [categoryAndFile, trackCfg] of Object.entries(packTracks)) {\n      const slashIdx = categoryAndFile.indexOf('/');\n      const filename = slashIdx >= 0 ? categoryAndFile.slice(slashIdx + 1) : categoryAndFile;\n      const overrideKey = `${packName}/${filename}`;\n      if (!(overrideKey in overrides)) {\n        overrides[overrideKey] = { volume: trackCfg.volume, enabled: trackCfg.enabled };\n      }\n    }\n  }\n  return overrides;\n}\n\nconst AUDIO_EXTENSIONS = new Set(['.mp3', '.ogg', '.wav', '.flac', '.m4a', '.webm']);\n\nfunction hasAudioExtension(filename: string): boolean {\n  const dot = filename.lastIndexOf('.');\n  if (dot < 0) return false;\n  return AUDIO_EXTENSIONS.has(filename.slice(dot).toLowerCase());\n}\n\nexport const useSoundStore = defineStore('sound', () => {\n  const config = ref<SoundConfig>({ ...DEFAULT_CONFIG, soundOverrides: {} });\n  const packs = ref<PackInfo[]>([]);\n\n  // Reactive state for sound indicator (US-009)\n  const lastPlayedSessionId = ref<string | null>(null);\n\n  let soundPacksDir = '';\n  let configPath = '';\n\n  // AudioContext — lazy init on first playback\n  let audioCtx: AudioContext | null = null;\n\n  // Buffer cache: absolute file path → AudioBuffer\n  const bufferCache = new Map<string, AudioBuffer>();\n\n  // Per-category cooldown timestamps (category → last played ms)\n  const cooldownMap = new Map<string, number>();\n\n  // Whether any sound is currently playing\n  let playing = false;\n\n  // Per-session pack assignment\n  const sessionPacks = new Map<string, string>();\n\n  // -------------------------------------------------------------------------\n  // Init / persistence\n  // -------------------------------------------------------------------------\n\n  async function init(): Promise<void> {\n    const home = await homeDir();\n    soundPacksDir = `${home}/.agents-in-the-office/sound-packs`;\n    configPath = `${soundPacksDir}/config.json`;\n\n    const dirExists = await exists(soundPacksDir);\n    if (!dirExists) {\n      await mkdir(soundPacksDir, { recursive: true });\n    }\n\n    const cfgExists = await exists(configPath);\n    if (cfgExists) {\n      try {\n        const raw = await readTextFile(configPath);\n        const parsed = JSON.parse(raw) as Partial<SoundConfig>;\n        // Migrate legacy tracks field to soundOverrides\n        if (!parsed.soundOverrides && parsed.tracks) {\n          parsed.soundOverrides = migrateTracksToSoundOverrides(parsed.tracks);\n        }\n        const { tracks: _tracks, ...rest } = parsed;\n        void _tracks; // consumed by migration above, drop from config\n        config.value = { ...DEFAULT_CONFIG, ...rest };\n      } catch {\n        config.value = { ...DEFAULT_CONFIG, soundOverrides: {} };\n      }\n    } else {\n      config.value = { ...DEFAULT_CONFIG, soundOverrides: {} };\n      await saveConfig();\n    }\n  }\n\n  async function saveConfig(): Promise<void> {\n    await writeTextFile(configPath, JSON.stringify(config.value, null, 2));\n  }\n\n  // -------------------------------------------------------------------------\n  // Pack manifest read/write\n  // -------------------------------------------------------------------------\n\n  async function loadPackManifest(packName: string): Promise<PackManifest> {\n    const manifestPath = `${soundPacksDir}/${packName}/manifest.json`;\n    const manifestExists = await exists(manifestPath);\n    if (!manifestExists) return { sounds: [], assignments: [] };\n    try {\n      const raw = await readTextFile(manifestPath);\n      const parsed = JSON.parse(raw) as Partial<PackManifest>;\n      return {\n        sounds: Array.isArray(parsed.sounds) ? parsed.sounds : [],\n        assignments: Array.isArray(parsed.assignments) ? parsed.assignments : [],\n      };\n    } catch {\n      return { sounds: [], assignments: [] };\n    }\n  }\n\n  async function savePackManifest(packName: string, manifest: PackManifest): Promise<void> {\n    const manifestPath = `${soundPacksDir}/${packName}/manifest.json`;\n    await writeTextFile(manifestPath, JSON.stringify(manifest, null, 2));\n  }\n\n  // -------------------------------------------------------------------------\n  // Pack scanning\n  // -------------------------------------------------------------------------\n\n  async function scanPacks(): Promise<PackInfo[]> {\n    const discovered: PackInfo[] = [];\n\n    const dirExists = await exists(soundPacksDir);\n    if (!dirExists) return discovered;\n\n    const entries = await readDir(soundPacksDir);\n    for (const entry of entries) {\n      if (!entry.isDirectory) continue;\n      if (entry.name === undefined || entry.name.startsWith('.')) continue;\n      const packName = entry.name;\n      const packPath = `${soundPacksDir}/${packName}`;\n      const categories: Record<string, string[]> = {};\n\n      const manifest = await loadPackManifest(packName);\n      const hasManifest = await exists(`${packPath}/manifest.json`);\n\n      const catEntries = await readDir(packPath);\n      for (const cat of catEntries) {\n        if (!cat.isDirectory) continue;\n        if (cat.name === undefined || cat.name.startsWith('.')) continue;\n        const catName = cat.name;\n        const catPath = `${packPath}/${catName}`;\n        const fileEntries = await readDir(catPath);\n        const audioFiles = fileEntries\n          .filter((f) => !f.isDirectory && f.name !== undefined && hasAudioExtension(f.name))\n          .map((f) => f.name as string);\n        if (audioFiles.length > 0 || AGENT_EVENT_TYPES.includes(catName as AgentEventType)) {\n          categories[catName] = audioFiles.sort();\n        }\n      }\n\n      for (const eventType of AGENT_EVENT_TYPES) {\n        if (!(eventType in categories)) {\n          categories[eventType] = [];\n        }\n      }\n\n      discovered.push({ name: packName, categories, manifest, hasManifest });\n    }\n\n    packs.value = discovered;\n    return discovered;\n  }\n\n  // -------------------------------------------------------------------------\n  // Sound override helpers (two-layer: soundOverrides → manifest default)\n  // -------------------------------------------------------------------------\n\n  /** Extract filename from \"category/filename\" or plain \"filename\" key. */\n  function extractFilename(categoryAndFile: string): string {\n    const slashIdx = categoryAndFile.indexOf('/');\n    return slashIdx >= 0 ? categoryAndFile.slice(slashIdx + 1) : categoryAndFile;\n  }\n\n  /**\n   * Effective volume for a sound: soundOverrides → manifest default → 1.0\n   */\n  function effectiveVolume(packName: string, filename: string, manifestSound?: PackManifestSound): number {\n    const override = config.value.soundOverrides[`${packName}/${filename}`];\n    if (override !== undefined) return override.volume;\n    return manifestSound?.volume ?? 1.0;\n  }\n\n  /**\n   * Effective enabled state: soundOverrides → manifest default → true\n   */\n  function isEnabled(packName: string, filename: string, manifestSound?: PackManifestSound): boolean {\n    const override = config.value.soundOverrides[`${packName}/${filename}`];\n    if (override !== undefined) return override.enabled;\n    return manifestSound?.enabled ?? true;\n  }\n\n  /**\n   * Get track config for a sound. Accepts legacy \"category/filename\" key format.\n   * Reads from soundOverrides using packName/filename key.\n   */\n  function getTrackConfig(packName: string, categoryAndFile: string): TrackConfig {\n    const filename = extractFilename(categoryAndFile);\n    const override = config.value.soundOverrides[`${packName}/${filename}`];\n    return override ?? { enabled: true, volume: 1.0 };\n  }\n\n  /**\n   * Set track config for a sound. Accepts legacy \"category/filename\" key format.\n   * Writes to soundOverrides using packName/filename key.\n   */\n  function setTrackConfig(packName: string, categoryAndFile: string, track: TrackConfig): void {\n    const filename = extractFilename(categoryAndFile);\n    config.value.soundOverrides[`${packName}/${filename}`] = track;\n  }\n\n  function getSoundPacksDir(): string {\n    return soundPacksDir;\n  }\n\n  function getSessionPack(sessionId: string): string | undefined {\n    return sessionPacks.get(sessionId);\n  }\n\n  function assignSessionPack(sessionId: string, preferredPacks: string[]): void {\n    const pool = preferredPacks.length > 0 ? preferredPacks : config.value.activePacks;\n    if (pool.length === 0) return;\n    const chosen = pool[Math.floor(Math.random() * pool.length)];\n    if (chosen !== undefined) {\n      sessionPacks.set(sessionId, chosen);\n    }\n  }\n\n  // -------------------------------------------------------------------------\n  // AudioContext helpers\n  // -------------------------------------------------------------------------\n\n  function getAudioContext(): AudioContext {\n    if (!audioCtx) {\n      audioCtx = new AudioContext();\n    }\n    return audioCtx;\n  }\n\n  async function loadBuffer(filePath: string): Promise<AudioBuffer | null> {\n    const cached = bufferCache.get(filePath);\n    if (cached !== undefined) return cached;\n\n    try {\n      const bytes = await readFile(filePath);\n      const ctx = getAudioContext();\n      const buffer = await ctx.decodeAudioData(bytes.buffer as ArrayBuffer);\n      bufferCache.set(filePath, buffer);\n      return buffer;\n    } catch (err) {\n      console.warn(`[soundStore] Failed to decode audio: ${filePath}`, err);\n      return null;\n    }\n  }\n\n  // -------------------------------------------------------------------------\n  // Playback engine\n  // -------------------------------------------------------------------------\n\n  async function playForEvent(event: AgentEvent): Promise<void> {\n    if (!config.value.enabled) return;\n\n    // Session pack assignment on session_start\n    if (event.type === 'session_start') {\n      const { activePacks } = config.value;\n      if (activePacks.length > 0) {\n        const randomIdx = Math.floor(Math.random() * activePacks.length);\n        const chosen = activePacks[randomIdx];\n        if (chosen !== undefined) {\n          sessionPacks.set(event.sessionId, chosen);\n        }\n      }\n    }\n\n    const packName = sessionPacks.get(event.sessionId);\n    if (!packName) return;\n\n    const category = event.type;\n    const now = Date.now();\n    const cooldownMs = config.value.cooldownSeconds * 1000;\n    const lastPlayed = cooldownMap.get(category) ?? 0;\n    if (now - lastPlayed < cooldownMs) return;\n\n    if (playing) return;\n\n    // Find the pack info\n    const packInfo = packs.value.find((p) => p.name === packName);\n    if (!packInfo) return;\n\n    // Look up manifest assignments for this event type\n    const assignedFiles = packInfo.manifest.assignments\n      .filter((a) => a.event === event.type)\n      .map((a) => a.file);\n\n    // Build a lookup map for manifest sound defaults\n    const manifestSoundMap = new Map(packInfo.manifest.sounds.map((s) => [s.file, s]));\n\n    // Filter to enabled files using two-layer rule (soundOverrides → manifest default)\n    const enabledFiles = assignedFiles.filter((filename) =>\n      isEnabled(packName, filename, manifestSoundMap.get(filename)),\n    );\n\n    if (enabledFiles.length === 0) return;\n\n    const randomFileIdx = Math.floor(Math.random() * enabledFiles.length);\n    const chosenFile = enabledFiles[randomFileIdx];\n    if (chosenFile === undefined) return;\n\n    // Files live at pack root, not in category subdirectories\n    const filePath = `${soundPacksDir}/${packName}/${chosenFile}`;\n\n    // Skip missing file with a warning — no crash\n    const fileOnDisk = await exists(filePath);\n    if (!fileOnDisk) {\n      console.warn(`[soundStore] Sound file not found on disk, skipping: ${filePath}`);\n      return;\n    }\n\n    const buffer = await loadBuffer(filePath);\n    if (!buffer) return;\n\n    const manifestSound = manifestSoundMap.get(chosenFile);\n    const vol = effectiveVolume(packName, chosenFile, manifestSound);\n    const ctx = getAudioContext();\n\n    const gainNode = ctx.createGain();\n    gainNode.gain.value = config.value.globalVolume * vol;\n    gainNode.connect(ctx.destination);\n\n    const source = ctx.createBufferSource();\n    source.buffer = buffer;\n    source.connect(gainNode);\n\n    playing = true;\n    cooldownMap.set(category, now);\n    lastPlayedSessionId.value = event.sessionId;\n\n    source.onended = () => {\n      playing = false;\n    };\n\n    source.start();\n  }\n\n  // -------------------------------------------------------------------------\n  // Public AudioContext access (for AudioPlayer.vue)\n  // -------------------------------------------------------------------------\n\n  function getOrCreateAudioContext(): AudioContext {\n    return getAudioContext();\n  }\n\n  function getBufferCache(): Map<string, AudioBuffer> {\n    return bufferCache;\n  }\n\n  return {\n    config,\n    packs,\n    lastPlayedSessionId,\n    init,\n    saveConfig,\n    scanPacks,\n    loadPackManifest,\n    savePackManifest,\n    getTrackConfig,\n    setTrackConfig,\n    effectiveVolume,\n    isEnabled,\n    getSoundPacksDir,\n    playForEvent,\n    getOrCreateAudioContext,\n    getBufferCache,\n    loadBuffer,\n    getSessionPack,\n    assignSessionPack,\n  };\n});\n","numLines":458,"startLine":1,"totalLines":458}}}
