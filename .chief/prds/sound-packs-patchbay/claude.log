{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01M2D66SZK2VyGmJHZA4ZTCC","type":"tool_result","content":"     1→<script setup lang=\"ts\">\n     2→import {\n     3→  ref,\n     4→  computed,\n     5→  watch,\n     6→  nextTick,\n     7→  onMounted,\n     8→  onUnmounted,\n     9→} from 'vue';\n    10→import { listen } from '@tauri-apps/api/event';\n    11→import type { UnlistenFn } from '@tauri-apps/api/event';\n    12→import { open } from '@tauri-apps/plugin-dialog';\n    13→import {\n    14→  mkdir,\n    15→  readFile,\n    16→  writeFile,\n    17→  exists,\n    18→  rename,\n    19→  remove,\n    20→} from '@tauri-apps/plugin-fs';\n    21→import JSZip from 'jszip';\n    22→import { useSoundStore, AGENT_EVENT_TYPES } from '../stores/soundStore';\n    23→import type { PackManifestSound } from '../stores/soundStore';\n    24→import type { AgentEvent, AgentEventType } from '../drivers/types';\n    25→import PackContextMenu from './PackContextMenu.vue';\n    26→\n    27→const emit = defineEmits<{ close: [] }>();\n    28→\n    29→const soundStore = useSoundStore();\n    30→\n    31→// ---- Global settings ----\n    32→const globalEnabled = computed({\n    33→  get: () => soundStore.config.enabled,\n    34→  set: (v: boolean) => { soundStore.config.enabled = v; void soundStore.saveConfig(); },\n    35→});\n    36→const globalVolume = computed({\n    37→  get: () => Math.round(soundStore.config.globalVolume * 100),\n    38→  set: (v: number) => { soundStore.config.globalVolume = v / 100; void soundStore.saveConfig(); },\n    39→});\n    40→const cooldown = computed({\n    41→  get: () => soundStore.config.cooldownSeconds,\n    42→  set: (v: number) => { soundStore.config.cooldownSeconds = v; void soundStore.saveConfig(); },\n    43→});\n    44→\n    45→// ---- Pack list ----\n    46→const selectedPack = ref<string | null>(null);\n    47→const rightPanel = ref<HTMLElement | null>(null);\n    48→\n    49→onMounted(async () => {\n    50→  await soundStore.init();\n    51→  await soundStore.scanPacks();\n    52→  if (soundStore.packs.length > 0 && soundStore.packs[0]) {\n    53→    selectedPack.value = soundStore.packs[0].name;\n    54→  }\n    55→  agentEventUnlisten = await listen<string>(\n    56→    'agent-event',\n    57→    (e) => {\n    58→      try {\n    59→        const parsed = JSON.parse(e.payload) as AgentEvent;\n    60→        flashEventRow(parsed.type);\n    61→      } catch { /* ignore parse errors */ }\n    62→    },\n    63→  );\n    64→});\n    65→\n    66→onUnmounted(() => {\n    67→  if (agentEventUnlisten) agentEventUnlisten();\n    68→  if (flashTimeout) clearTimeout(flashTimeout);\n    69→});\n    70→\n    71→function isPackActive(packName: string): boolean {\n    72→  return soundStore.config.activePacks.includes(packName);\n    73→}\n    74→\n    75→function togglePackActive(packName: string, active: boolean) {\n    76→  if (active) {\n    77→    if (!soundStore.config.activePacks.includes(packName)) {\n    78→      soundStore.config.activePacks.push(packName);\n    79→    }\n    80→  } else {\n    81→    soundStore.config.activePacks = soundStore.config.activePacks.filter(\n    82→      (p) => p !== packName,\n    83→    );\n    84→  }\n    85→  void soundStore.saveConfig();\n    86→}\n    87→\n    88→function selectPack(name: string) {\n    89→  selectedPack.value = name;\n    90→  void nextTick(() => {\n    91→    if (rightPanel.value) rightPanel.value.scrollTop = 0;\n    92→  });\n    93→}\n    94→\n    95→// ---- Context menu ----\n    96→const ctxMenu = ref<{ packName: string; x: number; y: number } | null>(null);\n    97→\n    98→function onPackRightClick(e: MouseEvent, packName: string) {\n    99→  e.preventDefault();\n   100→  ctxMenu.value = { packName, x: e.clientX, y: e.clientY };\n   101→}\n   102→\n   103→function closeCtxMenu() {\n   104→  ctxMenu.value = null;\n   105→}\n   106→\n   107→async function onPackRenamed(oldName: string, newName: string) {\n   108→  await soundStore.scanPacks();\n   109→  if (selectedPack.value === oldName) selectedPack.value = newName;\n   110→  closeCtxMenu();\n   111→}\n   112→\n   113→async function onPackDuplicated() {\n   114→  await soundStore.scanPacks();\n   115→  closeCtxMenu();\n   116→}\n   117→\n   118→async function onPackDeleted(name: string) {\n   119→  await soundStore.scanPacks();\n   120→  if (selectedPack.value === name) {\n   121→    selectedPack.value = soundStore.packs[0]?.name ?? null;\n   122→  }\n   123→  closeCtxMenu();\n   124→}\n   125→\n   126→// ---- New pack / inline rename ----\n   127→const editingPackName = ref<string | null>(null);\n   128→const editPackNameValue = ref('');\n   129→const editPackInput = ref<HTMLInputElement | null>(null);\n   130→const isNewPack = ref(false);\n   131→\n   132→function generatePackName(): string {\n   133→  const existingNames = new Set(soundStore.packs.map((p) => p.name));\n   134→  const base = 'New Pack';\n   135→  if (!existingNames.has(base)) return base;\n   136→  for (let i = 2; i < 100; i++) {\n   137→    const candidate = `${base} ${i}`;\n   138→    if (!existingNames.has(candidate)) return candidate;\n   139→  }\n   140→  return `${base} ${Date.now()}`;\n   141→}\n   142→\n   143→async function startCreatePack(): Promise<void> {\n   144→  const packName = generatePackName();\n   145→  const baseDir = soundStore.getSoundPacksDir();\n   146→  const packPath = `${baseDir}/${packName}`;\n   147→  try {\n   148→    await mkdir(packPath, { recursive: true });\n   149→    await soundStore.savePackManifest(packName, { sounds: [], assignments: [] });\n   150→    await soundStore.scanPacks();\n   151→    selectedPack.value = packName;\n   152→    isNewPack.value = true;\n   153→    editingPackName.value = packName;\n   154→    editPackNameValue.value = packName;\n   155→    void nextTick(() => editPackInput.value?.select());\n   156→  } catch (err) {\n   157→    console.error('[SoundsDialog] createNewPack failed', err);\n   158→  }\n   159→}\n   160→\n   161→async function confirmEditPackName(): Promise<void> {\n   162→  const oldName = editingPackName.value;\n   163→  if (!oldName) return;\n   164→  const newName = editPackNameValue.value.trim();\n   165→  editingPackName.value = null;\n   166→  isNewPack.value = false;\n   167→\n   168→  if (!newName || newName === oldName) return;\n   169→\n   170→  const baseDir = soundStore.getSoundPacksDir();\n   171→  try {\n   172→    await rename(`${baseDir}/${oldName}`, `${baseDir}/${newName}`);\n   173→    // Update activePacks\n   174→    const idx = soundStore.config.activePacks.indexOf(oldName);\n   175→    if (idx >= 0) soundStore.config.activePacks[idx] = newName;\n   176→    // Move soundOverrides entries\n   177→    const oldPrefix = `${oldName}/`;\n   178→    const newPrefix = `${newName}/`;\n   179→    for (const key of Object.keys(soundStore.config.soundOverrides)) {\n   180→      if (key.startsWith(oldPrefix)) {\n   181→        const filename = key.slice(oldPrefix.length);\n   182→        soundStore.config.soundOverrides[`${newPrefix}${filename}`] =\n   183→          soundStore.config.soundOverrides[key]!;\n   184→        delete soundStore.config.soundOverrides[key];\n   185→      }\n   186→    }\n   187→    await soundStore.saveConfig();\n   188→    await soundStore.scanPacks();\n   189→    if (selectedPack.value === oldName) selectedPack.value = newName;\n   190→  } catch (err) {\n   191→    console.error('[SoundsDialog] rename pack failed', err);\n   192→  }\n   193→}\n   194→\n   195→async function cancelEditPackName(): Promise<void> {\n   196→  const oldName = editingPackName.value;\n   197→  const wasNew = isNewPack.value;\n   198→  editingPackName.value = null;\n   199→  isNewPack.value = false;\n   200→\n   201→  if (wasNew && oldName) {\n   202→    const baseDir = soundStore.getSoundPacksDir();\n   203→    try {\n   204→      await remove(`${baseDir}/${oldName}`, { recursive: true });\n   205→      await soundStore.scanPacks();\n   206→      if (selectedPack.value === oldName) {\n   207→        selectedPack.value = soundStore.packs[0]?.name ?? null;\n   208→      }\n   209→    } catch (err) {\n   210→      console.error('[SoundsDialog] cancel new pack failed', err);\n   211→    }\n   212→  }\n   213→}\n   214→\n   215→// ---- Import zip ----\n   216→const dragOver = ref(false);\n   217→\n   218→async function importZipBytes(filename: string, bytes: Uint8Array): Promise<void> {\n   219→  const dotIdx = filename.lastIndexOf('.');\n   220→  const packName = dotIdx > 0 ? filename.slice(0, dotIdx) : filename;\n   221→  const baseDir = soundStore.getSoundPacksDir();\n   222→  const packPath = `${baseDir}/${packName}`;\n   223→\n   224→  const zip = await JSZip.loadAsync(bytes);\n   225→  for (const [relativePath, file] of Object.entries(zip.files)) {\n   226→    if (file.dir) {\n   227→      await mkdir(`${packPath}/${relativePath}`, { recursive: true });\n   228→    } else {\n   229→      const data = await file.async('uint8array');\n   230→      const dirPart = relativePath.includes('/')\n   231→        ? relativePath.slice(0, relativePath.lastIndexOf('/'))\n   232→        : '';\n   233→      if (dirPart) {\n   234→        await mkdir(`${packPath}/${dirPart}`, { recursive: true });\n   235→      }\n   236→      await writeFile(`${packPath}/${relativePath}`, data);\n   237→    }\n   238→  }\n   239→\n   240→  await soundStore.scanPacks();\n   241→  selectedPack.value = packName;\n   242→}\n   243→\n   244→async function openImportPicker() {\n   245→  const result = await open({\n   246→    filters: [{ name: 'ZIP', extensions: ['zip'] }],\n   247→    multiple: false,\n   248→  });\n   249→  if (!result) return;\n   250→  const filePath = typeof result === 'string' ? result : result;\n   251→  if (!filePath) return;\n   252→  try {\n   253→    const bytes = await readFile(filePath);\n   254→    const filename = (filePath as string).split('/').pop() ?? 'pack.zip';\n   255→    await importZipBytes(filename, bytes);\n   256→  } catch (err) {\n   257→    console.error('[SoundsDialog] import failed', err);\n   258→  }\n   259→}\n   260→\n   261→function onDragOver(e: DragEvent) {\n   262→  e.preventDefault();\n   263→  dragOver.value = true;\n   264→}\n   265→\n   266→function onDragLeave() {\n   267→  dragOver.value = false;\n   268→}\n   269→\n   270→async function onDrop(e: DragEvent) {\n   271→  e.preventDefault();\n   272→  dragOver.value = false;\n   273→  const file = e.dataTransfer?.files[0];\n   274→  if (!file) return;\n   275→  try {\n   276→    const arrayBuffer = await file.arrayBuffer();\n   277→    await importZipBytes(file.name, new Uint8Array(arrayBuffer));\n   278→  } catch (err) {\n   279→    console.error('[SoundsDialog] drop import failed', err);\n   280→  }\n   281→}\n   282→\n   283→// ---- Event descriptions ----\n   284→const EVENT_DESCRIPTIONS: Record<string, string> = {\n   285→  session_start: 'Agent session begins.',\n   286→  session_end: 'Agent session ends or is interrupted.',\n   287→  prompt_submit: 'User submits a prompt to the agent.',\n   288→  tool_start: 'Agent begins executing a tool (e.g. Bash, Read, Edit).',\n   289→  tool_end: 'Agent finishes executing a tool.',\n   290→  turn_end: 'Agent completes a full response turn.',\n   291→  permission_wait: 'Agent pauses waiting for the user to approve a tool call.',\n   292→  subagent_start: 'A subagent is spawned by the parent agent.',\n   293→  subagent_end: 'A subagent finishes its work.',\n   294→  idle_notification: 'Agent has been idle and sends a nudge notification.',\n   295→  elicitation_wait: 'Agent pauses waiting for user input.',\n   296→  auth_success: 'Authentication to an external service succeeds.',\n   297→  worktree_create: 'A new git worktree is created.',\n   298→  worktree_remove: 'A git worktree is removed.',\n   299→  teammate_idle: \"A teammate's agent session goes idle.\",\n   300→  task_completed: 'Agent marks a task as completed.',\n   301→};\n   302→\n   303→const activeInfoPopover = ref<string | null>(null);\n   304→\n   305→function toggleInfoPopover(eventType: string) {\n   306→  activeInfoPopover.value = activeInfoPopover.value === eventType ? null : eventType;\n   307→}\n   308→\n   309→// ---- Patchbay data ----\n   310→const selectedPackInfo = computed(() =>\n   311→  soundStore.packs.find((p) => p.name === selectedPack.value) ?? null,\n   312→);\n   313→\n   314→function hasAssignments(eventType: AgentEventType): boolean {\n   315→  if (!selectedPackInfo.value) return false;\n   316→  return selectedPackInfo.value.manifest.assignments.some((a) => a.event === eventType);\n   317→}\n   318→\n   319→// ---- Sound preview (left column) ----\n   320→let previewSource: AudioBufferSourceNode | null = null;\n   321→const previewFile = ref<string | null>(null);\n   322→const soundFileExists = ref<Map<string, boolean>>(new Map());\n   323→const hoveredSoundFile = ref<string | null>(null);\n   324→\n   325→async function checkSoundFileExistence(packName: string): Promise<void> {\n   326→  const sounds = selectedPackInfo.value?.manifest.sounds ?? [];\n   327→  const baseDir = soundStore.getSoundPacksDir();\n   328→  const newMap = new Map<string, boolean>();\n   329→  await Promise.all(\n   330→    sounds.map(async (sound) => {\n   331→      const filePath = `${baseDir}/${packName}/${sound.file}`;\n   332→      const fileExists = await exists(filePath);\n   333→      newMap.set(sound.file, fileExists);\n   334→    }),\n   335→  );\n   336→  soundFileExists.value = newMap;\n   337→}\n   338→\n   339→function stopPreview(): void {\n   340→  if (previewSource) {\n   341→    try { previewSource.stop(); } catch { /* already stopped */ }\n   342→    previewSource = null;\n   343→  }\n   344→  previewFile.value = null;\n   345→}\n   346→\n   347→async function playPreview(filename: string): Promise<void> {\n   348→  if (!selectedPack.value) return;\n   349→  stopPreview();\n   350→  const baseDir = soundStore.getSoundPacksDir();\n   351→  const filePath = `${baseDir}/${selectedPack.value}/${filename}`;\n   352→  const buffer = await soundStore.loadBuffer(filePath);\n   353→  if (!buffer) return;\n   354→  const ctx = soundStore.getOrCreateAudioContext();\n   355→  const sound = selectedPackInfo.value?.manifest.sounds.find((s) => s.file === filename);\n   356→  const gainNode = ctx.createGain();\n   357→  gainNode.gain.value =\n   358→    soundStore.config.globalVolume * soundStore.effectiveVolume(selectedPack.value, filename, sound);\n   359→  gainNode.connect(ctx.destination);\n   360→  const source = ctx.createBufferSource();\n   361→  source.buffer = buffer;\n   362→  source.connect(gainNode);\n   363→  previewFile.value = filename;\n   364→  previewSource = source;\n   365→  source.onended = () => {\n   366→    if (previewFile.value === filename) {\n   367→      previewFile.value = null;\n   368→      previewSource = null;\n   369→    }\n   370→  };\n   371→  source.start();\n   372→}\n   373→\n   374→async function updateSoundVolume(sound: PackManifestSound, volume: number): Promise<void> {\n   375→  if (!selectedPack.value || !selectedPackInfo.value) return;\n   376→  sound.volume = volume;\n   377→  await soundStore.savePackManifest(selectedPack.value, selectedPackInfo.value.manifest);\n   378→}\n   379→\n   380→async function updateSoundEnabled(sound: PackManifestSound, enabled: boolean): Promise<void> {\n   381→  if (!selectedPack.value || !selectedPackInfo.value) return;\n   382→  sound.enabled = enabled;\n   383→  await soundStore.savePackManifest(selectedPack.value, selectedPackInfo.value.manifest);\n   384→}\n   385→\n   386→// ---- Assignment chips (right column) ----\n   387→function assignmentsForEvent(eventType: AgentEventType): string[] {\n   388→  if (!selectedPackInfo.value) return [];\n   389→  return selectedPackInfo.value.manifest.assignments\n   390→    .filter((a) => a.event === eventType)\n   391→    .map((a) => a.file);\n   392→}\n   393→\n   394→function truncateFilename(name: string, max = 20): string {\n   395→  if (name.length <= max) return name;\n   396→  return name.slice(0, max - 1) + '\\u2026';\n   397→}\n   398→\n   399→async function removeAssignment(\n   400→  file: string,\n   401→  eventType: AgentEventType,\n   402→): Promise<void> {\n   403→  if (!selectedPack.value || !selectedPackInfo.value) return;\n   404→  const manifest = selectedPackInfo.value.manifest;\n   405→  manifest.assignments = manifest.assignments.filter(\n   406→    (a) => !(a.file === file && a.event === eventType),\n   407→  );\n   408→  await soundStore.savePackManifest(selectedPack.value, manifest);\n   409→}\n   410→\n   411→// ---- Drag-and-drop: sound → event row ----\n   412→const draggingSoundFile = ref<string | null>(null);\n   413→const dragOverEventType = ref<AgentEventType | null>(null);\n   414→\n   415→// ---- Drag-and-drop: chip → sound row (re-assign) ----\n   416→const draggingChip = ref<{ file: string; event: AgentEventType } | null>(null);\n   417→const dragOverSoundFile = ref<string | null>(null);\n   418→\n   419→function onSoundDragStart(e: DragEvent, filename: string): void {\n   420→  draggingSoundFile.value = filename;\n   421→  if (e.dataTransfer) {\n   422→    e.dataTransfer.effectAllowed = 'copy';\n   423→    e.dataTransfer.setData('text/plain', filename);\n   424→  }\n   425→}\n   426→\n   427→function onSoundDragEnd(): void {\n   428→  draggingSoundFile.value = null;\n   429→  dragOverEventType.value = null;\n   430→}\n   431→\n   432→function onEventDragOver(e: DragEvent, eventType: AgentEventType): void {\n   433→  if (!draggingSoundFile.value) return;\n   434→  e.preventDefault();\n   435→  if (e.dataTransfer) e.dataTransfer.dropEffect = 'copy';\n   436→  dragOverEventType.value = eventType;\n   437→}\n   438→\n   439→function onEventDragLeaveRow(): void {\n   440→  dragOverEventType.value = null;\n   441→}\n   442→\n   443→async function onEventDrop(\n   444→  e: DragEvent,\n   445→  eventType: AgentEventType,\n   446→): Promise<void> {\n   447→  e.preventDefault();\n   448→  dragOverEventType.value = null;\n   449→  const file = draggingSoundFile.value;\n   450→  draggingSoundFile.value = null;\n   451→  if (!file) return;\n   452→  await addAssignment(file, eventType);\n   453→}\n   454→\n   455→async function addAssignment(\n   456→  file: string,\n   457→  eventType: AgentEventType,\n   458→): Promise<void> {\n   459→  if (!selectedPack.value || !selectedPackInfo.value) return;\n   460→  const manifest = selectedPackInfo.value.manifest;\n   461→  const alreadyExists = manifest.assignments.some(\n   462→    (a) => a.file === file && a.event === eventType,\n   463→  );\n   464→  if (alreadyExists) return;\n   465→  manifest.assignments.push({ file, event: eventType });\n   466→  await soundStore.savePackManifest(selectedPack.value, manifest);\n   467→}\n   468→\n   469→// ---- Chip drag handlers (re-assign chip to different sound) ----\n   470→function onChipDragStart(\n   471→  e: DragEvent,\n   472→  file: string,\n   473→  eventType: AgentEventType,\n   474→): void {\n   475→  draggingChip.value = { file, event: eventType };\n   476→  if (e.dataTransfer) {\n   477→    e.dataTransfer.effectAllowed = 'move';\n   478→    e.dataTransfer.setData('text/plain', file);\n   479→  }\n   480→}\n   481→\n   482→function onChipDragEnd(): void {\n   483→  draggingChip.value = null;\n   484→  dragOverSoundFile.value = null;\n   485→}\n   486→\n   487→function onSoundRowDragOver(e: DragEvent, filename: string): void {\n   488→  if (!draggingChip.value) return;\n   489→  e.preventDefault();\n   490→  if (e.dataTransfer) e.dataTransfer.dropEffect = 'move';\n   491→  dragOverSoundFile.value = filename;\n   492→}\n   493→\n   494→function onSoundRowDragLeave(): void {\n   495→  dragOverSoundFile.value = null;\n   496→}\n   497→\n   498→async function onSoundRowDrop(\n   499→  e: DragEvent,\n   500→  newFile: string,\n   501→): Promise<void> {\n   502→  e.preventDefault();\n   503→  dragOverSoundFile.value = null;\n   504→  const chip = draggingChip.value;\n   505→  draggingChip.value = null;\n   506→  if (!chip || !selectedPack.value || !selectedPackInfo.value) return;\n   507→  if (chip.file === newFile) return;\n   508→  const manifest = selectedPackInfo.value.manifest;\n   509→  manifest.assignments = manifest.assignments.filter(\n   510→    (a) => !(a.file === chip.file && a.event === chip.event),\n   511→  );\n   512→  const alreadyExists = manifest.assignments.some(\n   513→    (a) => a.file === newFile && a.event === chip.event,\n   514→  );\n   515→  if (!alreadyExists) {\n   516→    manifest.assignments.push({ file: newFile, event: chip.event });\n   517→  }\n   518→  await soundStore.savePackManifest(selectedPack.value, manifest);\n   519→}\n   520→\n   521→// ---- Live highlight on incoming agent events ----\n   522→const flashingEvent = ref<AgentEventType | null>(null);\n   523→let flashTimeout: ReturnType<typeof setTimeout> | null = null;\n   524→let agentEventUnlisten: UnlistenFn | null = null;\n   525→\n   526→function flashEventRow(eventType: AgentEventType): void {\n   527→  flashingEvent.value = eventType;\n   528→  if (flashTimeout) clearTimeout(flashTimeout);\n   529→  flashTimeout = setTimeout(() => {\n   530→    flashingEvent.value = null;\n   531→    flashTimeout = null;\n   532→  }, 200);\n   533→}\n   534→\n   535→// ---- Add audio files to pack (OS drag + file picker) ----\n   536→const AUDIO_EXTENSIONS = new Set(['.wav', '.mp3', '.ogg', '.flac', '.m4a', '.webm']);\n   537→const audioDragOver = ref(false);\n   538→\n   539→function isAudioFile(filename: string): boolean {\n   540→  const dot = filename.lastIndexOf('.');\n   541→  if (dot < 0) return false;\n   542→  return AUDIO_EXTENSIONS.has(filename.slice(dot).toLowerCase());\n   543→}\n   544→\n   545→async function addAudioFilesFromBlobs(\n   546→  files: { name: string; bytes: Uint8Array }[],\n   547→): Promise<void> {\n   548→  if (!selectedPack.value || !selectedPackInfo.value) return;\n   549→  const baseDir = soundStore.getSoundPacksDir();\n   550→  const packPath = `${baseDir}/${selectedPack.value}`;\n   551→  const manifest = selectedPackInfo.value.manifest;\n   552→  let changed = false;\n   553→\n   554→  for (const file of files) {\n   555→    if (!isAudioFile(file.name)) continue;\n   556→    await writeFile(`${packPath}/${file.name}`, file.bytes);\n   557→    const alreadyInManifest = manifest.sounds.some(\n   558→      (s) => s.file === file.name,\n   559→    );\n   560→    if (!alreadyInManifest) {\n   561→      manifest.sounds.push({\n   562→        file: file.name,\n   563→        volume: 1.0,\n   564→        enabled: true,\n   565→      });\n   566→      changed = true;\n   567→    }\n   568→  }\n   569→\n   570→  if (changed) {\n   571→    await soundStore.savePackManifest(selectedPack.value, manifest);\n   572→  }\n   573→  if (selectedPack.value) {\n   574→    void checkSoundFileExistence(selectedPack.value);\n   575→  }\n   576→}\n   577→\n   578→function onAudioDragOver(e: DragEvent): void {\n   579→  if (!selectedPack.value) return;\n   580→  e.preventDefault();\n   581→  e.stopPropagation();\n   582→  audioDragOver.value = true;\n   583→}\n   584→\n   585→function onAudioDragLeave(): void {\n   586→  audioDragOver.value = false;\n   587→}\n   588→\n   589→async function onAudioDrop(e: DragEvent): Promise<void> {\n   590→  e.preventDefault();\n   591→  e.stopPropagation();\n   592→  audioDragOver.value = false;\n   593→  if (!selectedPack.value) return;\n   594→  const dataFiles = e.dataTransfer?.files;\n   595→  if (!dataFiles || dataFiles.length === 0) return;\n   596→\n   597→  const blobs: { name: string; bytes: Uint8Array }[] = [];\n   598→  for (let i = 0; i < dataFiles.length; i++) {\n   599→    const f = dataFiles[i];\n   600→    if (!f || !isAudioFile(f.name)) continue;\n   601→    const buf = await f.arrayBuffer();\n   602→    blobs.push({ name: f.name, bytes: new Uint8Array(buf) });\n   603→  }\n   604→  if (blobs.length > 0) {\n   605→    await addAudioFilesFromBlobs(blobs);\n   606→  }\n   607→}\n   608→\n   609→async function openAddFilePicker(): Promise<void> {\n   610→  if (!selectedPack.value) return;\n   611→  const result = await open({\n   612→    filters: [{\n   613→      name: 'Audio',\n   614→      extensions: ['wav', 'mp3', 'ogg', 'flac', 'm4a', 'webm'],\n   615→    }],\n   616→    multiple: true,\n   617→  });\n   618→  if (!result) return;\n   619→  const paths = Array.isArray(result) ? result : [result];\n   620→  const blobs: { name: string; bytes: Uint8Array }[] = [];\n   621→  for (const filePath of paths) {\n   622→    if (!filePath) continue;\n   623→    const filename = filePath.split('/').pop() ?? '';\n   624→    if (!isAudioFile(filename)) continue;\n   625→    const bytes = await readFile(filePath);\n   626→    blobs.push({ name: filename, bytes });\n   627→  }\n   628→  if (blobs.length > 0) {\n   629→    await addAudioFilesFromBlobs(blobs);\n   630→  }\n   631→}\n   632→\n   633→// Reset scroll + stop preview + check file existence on pack change\n   634→watch(selectedPack, async (packName) => {\n   635→  stopPreview();\n   636→  soundFileExists.value = new Map();\n   637→  if (packName) void checkSoundFileExistence(packName);\n   638→  await nextTick(() => {\n   639→    if (rightPanel.value) rightPanel.value.scrollTop = 0;\n   640→  });\n   641→});\n   642→\n   643→</script>\n   644→\n   645→<template>\n   646→  <Teleport to=\"body\">\n   647→    <!-- Backdrop -->\n   648→    <div class=\"fixed inset-0 z-[100] flex items-center justify-center bg-black/50\">\n   649→      <!-- Drop zone wrapper -->\n   650→      <div\n   651→        class=\"relative w-[960px] max-w-[90vw] h-[700px] max-h-[90vh] flex flex-col bg-gray-900 border border-gray-700 rounded-lg shadow-2xl overflow-hidden\"\n   652→        @dragover=\"onDragOver\"\n   653→        @dragleave=\"onDragLeave\"\n   654→        @drop=\"onDrop\"\n   655→      >\n   656→        <!-- Drag overlay -->\n   657→        <div\n   658→          v-if=\"dragOver\"\n   659→          class=\"absolute inset-0 z-[150] flex items-center justify-center bg-indigo-900/80 border-2 border-dashed border-indigo-400 rounded-lg pointer-events-none\"\n   660→        >\n   661→          <span class=\"text-indigo-200 text-lg font-semibold\">Drop sound pack here</span>\n   662→        </div>\n   663→\n   664→        <!-- Header -->\n   665→        <div class=\"flex items-center gap-4 px-4 py-3 border-b border-gray-700 shrink-0\">\n   666→          <span class=\"text-gray-200 font-semibold text-sm\">Sounds</span>\n   667→\n   668→          <!-- Master enable -->\n   669→          <label class=\"flex items-center gap-1.5 text-xs text-gray-300 cursor-pointer\">\n   670→            <input\n   671→              type=\"checkbox\"\n   672→              :checked=\"globalEnabled\"\n   673→              class=\"w-4 h-4 accent-indigo-400\"\n   674→              @change=\"globalEnabled = ($event.target as HTMLInputElement).checked\"\n   675→            />\n   676→            Enable\n   677→          </label>\n   678→\n   679→          <!-- Global volume -->\n   680→          <label class=\"flex items-center gap-1.5 text-xs text-gray-300\">\n   681→            Vol\n   682→            <input\n   683→              type=\"range\"\n   684→              min=\"0\"\n   685→              max=\"100\"\n   686→              :value=\"globalVolume\"\n   687→              class=\"w-24 accent-indigo-400\"\n   688→              @input=\"globalVolume = parseInt(($event.target as HTMLInputElement).value)\"\n   689→            />\n   690→            <span class=\"w-7 tabular-nums\">{{ globalVolume }}%</span>\n   691→          </label>\n   692→\n   693→          <!-- Cooldown -->\n   694→          <label class=\"flex items-center gap-1.5 text-xs text-gray-300\">\n   695→            Cooldown\n   696→            <input\n   697→              type=\"range\"\n   698→              min=\"0\"\n   699→              max=\"10\"\n   700→              step=\"0.5\"\n   701→              :value=\"cooldown\"\n   702→              class=\"w-20 accent-indigo-400\"\n   703→              @input=\"cooldown = parseFloat(($event.target as HTMLInputElement).value)\"\n   704→            />\n   705→            <span class=\"w-8 tabular-nums\">{{ cooldown }}s</span>\n   706→          </label>\n   707→        </div>\n   708→\n   709→        <!-- Body -->\n   710→        <div class=\"flex flex-1 min-h-0\">\n   711→          <!-- Left panel: pack list -->\n   712→          <div class=\"w-60 shrink-0 border-r border-gray-700 flex flex-col\">\n   713→            <div class=\"px-3 pt-2 pb-1 text-xs font-semibold text-gray-400 uppercase tracking-wide\">\n   714→              Packs\n   715→            </div>\n   716→            <div class=\"flex-1 overflow-y-auto\">\n   717→              <div\n   718→                v-for=\"pack in soundStore.packs\"\n   719→                :key=\"pack.name\"\n   720→                class=\"flex items-center gap-2 px-2 py-1.5 cursor-pointer rounded mx-1\"\n   721→                :class=\"selectedPack === pack.name ? 'bg-gray-700' : 'hover:bg-gray-800'\"\n   722→                @click=\"selectPack(pack.name)\"\n   723→                @contextmenu=\"onPackRightClick($event, pack.name)\"\n   724→              >\n   725→                <input\n   726→                  type=\"checkbox\"\n   727→                  :checked=\"isPackActive(pack.name)\"\n   728→                  class=\"w-4 h-4 accent-indigo-400 cursor-pointer\"\n   729→                  @click.stop\n   730→                  @change=\"togglePackActive(pack.name, ($event.target as HTMLInputElement).checked)\"\n   731→                />\n   732→                <input\n   733→                  v-if=\"editingPackName === pack.name\"\n   734→                  ref=\"editPackInput\"\n   735→                  v-model=\"editPackNameValue\"\n   736→                  class=\"flex-1 min-w-0 px-1 py-0.5 bg-gray-800 border border-indigo-400 rounded text-xs text-gray-200 outline-none\"\n   737→                  @click.stop\n   738→                  @keydown.enter.prevent=\"confirmEditPackName\"\n   739→                  @keydown.escape.prevent=\"cancelEditPackName\"\n   740→                  @blur=\"confirmEditPackName\"\n   741→                />\n   742→                <span v-else class=\"text-sm text-gray-200 truncate flex-1\">{{ pack.name }}</span>\n   743→              </div>\n   744→            </div>\n   745→            <!-- Buttons -->\n   746→            <div class=\"flex gap-1 p-2 border-t border-gray-700\">\n   747→              <button\n   748→                class=\"flex-1 px-2 py-1 bg-gray-700/60 rounded hover:bg-gray-600/70 text-xs text-gray-200\"\n   749→                @click=\"startCreatePack\"\n   750→              >\n   751→                New Pack\n   752→              </button>\n   753→              <button\n   754→                class=\"flex-1 px-2 py-1 bg-gray-700/60 rounded hover:bg-gray-600/70 text-xs text-gray-200\"\n   755→                @click=\"openImportPicker\"\n   756→              >\n   757→                Import\n   758→              </button>\n   759→            </div>\n   760→          </div>\n   761→\n   762→          <!-- Patchbay: Sounds + Events columns -->\n   763→          <div ref=\"rightPanel\" class=\"flex flex-1 min-h-0 overflow-hidden\">\n   764→            <!-- Sounds column -->\n   765→            <div\n   766→              class=\"flex-1 border-r border-gray-700 flex flex-col min-w-0\"\n   767→              @dragover=\"onAudioDragOver\"\n   768→              @dragleave=\"onAudioDragLeave\"\n   769→              @drop=\"onAudioDrop\"\n   770→            >\n   771→              <div class=\"flex items-center gap-2 px-3 py-2 border-b border-gray-700 shrink-0\">\n   772→                <span class=\"text-xs font-semibold text-gray-400 uppercase tracking-wide flex-1\">Sounds</span>\n   773→                <button\n   774→                  v-if=\"selectedPack\"\n   775→                  class=\"px-2 py-0.5 bg-gray-700/60 rounded hover:bg-gray-600/70 text-xs text-gray-300\"\n   776→                  @click=\"openAddFilePicker\"\n   777→                >Add file</button>\n   778→              </div>\n   779→              <div class=\"flex-1 overflow-y-auto relative\">\n   780→                <!-- Audio file drop overlay -->\n   781→                <div\n   782→                  v-if=\"audioDragOver && selectedPack\"\n   783→                  class=\"absolute inset-0 z-10 flex items-center justify-center bg-indigo-900/60 border-2 border-dashed border-indigo-400 rounded pointer-events-none\"\n   784→                >\n   785→                  <span class=\"text-indigo-200 text-sm font-semibold\">Drop audio files here</span>\n   786→                </div>\n   787→                <div\n   788→                  v-if=\"!selectedPackInfo\"\n   789→                  class=\"flex items-center justify-center h-full text-gray-600 text-sm\"\n   790→                >\n   791→                  Select a pack\n   792→                </div>\n   793→                <div\n   794→                  v-else-if=\"selectedPackInfo.manifest.sounds.length === 0\"\n   795→                  class=\"flex items-center justify-center h-full text-gray-600 text-sm\"\n   796→                >\n   797→                  No sounds in this pack\n   798→                </div>\n   799→                <div\n   800→                  v-for=\"sound in selectedPackInfo.manifest.sounds\"\n   801→                  v-else\n   802→                  :key=\"sound.file\"\n   803→                  draggable=\"true\"\n   804→                  class=\"flex items-center gap-2 px-3 py-1.5 border-b border-gray-800 hover:bg-gray-800/40 cursor-grab transition-colors duration-150\"\n   805→                  :class=\"[\n   806→                    draggingSoundFile === sound.file ? 'opacity-50' : '',\n   807→                    dragOverSoundFile === sound.file ? 'bg-indigo-500/20' : '',\n   808→                    draggingChip ? 'opacity-100' : '',\n   809→                  ]\"\n   810→                  @mouseenter=\"hoveredSoundFile = sound.file\"\n   811→                  @mouseleave=\"hoveredSoundFile = null\"\n   812→                  @dragstart=\"onSoundDragStart($event, sound.file)\"\n   813→                  @dragend=\"onSoundDragEnd\"\n   814→                  @dragover=\"onSoundRowDragOver($event, sound.file)\"\n   815→                  @dragleave=\"onSoundRowDragLeave\"\n   816→                  @drop=\"onSoundRowDrop($event, sound.file)\"\n   817→                >\n   818→                  <!-- Play button -->\n   819→                  <button\n   820→                    class=\"shrink-0 w-6 h-6 flex items-center justify-center rounded text-gray-400 hover:text-white hover:bg-gray-700 text-xs\"\n   821→                    title=\"Play preview\"\n   822→                    @click=\"playPreview(sound.file)\"\n   823→                  >▶</button>\n   824→\n   825→                  <!-- Filename -->\n   826→                  <span class=\"flex-1 text-xs font-mono text-gray-200 truncate min-w-0\">{{ sound.file }}</span>\n   827→\n   828→                  <!-- Broken link indicator -->\n   829→                  <span\n   830→                    v-if=\"soundFileExists.get(sound.file) === false\"\n   831→                    class=\"shrink-0 text-red-400 text-xs\"\n   832→                    title=\"File not found on disk\"\n   833→                  >⚠</span>\n   834→\n   835→                  <!-- Volume slider (visible on hover) -->\n   836→                  <input\n   837→                    v-show=\"hoveredSoundFile === sound.file\"\n   838→                    type=\"range\"\n   839→                    min=\"0\"\n   840→                    max=\"1\"\n   841→                    step=\"0.01\"\n   842→                    :value=\"sound.volume\"\n   843→                    class=\"shrink-0 w-16 accent-indigo-400\"\n   844→                    title=\"Volume\"\n   845→                    @input=\"updateSoundVolume(sound, parseFloat(($event.target as HTMLInputElement).value))\"\n   846→                  />\n   847→\n   848→                  <!-- Enabled toggle -->\n   849→                  <input\n   850→                    type=\"checkbox\"\n   851→                    :checked=\"sound.enabled\"\n   852→                    class=\"shrink-0 w-4 h-4 accent-indigo-400 cursor-pointer\"\n   853→                    title=\"Enable/disable this sound\"\n   854→                    @change=\"updateSoundEnabled(sound, ($event.target as HTMLInputElement).checked)\"\n   855→                  />\n   856→\n   857→                  <!-- Stop button -->\n   858→                  <button\n   859→                    class=\"shrink-0 w-6 h-6 flex items-center justify-center rounded text-xs\"\n   860→                    :class=\"previewFile === sound.file\n   861→                      ? 'text-red-400 hover:text-red-300 hover:bg-gray-700'\n   862→                      : 'text-gray-600 cursor-default'\"\n   863→                    title=\"Stop preview\"\n   864→                    @click=\"previewFile === sound.file ? stopPreview() : undefined\"\n   865→                  >■</button>\n   866→                </div>\n   867→              </div>\n   868→            </div>\n   869→\n   870→            <!-- Events column -->\n   871→            <div class=\"flex-1 flex flex-col min-w-0\">\n   872→              <div class=\"px-3 py-2 border-b border-gray-700 shrink-0\">\n   873→                <span class=\"text-xs font-semibold text-gray-400 uppercase tracking-wide\">Events</span>\n   874→              </div>\n   875→              <div class=\"flex-1 overflow-y-auto\">\n   876→                <div\n   877→                  v-for=\"eventType in AGENT_EVENT_TYPES\"\n   878→                  :key=\"eventType\"\n   879→                  class=\"px-3 py-2 border-b border-gray-800 transition-all duration-200\"\n   880→                  :class=\"[\n   881→                    hasAssignments(eventType) ? 'opacity-100' : 'opacity-40',\n   882→                    flashingEvent === eventType ? 'bg-indigo-600/30' : '',\n   883→                    dragOverEventType === eventType ? 'bg-indigo-500/20 opacity-100' : '',\n   884→                    draggingSoundFile ? 'opacity-100' : '',\n   885→                  ]\"\n   886→                  @dragover=\"onEventDragOver($event, eventType)\"\n   887→                  @dragleave=\"onEventDragLeaveRow\"\n   888→                  @drop=\"onEventDrop($event, eventType)\"\n   889→                >\n   890→                  <div class=\"flex items-center gap-2\">\n   891→                    <span class=\"text-sm font-mono text-gray-300 flex-1\">{{ eventType }}</span>\n   892→                    <!-- Info icon + popover -->\n   893→                    <span\n   894→                      v-if=\"EVENT_DESCRIPTIONS[eventType]\"\n   895→                      class=\"relative shrink-0\"\n   896→                      @click.stop\n   897→                    >\n   898→                      <span\n   899→                        class=\"w-4 h-4 flex items-center justify-center rounded-full border text-[10px] leading-none cursor-pointer select-none\"\n   900→                        :class=\"activeInfoPopover === eventType\n   901→                          ? 'border-indigo-400 text-indigo-300 bg-indigo-900/40'\n   902→                          : 'border-gray-500 text-gray-400 hover:border-gray-300 hover:text-gray-200'\"\n   903→                        @click=\"toggleInfoPopover(eventType)\"\n   904→                      >i</span>\n   905→                      <div\n   906→                        v-if=\"activeInfoPopover === eventType\"\n   907→                        class=\"absolute right-0 top-6 z-50 w-56 bg-gray-800 border border-gray-600 rounded shadow-lg px-3 py-2 text-xs text-gray-200 leading-relaxed\"\n   908→                      >\n   909→                        {{ EVENT_DESCRIPTIONS[eventType] }}\n   910→                      </div>\n   911→                    </span>\n   912→                  </div>\n   913→                  <!-- Assignment chips -->\n   914→                  <div\n   915→                    v-if=\"assignmentsForEvent(eventType).length > 0\"\n   916→                    class=\"flex flex-wrap gap-1 mt-1\"\n   917→                  >\n   918→                    <span\n   919→                      v-for=\"file in assignmentsForEvent(eventType)\"\n   920→                      :key=\"file\"\n   921→                      draggable=\"true\"\n   922→                      class=\"inline-flex items-center gap-1 px-2 py-0.5 bg-gray-700/80 rounded text-xs text-gray-200 cursor-grab hover:bg-gray-600/80\"\n   923→                      :class=\"draggingChip?.file === file && draggingChip?.event === eventType ? 'opacity-50' : ''\"\n   924→                      :title=\"file\"\n   925→                      @click=\"playPreview(file)\"\n   926→                      @dragstart.stop=\"onChipDragStart($event, file, eventType)\"\n   927→                      @dragend=\"onChipDragEnd\"\n   928→                    >\n   929→                      {{ truncateFilename(file) }}\n   930→                      <button\n   931→                        class=\"ml-0.5 text-gray-400 hover:text-red-400 leading-none\"\n   932→                        title=\"Remove assignment\"\n   933→                        @click.stop=\"removeAssignment(file, eventType)\"\n   934→                      >&times;</button>\n   935→                    </span>\n   936→                  </div>\n   937→                </div>\n   938→              </div>\n   939→            </div>\n   940→          </div>\n   941→        </div>\n   942→\n   943→        <!-- Footer -->\n   944→        <div class=\"flex justify-end px-4 py-3 border-t border-gray-700 shrink-0\">\n   945→          <button\n   946→            class=\"px-4 py-1.5 bg-gray-700/60 rounded hover:bg-gray-600/70 text-sm text-gray-200\"\n   947→            @click=\"emit('close')\"\n   948→          >\n   949→            Close\n   950→          </button>\n   951→        </div>\n   952→      </div>\n   953→    </div>\n   954→\n   955→    <!-- Context menu -->\n   956→    <PackContextMenu\n   957→      v-if=\"ctxMenu\"\n   958→      :pack-name=\"ctxMenu.packName\"\n   959→      :x=\"ctxMenu.x\"\n   960→      :y=\"ctxMenu.y\"\n   961→      @close=\"closeCtxMenu\"\n   962→      @renamed=\"onPackRenamed\"\n   963→      @duplicated=\"onPackDuplicated\"\n   964→      @deleted=\"onPackDeleted\"\n   965→    />\n   966→  </Teleport>\n   967→</template>\n   968→"}]},"parent_tool_use_id":null,"session_id":"aad13967-80bc-4110-aefd-964e65e8c225","uuid":"8ce5eaa6-f50c-4641-9f6d-d6b6a749fff2","tool_use_result":{"type":"text","file":{"filePath":"/Users/markus/baustelle/projects/agents-in-the-office/agents-in-the-office/.chief/worktrees/sound-packs-patchbay/src/components/SoundsDialog.vue","content":"<script setup lang=\"ts\">\nimport {\n  ref,\n  computed,\n  watch,\n  nextTick,\n  onMounted,\n  onUnmounted,\n} from 'vue';\nimport { listen } from '@tauri-apps/api/event';\nimport type { UnlistenFn } from '@tauri-apps/api/event';\nimport { open } from '@tauri-apps/plugin-dialog';\nimport {\n  mkdir,\n  readFile,\n  writeFile,\n  exists,\n  rename,\n  remove,\n} from '@tauri-apps/plugin-fs';\nimport JSZip from 'jszip';\nimport { useSoundStore, AGENT_EVENT_TYPES } from '../stores/soundStore';\nimport type { PackManifestSound } from '../stores/soundStore';\nimport type { AgentEvent, AgentEventType } from '../drivers/types';\nimport PackContextMenu from './PackContextMenu.vue';\n\nconst emit = defineEmits<{ close: [] }>();\n\nconst soundStore = useSoundStore();\n\n// ---- Global settings ----\nconst globalEnabled = computed({\n  get: () => soundStore.config.enabled,\n  set: (v: boolean) => { soundStore.config.enabled = v; void soundStore.saveConfig(); },\n});\nconst globalVolume = computed({\n  get: () => Math.round(soundStore.config.globalVolume * 100),\n  set: (v: number) => { soundStore.config.globalVolume = v / 100; void soundStore.saveConfig(); },\n});\nconst cooldown = computed({\n  get: () => soundStore.config.cooldownSeconds,\n  set: (v: number) => { soundStore.config.cooldownSeconds = v; void soundStore.saveConfig(); },\n});\n\n// ---- Pack list ----\nconst selectedPack = ref<string | null>(null);\nconst rightPanel = ref<HTMLElement | null>(null);\n\nonMounted(async () => {\n  await soundStore.init();\n  await soundStore.scanPacks();\n  if (soundStore.packs.length > 0 && soundStore.packs[0]) {\n    selectedPack.value = soundStore.packs[0].name;\n  }\n  agentEventUnlisten = await listen<string>(\n    'agent-event',\n    (e) => {\n      try {\n        const parsed = JSON.parse(e.payload) as AgentEvent;\n        flashEventRow(parsed.type);\n      } catch { /* ignore parse errors */ }\n    },\n  );\n});\n\nonUnmounted(() => {\n  if (agentEventUnlisten) agentEventUnlisten();\n  if (flashTimeout) clearTimeout(flashTimeout);\n});\n\nfunction isPackActive(packName: string): boolean {\n  return soundStore.config.activePacks.includes(packName);\n}\n\nfunction togglePackActive(packName: string, active: boolean) {\n  if (active) {\n    if (!soundStore.config.activePacks.includes(packName)) {\n      soundStore.config.activePacks.push(packName);\n    }\n  } else {\n    soundStore.config.activePacks = soundStore.config.activePacks.filter(\n      (p) => p !== packName,\n    );\n  }\n  void soundStore.saveConfig();\n}\n\nfunction selectPack(name: string) {\n  selectedPack.value = name;\n  void nextTick(() => {\n    if (rightPanel.value) rightPanel.value.scrollTop = 0;\n  });\n}\n\n// ---- Context menu ----\nconst ctxMenu = ref<{ packName: string; x: number; y: number } | null>(null);\n\nfunction onPackRightClick(e: MouseEvent, packName: string) {\n  e.preventDefault();\n  ctxMenu.value = { packName, x: e.clientX, y: e.clientY };\n}\n\nfunction closeCtxMenu() {\n  ctxMenu.value = null;\n}\n\nasync function onPackRenamed(oldName: string, newName: string) {\n  await soundStore.scanPacks();\n  if (selectedPack.value === oldName) selectedPack.value = newName;\n  closeCtxMenu();\n}\n\nasync function onPackDuplicated() {\n  await soundStore.scanPacks();\n  closeCtxMenu();\n}\n\nasync function onPackDeleted(name: string) {\n  await soundStore.scanPacks();\n  if (selectedPack.value === name) {\n    selectedPack.value = soundStore.packs[0]?.name ?? null;\n  }\n  closeCtxMenu();\n}\n\n// ---- New pack / inline rename ----\nconst editingPackName = ref<string | null>(null);\nconst editPackNameValue = ref('');\nconst editPackInput = ref<HTMLInputElement | null>(null);\nconst isNewPack = ref(false);\n\nfunction generatePackName(): string {\n  const existingNames = new Set(soundStore.packs.map((p) => p.name));\n  const base = 'New Pack';\n  if (!existingNames.has(base)) return base;\n  for (let i = 2; i < 100; i++) {\n    const candidate = `${base} ${i}`;\n    if (!existingNames.has(candidate)) return candidate;\n  }\n  return `${base} ${Date.now()}`;\n}\n\nasync function startCreatePack(): Promise<void> {\n  const packName = generatePackName();\n  const baseDir = soundStore.getSoundPacksDir();\n  const packPath = `${baseDir}/${packName}`;\n  try {\n    await mkdir(packPath, { recursive: true });\n    await soundStore.savePackManifest(packName, { sounds: [], assignments: [] });\n    await soundStore.scanPacks();\n    selectedPack.value = packName;\n    isNewPack.value = true;\n    editingPackName.value = packName;\n    editPackNameValue.value = packName;\n    void nextTick(() => editPackInput.value?.select());\n  } catch (err) {\n    console.error('[SoundsDialog] createNewPack failed', err);\n  }\n}\n\nasync function confirmEditPackName(): Promise<void> {\n  const oldName = editingPackName.value;\n  if (!oldName) return;\n  const newName = editPackNameValue.value.trim();\n  editingPackName.value = null;\n  isNewPack.value = false;\n\n  if (!newName || newName === oldName) return;\n\n  const baseDir = soundStore.getSoundPacksDir();\n  try {\n    await rename(`${baseDir}/${oldName}`, `${baseDir}/${newName}`);\n    // Update activePacks\n    const idx = soundStore.config.activePacks.indexOf(oldName);\n    if (idx >= 0) soundStore.config.activePacks[idx] = newName;\n    // Move soundOverrides entries\n    const oldPrefix = `${oldName}/`;\n    const newPrefix = `${newName}/`;\n    for (const key of Object.keys(soundStore.config.soundOverrides)) {\n      if (key.startsWith(oldPrefix)) {\n        const filename = key.slice(oldPrefix.length);\n        soundStore.config.soundOverrides[`${newPrefix}${filename}`] =\n          soundStore.config.soundOverrides[key]!;\n        delete soundStore.config.soundOverrides[key];\n      }\n    }\n    await soundStore.saveConfig();\n    await soundStore.scanPacks();\n    if (selectedPack.value === oldName) selectedPack.value = newName;\n  } catch (err) {\n    console.error('[SoundsDialog] rename pack failed', err);\n  }\n}\n\nasync function cancelEditPackName(): Promise<void> {\n  const oldName = editingPackName.value;\n  const wasNew = isNewPack.value;\n  editingPackName.value = null;\n  isNewPack.value = false;\n\n  if (wasNew && oldName) {\n    const baseDir = soundStore.getSoundPacksDir();\n    try {\n      await remove(`${baseDir}/${oldName}`, { recursive: true });\n      await soundStore.scanPacks();\n      if (selectedPack.value === oldName) {\n        selectedPack.value = soundStore.packs[0]?.name ?? null;\n      }\n    } catch (err) {\n      console.error('[SoundsDialog] cancel new pack failed', err);\n    }\n  }\n}\n\n// ---- Import zip ----\nconst dragOver = ref(false);\n\nasync function importZipBytes(filename: string, bytes: Uint8Array): Promise<void> {\n  const dotIdx = filename.lastIndexOf('.');\n  const packName = dotIdx > 0 ? filename.slice(0, dotIdx) : filename;\n  const baseDir = soundStore.getSoundPacksDir();\n  const packPath = `${baseDir}/${packName}`;\n\n  const zip = await JSZip.loadAsync(bytes);\n  for (const [relativePath, file] of Object.entries(zip.files)) {\n    if (file.dir) {\n      await mkdir(`${packPath}/${relativePath}`, { recursive: true });\n    } else {\n      const data = await file.async('uint8array');\n      const dirPart = relativePath.includes('/')\n        ? relativePath.slice(0, relativePath.lastIndexOf('/'))\n        : '';\n      if (dirPart) {\n        await mkdir(`${packPath}/${dirPart}`, { recursive: true });\n      }\n      await writeFile(`${packPath}/${relativePath}`, data);\n    }\n  }\n\n  await soundStore.scanPacks();\n  selectedPack.value = packName;\n}\n\nasync function openImportPicker() {\n  const result = await open({\n    filters: [{ name: 'ZIP', extensions: ['zip'] }],\n    multiple: false,\n  });\n  if (!result) return;\n  const filePath = typeof result === 'string' ? result : result;\n  if (!filePath) return;\n  try {\n    const bytes = await readFile(filePath);\n    const filename = (filePath as string).split('/').pop() ?? 'pack.zip';\n    await importZipBytes(filename, bytes);\n  } catch (err) {\n    console.error('[SoundsDialog] import failed', err);\n  }\n}\n\nfunction onDragOver(e: DragEvent) {\n  e.preventDefault();\n  dragOver.value = true;\n}\n\nfunction onDragLeave() {\n  dragOver.value = false;\n}\n\nasync function onDrop(e: DragEvent) {\n  e.preventDefault();\n  dragOver.value = false;\n  const file = e.dataTransfer?.files[0];\n  if (!file) return;\n  try {\n    const arrayBuffer = await file.arrayBuffer();\n    await importZipBytes(file.name, new Uint8Array(arrayBuffer));\n  } catch (err) {\n    console.error('[SoundsDialog] drop import failed', err);\n  }\n}\n\n// ---- Event descriptions ----\nconst EVENT_DESCRIPTIONS: Record<string, string> = {\n  session_start: 'Agent session begins.',\n  session_end: 'Agent session ends or is interrupted.',\n  prompt_submit: 'User submits a prompt to the agent.',\n  tool_start: 'Agent begins executing a tool (e.g. Bash, Read, Edit).',\n  tool_end: 'Agent finishes executing a tool.',\n  turn_end: 'Agent completes a full response turn.',\n  permission_wait: 'Agent pauses waiting for the user to approve a tool call.',\n  subagent_start: 'A subagent is spawned by the parent agent.',\n  subagent_end: 'A subagent finishes its work.',\n  idle_notification: 'Agent has been idle and sends a nudge notification.',\n  elicitation_wait: 'Agent pauses waiting for user input.',\n  auth_success: 'Authentication to an external service succeeds.',\n  worktree_create: 'A new git worktree is created.',\n  worktree_remove: 'A git worktree is removed.',\n  teammate_idle: \"A teammate's agent session goes idle.\",\n  task_completed: 'Agent marks a task as completed.',\n};\n\nconst activeInfoPopover = ref<string | null>(null);\n\nfunction toggleInfoPopover(eventType: string) {\n  activeInfoPopover.value = activeInfoPopover.value === eventType ? null : eventType;\n}\n\n// ---- Patchbay data ----\nconst selectedPackInfo = computed(() =>\n  soundStore.packs.find((p) => p.name === selectedPack.value) ?? null,\n);\n\nfunction hasAssignments(eventType: AgentEventType): boolean {\n  if (!selectedPackInfo.value) return false;\n  return selectedPackInfo.value.manifest.assignments.some((a) => a.event === eventType);\n}\n\n// ---- Sound preview (left column) ----\nlet previewSource: AudioBufferSourceNode | null = null;\nconst previewFile = ref<string | null>(null);\nconst soundFileExists = ref<Map<string, boolean>>(new Map());\nconst hoveredSoundFile = ref<string | null>(null);\n\nasync function checkSoundFileExistence(packName: string): Promise<void> {\n  const sounds = selectedPackInfo.value?.manifest.sounds ?? [];\n  const baseDir = soundStore.getSoundPacksDir();\n  const newMap = new Map<string, boolean>();\n  await Promise.all(\n    sounds.map(async (sound) => {\n      const filePath = `${baseDir}/${packName}/${sound.file}`;\n      const fileExists = await exists(filePath);\n      newMap.set(sound.file, fileExists);\n    }),\n  );\n  soundFileExists.value = newMap;\n}\n\nfunction stopPreview(): void {\n  if (previewSource) {\n    try { previewSource.stop(); } catch { /* already stopped */ }\n    previewSource = null;\n  }\n  previewFile.value = null;\n}\n\nasync function playPreview(filename: string): Promise<void> {\n  if (!selectedPack.value) return;\n  stopPreview();\n  const baseDir = soundStore.getSoundPacksDir();\n  const filePath = `${baseDir}/${selectedPack.value}/${filename}`;\n  const buffer = await soundStore.loadBuffer(filePath);\n  if (!buffer) return;\n  const ctx = soundStore.getOrCreateAudioContext();\n  const sound = selectedPackInfo.value?.manifest.sounds.find((s) => s.file === filename);\n  const gainNode = ctx.createGain();\n  gainNode.gain.value =\n    soundStore.config.globalVolume * soundStore.effectiveVolume(selectedPack.value, filename, sound);\n  gainNode.connect(ctx.destination);\n  const source = ctx.createBufferSource();\n  source.buffer = buffer;\n  source.connect(gainNode);\n  previewFile.value = filename;\n  previewSource = source;\n  source.onended = () => {\n    if (previewFile.value === filename) {\n      previewFile.value = null;\n      previewSource = null;\n    }\n  };\n  source.start();\n}\n\nasync function updateSoundVolume(sound: PackManifestSound, volume: number): Promise<void> {\n  if (!selectedPack.value || !selectedPackInfo.value) return;\n  sound.volume = volume;\n  await soundStore.savePackManifest(selectedPack.value, selectedPackInfo.value.manifest);\n}\n\nasync function updateSoundEnabled(sound: PackManifestSound, enabled: boolean): Promise<void> {\n  if (!selectedPack.value || !selectedPackInfo.value) return;\n  sound.enabled = enabled;\n  await soundStore.savePackManifest(selectedPack.value, selectedPackInfo.value.manifest);\n}\n\n// ---- Assignment chips (right column) ----\nfunction assignmentsForEvent(eventType: AgentEventType): string[] {\n  if (!selectedPackInfo.value) return [];\n  return selectedPackInfo.value.manifest.assignments\n    .filter((a) => a.event === eventType)\n    .map((a) => a.file);\n}\n\nfunction truncateFilename(name: string, max = 20): string {\n  if (name.length <= max) return name;\n  return name.slice(0, max - 1) + '\\u2026';\n}\n\nasync function removeAssignment(\n  file: string,\n  eventType: AgentEventType,\n): Promise<void> {\n  if (!selectedPack.value || !selectedPackInfo.value) return;\n  const manifest = selectedPackInfo.value.manifest;\n  manifest.assignments = manifest.assignments.filter(\n    (a) => !(a.file === file && a.event === eventType),\n  );\n  await soundStore.savePackManifest(selectedPack.value, manifest);\n}\n\n// ---- Drag-and-drop: sound → event row ----\nconst draggingSoundFile = ref<string | null>(null);\nconst dragOverEventType = ref<AgentEventType | null>(null);\n\n// ---- Drag-and-drop: chip → sound row (re-assign) ----\nconst draggingChip = ref<{ file: string; event: AgentEventType } | null>(null);\nconst dragOverSoundFile = ref<string | null>(null);\n\nfunction onSoundDragStart(e: DragEvent, filename: string): void {\n  draggingSoundFile.value = filename;\n  if (e.dataTransfer) {\n    e.dataTransfer.effectAllowed = 'copy';\n    e.dataTransfer.setData('text/plain', filename);\n  }\n}\n\nfunction onSoundDragEnd(): void {\n  draggingSoundFile.value = null;\n  dragOverEventType.value = null;\n}\n\nfunction onEventDragOver(e: DragEvent, eventType: AgentEventType): void {\n  if (!draggingSoundFile.value) return;\n  e.preventDefault();\n  if (e.dataTransfer) e.dataTransfer.dropEffect = 'copy';\n  dragOverEventType.value = eventType;\n}\n\nfunction onEventDragLeaveRow(): void {\n  dragOverEventType.value = null;\n}\n\nasync function onEventDrop(\n  e: DragEvent,\n  eventType: AgentEventType,\n): Promise<void> {\n  e.preventDefault();\n  dragOverEventType.value = null;\n  const file = draggingSoundFile.value;\n  draggingSoundFile.value = null;\n  if (!file) return;\n  await addAssignment(file, eventType);\n}\n\nasync function addAssignment(\n  file: string,\n  eventType: AgentEventType,\n): Promise<void> {\n  if (!selectedPack.value || !selectedPackInfo.value) return;\n  const manifest = selectedPackInfo.value.manifest;\n  const alreadyExists = manifest.assignments.some(\n    (a) => a.file === file && a.event === eventType,\n  );\n  if (alreadyExists) return;\n  manifest.assignments.push({ file, event: eventType });\n  await soundStore.savePackManifest(selectedPack.value, manifest);\n}\n\n// ---- Chip drag handlers (re-assign chip to different sound) ----\nfunction onChipDragStart(\n  e: DragEvent,\n  file: string,\n  eventType: AgentEventType,\n): void {\n  draggingChip.value = { file, event: eventType };\n  if (e.dataTransfer) {\n    e.dataTransfer.effectAllowed = 'move';\n    e.dataTransfer.setData('text/plain', file);\n  }\n}\n\nfunction onChipDragEnd(): void {\n  draggingChip.value = null;\n  dragOverSoundFile.value = null;\n}\n\nfunction onSoundRowDragOver(e: DragEvent, filename: string): void {\n  if (!draggingChip.value) return;\n  e.preventDefault();\n  if (e.dataTransfer) e.dataTransfer.dropEffect = 'move';\n  dragOverSoundFile.value = filename;\n}\n\nfunction onSoundRowDragLeave(): void {\n  dragOverSoundFile.value = null;\n}\n\nasync function onSoundRowDrop(\n  e: DragEvent,\n  newFile: string,\n): Promise<void> {\n  e.preventDefault();\n  dragOverSoundFile.value = null;\n  const chip = draggingChip.value;\n  draggingChip.value = null;\n  if (!chip || !selectedPack.value || !selectedPackInfo.value) return;\n  if (chip.file === newFile) return;\n  const manifest = selectedPackInfo.value.manifest;\n  manifest.assignments = manifest.assignments.filter(\n    (a) => !(a.file === chip.file && a.event === chip.event),\n  );\n  const alreadyExists = manifest.assignments.some(\n    (a) => a.file === newFile && a.event === chip.event,\n  );\n  if (!alreadyExists) {\n    manifest.assignments.push({ file: newFile, event: chip.event });\n  }\n  await soundStore.savePackManifest(selectedPack.value, manifest);\n}\n\n// ---- Live highlight on incoming agent events ----\nconst flashingEvent = ref<AgentEventType | null>(null);\nlet flashTimeout: ReturnType<typeof setTimeout> | null = null;\nlet agentEventUnlisten: UnlistenFn | null = null;\n\nfunction flashEventRow(eventType: AgentEventType): void {\n  flashingEvent.value = eventType;\n  if (flashTimeout) clearTimeout(flashTimeout);\n  flashTimeout = setTimeout(() => {\n    flashingEvent.value = null;\n    flashTimeout = null;\n  }, 200);\n}\n\n// ---- Add audio files to pack (OS drag + file picker) ----\nconst AUDIO_EXTENSIONS = new Set(['.wav', '.mp3', '.ogg', '.flac', '.m4a', '.webm']);\nconst audioDragOver = ref(false);\n\nfunction isAudioFile(filename: string): boolean {\n  const dot = filename.lastIndexOf('.');\n  if (dot < 0) return false;\n  return AUDIO_EXTENSIONS.has(filename.slice(dot).toLowerCase());\n}\n\nasync function addAudioFilesFromBlobs(\n  files: { name: string; bytes: Uint8Array }[],\n): Promise<void> {\n  if (!selectedPack.value || !selectedPackInfo.value) return;\n  const baseDir = soundStore.getSoundPacksDir();\n  const packPath = `${baseDir}/${selectedPack.value}`;\n  const manifest = selectedPackInfo.value.manifest;\n  let changed = false;\n\n  for (const file of files) {\n    if (!isAudioFile(file.name)) continue;\n    await writeFile(`${packPath}/${file.name}`, file.bytes);\n    const alreadyInManifest = manifest.sounds.some(\n      (s) => s.file === file.name,\n    );\n    if (!alreadyInManifest) {\n      manifest.sounds.push({\n        file: file.name,\n        volume: 1.0,\n        enabled: true,\n      });\n      changed = true;\n    }\n  }\n\n  if (changed) {\n    await soundStore.savePackManifest(selectedPack.value, manifest);\n  }\n  if (selectedPack.value) {\n    void checkSoundFileExistence(selectedPack.value);\n  }\n}\n\nfunction onAudioDragOver(e: DragEvent): void {\n  if (!selectedPack.value) return;\n  e.preventDefault();\n  e.stopPropagation();\n  audioDragOver.value = true;\n}\n\nfunction onAudioDragLeave(): void {\n  audioDragOver.value = false;\n}\n\nasync function onAudioDrop(e: DragEvent): Promise<void> {\n  e.preventDefault();\n  e.stopPropagation();\n  audioDragOver.value = false;\n  if (!selectedPack.value) return;\n  const dataFiles = e.dataTransfer?.files;\n  if (!dataFiles || dataFiles.length === 0) return;\n\n  const blobs: { name: string; bytes: Uint8Array }[] = [];\n  for (let i = 0; i < dataFiles.length; i++) {\n    const f = dataFiles[i];\n    if (!f || !isAudioFile(f.name)) continue;\n    const buf = await f.arrayBuffer();\n    blobs.push({ name: f.name, bytes: new Uint8Array(buf) });\n  }\n  if (blobs.length > 0) {\n    await addAudioFilesFromBlobs(blobs);\n  }\n}\n\nasync function openAddFilePicker(): Promise<void> {\n  if (!selectedPack.value) return;\n  const result = await open({\n    filters: [{\n      name: 'Audio',\n      extensions: ['wav', 'mp3', 'ogg', 'flac', 'm4a', 'webm'],\n    }],\n    multiple: true,\n  });\n  if (!result) return;\n  const paths = Array.isArray(result) ? result : [result];\n  const blobs: { name: string; bytes: Uint8Array }[] = [];\n  for (const filePath of paths) {\n    if (!filePath) continue;\n    const filename = filePath.split('/').pop() ?? '';\n    if (!isAudioFile(filename)) continue;\n    const bytes = await readFile(filePath);\n    blobs.push({ name: filename, bytes });\n  }\n  if (blobs.length > 0) {\n    await addAudioFilesFromBlobs(blobs);\n  }\n}\n\n// Reset scroll + stop preview + check file existence on pack change\nwatch(selectedPack, async (packName) => {\n  stopPreview();\n  soundFileExists.value = new Map();\n  if (packName) void checkSoundFileExistence(packName);\n  await nextTick(() => {\n    if (rightPanel.value) rightPanel.value.scrollTop = 0;\n  });\n});\n\n</script>\n\n<template>\n  <Teleport to=\"body\">\n    <!-- Backdrop -->\n    <div class=\"fixed inset-0 z-[100] flex items-center justify-center bg-black/50\">\n      <!-- Drop zone wrapper -->\n      <div\n        class=\"relative w-[960px] max-w-[90vw] h-[700px] max-h-[90vh] flex flex-col bg-gray-900 border border-gray-700 rounded-lg shadow-2xl overflow-hidden\"\n        @dragover=\"onDragOver\"\n        @dragleave=\"onDragLeave\"\n        @drop=\"onDrop\"\n      >\n        <!-- Drag overlay -->\n        <div\n          v-if=\"dragOver\"\n          class=\"absolute inset-0 z-[150] flex items-center justify-center bg-indigo-900/80 border-2 border-dashed border-indigo-400 rounded-lg pointer-events-none\"\n        >\n          <span class=\"text-indigo-200 text-lg font-semibold\">Drop sound pack here</span>\n        </div>\n\n        <!-- Header -->\n        <div class=\"flex items-center gap-4 px-4 py-3 border-b border-gray-700 shrink-0\">\n          <span class=\"text-gray-200 font-semibold text-sm\">Sounds</span>\n\n          <!-- Master enable -->\n          <label class=\"flex items-center gap-1.5 text-xs text-gray-300 cursor-pointer\">\n            <input\n              type=\"checkbox\"\n              :checked=\"globalEnabled\"\n              class=\"w-4 h-4 accent-indigo-400\"\n              @change=\"globalEnabled = ($event.target as HTMLInputElement).checked\"\n            />\n            Enable\n          </label>\n\n          <!-- Global volume -->\n          <label class=\"flex items-center gap-1.5 text-xs text-gray-300\">\n            Vol\n            <input\n              type=\"range\"\n              min=\"0\"\n              max=\"100\"\n              :value=\"globalVolume\"\n              class=\"w-24 accent-indigo-400\"\n              @input=\"globalVolume = parseInt(($event.target as HTMLInputElement).value)\"\n            />\n            <span class=\"w-7 tabular-nums\">{{ globalVolume }}%</span>\n          </label>\n\n          <!-- Cooldown -->\n          <label class=\"flex items-center gap-1.5 text-xs text-gray-300\">\n            Cooldown\n            <input\n              type=\"range\"\n              min=\"0\"\n              max=\"10\"\n              step=\"0.5\"\n              :value=\"cooldown\"\n              class=\"w-20 accent-indigo-400\"\n              @input=\"cooldown = parseFloat(($event.target as HTMLInputElement).value)\"\n            />\n            <span class=\"w-8 tabular-nums\">{{ cooldown }}s</span>\n          </label>\n        </div>\n\n        <!-- Body -->\n        <div class=\"flex flex-1 min-h-0\">\n          <!-- Left panel: pack list -->\n          <div class=\"w-60 shrink-0 border-r border-gray-700 flex flex-col\">\n            <div class=\"px-3 pt-2 pb-1 text-xs font-semibold text-gray-400 uppercase tracking-wide\">\n              Packs\n            </div>\n            <div class=\"flex-1 overflow-y-auto\">\n              <div\n                v-for=\"pack in soundStore.packs\"\n                :key=\"pack.name\"\n                class=\"flex items-center gap-2 px-2 py-1.5 cursor-pointer rounded mx-1\"\n                :class=\"selectedPack === pack.name ? 'bg-gray-700' : 'hover:bg-gray-800'\"\n                @click=\"selectPack(pack.name)\"\n                @contextmenu=\"onPackRightClick($event, pack.name)\"\n              >\n                <input\n                  type=\"checkbox\"\n                  :checked=\"isPackActive(pack.name)\"\n                  class=\"w-4 h-4 accent-indigo-400 cursor-pointer\"\n                  @click.stop\n                  @change=\"togglePackActive(pack.name, ($event.target as HTMLInputElement).checked)\"\n                />\n                <input\n                  v-if=\"editingPackName === pack.name\"\n                  ref=\"editPackInput\"\n                  v-model=\"editPackNameValue\"\n                  class=\"flex-1 min-w-0 px-1 py-0.5 bg-gray-800 border border-indigo-400 rounded text-xs text-gray-200 outline-none\"\n                  @click.stop\n                  @keydown.enter.prevent=\"confirmEditPackName\"\n                  @keydown.escape.prevent=\"cancelEditPackName\"\n                  @blur=\"confirmEditPackName\"\n                />\n                <span v-else class=\"text-sm text-gray-200 truncate flex-1\">{{ pack.name }}</span>\n              </div>\n            </div>\n            <!-- Buttons -->\n            <div class=\"flex gap-1 p-2 border-t border-gray-700\">\n              <button\n                class=\"flex-1 px-2 py-1 bg-gray-700/60 rounded hover:bg-gray-600/70 text-xs text-gray-200\"\n                @click=\"startCreatePack\"\n              >\n                New Pack\n              </button>\n              <button\n                class=\"flex-1 px-2 py-1 bg-gray-700/60 rounded hover:bg-gray-600/70 text-xs text-gray-200\"\n                @click=\"openImportPicker\"\n              >\n                Import\n              </button>\n            </div>\n          </div>\n\n          <!-- Patchbay: Sounds + Events columns -->\n          <div ref=\"rightPanel\" class=\"flex flex-1 min-h-0 overflow-hidden\">\n            <!-- Sounds column -->\n            <div\n              class=\"flex-1 border-r border-gray-700 flex flex-col min-w-0\"\n              @dragover=\"onAudioDragOver\"\n              @dragleave=\"onAudioDragLeave\"\n              @drop=\"onAudioDrop\"\n            >\n              <div class=\"flex items-center gap-2 px-3 py-2 border-b border-gray-700 shrink-0\">\n                <span class=\"text-xs font-semibold text-gray-400 uppercase tracking-wide flex-1\">Sounds</span>\n                <button\n                  v-if=\"selectedPack\"\n                  class=\"px-2 py-0.5 bg-gray-700/60 rounded hover:bg-gray-600/70 text-xs text-gray-300\"\n                  @click=\"openAddFilePicker\"\n                >Add file</button>\n              </div>\n              <div class=\"flex-1 overflow-y-auto relative\">\n                <!-- Audio file drop overlay -->\n                <div\n                  v-if=\"audioDragOver && selectedPack\"\n                  class=\"absolute inset-0 z-10 flex items-center justify-center bg-indigo-900/60 border-2 border-dashed border-indigo-400 rounded pointer-events-none\"\n                >\n                  <span class=\"text-indigo-200 text-sm font-semibold\">Drop audio files here</span>\n                </div>\n                <div\n                  v-if=\"!selectedPackInfo\"\n                  class=\"flex items-center justify-center h-full text-gray-600 text-sm\"\n                >\n                  Select a pack\n                </div>\n                <div\n                  v-else-if=\"selectedPackInfo.manifest.sounds.length === 0\"\n                  class=\"flex items-center justify-center h-full text-gray-600 text-sm\"\n                >\n                  No sounds in this pack\n                </div>\n                <div\n                  v-for=\"sound in selectedPackInfo.manifest.sounds\"\n                  v-else\n                  :key=\"sound.file\"\n                  draggable=\"true\"\n                  class=\"flex items-center gap-2 px-3 py-1.5 border-b border-gray-800 hover:bg-gray-800/40 cursor-grab transition-colors duration-150\"\n                  :class=\"[\n                    draggingSoundFile === sound.file ? 'opacity-50' : '',\n                    dragOverSoundFile === sound.file ? 'bg-indigo-500/20' : '',\n                    draggingChip ? 'opacity-100' : '',\n                  ]\"\n                  @mouseenter=\"hoveredSoundFile = sound.file\"\n                  @mouseleave=\"hoveredSoundFile = null\"\n                  @dragstart=\"onSoundDragStart($event, sound.file)\"\n                  @dragend=\"onSoundDragEnd\"\n                  @dragover=\"onSoundRowDragOver($event, sound.file)\"\n                  @dragleave=\"onSoundRowDragLeave\"\n                  @drop=\"onSoundRowDrop($event, sound.file)\"\n                >\n                  <!-- Play button -->\n                  <button\n                    class=\"shrink-0 w-6 h-6 flex items-center justify-center rounded text-gray-400 hover:text-white hover:bg-gray-700 text-xs\"\n                    title=\"Play preview\"\n                    @click=\"playPreview(sound.file)\"\n                  >▶</button>\n\n                  <!-- Filename -->\n                  <span class=\"flex-1 text-xs font-mono text-gray-200 truncate min-w-0\">{{ sound.file }}</span>\n\n                  <!-- Broken link indicator -->\n                  <span\n                    v-if=\"soundFileExists.get(sound.file) === false\"\n                    class=\"shrink-0 text-red-400 text-xs\"\n                    title=\"File not found on disk\"\n                  >⚠</span>\n\n                  <!-- Volume slider (visible on hover) -->\n                  <input\n                    v-show=\"hoveredSoundFile === sound.file\"\n                    type=\"range\"\n                    min=\"0\"\n                    max=\"1\"\n                    step=\"0.01\"\n                    :value=\"sound.volume\"\n                    class=\"shrink-0 w-16 accent-indigo-400\"\n                    title=\"Volume\"\n                    @input=\"updateSoundVolume(sound, parseFloat(($event.target as HTMLInputElement).value))\"\n                  />\n\n                  <!-- Enabled toggle -->\n                  <input\n                    type=\"checkbox\"\n                    :checked=\"sound.enabled\"\n                    class=\"shrink-0 w-4 h-4 accent-indigo-400 cursor-pointer\"\n                    title=\"Enable/disable this sound\"\n                    @change=\"updateSoundEnabled(sound, ($event.target as HTMLInputElement).checked)\"\n                  />\n\n                  <!-- Stop button -->\n                  <button\n                    class=\"shrink-0 w-6 h-6 flex items-center justify-center rounded text-xs\"\n                    :class=\"previewFile === sound.file\n                      ? 'text-red-400 hover:text-red-300 hover:bg-gray-700'\n                      : 'text-gray-600 cursor-default'\"\n                    title=\"Stop preview\"\n                    @click=\"previewFile === sound.file ? stopPreview() : undefined\"\n                  >■</button>\n                </div>\n              </div>\n            </div>\n\n            <!-- Events column -->\n            <div class=\"flex-1 flex flex-col min-w-0\">\n              <div class=\"px-3 py-2 border-b border-gray-700 shrink-0\">\n                <span class=\"text-xs font-semibold text-gray-400 uppercase tracking-wide\">Events</span>\n              </div>\n              <div class=\"flex-1 overflow-y-auto\">\n                <div\n                  v-for=\"eventType in AGENT_EVENT_TYPES\"\n                  :key=\"eventType\"\n                  class=\"px-3 py-2 border-b border-gray-800 transition-all duration-200\"\n                  :class=\"[\n                    hasAssignments(eventType) ? 'opacity-100' : 'opacity-40',\n                    flashingEvent === eventType ? 'bg-indigo-600/30' : '',\n                    dragOverEventType === eventType ? 'bg-indigo-500/20 opacity-100' : '',\n                    draggingSoundFile ? 'opacity-100' : '',\n                  ]\"\n                  @dragover=\"onEventDragOver($event, eventType)\"\n                  @dragleave=\"onEventDragLeaveRow\"\n                  @drop=\"onEventDrop($event, eventType)\"\n                >\n                  <div class=\"flex items-center gap-2\">\n                    <span class=\"text-sm font-mono text-gray-300 flex-1\">{{ eventType }}</span>\n                    <!-- Info icon + popover -->\n                    <span\n                      v-if=\"EVENT_DESCRIPTIONS[eventType]\"\n                      class=\"relative shrink-0\"\n                      @click.stop\n                    >\n                      <span\n                        class=\"w-4 h-4 flex items-center justify-center rounded-full border text-[10px] leading-none cursor-pointer select-none\"\n                        :class=\"activeInfoPopover === eventType\n                          ? 'border-indigo-400 text-indigo-300 bg-indigo-900/40'\n                          : 'border-gray-500 text-gray-400 hover:border-gray-300 hover:text-gray-200'\"\n                        @click=\"toggleInfoPopover(eventType)\"\n                      >i</span>\n                      <div\n                        v-if=\"activeInfoPopover === eventType\"\n                        class=\"absolute right-0 top-6 z-50 w-56 bg-gray-800 border border-gray-600 rounded shadow-lg px-3 py-2 text-xs text-gray-200 leading-relaxed\"\n                      >\n                        {{ EVENT_DESCRIPTIONS[eventType] }}\n                      </div>\n                    </span>\n                  </div>\n                  <!-- Assignment chips -->\n                  <div\n                    v-if=\"assignmentsForEvent(eventType).length > 0\"\n                    class=\"flex flex-wrap gap-1 mt-1\"\n                  >\n                    <span\n                      v-for=\"file in assignmentsForEvent(eventType)\"\n                      :key=\"file\"\n                      draggable=\"true\"\n                      class=\"inline-flex items-center gap-1 px-2 py-0.5 bg-gray-700/80 rounded text-xs text-gray-200 cursor-grab hover:bg-gray-600/80\"\n                      :class=\"draggingChip?.file === file && draggingChip?.event === eventType ? 'opacity-50' : ''\"\n                      :title=\"file\"\n                      @click=\"playPreview(file)\"\n                      @dragstart.stop=\"onChipDragStart($event, file, eventType)\"\n                      @dragend=\"onChipDragEnd\"\n                    >\n                      {{ truncateFilename(file) }}\n                      <button\n                        class=\"ml-0.5 text-gray-400 hover:text-red-400 leading-none\"\n                        title=\"Remove assignment\"\n                        @click.stop=\"removeAssignment(file, eventType)\"\n                      >&times;</button>\n                    </span>\n                  </div>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        <!-- Footer -->\n        <div class=\"flex justify-end px-4 py-3 border-t border-gray-700 shrink-0\">\n          <button\n            class=\"px-4 py-1.5 bg-gray-700/60 rounded hover:bg-gray-600/70 text-sm text-gray-200\"\n            @click=\"emit('close')\"\n          >\n            Close\n          </button>\n        </div>\n      </div>\n    </div>\n\n    <!-- Context menu -->\n    <PackContextMenu\n      v-if=\"ctxMenu\"\n      :pack-name=\"ctxMenu.packName\"\n      :x=\"ctxMenu.x\"\n      :y=\"ctxMenu.y\"\n      @close=\"closeCtxMenu\"\n      @renamed=\"onPackRenamed\"\n      @duplicated=\"onPackDuplicated\"\n      @deleted=\"onPackDeleted\"\n    />\n  </Teleport>\n</template>\n","numLines":968,"startLine":1,"totalLines":968}}}
