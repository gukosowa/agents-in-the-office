{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013M5Br1jMsSpxrxZEh8cSqX","type":"tool_result","content":"     1→import { defineStore } from 'pinia';\n     2→import { ref } from 'vue';\n     3→import { homeDir } from '@tauri-apps/api/path';\n     4→import {\n     5→  readTextFile,\n     6→  writeTextFile,\n     7→  mkdir,\n     8→  exists,\n     9→  readDir,\n    10→  readFile,\n    11→} from '@tauri-apps/plugin-fs';\n    12→import type { AgentEvent, AgentEventType } from '../drivers/types';\n    13→\n    14→export const AGENT_EVENT_TYPES: AgentEventType[] = [\n    15→  'session_start',\n    16→  'session_end',\n    17→  'prompt_submit',\n    18→  'tool_start',\n    19→  'tool_end',\n    20→  'turn_end',\n    21→  'permission_wait',\n    22→  'subagent_start',\n    23→  'subagent_end',\n    24→  'idle_notification',\n    25→  'elicitation_wait',\n    26→  'auth_success',\n    27→  'worktree_create',\n    28→  'worktree_remove',\n    29→  'teammate_idle',\n    30→  'task_completed',\n    31→];\n    32→\n    33→export interface TrackConfig {\n    34→  enabled: boolean;\n    35→  volume: number;\n    36→}\n    37→\n    38→export interface SoundConfig {\n    39→  enabled: boolean;\n    40→  globalVolume: number;\n    41→  cooldownSeconds: number;\n    42→  activePacks: string[];\n    43→  /** Per-sound overrides, key: \"<packName>/<filename>\" */\n    44→  soundOverrides: Record<string, { volume: number; enabled: boolean }>;\n    45→  /** Legacy field — read for migration only, not written on save */\n    46→  tracks?: Record<string, Record<string, TrackConfig>>;\n    47→}\n    48→\n    49→export interface PackManifestSound {\n    50→  file: string;\n    51→  volume: number;\n    52→  enabled: boolean;\n    53→}\n    54→\n    55→export interface PackManifestAssignment {\n    56→  file: string;\n    57→  event: AgentEventType;\n    58→}\n    59→\n    60→export interface PackManifest {\n    61→  sounds: PackManifestSound[];\n    62→  assignments: PackManifestAssignment[];\n    63→}\n    64→\n    65→export interface PackInfo {\n    66→  name: string;\n    67→  categories: Record<string, string[]>;\n    68→  manifest: PackManifest;\n    69→  hasManifest: boolean;\n    70→}\n    71→\n    72→\n    73→const DEFAULT_CONFIG: SoundConfig = {\n    74→  enabled: true,\n    75→  globalVolume: 0.8,\n    76→  cooldownSeconds: 2,\n    77→  activePacks: [],\n    78→  soundOverrides: {},\n    79→};\n    80→\n    81→function migrateTracksToSoundOverrides(\n    82→  tracks: Record<string, Record<string, TrackConfig>>,\n    83→): Record<string, { volume: number; enabled: boolean }> {\n    84→  const overrides: Record<string, { volume: number; enabled: boolean }> = {};\n    85→  for (const [packName, packTracks] of Object.entries(tracks)) {\n    86→    for (const [categoryAndFile, trackCfg] of Object.entries(packTracks)) {\n    87→      const slashIdx = categoryAndFile.indexOf('/');\n    88→      const filename = slashIdx >= 0 ? categoryAndFile.slice(slashIdx + 1) : categoryAndFile;\n    89→      const overrideKey = `${packName}/${filename}`;\n    90→      if (!(overrideKey in overrides)) {\n    91→        overrides[overrideKey] = { volume: trackCfg.volume, enabled: trackCfg.enabled };\n    92→      }\n    93→    }\n    94→  }\n    95→  return overrides;\n    96→}\n    97→\n    98→const AUDIO_EXTENSIONS = new Set(['.mp3', '.ogg', '.wav', '.flac', '.m4a', '.webm']);\n    99→\n   100→function hasAudioExtension(filename: string): boolean {\n   101→  const dot = filename.lastIndexOf('.');\n   102→  if (dot < 0) return false;\n   103→  return AUDIO_EXTENSIONS.has(filename.slice(dot).toLowerCase());\n   104→}\n   105→\n   106→export const useSoundStore = defineStore('sound', () => {\n   107→  const config = ref<SoundConfig>({ ...DEFAULT_CONFIG, soundOverrides: {} });\n   108→  const packs = ref<PackInfo[]>([]);\n   109→\n   110→  // Reactive state for sound indicator (US-009)\n   111→  const lastPlayedSessionId = ref<string | null>(null);\n   112→\n   113→  let soundPacksDir = '';\n   114→  let configPath = '';\n   115→\n   116→  // AudioContext — lazy init on first playback\n   117→  let audioCtx: AudioContext | null = null;\n   118→\n   119→  // Buffer cache: absolute file path → AudioBuffer\n   120→  const bufferCache = new Map<string, AudioBuffer>();\n   121→\n   122→  // Per-category cooldown timestamps (category → last played ms)\n   123→  const cooldownMap = new Map<string, number>();\n   124→\n   125→  // Whether any sound is currently playing\n   126→  let playing = false;\n   127→\n   128→  // Per-session pack assignment\n   129→  const sessionPacks = new Map<string, string>();\n   130→\n   131→  // -------------------------------------------------------------------------\n   132→  // Init / persistence\n   133→  // -------------------------------------------------------------------------\n   134→\n   135→  async function init(): Promise<void> {\n   136→    const home = await homeDir();\n   137→    soundPacksDir = `${home}/.agents-in-the-office/sound-packs`;\n   138→    configPath = `${soundPacksDir}/config.json`;\n   139→\n   140→    const dirExists = await exists(soundPacksDir);\n   141→    if (!dirExists) {\n   142→      await mkdir(soundPacksDir, { recursive: true });\n   143→    }\n   144→\n   145→    const cfgExists = await exists(configPath);\n   146→    if (cfgExists) {\n   147→      try {\n   148→        const raw = await readTextFile(configPath);\n   149→        const parsed = JSON.parse(raw) as Partial<SoundConfig>;\n   150→        // Migrate legacy tracks field to soundOverrides\n   151→        if (!parsed.soundOverrides && parsed.tracks) {\n   152→          parsed.soundOverrides = migrateTracksToSoundOverrides(parsed.tracks);\n   153→        }\n   154→        const { tracks: _tracks, ...rest } = parsed;\n   155→        void _tracks; // consumed by migration above, drop from config\n   156→        config.value = { ...DEFAULT_CONFIG, ...rest };\n   157→      } catch {\n   1